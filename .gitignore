# Build output
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/

# Migrator publish landing dir — populated by redeploy-staging.ps1 as a
# staging step before the SMB sidecar copy to \\<staging>\C$\Enki\.
# Not source.
publish/

# Re-include source-code "Logs" namespaces. The broad [Ll]ogs/ rule above
# is for Serilog's runtime log directories (e.g. src/SDI.Enki.WebApi/logs/),
# but it also silently swallows source-code paths whose namespace is "Logs"
# — TenantDb.Logs (Log.cs / LogResultFile.cs) and Shared.Logs (the Log DTOs).
# A fresh clone on a colleague's machine produced a build break with
# missing types until these explicit re-includes were added.
#
# Pattern: list each source Logs/ folder explicitly so the runtime
# logs/ dirs at the host-project roots stay ignored. Add a new line
# here if a future namespace is called "Logs".
!src/SDI.Enki.Core/TenantDb/Logs/
!src/SDI.Enki.Core/TenantDb/Logs/**
!src/SDI.Enki.Shared/Logs/
!src/SDI.Enki.Shared/Logs/**

# Visual Studio
.vs/
*.user
*.suo
*.userprefs
*.sln.docstates
*.cache

# Rider / ReSharper
.idea/
*.DotSettings.user

# Build tools
.vscode/
*.lock.json

# Stray dotnet-tools.json files. The canonical location is
# `<repo>/.config/dotnet-tools.json` (one manifest at the repo root,
# created via `dotnet new tool-manifest`). `dotnet ef migrations add`
# inside a project folder sometimes spawns a manifest at the project
# root instead — those are dead weight (the tooling doesn't search
# project-level paths) and clutter the working tree. Ignore them
# everywhere except the canonical `.config/` path.
**/dotnet-tools.json
!**/.config/dotnet-tools.json

# NuGet
*.nupkg
*.snupkg
packages/
!packages/build/
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Core publish + secrets
*.pubxml
*.publishproj
PublishProfiles/
StyleCopReport.xml
secrets.json
launchSettings.Development.json

# EF Core
# keep migrations but ignore local scratch databases
*.mdf
*.ldf
*.ndf
*.bacpac

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Coverage
coverage/
TestResults/
*.coverage
*.coveragexml

# Claude Code per-user state (agent memory, worktree metadata, local
# build-tree overrides like the Marduk-junction Directory.Build.props).
# Worktrees themselves live under here but git tracks them via a
# separate per-worktree .git file, so ignoring the parent directory
# doesn't break worktree operation — it just prevents per-developer
# scratch from accidentally landing in the repo.
.claude/
