@*
    Collapsible JSON-snapshot viewer for an audit row's OldValues /
    NewValues. Hidden by default — click the toggle to expand. On
    Updated rows we show side-by-side; on Created (NewValues only) or
    Deleted (OldValues only) we show a single pane.

    The JSON is rendered as a <pre> with the raw payload from the API.
    No client-side reformat — keeps the surface tiny and the rendering
    deterministic. The OldValues/NewValues columns are
    nvarchar(max) so size in practice is bounded by the entity row's
    serialised footprint.
*@

@if (HasContent)
{
    <button class="enki-button enki-button-link"
            style="padding: 0; font-size: 0.85rem;"
            type="button"
            @onclick="Toggle">
        @(_expanded ? "Hide details" : "Show details")
    </button>

    @if (_expanded)
    {
        <div class="enki-json-grid">
            @if (OldValues is not null)
            {
                <div>
                    <div class="enki-form-hint" style="margin-bottom: 0.25rem;">Before</div>
                    <pre class="enki-json-pre">@PrettyPrint(OldValues)</pre>
                </div>
            }
            @if (NewValues is not null)
            {
                <div>
                    <div class="enki-form-hint" style="margin-bottom: 0.25rem;">After</div>
                    <pre class="enki-json-pre">@PrettyPrint(NewValues)</pre>
                </div>
            }
        </div>
    }
}

