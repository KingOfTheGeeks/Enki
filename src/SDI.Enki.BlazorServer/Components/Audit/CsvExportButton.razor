@*
    Reusable CSV-export button for audit feeds. Caller supplies:
      - ClientName: the named HttpClient ("EnkiApi" or "EnkiIdentity").
      - Path: the relative URL with the matching filter query-string,
        e.g. "admin/audit/master/csv?from=...&entityType=...".
      - DownloadName: the file the browser should save as.

    Fetches via the bearer-authed HttpClient (same plumbing as the
    page's other API calls), then streams the bytes through the
    SignalR circuit using DotNetStreamReference and triggers the
    save-as via enkiDownloads.fromStream — pattern shared with the
    Shot / Log / Run binary download buttons.
*@

<button class="enki-button" type="button"
        @onclick="DownloadAsync"
        disabled="@_busy">
    @(_busy ? "Exporting…" : "Export CSV")
</button>

@if (_error is not null)
{
    <span class="enki-form-hint" style="margin-left: 0.5rem; color: var(--enki-warn, #ffb84a);">@_error</span>
}

