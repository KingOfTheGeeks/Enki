@*
    Date-range filter with quick-preset buttons (24h, 7d, 30d, All).
    Two-way binds From + To on the host page so the host can fold
    them into its query-string state and re-fetch.

    Default selection on first paint is 7d — wide enough to give
    context, narrow enough that the first paint isn't gigantic.
    The host page is responsible for setting that initial state;
    this component is presentation-only.

    "All" sets both From and To to null — the controller treats null
    as "no bound" rather than "epoch start."
*@

<div class="enki-filter-row">
    <div class="enki-filter-group">
        <label class="enki-form-label" for="audit-from">From</label>
        <input id="audit-from"
               class="enki-form-input"
               type="datetime-local"
               value="@FormatLocal(From)"
               @onchange="OnFromChanged" />
    </div>

    <div class="enki-filter-group">
        <label class="enki-form-label" for="audit-to">To</label>
        <input id="audit-to"
               class="enki-form-input"
               type="datetime-local"
               value="@FormatLocal(To)"
               @onchange="OnToChanged" />
    </div>

    <div class="enki-filter-group" style="align-self: flex-end;">
        <button class="enki-button enki-button-link" type="button" @onclick="() => SetPreset(TimeSpan.FromHours(24))">24h</button>
        <button class="enki-button enki-button-link" type="button" @onclick="() => SetPreset(TimeSpan.FromDays(7))">7d</button>
        <button class="enki-button enki-button-link" type="button" @onclick="() => SetPreset(TimeSpan.FromDays(30))">30d</button>
        <button class="enki-button enki-button-link" type="button" @onclick="ClearRange">All</button>
    </div>
</div>

