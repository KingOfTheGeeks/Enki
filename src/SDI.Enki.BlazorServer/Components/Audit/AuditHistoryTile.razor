@rendermode InteractiveServer

@*
    Lazy "Recent activity" tile for entity detail pages. Renders only
    a reveal button by default — no audit fetch fires on page load.
    Clicking the button expands the panel and fetches the audit history
    at whatever granularity is right for the host page (see scoping
    rules below).

    Render mode: InteractiveServer is set on the component itself (not
    just the host pages) because some hosts — JobDetail, WellDetail,
    TenantDetail — are static SSR. Without an explicit rendermode here,
    the toggle button's @onclick handler is statically rendered and
    becomes a no-op. Opting the tile in directly means it works on any
    host regardless of the host's render mode.

    Per-page scoping (driven by HasChildren below). The principle is
    "roll up the smallest grouping" — each tile only fans out to children
    that don't already own a detail page with their own audit tile:
      - WellDetail   → Well + surveys/tubulars/formations/etc. (subtree)
      - RunDetail    → Run + shots/logs (subtree)
      - JobDetail    → Job only (wells/runs each have their own page)
      - TenantDetail → Tenant only (jobs each have their own page)
      - ShotDetail / LogDetail → leaf entities, no subtree

    NOT wired on per-Survey or per-Tubular detail pages — every Survey
    edit triggers Marduk's per-well auto-recalc which writes back to
    every other survey on the well. A per-Survey tile would be
    flooded with "Updated" rows from neighbouring edits; the per-Well
    tile is the right granularity for the trajectory ripple.

    Internals: uses the shared AuditActionBadge / ChangedColumnsChips /
    JsonExpandableRow components so the per-entity tile and the
    full-feed pages share visual language.
*@

<div class="enki-card" style="margin-top: 1.5rem;">
    <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; flex-wrap: wrap;">
        <div style="flex: 1; min-width: 240px;">
            <h3 class="enki-section-title" style="font-size: 1.1rem; margin-top: 0;">Recent activity</h3>
            <p class="enki-section-subtitle" style="margin-bottom: 0;">
                @if (_revealed && _entries is { Count: > 0 })
                {
                    @* After the first reveal, replace the call-to-action
                       copy with a status line so the prompt to "click to
                       load" doesn't keep telling the user to click
                       something that's already done its job. *@
                    if (_total > _entries.Count)
                    {
                        <text>Showing the most recent @_entries.Count of @_total audit entries.</text>
                    }
                    else
                    {
                        <text>@_entries.Count audit @(_entries.Count == 1 ? "entry" : "entries").</text>
                    }
                }
                else if (HasChildren)
                {
                    <text>Audit log for this @FriendlyEntityName and everything under it — every change to the @FriendlyEntityName itself plus all the rows underneath. Loaded on demand.</text>
                }
                else
                {
                    <text>Audit log for this @FriendlyEntityName. Loaded on demand.</text>
                }
            </p>
        </div>
        <button class="enki-button" type="button"
                disabled="@_busy"
                @onclick="ToggleAsync">
            @ButtonLabel
        </button>
    </div>

    @if (_revealed)
    {
        <div style="margin-top: 1rem;">
            @if (_loadError is not null)
            {
                <div class="alert alert-warning">@_loadError</div>
            }
            else if (_entries is null)
            {
                <div class="enki-form-hint">Loading audit history&hellip;</div>
            }
            else if (_entries.Count == 0)
            {
                <p class="enki-form-hint">No changes recorded yet.</p>
            }
            else
            {
                @* Overflow banner — only fires for entities with so much
                   audit churn that even the server's 500-row cap is hit.
                   The grid still has paging/sort/filter for everything
                   that did come back; this just flags that older rows
                   exist beyond the fetched window. *@
                @if (_total > _entries.Count)
                {
                    <div class="alert alert-info" style="margin-bottom: 0.75rem;">
                        Showing the most recent @_entries.Count of @_total total audit entries — older rows are out of view.
                    </div>
                }

                <SfGrid DataSource="@_entries"
                        AllowPaging="true"
                        AllowSorting="true"
                        AllowFiltering="true"
                        AllowResizing="true"
                        Height="auto">
                    <GridPageSettings PageSize="10" PageSizes="true" />
                    <GridColumns>
                        <GridColumn Field="@nameof(AuditLogEntryDto.ChangedAt)"
                                    HeaderText="When"
                                    Format="yyyy-MM-dd HH:mm:ss.fff"
                                    Type="ColumnType.DateTime"
                                    Width="220" MinWidth="200">
                            <Template>
                                @{ var entry = context as AuditLogEntryDto; }
                                @if (entry is not null)
                                {
                                    <span class="enki-mono">@entry.ChangedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss.fff")</span>
                                }
                            </Template>
                        </GridColumn>
                        <GridColumn Field="@nameof(AuditLogEntryDto.Action)"
                                    HeaderText="Action"
                                    Width="110" MinWidth="90">
                            <Template>
                                @{ var entry = context as AuditLogEntryDto; }
                                @if (entry is not null)
                                {
                                    <AuditActionBadge Action="@entry.Action" />
                                }
                            </Template>
                        </GridColumn>
                        @if (HasChildren)
                        {
                            @* Field=EntityType so users can sort/filter to
                               isolate "all the Survey rows" or "all the
                               Tubular rows" within the well subtree. *@
                            <GridColumn Field="@nameof(AuditLogEntryDto.EntityType)"
                                        HeaderText="Entity"
                                        Width="160" MinWidth="130">
                                <Template>
                                    @{ var entry = context as AuditLogEntryDto; }
                                    @if (entry is not null)
                                    {
                                        <span class="enki-mono" style="font-size: 0.85em;">
                                            @entry.EntityType <span class="enki-form-hint">#@entry.EntityId</span>
                                        </span>
                                    }
                                </Template>
                            </GridColumn>
                        }
                        <GridColumn Field="@nameof(AuditLogEntryDto.ChangedBy)"
                                    HeaderText="By"
                                    Width="160" MinWidth="130" />
                        @* Changed = chips + JSON expander, no meaningful
                           sort or filter handle on the compound content. *@
                        <GridColumn HeaderText="Changed"
                                    AllowSorting="false"
                                    AllowFiltering="false"
                                    MinWidth="240">
                            <Template>
                                @{ var entry = context as AuditLogEntryDto; }
                                @if (entry is not null)
                                {
                                    <ChangedColumnsChips Value="@entry.ChangedColumns" Action="@entry.Action" />
                                    <div style="margin-top: 0.25rem;">
                                        <JsonExpandableRow OldValues="@entry.OldValues" NewValues="@entry.NewValues" />
                                    </div>
                                }
                            </Template>
                        </GridColumn>
                    </GridColumns>
                </SfGrid>
            }
        </div>
    }
</div>

