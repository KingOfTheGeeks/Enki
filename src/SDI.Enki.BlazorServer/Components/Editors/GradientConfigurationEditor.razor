@*
    Inline edit form for AMR.Core.Gradient.Models.GradientConfiguration.
    Pure-typed UI — no JSON exposed to the human; the parent calls
    ToJson() on submit and posts the serialized payload to
    PUT /shots/{id}/config. Property names + defaults match the
    Marduk class verbatim so the JSON drops in unchanged.

    MagnetometerLocations is a flat double[] of (x,y,z) triplets;
    the textarea collects one mag per line ("x, y, z") and the
    serializer flattens.
*@

<div class="enki-detail-grid" style="grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr); gap: 0.4rem 0.75rem;">
    <div class="enki-detail-label">Sensor depth (m)</div>
    <div class="enki-detail-value">
        <InputNumber @bind-Value="_f.SensorMeasuredDepthMeter" class="enki-form-input" step="0.001" />
    </div>

    <div class="enki-detail-label">Sensor inclination (°)</div>
    <div class="enki-detail-value">
        <InputNumber @bind-Value="_f.SensorInclinationDegree" class="enki-form-input" step="0.001" />
    </div>

    <div class="enki-detail-label">Sensor azimuth (°)</div>
    <div class="enki-detail-value">
        <InputNumber @bind-Value="_f.SensorAzimuthDegree" class="enki-form-input" step="0.001" />
    </div>

    <div class="enki-detail-label">Sensor toolface (°)</div>
    <div class="enki-detail-value">
        <InputNumber @bind-Value="_f.SensorToolfaceDegree" class="enki-form-input" step="0.001" />
    </div>

    <div class="enki-detail-label">Current (A)</div>
    <div class="enki-detail-value">
        <InputNumber @bind-Value="_f.Current" class="enki-form-input" step="0.01" />
    </div>

    <div class="enki-detail-label">Flip sign</div>
    <div class="enki-detail-value">
        <InputCheckbox @bind-Value="_f.FlipSign" />
    </div>

    <div class="enki-detail-label">Sample frequency (Hz)</div>
    <div class="enki-detail-value">
        <InputNumber @bind-Value="_f.SampleFrequency" class="enki-form-input" step="0.1" />
    </div>

    <div class="enki-detail-label">High cutoff frequency (Hz)</div>
    <div class="enki-detail-value">
        <InputNumber @bind-Value="_f.HighCutoffFrequency" class="enki-form-input" step="0.1" />
    </div>

    <div class="enki-detail-label">Low cutoff frequency (Hz)</div>
    <div class="enki-detail-value">
        <InputNumber @bind-Value="_f.LowCutoffFrequency" class="enki-form-input" step="0.1" />
    </div>

    <div class="enki-detail-label">Op. processing frequency (Hz)</div>
    <div class="enki-detail-value">
        <InputNumber @bind-Value="_f.OperatorProcessingFrequency" class="enki-form-input" step="0.1" />
        <div class="enki-form-hint">Marduk default: NaN</div>
    </div>

    <div class="enki-detail-label">Op. processing bandwidth (Hz)</div>
    <div class="enki-detail-value">
        <InputNumber @bind-Value="_f.OperatorProcessingBandwidth" class="enki-form-input" step="0.1" />
        <div class="enki-form-hint">Marduk default: NaN</div>
    </div>
</div>

<div class="enki-form-group" style="margin-top: 0.75rem;">
    <label class="enki-form-label">Magnetometer locations</label>
    <textarea class="enki-form-input" rows="4"
              placeholder="x, y, z&#10;x, y, z&#10;... one magnetometer per line"
              @bind="_magLocsText"></textarea>
    <div class="enki-form-hint">
        Spatial offsets from calibration — one magnetometer per line as
        <span class="enki-mono">x, y, z</span>. Leave empty for no offsets.
    </div>
</div>

