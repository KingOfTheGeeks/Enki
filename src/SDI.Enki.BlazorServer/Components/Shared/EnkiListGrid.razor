@*
    Standard list-grid wrapper for Enki list pages. Wraps Syncfusion's
    SfGrid with the codebase convention: one elastic column (the
    ElasticField, usually the first / link / name column) absorbs the
    container's leftover width while every other field-bound column
    auto-fits to max(header, widest cell).

    The result: list grids span full container width with no dead space
    on the right, no column starved, no column given gratuitous extra
    room. AllowResizing leaves the user a manual override on top of the
    auto-fit.

    Usage:

        <EnkiListGrid TValue="JobSummaryDto"
                      DataSource="_jobs"
                      ElasticField="@nameof(JobSummaryDto.Name)">
            <GridColumn Field="@nameof(JobSummaryDto.Name)" HeaderText="Name" MinWidth="200">
                <Template>...</Template>
            </GridColumn>
            <GridColumn Field="@nameof(JobSummaryDto.WellName)" HeaderText="Well" />
            ...
        </EnkiListGrid>

    Action / template-only columns (those with no <c>Field</c>) are
    skipped by the AutoFit call — they keep whatever explicit Width the
    caller declared. That's how you surface a fixed-width "Remove"
    button column or similar.
*@

@typeparam TValue

<SfGrid @ref="_grid"
        DataSource="@DataSource"
        AllowSorting="@AllowSorting"
        AllowFiltering="@AllowFiltering"
        AllowResizing="@AllowResizing"
        AllowPaging="@AllowPaging"
        Height="@Height">
    <GridEvents DataBound="OnDataBoundAsync" TValue="TValue" />
    <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Menu" />
    @if (AllowPaging)
    {
        <GridPageSettings PageSize="@PageSize" PageSizes="true" />
    }
    <GridColumns>
        @ChildContent
    </GridColumns>
</SfGrid>

