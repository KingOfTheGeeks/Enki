@*
    Standard list-grid wrapper for Enki list pages. Wraps Syncfusion's
    SfGrid with the codebase convention: one elastic column (the
    ElasticField, usually the first / link / name column) absorbs the
    container's leftover width while every other field-bound column
    auto-fits to max(header, widest cell).

    The result: list grids span full container width with no dead space
    on the right, no column starved, no column given gratuitous extra
    room. AllowResizing leaves the user a manual override on top of the
    auto-fit.

    Usage:

        <EnkiListGrid TValue="JobSummaryDto"
                      DataSource="_jobs"
                      ElasticField="@nameof(JobSummaryDto.Name)">
            <GridColumn Field="@nameof(JobSummaryDto.Name)" HeaderText="Name" MinWidth="200">
                <Template>...</Template>
            </GridColumn>
            <GridColumn Field="@nameof(JobSummaryDto.WellName)" HeaderText="Well" />
            ...
        </EnkiListGrid>

    Action / template-only columns (those with no <c>Field</c>) are
    skipped by the AutoFit call — they keep whatever explicit Width the
    caller declared. That's how you surface a fixed-width "Remove"
    button column or similar.
*@

@typeparam TValue

<SfGrid @ref="_grid"
        DataSource="@DataSource"
        AllowSorting="@AllowSorting"
        AllowFiltering="@AllowFiltering"
        AllowResizing="@AllowResizing"
        AllowPaging="@AllowPaging"
        Height="@Height">
    <GridEvents DataBound="OnDataBoundAsync" TValue="TValue" />
    <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Menu" />
    @if (AllowPaging)
    {
        <GridPageSettings PageSize="@PageSize" PageSizes="true" />
    }
    <GridColumns>
        @ChildContent
    </GridColumns>
</SfGrid>

@code {
    /// <summary>Row source. Re-AutoFit fires on every bind, so filter / refresh re-fits.</summary>
    [Parameter] public IEnumerable<TValue>? DataSource { get; set; }

    /// <summary>
    /// Field name of the column that should stay elastic (no Width, absorbs leftover container
    /// width). Typically the first / link / human-readable identifier column. Required.
    /// </summary>
    [Parameter, EditorRequired] public string ElasticField { get; set; } = "";

    /// <summary>The page's <c>&lt;GridColumn&gt;</c> declarations.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter] public bool AllowSorting { get; set; } = true;
    [Parameter] public bool AllowFiltering { get; set; } = true;
    [Parameter] public bool AllowResizing { get; set; } = true;
    [Parameter] public bool AllowPaging { get; set; }

    /// <summary>Initial page size when <see cref="AllowPaging"/> is true. Default 10.</summary>
    [Parameter] public int PageSize { get; set; } = 10;

    /// <summary>SfGrid Height. Default <c>"auto"</c> — grid sizes to its content.</summary>
    [Parameter] public string Height { get; set; } = "auto";

    private SfGrid<TValue>? _grid;

    /// <summary>
    /// Fired by SfGrid after each data bind. AutoFits every field-bound
    /// column except <see cref="ElasticField"/>; the elastic column is
    /// left unconstrained so it absorbs the container's leftover width.
    /// </summary>
    private async Task OnDataBoundAsync()
    {
        if (_grid?.Columns is not { } columns) return;

        var fields = columns
            .Select(c => c.Field)
            .Where(f => !string.IsNullOrEmpty(f) && f != ElasticField)
            .ToArray();

        if (fields.Length > 0)
        {
            await _grid.AutoFitColumnsAsync(fields);
        }
    }
}
