@*
    Standard page header — title on the left, actions on the right,
    optional subtitle below. Used on every detail and list page so
    action buttons (Edit / Archive / Back) are immediately visible
    above the fold rather than hidden after the data.

    Original pattern was on Surveys.razor; this component lifts the
    flexbox into one place and adds a TitleSuffix slot for status
    pills / mono IDs.

    Usage:

        <PageHeader Title="Cold-Lake-Pad-7">
            <TitleSuffix>
                <span class="enki-status-pill enki-status-active">Active</span>
            </TitleSuffix>
            <Subtitle>
                BOREAL · 019ddb24-...
            </Subtitle>
            <Actions>
                <NavLink class="enki-button" href="/tenants/.../jobs">Back to Jobs</NavLink>
                <button class="enki-button" @onclick="EditAsync">Edit</button>
                <button class="enki-button enki-button-danger" @onclick="ArchiveAsync">Archive</button>
            </Actions>
        </PageHeader>

    Layout collapses to two stacked rows on viewports under ~720px;
    no styling needed on the call site.
*@

<div class="enki-page-header">
    <div class="enki-page-header-text">
        <h1 class="enki-section-title">
            @Title
            @if (TitleSuffix is not null)
            {
                <span class="enki-page-header-suffix">
                    @TitleSuffix
                </span>
            }
        </h1>
        @if (Subtitle is not null)
        {
            <div class="enki-section-subtitle">
                @Subtitle
            </div>
        }
    </div>
    <div class="enki-page-header-actions">
        @Actions
    </div>
</div>

