@inject IHttpClientFactory HttpClientFactory
@using SDI.Enki.Core.Units
@using SDI.Enki.Shared.Jobs
@using System.Net.Http.Json

@*
    Cascading-parameter wrapper that fetches a Job's UnitSystem once
    and exposes it to descendants. Wells-area pages (Surveys, Tubulars,
    Formations, CommonMeasures, etc.) wrap their content in this; any
    descendant component picks up the system via:

        [CascadingParameter] public UnitSystem Units { get; set; } = UnitSystem.SI;

    Two values are cascaded:
      * UnitSystem    — the resolved Units enum
      * JobDetailDto  — the whole Job in case a child wants Region /
                        WellName / etc. without an extra round trip

    Until the Job loads, the cascading UnitSystem is the strict-SI
    default. That's a deliberate choice: a half-second flash of raw SI
    numbers on a slow Job-fetch is better than blocking the whole page
    behind a spinner. If a page wants to gate on the Job, it can check
    CurrentJob == null itself.
*@

<CascadingValue Value="@_units" Name="UnitSystem" IsFixed="false">
    <CascadingValue Value="@_job" Name="CurrentJob" IsFixed="false">
        @ChildContent
    </CascadingValue>
</CascadingValue>

@if (_loadError is not null)
{
    @* Render the error inline so callers don't have to handle it
       themselves; keeps the cascade tree simple. *@
    <div class="alert alert-danger" style="margin-top: 0.5rem;">
        Could not load Job @JobId for unit-system context: @_loadError
    </div>
}

@code {
    [Parameter, EditorRequired] public string TenantCode { get; set; } = "";
    [Parameter, EditorRequired] public Guid JobId { get; set; }
    [Parameter, EditorRequired] public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Falls back to strict SI while the Job is loading or if the
    /// fetch fails — display layer renders the raw stored values
    /// (which are SI by storage convention) so a half-second flash
    /// of m / kg/m³ / etc. is the worst case.
    /// </summary>
    private UnitSystem _units = UnitSystem.SI;

    private JobDetailDto? _job;
    private string? _loadError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("EnkiApi");
            _job = await client.GetFromJsonAsync<JobDetailDto>(
                $"tenants/{TenantCode}/jobs/{JobId}");

            if (_job is not null)
            {
                _units = UnitSystem.FromNameOrSi(_job.UnitSystem);
            }
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
    }
}
