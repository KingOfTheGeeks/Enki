@*
    Render a numeric value the user-facing way. The stored value is
    always SI (Length in m, Density in kg/m³, etc.); this component
    looks up the Job's UnitSystem from the cascade, projects the
    value into the right unit, formats it, and appends the
    abbreviation if requested.

    Special cases:
      * EnkiQuantity.Angle — short-circuit, render the raw double
        with the ° suffix. The DB stores degrees regardless of what
        UnitSystemPresets says about SI = radians; the user never
        sees radians. (Per Mike's lock-in.)
      * OverrideUnit — opt out of the Job's preset for this cell.
        Tubular OD uses this so it reads `in` for Field jobs and
        `mm` for Metric / SI, neither of which matches the
        default Length unit (ft / m).
*@

@if (IsAngle)
{
    @* Angles always render as degrees, no preset lookup. *@
    <span class="enki-mono">@FormatAngle(Value, Format)°</span>
}
else if (OverrideUnit is not null)
{
    // Caller pinned a specific unit (tubular OD = in / mm, etc.).
    // Convert via UnitConverter directly without going through the
    // preset table.
    var converted = UnitConverter.FromSi(Value, Quantity, OverrideUnit);
    var abbrev    = OverrideAbbreviation ?? "";
    <span class="enki-mono">@FormatNumber(converted, Format)@(ShowUnit && abbrev.Length > 0 ? " " + abbrev : "")</span>
}
else
{
    // Default path: route through the Measurement struct's Format.
    // That picks the unit from UnitSystemPresets and runs the
    // appropriate converter (UnitsNet for the standard quantities,
    // ConvertOilfield for sonic / curvature / etc.).
    var measurement = new Measurement(Value, Quantity);
    var rendered    = ShowUnit
        ? measurement.Format(Units, Format)
        : FormatNumber(measurement.As(Units).Value, Format);
    <span class="enki-mono">@rendered</span>
}

