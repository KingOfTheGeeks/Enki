<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    @* Syncfusion Fluent Dark theme — Enki overrides layer on top. *@
    <link rel="stylesheet" href="_content/Syncfusion.Blazor.Themes/fluent-dark.css" />
    @* Enki global theme — palette, shell, components. *@
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["css/enki-theme.css"]" />
    <link rel="stylesheet" href="@Assets["SDI.Enki.BlazorServer.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <title>Enki</title>
    <HeadOutlet />
</head>

<body>
    @* Navigation feedback — shown on same-origin link clicks, hidden on
       Blazor's enhancedload event. Controlled entirely by enki-nav.js so
       it works regardless of a page's render mode. *@
    <div id="enki-nav-progress" aria-hidden="true"></div>
    <div id="enki-loading-overlay" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Loading&hellip;</div>
    </div>

    <Routes />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="@Assets["js/enki-nav.js"]"></script>
    <script src="@Assets["js/enki-forms.js"]"></script>
</body>

</html>
