@page "/tenants/new"
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using SDI.Enki.Shared.Tenants

<PageTitle>Enki &mdash; New Tenant</PageTitle>

<h1 class="enki-section-title">New Tenant</h1>
<p class="enki-section-subtitle">
    Provisions a tenant: writes the master-registry row, creates
    <code>Enki_{Code}_Active</code> and <code>Enki_{Code}_Archive</code>
    databases on the master SQL Server, and applies the current tenant
    schema to both.
</p>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

<div class="enki-card" style="max-width: 620px; margin-top: 1.25rem;">
    <EditForm Model="Form" OnValidSubmit="Submit" FormName="create-tenant"
              class="enki-form" Enhance="true">
        <DataAnnotationsValidator />
        <ValidationSummary class="enki-validation-summary" />

        <div class="enki-form-group">
            <label class="enki-form-label required" for="f-code">Code</label>
            <InputText @bind-Value="Form!.Code" id="f-code" class="enki-form-input"
                       placeholder="ACME" autocomplete="off" spellcheck="false"
                       required
                       pattern="[A-Za-z][A-Za-z0-9_]{0,23}"
                       maxlength="24"
                       data-error="1–24 chars, letters / digits / underscore, starting with a letter."
                       style="text-transform: uppercase; letter-spacing: 0.05em;"
                       oninput="this.value = this.value.toUpperCase()" />
            <div class="enki-form-hint">
                1&ndash;24 chars. Letters, digits, underscore. Must start with a
                letter. Auto-uppercased as you type &mdash; becomes part of the
                database names (<code>Enki_{Code}_Active</code>).
            </div>
            <ValidationMessage For="() => Form.Code" class="enki-form-error" />
        </div>

        <div class="enki-form-group">
            <label class="enki-form-label required" for="f-name">Name</label>
            <InputText @bind-Value="Form!.Name" id="f-name" class="enki-form-input"
                       placeholder="Acme Corporation"
                       required maxlength="200"
                       data-error="Name is required." />
            <ValidationMessage For="() => Form.Name" class="enki-form-error" />
        </div>

        <div class="enki-form-group">
            <label class="enki-form-label" for="f-display">Display Name</label>
            <InputText @bind-Value="Form!.DisplayName" id="f-display" class="enki-form-input"
                       placeholder="Acme" maxlength="200"
                       data-error="Display name must be 200 chars or fewer." />
            <div class="enki-form-hint">UI-friendly override; falls back to Name when blank.</div>
            <ValidationMessage For="() => Form.DisplayName" class="enki-form-error" />
        </div>

        <div class="enki-form-group">
            <label class="enki-form-label" for="f-email">Contact Email</label>
            <InputText @bind-Value="Form!.ContactEmail" id="f-email" class="enki-form-input"
                       placeholder="ops@acme.example"
                       type="email" maxlength="256"
                       data-error="Must be a valid email address." />
            <ValidationMessage For="() => Form.ContactEmail" class="enki-form-error" />
        </div>

        <div class="enki-form-group">
            <label class="enki-form-label" for="f-notes">Notes</label>
            <InputTextArea @bind-Value="Form!.Notes" id="f-notes" class="enki-form-textarea"
                           placeholder="&mdash;" />
            <ValidationMessage For="() => Form.Notes" class="enki-form-error" />
        </div>

        <div class="enki-form-actions">
            <button type="submit" class="enki-button enki-button-primary">
                Provision tenant
            </button>
            <NavLink class="enki-button" href="tenants">Cancel</NavLink>
        </div>
    </EditForm>
</div>

@code {
    /// <summary>
    /// Bound from the posted form. <c>[SupplyParameterFromForm]</c> is the
    /// Blazor-Web-App way to hydrate a property directly from the form post
    /// without manually reading the request. Works with static SSR, which is
    /// important here because we need the server-side HttpContext alive so
    /// the BearerTokenHandler can attach the access token to the /tenants
    /// POST.
    /// </summary>
    [SupplyParameterFromForm]
    public CreateForm? Form { get; set; }

    private string? _error;

    protected override void OnInitialized()
    {
        // Per Blazor's BL0008 guidance: don't use a property initializer on
        // a [SupplyParameterFromForm] property (it can get overwritten with
        // null during form post). Populate here instead so GETs get a fresh
        // instance and POSTs keep whatever the form sent.
        Form ??= new CreateForm();
    }

    private async Task Submit()
    {
        if (Form is null) return;
        _error = null;
        var code = Form.Code.ToUpperInvariant();
        try
        {
            var client = HttpClientFactory.CreateClient("EnkiApi");

            // Pre-submit uniqueness probe — catches "code already taken"
            // before kicking off the (expensive, side-effectful) real
            // provisioning call. GET /tenants/{code}: 200 = taken, 404 = free.
            using (var probe = await client.GetAsync($"tenants/{code}"))
            {
                if (probe.IsSuccessStatusCode)
                {
                    _error = $"Tenant code '{code}' is already in use. Pick another.";
                    return;
                }
            }

            var dto = new ProvisionTenantDto(
                Code:         code,
                Name:         Form.Name,
                DisplayName:  Emptied(Form.DisplayName),
                ContactEmail: Emptied(Form.ContactEmail),
                Notes:        Emptied(Form.Notes));

            using var resp = await client.PostAsJsonAsync("tenants", dto);
            if (resp.IsSuccessStatusCode)
            {
                Nav.NavigateTo($"/tenants/{dto.Code}");
                return;
            }
            var body = await resp.Content.ReadAsStringAsync();
            _error = $"Provision failed ({(int)resp.StatusCode} {resp.StatusCode}): {body}";
        }
        catch (Exception ex)
        {
            _error = $"Unexpected error: {ex.Message}";
        }
    }

    // Treat all-whitespace / empty strings as null so the DB doesn't get
    // rows with Region="", ContactEmail="", etc.
    private static string? Emptied(string? s) => string.IsNullOrWhiteSpace(s) ? null : s.Trim();

    public sealed class CreateForm
    {
        // Client regex is case-insensitive — the input field auto-uppercases
        // as the user types and Submit() normalises with ToUpperInvariant()
        // before sending. The server-side regex on ProvisionTenantDto stays
        // strict-uppercase; if anything ever bypasses the client and sends
        // lowercase, it fails fast with a clear 400.
        [Required(ErrorMessage = "Code is required.")]
        [RegularExpression(@"^[A-Za-z][A-Za-z0-9_]{0,23}$",
            ErrorMessage = "Code must be 1–24 chars, letters / digits / underscore, starting with a letter.")]
        public string Code { get; set; } = "";

        [Required(ErrorMessage = "Name is required.")]
        [MaxLength(200, ErrorMessage = "Name must be 200 chars or fewer.")]
        public string Name { get; set; } = "";

        [MaxLength(200, ErrorMessage = "Display name must be 200 chars or fewer.")]
        public string? DisplayName { get; set; }

        [EmailAddress(ErrorMessage = "Not a valid email address.")]
        [MaxLength(256, ErrorMessage = "Email must be 256 chars or fewer.")]
        public string? ContactEmail { get; set; }

        public string? Notes { get; set; }
    }
}
