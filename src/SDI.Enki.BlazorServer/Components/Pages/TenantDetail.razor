
<PageTitle>Enki &mdash; Tenant @Code</PageTitle>

@if (_error is not null)
{
    <PageHeader Title="@($"Tenant {Code}")">
        <Actions>
            <NavLink class="enki-button" href="tenants">Back to tenants</NavLink>
        </Actions>
    </PageHeader>
    <div class="alert alert-danger">@_error</div>
}
else if (_tenant is null)
{
    <PageHeader Title="@($"Tenant {Code}")">
        <Actions>
            <NavLink class="enki-button" href="tenants">Back to tenants</NavLink>
        </Actions>
    </PageHeader>
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Loading tenant&hellip;</div>
    </div>
}
else
{
    <PageHeader Title="@(_tenant.DisplayName ?? _tenant.Name)">
        <TitleSuffix>
            <span class="enki-status-pill @StatusClass(_tenant.Status)">@_tenant.Status</span>
        </TitleSuffix>
        <Subtitle>
            <span class="enki-mono">@_tenant.Code</span>
        </Subtitle>
        <Actions>
            <NavLink class="enki-button" href="tenants">Back to tenants</NavLink>

            @* Lifecycle (Deactivate/Reactivate) and tenant settings (Edit)
               are split across two policies. Lifecycle = Supervisor+
               (CanManageTenantLifecycle). Edit = Office+
               (CanWriteMasterContent). Members button gates by the
               tenant-scoped CanManageTenantMembersAsync — but that's
               async and we want sync here, so we cache the answer in
               OnInitializedAsync. *@
            @if (Capabilities.CanManageTenantLifecycle)
            {
                @if (_tenant.Status == "Active")
                {
                    <form method="post" action="@($"/tenants/{_tenant.Code}/deactivate")"
                          style="display:inline">
                        <AntiforgeryToken />
                        @* RowVersion round-trip pins the optimistic-concurrency check
                           on the WebApi side — see LifecycleTransitionDto. Without
                           it the WebApi rejects the post with a 400. *@
                        <input type="hidden" name="rowVersion" value="@_tenant.RowVersion" />
                        <button type="submit" class="enki-button enki-button-danger"
                                onclick="return confirm('Deactivate tenant @(_tenant.Code)?');">
                            Deactivate
                        </button>
                    </form>
                }
                else if (_tenant.Status == "Inactive")
                {
                    <form method="post" action="@($"/tenants/{_tenant.Code}/reactivate")"
                          style="display:inline">
                        <AntiforgeryToken />
                        <input type="hidden" name="rowVersion" value="@_tenant.RowVersion" />
                        <button type="submit" class="enki-button">Reactivate</button>
                    </form>
                }
            }

            @if (_canManageMembers)
            {
                <NavLink class="enki-button" href="@($"tenants/{_tenant.Code}/members")">
                    Members
                </NavLink>
            }
            @if (Capabilities.CanWriteMasterContent)
            {
                <NavLink class="enki-button" href="@($"tenants/{_tenant.Code}/edit")">
                    Edit
                </NavLink>
            }
            <NavLink class="enki-button enki-button-primary" href="@($"tenants/{_tenant.Code}/jobs")">
                View jobs
            </NavLink>
        </Actions>
    </PageHeader>

    @if (_statusError is not null)
    {
        <div class="alert alert-danger">@_statusError</div>
    }

    <div class="enki-detail-grid">
        <div class="enki-detail-label">Code</div>
        <div class="enki-detail-value">@_tenant.Code</div>

        <div class="enki-detail-label">Legal name</div>
        <div class="enki-detail-value">@_tenant.Name</div>

        <div class="enki-detail-label">Display name</div>
        <div class="enki-detail-value @DashClass(_tenant.DisplayName)">@Dashed(_tenant.DisplayName)</div>

        <div class="enki-detail-label">Status</div>
        <div class="enki-detail-value">@_tenant.Status</div>

        <div class="enki-detail-label">Contact</div>
        <div class="enki-detail-value @DashClass(_tenant.ContactEmail)">@Dashed(_tenant.ContactEmail)</div>

        <div class="enki-detail-label">Notes</div>
        <div class="enki-detail-value @DashClass(_tenant.Notes)">@Dashed(_tenant.Notes)</div>

        <div class="enki-detail-label">Created</div>
        <div class="enki-detail-value">@_tenant.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>

        <div class="enki-detail-label">Updated</div>
        <div class="enki-detail-value @DashClass(_tenant.UpdatedAt?.ToString())">
            @(_tenant.UpdatedAt is { } u ? u.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "—")
        </div>

        <div class="enki-detail-label">Deactivated</div>
        <div class="enki-detail-value @DashClass(_tenant.DeactivatedAt?.ToString())">
            @(_tenant.DeactivatedAt is { } d ? d.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "—")
        </div>
    </div>

    <h2 class="enki-section-title" style="font-size: 1.1rem; margin-top: 2rem;">Databases</h2>
    <div class="enki-detail-grid">
        <div class="enki-detail-label">Active</div>
        <div class="enki-detail-value @DashClass(_tenant.ActiveDatabaseName)">
            @Dashed(_tenant.ActiveDatabaseName)
        </div>

        <div class="enki-detail-label">Archive</div>
        <div class="enki-detail-value @DashClass(_tenant.ArchiveDatabaseName)">
            @Dashed(_tenant.ArchiveDatabaseName)
        </div>

        <div class="enki-detail-label">Schema version</div>
        <div class="enki-detail-value @DashClass(_tenant.SchemaVersion)">
            @Dashed(_tenant.SchemaVersion)
        </div>
    </div>

}

