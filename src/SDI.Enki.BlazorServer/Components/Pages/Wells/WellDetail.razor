@page "/tenants/{TenantCode}/jobs/{JobId:guid}/wells/{WellId:int}"
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@inject UnitPreferenceProvider UnitPrefs
@using SDI.Enki.BlazorServer.Api
@using SDI.Enki.BlazorServer.Components.Audit
@using SDI.Enki.Core.Units
@using SDI.Enki.Shared.Jobs
@using SDI.Enki.Shared.Wells

@*
    Well detail — identity, audit, and the five child-entity entry-point
    cards. Each card is a NavLink to the matching child page; the count
    on the card is the row count returned by the WebApi's projection so
    the user sees what's actually under the well at a glance.
*@

<PageTitle>Enki &mdash; Well @WellId (@TenantCode)</PageTitle>

@if (_error is not null)
{
    <PageHeader Title="@($"Well {WellId}")">
        <Actions>
            <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells")">Back to wells</NavLink>
        </Actions>
    </PageHeader>
    <div class="alert alert-danger">@_error</div>
}
else if (_well is null)
{
    <PageHeader Title="@($"Well {WellId}")">
        <Actions>
            <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells")">Back to wells</NavLink>
        </Actions>
    </PageHeader>
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Loading well&hellip;</div>
    </div>
}
else
{
    <PageHeader Title="@_well.Name">
        <TitleSuffix>
            <span class="enki-status-pill @TypeClass(_well.Type)">@_well.Type</span>
        </TitleSuffix>
        <Subtitle>
            <span class="enki-mono">@TenantCode</span> &middot;
            <span class="enki-mono">Well @_well.Id</span>
        </Subtitle>
        <Actions>
            <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells")">Back to wells</NavLink>
            <NavLink class="enki-button"
                     href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/plot")">
                Plan view
            </NavLink>
            <NavLink class="enki-button enki-button-primary"
                     href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/edit")">
                Edit
            </NavLink>
        </Actions>
    </PageHeader>

    <div class="enki-detail-grid">
        <div class="enki-detail-label">Name</div>
        <div class="enki-detail-value">@_well.Name</div>

        <div class="enki-detail-label">Type</div>
        <div class="enki-detail-value">@_well.Type</div>

        <div class="enki-detail-label">Created</div>
        <div class="enki-detail-value">
            @_well.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
            @if (!string.IsNullOrWhiteSpace(_well.CreatedBy))
            {
                <span class="enki-form-hint" style="margin-left: 0.5rem;">by @_well.CreatedBy</span>
            }
        </div>

        @if (_well.UpdatedAt is { } updated)
        {
            <div class="enki-detail-label">Updated</div>
            <div class="enki-detail-value">
                @updated.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                @if (!string.IsNullOrWhiteSpace(_well.UpdatedBy))
                {
                    <span class="enki-form-hint" style="margin-left: 0.5rem;">by @_well.UpdatedBy</span>
                }
            </div>
        }
    </div>

    <h2 class="enki-section-title" style="margin-top: 2rem; font-size: 1.25rem;">Data</h2>
    <p class="enki-section-subtitle">
        Click into any tile to view, edit, or add rows.
    </p>

    @* Tie-on lives inline at the top of the Surveys grid (not a
       separate child entity any more) — no Tie-Ons card here. *@
    <CascadingValue Name="UnitSystem" Value="_units" IsFixed="false">
    <div class="enki-stat-grid">
        <a class="enki-stat-card enki-link-card"
           href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{_well.Id}/surveys")">
            <div class="enki-stat-value">@_well.SurveyCount.ToString("D2")</div>
            <div class="enki-stat-label">Surveys</div>
        </a>
        <a class="enki-stat-card enki-link-card"
           href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{_well.Id}/tubulars")">
            <div class="enki-stat-value">@_well.TubularCount.ToString("D2")</div>
            <div class="enki-stat-label">Tubulars</div>
        </a>
        <a class="enki-stat-card enki-link-card"
           href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{_well.Id}/formations")">
            <div class="enki-stat-value">@_well.FormationCount.ToString("D2")</div>
            <div class="enki-stat-label">Formations</div>
        </a>
        <a class="enki-stat-card enki-link-card"
           href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{_well.Id}/common-measures")">
            <div class="enki-stat-value">@_well.CommonMeasureCount.ToString("D2")</div>
            <div class="enki-stat-label">Common Measures</div>
        </a>
    </div>

    @* Magnetic reference — values inline if curated, otherwise a
       prompt to set them. Distinct from a click-through stat tile
       because the three values (Dec / Dip / Field) are themselves
       what the user wants to see at a glance, not a count. *@
    <h2 class="enki-section-title" style="margin-top: 2rem; font-size: 1.25rem;">Magnetic reference</h2>
    @if (_magnetics is null)
    {
        <p class="enki-section-subtitle">
            No magnetic reference recorded yet for this well. Set
            one once the upstream correction values are known —
            stored for traceability of what was applied to imported
            survey azimuths.
        </p>
        <div class="enki-form-actions" style="border-top: none; margin-top: 0.5rem; padding-top: 0;">
            <NavLink class="enki-button enki-button-primary"
                     href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{_well.Id}/magnetics/edit")">
                Set magnetic reference
            </NavLink>
        </div>
    }
    else
    {
        <div class="enki-detail-grid">
            <div class="enki-detail-label">Declination</div>
            <div class="enki-detail-value enki-mono">
                <UnitFormatted Value="@_magnetics.Declination" Quantity="EnkiQuantity.Angle" Format="N3" />
            </div>

            <div class="enki-detail-label">Dip</div>
            <div class="enki-detail-value enki-mono">
                <UnitFormatted Value="@_magnetics.Dip" Quantity="EnkiQuantity.Angle" Format="N3" />
            </div>

            <div class="enki-detail-label">Total field</div>
            <div class="enki-detail-value enki-mono">
                @* Stored convention is nT (matching the legacy
                   per-shot lookup column); UnitFormatted with
                   MagneticFluxDensity treats SI values in tesla, so
                   render the raw stored value with an explicit
                   abbreviation rather than projecting through the
                   units cascade. *@
                @_magnetics.BTotal.ToString("N0", System.Globalization.CultureInfo.InvariantCulture)
                <span class="enki-form-hint" style="margin-left: 0.4rem;">nT</span>
            </div>

            @if (_magnetics.UpdatedAt is { } mUpdated)
            {
                <div class="enki-detail-label">Updated</div>
                <div class="enki-detail-value">
                    @mUpdated.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                    @if (!string.IsNullOrWhiteSpace(_magnetics.UpdatedBy))
                    {
                        <span class="enki-form-hint" style="margin-left: 0.5rem;">by @_magnetics.UpdatedBy</span>
                    }
                </div>
            }
        </div>
        <div class="enki-form-actions" style="border-top: none; margin-top: 0.5rem; padding-top: 0;">
            <NavLink class="enki-button"
                     href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{_well.Id}/magnetics/edit")">
                Edit magnetic reference
            </NavLink>
        </div>
    }
    </CascadingValue>

    <AuditHistoryTile TenantCode="@TenantCode"
                      EntityType="Well"
                      EntityId="@WellId.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                      FriendlyEntityName="well" />
}

@code {
    [Parameter] public string TenantCode { get; set; } = "";
    [Parameter] public Guid   JobId      { get; set; }
    [Parameter] public int    WellId     { get; set; }

    private WellDetailDto? _well;
    private MagneticsDto? _magnetics;
    private UnitSystem    _units = UnitSystem.SI;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var client = HttpClientFactory.CreateClient("EnkiApi");

        // Three independent fetches in parallel: the Job (drives
        // the units cascade), the Well, and the optional per-well
        // magnetic-reference. The magnetics call returning 404 is
        // the "Not set" state — handled by leaving _magnetics null.
        var jobTask  = client.GetAsync<JobDetailDto>(
            $"tenants/{TenantCode}/jobs/{JobId}");
        var wellTask = client.GetAsync<WellDetailDto>(
            $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}");
        var magTask  = client.GetAsync<MagneticsDto>(
            $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/magnetics");

        await Task.WhenAll(jobTask, wellTask, magTask);

        var jobResult  = jobTask.Result;
        var wellResult = wellTask.Result;
        var magResult  = magTask.Result;

        _units = await UnitPrefs.ResolveAsync(jobResult.IsSuccess ? jobResult.Value.UnitSystem : null);

        if (!wellResult.IsSuccess)
        {
            _error = wellResult.Error.Kind == ApiErrorKind.NotFound
                ? $"Well {WellId} not found in tenant {TenantCode}."
                : wellResult.Error.AsAlertText();
            return;
        }
        _well = wellResult.Value;

        if (magResult.IsSuccess)
        {
            _magnetics = magResult.Value;
        }
        // 404 → no per-well magnetics; _magnetics stays null and
        // the "Not set" branch renders. Any other failure is
        // non-fatal — surface as null and let the user re-curate.
    }

    private static string TypeClass(string s) => s switch
    {
        "Target"    => "enki-status-active",
        "Intercept" => "enki-status-inactive",
        "Offset"    => "enki-status-archived",
        _           => "",
    };
}
