@page "/tenants/{TenantCode}/jobs/{JobId:guid}/wells/{WellId:int}/tubulars"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@inject UnitPreferenceProvider UnitPrefs
@using SDI.Enki.BlazorServer.Api
@using SDI.Enki.Core.Units
@using SDI.Enki.Shared.Wells.Tubulars

@*
    Tubular segments under a Well — the drillstring composition list,
    surface (Order = 0) at the top.

    Headers + cells route through UnitLabel / UnitFormatted so depths
    flip ft↔m with the Job's preset, and the OD column always reads
    in / mm via UnitOverrides.TubularDiameter (driller idiom across
    both hemispheres). Weight is LinearMassDensity — lb/ft on Field,
    kg/m on Metric and SI.

    Editing is wired through Syncfusion's native inline edit, mirroring
    Surveys.razor:

      * Double-click a row → Normal edit mode opens it.
      * Enter saves, Esc cancels. Toolbar Update / Cancel are the
        visible affordance.
      * OnActionCompleteAsync fires on Save: build UpdateTubularDto
        from the row, PUT to TubularsController, force-reload.

    Type column uses an HTML <select> in EditTemplate — five values
    matching the WellType / TubularType SmartEnum (Casing, Liner,
    Tubing, DrillPipe, OpenHole). The PUT validates against the
    SmartEnum on the server side; an unknown value here returns 400.
*@

<PageTitle>Enki &mdash; Tubulars (Well @WellId)</PageTitle>

<PageHeader Title="Tubulars">
    <TitleSuffix>
        <span class="enki-mono">@TenantCode &middot; Well @WellId</span>
    </TitleSuffix>
    <Subtitle>
        Casing, liner, tubing, drill-pipe, and open-hole segments —
        ordered surface-to-bottom. <strong>Double-click a row</strong>
        to edit it inline; Enter saves.
    </Subtitle>
    <Actions>
        <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}")">Back to well</NavLink>
        <NavLink class="enki-button enki-button-primary"
                 href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/tubulars/new")">
            + New tubular
        </NavLink>
    </Actions>
</PageHeader>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
@if (_saveStatus is not null)
{
    <div class="alert @_saveAlertClass">@_saveStatus</div>
}
@if (_rows is null && _error is null)
{
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Fetching tubulars from API&hellip;</div>
    </div>
}

@if (_rows is not null && _error is null)
{
    <CascadingValue Name="UnitSystem" Value="_units" IsFixed="false">
    <div class="enki-stat-grid">
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_rows.Count.ToString("D2")</div>
            <div class="enki-stat-label">Segments</div>
        </div>
    </div>

    @{ var od = UnitOverrides.TubularDiameter(_units); }
    <SfGrid DataSource="_rows"
            AllowSorting="true"
            AllowFiltering="true"
            AllowResizing="true"
            Toolbar="@(new List<string> { "Update", "Cancel", "Delete" })"
            Height="auto">
        <GridEditSettings AllowEditing="true"
                          AllowAdding="false"
                          AllowDeleting="true"
                          ShowDeleteConfirmDialog="true"
                          Mode="EditMode.Normal" />
        <GridEvents OnActionComplete="OnActionCompleteAsync" TValue="GridRow" />
        <GridColumns>
            <GridColumn Field="@nameof(GridRow.Id)" IsPrimaryKey="true" Visible="false" />

            <GridColumn Field="@nameof(GridRow.Order)" HeaderText="#" Width="80">
                <EditTemplate>
                    @{ var row = (GridRow)context!; }
                    <input type="number" step="1" min="0" class="enki-form-input"
                           @bind="row.Order" @bind:event="oninput" />
                </EditTemplate>
            </GridColumn>
            <GridColumn Field="@nameof(GridRow.Type)" HeaderText="Type" Width="130">
                <EditTemplate>
                    @{ var row = (GridRow)context!; }
                    <select class="enki-form-input" @bind="row.Type">
                        <option value="Casing">Casing</option>
                        <option value="Liner">Liner</option>
                        <option value="Tubing">Tubing</option>
                        <option value="DrillPipe">Drill pipe</option>
                        <option value="OpenHole">Open hole</option>
                    </select>
                </EditTemplate>
            </GridColumn>
            @* Name: bounded width so it can't eat the unit-bearing
               columns to the right. Names are usually short ("Surface
               casing", "Production liner"); 240 holds the long ones. *@
            <GridColumn Field="@nameof(GridRow.Name)" HeaderText="Name" Width="240" />
            <GridColumn Field="@nameof(GridRow.FromMeasured)" HeaderText="@UnitLabel.For("From MD", EnkiQuantity.Length, _units)" Width="150" MinWidth="140">
                <Template>
                    @{ var row = (GridRow)context!; }
                    <UnitFormatted Value="@row.FromMeasured" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                </Template>
                <EditTemplate>
                    @{ var row = (GridRow)context!; }
                    <UnitInput @bind-SiValue="row.FromMeasured" Quantity="EnkiQuantity.Length" ShowUnit="false" />
                </EditTemplate>
            </GridColumn>
            <GridColumn Field="@nameof(GridRow.ToMeasured)" HeaderText="@UnitLabel.For("To MD", EnkiQuantity.Length, _units)" Width="150" MinWidth="140">
                <Template>
                    @{ var row = (GridRow)context!; }
                    <UnitFormatted Value="@row.ToMeasured" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                </Template>
                <EditTemplate>
                    @{ var row = (GridRow)context!; }
                    <UnitInput @bind-SiValue="row.ToMeasured" Quantity="EnkiQuantity.Length" ShowUnit="false" />
                </EditTemplate>
            </GridColumn>
            @* Diameter uses the driller-idiom override unit (in / mm)
               instead of the Job's preset Length unit — diameters in
               feet would read absurdly. EditTemplate's UnitInput
               forwards the same OverrideUnit / OverrideAbbreviation
               so the edit cell shows in / mm to match the read view. *@
            <GridColumn Field="@nameof(GridRow.Diameter)" HeaderText="@UnitLabel.For("Diameter", EnkiQuantity.Length, _units, od.Unit, od.Abbreviation)" Width="160" MinWidth="150">
                <Template>
                    @{ var row = (GridRow)context!; }
                    <UnitFormatted Value="@row.Diameter" Quantity="EnkiQuantity.Length"
                                   OverrideUnit="@od.Unit" OverrideAbbreviation="@od.Abbreviation"
                                   Format="N3" ShowUnit="false" />
                </Template>
                <EditTemplate>
                    @{ var row = (GridRow)context!; }
                    <UnitInput @bind-SiValue="row.Diameter" Quantity="EnkiQuantity.Length"
                               OverrideUnit="@od.Unit" OverrideAbbreviation="@od.Abbreviation"
                               ShowUnit="false" />
                </EditTemplate>
            </GridColumn>
            <GridColumn Field="@nameof(GridRow.Weight)" HeaderText="@UnitLabel.For("Weight", EnkiQuantity.LinearMassDensity, _units)" Width="160" MinWidth="150">
                <Template>
                    @{ var row = (GridRow)context!; }
                    <UnitFormatted Value="@row.Weight" Quantity="EnkiQuantity.LinearMassDensity" Format="N2" ShowUnit="false" />
                </Template>
                <EditTemplate>
                    @{ var row = (GridRow)context!; }
                    <UnitInput @bind-SiValue="row.Weight" Quantity="EnkiQuantity.LinearMassDensity" ShowUnit="false" />
                </EditTemplate>
            </GridColumn>
        </GridColumns>
    </SfGrid>
    </CascadingValue>
}

@code {
    [Parameter] public string TenantCode { get; set; } = "";
    [Parameter] public Guid JobId { get; set; }
    [Parameter] public int WellId { get; set; }

    private List<GridRow>? _rows;
    private string? _error;
    private string? _saveStatus;
    private string  _saveAlertClass = "alert-info";

    /// <summary>Job's preferred display unit-system; drives column headers and cell projections.</summary>
    private UnitSystem _units = UnitSystem.SI;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        var client = HttpClientFactory.CreateClient("EnkiApi");

        // Two parallel reads — each returns an ApiResult<T> envelope
        // so a 401/403/404/5xx surfaces as a typed ApiError instead of
        // an exception. We branch on IsSuccess on each; if either
        // failed, we set _error from the first failure and bail.
        var jobTask      = client.GetAsync<JobDetailDto>($"tenants/{TenantCode}/jobs/{JobId}");
        var tubularsTask = client.GetAsync<List<TubularSummaryDto>>(
            $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/tubulars");
        await Task.WhenAll(jobTask, tubularsTask);

        var jobResult      = jobTask.Result;
        var tubularsResult = tubularsTask.Result;

        if (!jobResult.IsSuccess)      { _error = jobResult.Error.AsAlertText();      return; }
        if (!tubularsResult.IsSuccess) { _error = tubularsResult.Error.AsAlertText(); return; }

        _units = await UnitPrefs.ResolveAsync(jobResult.Value.UnitSystem);
        _rows  = tubularsResult.Value
            .Select(t => new GridRow
            {
                Id           = t.Id,
                Order        = t.Order,
                Type         = t.Type,
                Name         = t.Name,
                FromMeasured = t.FromMeasured,
                ToMeasured   = t.ToMeasured,
                Diameter     = t.Diameter,
                Weight       = t.Weight,
                RowVersion   = t.RowVersion,
            })
            .ToList();
    }

    /// <summary>
    /// Save / Delete handler. Save: UpdateTubularDto carries the full
    /// update set (Type, Order, FromMeasured, ToMeasured, Diameter,
    /// Weight, Name) so no detail-fetch round-trip is needed before
    /// PUT — Summary == Update field shape. Delete: Syncfusion's
    /// native confirm dialog gates the action; we just translate
    /// args.Data.Id into the DELETE call.
    /// </summary>
    private async Task OnActionCompleteAsync(ActionEventArgs<GridRow> args)
    {
        if (args.Data is not { } row) return;

        var client = HttpClientFactory.CreateClient("EnkiApi");
        var path   = $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/tubulars/{row.Id}";

        if (args.RequestType == Syncfusion.Blazor.Grids.Action.Delete)
        {
            // Explicit static-call form: HttpClient has an instance
            // DeleteAsync(string) returning HttpResponseMessage which
            // would win overload resolution over our extension.
            var deleteResult = await HttpClientApiExtensions.DeleteAsync(client, path);
            if (deleteResult.IsSuccess)
            {
                Nav.NavigateTo(Nav.Uri, forceLoad: true);
                return;
            }

            _saveStatus     = deleteResult.Error.AsAlertText();
            _saveAlertClass = "alert-danger";
            return;
        }

        if (args.RequestType != Syncfusion.Blazor.Grids.Action.Save) return;

        var dto = new UpdateTubularDto(
            Type:         row.Type,
            Order:        row.Order,
            FromMeasured: row.FromMeasured,
            ToMeasured:   row.ToMeasured,
            Diameter:     row.Diameter,
            Weight:       row.Weight,
            Name:         row.Name,
            // Round-trip the optimistic-concurrency token from the
            // summary loaded into the grid so a concurrent edit on
            // the same tubular 409s rather than silently overwriting.
            RowVersion:   row.RowVersion);

        var result = await client.PutAsync(path, dto);

        if (result.IsSuccess)
        {
            Nav.NavigateTo(Nav.Uri, forceLoad: true);
            return;
        }

        // ApiError carries a parsed title + per-field messages when the
        // WebApi returned a ValidationProblemDetails. Future polish:
        // surface FieldErrors next to the offending grid cell instead of
        // a single banner. For now the headline tells the user what
        // happened and they can re-edit.
        _saveStatus     = result.Error.AsAlertText();
        _saveAlertClass = "alert-danger";
    }

    /// <summary>
    /// Mutable row shape backing the editable grid. Mirrors
    /// <see cref="TubularSummaryDto"/> with the int <see cref="Id"/>
    /// as the Syncfusion primary key.
    /// </summary>
    public sealed class GridRow
    {
        public int     Id           { get; set; }
        public int     Order        { get; set; }
        public string  Type         { get; set; } = "";
        public string? Name         { get; set; }
        public double  FromMeasured { get; set; }
        public double  ToMeasured   { get; set; }
        public double  Diameter     { get; set; }
        public double  Weight       { get; set; }
        /// <summary>
        /// Carried through from the summary fetch so inline-edit
        /// commits round-trip the optimistic-concurrency token.
        /// </summary>
        public string? RowVersion   { get; set; }
    }
}
