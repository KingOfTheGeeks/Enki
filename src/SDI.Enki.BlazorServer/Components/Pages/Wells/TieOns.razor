@page "/tenants/{TenantCode}/jobs/{JobId:guid}/wells/{WellId:int}/tieons"
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@inject UnitPreferenceProvider UnitPrefs
@using SDI.Enki.BlazorServer.Api
@using SDI.Enki.Core.Units
@using SDI.Enki.Shared.Wells.TieOns

@*
    Tie-on stations under a Well. Lands at the Wells-area path (Wells
    list / detail pages arrive in Step 8 of the plan; TieOns can be
    reached directly today via this URL or via a deep-link from a
    future WellDetail card).

    Pattern matches Jobs.razor: stat cards, a Syncfusion grid, and
    paired "+ New tie-on" / "Back" buttons. Tie-ons are usually one or
    two rows per well so paging hasn't been wired here yet. Headers +
    cells route through UnitLabel / UnitFormatted so the values flip
    ft↔m with the Job's preset.
*@

<PageTitle>Enki &mdash; Tie-Ons (Well @WellId)</PageTitle>

<div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; flex-wrap: wrap;">
    <div style="flex: 1; min-width: 280px;">
        <h1 class="enki-section-title">
            Tie-Ons
            <span class="enki-mono" style="font-size: 0.65em; opacity: 0.65; margin-left: 0.5rem;">
                @TenantCode &middot; Well @WellId
            </span>
        </h1>
        <p class="enki-section-subtitle">
            Reference stations the survey calculator anchors to. A well
            normally has one active tie-on; additional rows are kept for
            historical / alternative references.
        </p>
    </div>
    <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
        <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}")">Back to well</NavLink>
        <NavLink class="enki-button enki-button-primary"
                 href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/tieons/new")">
            + New tie-on
        </NavLink>
    </div>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_tieOns is null)
{
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Fetching tie-ons from API&hellip;</div>
    </div>
}
else
{
    <CascadingValue Name="UnitSystem" Value="_units" IsFixed="false">
    <div class="enki-stat-grid">
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_tieOns.Count.ToString("D2")</div>
            <div class="enki-stat-label">Tie-Ons</div>
        </div>
    </div>

    <SfGrid DataSource="_tieOns"
            AllowSorting="true"
            AllowFiltering="true"
            AllowResizing="true"
            Height="auto">
        <GridColumns>
            <GridColumn Field="@nameof(TieOnSummaryDto.Depth)" HeaderText="@UnitLabel.For("Depth", EnkiQuantity.Length, _units)" Width="140" MinWidth="130">
                <Template>
                    @{ var row = context as TieOnSummaryDto; }
                    @if (row is not null)
                    {
                        <a class="enki-row-link"
                           href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/tieons/{row.Id}/edit")">
                            <UnitFormatted Value="@row.Depth" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                        </a>
                    }
                </Template>
            </GridColumn>
            <GridColumn Field="@nameof(TieOnSummaryDto.Inclination)" HeaderText="@UnitLabel.For("Inc", EnkiQuantity.Angle, _units)" Width="120" MinWidth="100">
                <Template>
                    @{ var row = (TieOnSummaryDto)context!; }
                    <UnitFormatted Value="@row.Inclination" Quantity="EnkiQuantity.Angle" Format="N2" ShowUnit="false" />
                </Template>
            </GridColumn>
            <GridColumn Field="@nameof(TieOnSummaryDto.Azimuth)" HeaderText="@UnitLabel.For("Az", EnkiQuantity.Angle, _units)" Width="120" MinWidth="100">
                <Template>
                    @{ var row = (TieOnSummaryDto)context!; }
                    <UnitFormatted Value="@row.Azimuth" Quantity="EnkiQuantity.Angle" Format="N2" ShowUnit="false" />
                </Template>
            </GridColumn>
            @* North + East are zero at the tie-on by definition; carried
               here for completeness so the grid shows the entire record. *@
            <GridColumn Field="@nameof(TieOnSummaryDto.North)" HeaderText="@UnitLabel.For("North", EnkiQuantity.Length, _units)" Width="130" MinWidth="120">
                <Template>
                    @{ var row = (TieOnSummaryDto)context!; }
                    <UnitFormatted Value="@row.North" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                </Template>
            </GridColumn>
            <GridColumn Field="@nameof(TieOnSummaryDto.East)" HeaderText="@UnitLabel.For("East", EnkiQuantity.Length, _units)" Width="130" MinWidth="120">
                <Template>
                    @{ var row = (TieOnSummaryDto)context!; }
                    <UnitFormatted Value="@row.East" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                </Template>
            </GridColumn>
            <GridColumn Field="@nameof(TieOnSummaryDto.Northing)" HeaderText="@UnitLabel.For("Northing", EnkiQuantity.Length, _units)" Width="160" MinWidth="150">
                <Template>
                    @{ var row = (TieOnSummaryDto)context!; }
                    <UnitFormatted Value="@row.Northing" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                </Template>
            </GridColumn>
            <GridColumn Field="@nameof(TieOnSummaryDto.Easting)" HeaderText="@UnitLabel.For("Easting", EnkiQuantity.Length, _units)" Width="160" MinWidth="150">
                <Template>
                    @{ var row = (TieOnSummaryDto)context!; }
                    <UnitFormatted Value="@row.Easting" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                </Template>
            </GridColumn>
            <GridColumn Field="@nameof(TieOnSummaryDto.VerticalReference)" HeaderText="@UnitLabel.For("Vert ref", EnkiQuantity.Length, _units)" Width="150" MinWidth="140">
                <Template>
                    @{ var row = (TieOnSummaryDto)context!; }
                    <UnitFormatted Value="@row.VerticalReference" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                </Template>
            </GridColumn>
            <GridColumn Field="@nameof(TieOnSummaryDto.SubSeaReference)" HeaderText="@UnitLabel.For("Sub-sea ref", EnkiQuantity.Length, _units)" Width="170" MinWidth="160">
                <Template>
                    @{ var row = (TieOnSummaryDto)context!; }
                    <UnitFormatted Value="@row.SubSeaReference" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                </Template>
            </GridColumn>
            <GridColumn Field="@nameof(TieOnSummaryDto.VerticalSectionDirection)" HeaderText="@UnitLabel.For("VSD", EnkiQuantity.Angle, _units)" Width="120" MinWidth="100">
                <Template>
                    @{ var row = (TieOnSummaryDto)context!; }
                    <UnitFormatted Value="@row.VerticalSectionDirection" Quantity="EnkiQuantity.Angle" Format="N2" ShowUnit="false" />
                </Template>
            </GridColumn>
            <GridColumn Field="@nameof(TieOnSummaryDto.CreatedAt)"
                        HeaderText="Created" Width="170"
                        Format="yyyy-MM-dd HH:mm" Type="ColumnType.DateTime" />
        </GridColumns>
    </SfGrid>
    </CascadingValue>
}

@code {
    [Parameter] public string TenantCode { get; set; } = "";
    [Parameter] public Guid JobId { get; set; }
    [Parameter] public int WellId { get; set; }

    private List<TieOnSummaryDto>? _tieOns;
    private string? _error;
    private UnitSystem _units = UnitSystem.SI;

    protected override async Task OnInitializedAsync()
    {
        var client = HttpClientFactory.CreateClient("EnkiApi");
        var jobTask = client.GetAsync<JobDetailDto>(
            $"tenants/{TenantCode}/jobs/{JobId}");
        var tieOnsTask = client.GetAsync<List<TieOnSummaryDto>>(
            $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/tieons");

        await Task.WhenAll(jobTask, tieOnsTask);

        var jobResult    = jobTask.Result;
        var tieOnsResult = tieOnsTask.Result;

        if (!jobResult.IsSuccess)    { _error = jobResult.Error.AsAlertText();    return; }
        if (!tieOnsResult.IsSuccess) { _error = tieOnsResult.Error.AsAlertText(); return; }

        _units  = await UnitPrefs.ResolveAsync(jobResult.Value.UnitSystem);
        _tieOns = tieOnsResult.Value;
    }
}
