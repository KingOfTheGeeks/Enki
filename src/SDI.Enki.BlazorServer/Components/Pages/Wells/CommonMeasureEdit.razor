@page "/tenants/{TenantCode}/jobs/{JobId:guid}/wells/{WellId:int}/common-measures/{MeasureId:int}/edit"
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using SDI.Enki.Core.Units
@using SDI.Enki.Shared.Wells.CommonMeasures

<PageTitle>Enki &mdash; Edit Common Measure (@MeasureId)</PageTitle>

<h1 class="enki-section-title">Edit Common Measure</h1>
<p class="enki-section-subtitle">
    <span class="enki-mono">@TenantCode</span> &middot;
    Well <span class="enki-mono">@WellId</span> &middot;
    Measure <span class="enki-mono">@MeasureId</span>
</p>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

@if (_loadFailed)
{
    <div class="alert alert-danger">
        Could not load measure. It may have been deleted.
        <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/common-measures")">
            Back to measures
        </NavLink>
    </div>
}
else if (Form is null)
{
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Loading measure&hellip;</div>
    </div>
}
else
{
    <CascadingValue Name="UnitSystem" Value="_units" IsFixed="false">
    <div class="enki-card" style="max-width: 620px; margin-top: 1.25rem;">
        <EditForm Model="Form" OnValidSubmit="Submit" FormName="edit-cm"
                  class="enki-form" Enhance="true">
            <DataAnnotationsValidator />
            <ValidationSummary class="enki-validation-summary" />

            <div class="enki-form-grid-2col">
                <div class="enki-form-group">
                    <label class="enki-form-label required">@UnitLabel.For("From TVD", EnkiQuantity.Length, _units)</label>
                    <UnitInput @bind-SiValue="Form.FromVertical" Quantity="EnkiQuantity.Length" CssClass="enki-form-input" />
                </div>
                <div class="enki-form-group">
                    <label class="enki-form-label required">@UnitLabel.For("To TVD", EnkiQuantity.Length, _units)</label>
                    <UnitInput @bind-SiValue="Form.ToVertical" Quantity="EnkiQuantity.Length" CssClass="enki-form-input" />
                </div>
                <div class="enki-form-group">
                    <label class="enki-form-label required" for="f-val">Signal factor</label>
                    <InputNumber @bind-Value="Form.Value" id="f-val" class="enki-form-input" required step="0.001" />
                </div>
            </div>

            <div class="enki-form-actions">
                <button type="submit" class="enki-button enki-button-primary">Save changes</button>
                <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/common-measures")">Cancel</NavLink>
            </div>
        </EditForm>
    </div>

    <div class="enki-card enki-danger-card" style="max-width: 620px; margin-top: 1.25rem;">
        <h2 class="enki-form-section-title">Danger zone</h2>
        <button type="button" class="enki-button enki-button-danger" @onclick="ConfirmDelete">
            @(_deleteArmed ? "Click again to confirm delete" : "Delete measure")
        </button>
    </div>
    </CascadingValue>
}

@code {
    [Parameter] public string TenantCode { get; set; } = "";
    [Parameter] public Guid JobId { get; set; }
    [Parameter] public int WellId { get; set; }
    [Parameter] public int MeasureId { get; set; }

    [SupplyParameterFromForm]
    public EditModel? Form { get; set; }

    private string? _error;
    private bool _loadFailed;
    private bool _deleteArmed;
    private UnitSystem _units = UnitSystem.SI;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("EnkiApi");
            var jobTask = client.GetFromJsonAsync<JobDetailDto>(
                $"tenants/{TenantCode}/jobs/{JobId}");
            var dtoTask = client.GetFromJsonAsync<CommonMeasureDetailDto>(
                $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/common-measures/{MeasureId}");

            await Task.WhenAll(jobTask, dtoTask);

            var dto = dtoTask.Result;
            if (dto is null) { _loadFailed = true; return; }

            _units = UnitSystem.FromNameOrSi(jobTask.Result?.UnitSystem);
            Form ??= new EditModel
            {
                FromVertical = dto.FromVertical,
                ToVertical   = dto.ToVertical,
                Value        = dto.Value,
            };
        }
        catch (HttpRequestException ex) { _error = $"WebApi call failed: {ex.Message}"; }
        catch (Exception ex)             { _error = $"Unexpected error: {ex.Message}"; }
    }

    private async Task Submit()
    {
        if (Form is null) return;
        _error = null;
        try
        {
            var client = HttpClientFactory.CreateClient("EnkiApi");
            var dto = new UpdateCommonMeasureDto(
                FromVertical: Form.FromVertical,
                ToVertical:   Form.ToVertical,
                Value:        Form.Value);

            using var resp = await client.PutAsJsonAsync(
                $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/common-measures/{MeasureId}", dto);

            if (resp.IsSuccessStatusCode)
            {
                Nav.NavigateTo($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/common-measures");
                return;
            }

            var body = await resp.Content.ReadAsStringAsync();
            _error = $"Save failed ({(int)resp.StatusCode} {resp.StatusCode}): {body}";
        }
        catch (Exception ex) { _error = $"Unexpected error: {ex.Message}"; }
    }

    private async Task ConfirmDelete()
    {
        if (!_deleteArmed) { _deleteArmed = true; return; }

        try
        {
            var client = HttpClientFactory.CreateClient("EnkiApi");
            using var resp = await client.DeleteAsync(
                $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/common-measures/{MeasureId}");

            if (resp.IsSuccessStatusCode)
            {
                Nav.NavigateTo($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/common-measures");
                return;
            }

            var body = await resp.Content.ReadAsStringAsync();
            _error = $"Delete failed ({(int)resp.StatusCode} {resp.StatusCode}): {body}";
            _deleteArmed = false;
        }
        catch (Exception ex)
        {
            _error = $"Unexpected error: {ex.Message}";
            _deleteArmed = false;
        }
    }

    public sealed class EditModel
    {
        [Required] public double FromVertical { get; set; }
        [Required] public double ToVertical { get; set; }
        [Required] public double Value { get; set; }
    }
}
