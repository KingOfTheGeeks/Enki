@page "/tenants/{TenantCode}/wells"
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@using SDI.Enki.Shared.Wells
@using System.Net.Http.Json

@*
    Wells under a tenant. Wells are the entry point to every drilling-data
    surface — Surveys, TieOns, Tubulars, Formations, CommonMeasures all
    nest under a Well, so this list lights up the rest of the surface.

    Pattern matches Jobs.razor: stat cards across the top, Syncfusion
    grid below, "+ New well" + "Back to tenant" actions in the header.
*@

<PageTitle>Enki &mdash; Wells (@TenantCode)</PageTitle>

<div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; flex-wrap: wrap;">
    <div style="flex: 1; min-width: 280px;">
        <h1 class="enki-section-title">
            Wells
            <span class="enki-mono" style="font-size: 0.65em; opacity: 0.65; margin-left: 0.5rem;">
                @TenantCode
            </span>
        </h1>
        <p class="enki-section-subtitle">
            Physical wellbores under this tenant. Wells own surveys,
            tie-ons, tubulars, formations, and common measures — all
            reachable from the per-well detail page.
        </p>
    </div>
    <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
        <NavLink class="enki-button" href="@($"/tenants/{TenantCode}")">Back to tenant</NavLink>
        <NavLink class="enki-button enki-button-primary" href="@($"/tenants/{TenantCode}/wells/new")">
            + New well
        </NavLink>
    </div>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_wells is null)
{
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Fetching wells from API&hellip;</div>
    </div>
}
else
{
    <div class="enki-stat-grid">
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_wells.Count.ToString("D2")</div>
            <div class="enki-stat-label">Wells</div>
        </div>
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_wells.Count(w => w.Type == "Target").ToString("D2")</div>
            <div class="enki-stat-label">Target</div>
        </div>
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_wells.Count(w => w.Type == "Injection").ToString("D2")</div>
            <div class="enki-stat-label">Injection</div>
        </div>
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_wells.Count(w => w.Type == "Offset").ToString("D2")</div>
            <div class="enki-stat-label">Offset</div>
        </div>
    </div>

    <SfGrid DataSource="_wells" AllowSorting="true" AllowFiltering="true" AllowResizing="true" Height="auto">
        <GridColumns>
            <GridColumn Field="@nameof(WellSummaryDto.Name)" HeaderText="Name">
                <Template>
                    @{ var row = context as WellSummaryDto; }
                    @if (row is not null)
                    {
                        <a class="enki-row-link"
                           href="@($"/tenants/{TenantCode}/wells/{row.Id}")">@row.Name</a>
                    }
                </Template>
            </GridColumn>
            <GridColumn Field="@nameof(WellSummaryDto.Type)" HeaderText="Type" Width="120">
                <Template>
                    @{ var row = context as WellSummaryDto; }
                    @if (row is not null)
                    {
                        <span class="enki-status-pill @TypeClass(row.Type)">@row.Type</span>
                    }
                </Template>
            </GridColumn>
            <GridColumn Field="@nameof(WellSummaryDto.SurveyCount)" HeaderText="Surveys" Width="120" Format="N0" />
            <GridColumn Field="@nameof(WellSummaryDto.TieOnCount)"  HeaderText="Tie-ons" Width="120" Format="N0" />
            <GridColumn Field="@nameof(WellSummaryDto.CreatedAt)"
                        HeaderText="Created" Width="180"
                        Format="yyyy-MM-dd HH:mm" Type="ColumnType.DateTime" />
        </GridColumns>
    </SfGrid>
}

@code {
    [Parameter] public string TenantCode { get; set; } = "";

    private List<WellSummaryDto>? _wells;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("EnkiApi");
            _wells = await client.GetFromJsonAsync<List<WellSummaryDto>>(
                $"tenants/{TenantCode}/wells") ?? new();
        }
        catch (HttpRequestException ex) { _error = $"WebApi call failed: {ex.Message}"; }
        catch (Exception ex)             { _error = $"Unexpected error: {ex.Message}"; }
    }

    private static string TypeClass(string s) => s switch
    {
        "Target"    => "enki-status-active",
        "Injection" => "enki-status-inactive",
        "Offset"    => "enki-status-archived",
        _           => "",
    };
}
