@page "/tenants/{TenantCode}/jobs/{JobId:guid}/wells"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@inject SDI.Enki.BlazorServer.Auth.IUserCapabilities Capabilities
@using SDI.Enki.BlazorServer.Api
@using SDI.Enki.Shared.Wells

@*
    Wells under a Job. Wells are the entry point to every drilling-data
    surface — Surveys, TieOns, Tubulars, Formations, CommonMeasures all
    nest under a Well, so this list lights up the rest of the surface.

    Pattern matches Jobs.razor: stat cards across the top, Syncfusion
    grid below, "+ New well" + "Back to job" actions in the header.
*@

<PageTitle>Enki &mdash; Wells (@TenantCode)</PageTitle>

<div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; flex-wrap: wrap;">
    <div style="flex: 1; min-width: 280px;">
        <h1 class="enki-section-title">
            Wells
            <span class="enki-mono" style="font-size: 0.65em; opacity: 0.65; margin-left: 0.5rem;">
                @TenantCode &middot; Job @ShortJobId
            </span>
        </h1>
        <p class="enki-section-subtitle">
            Physical wellbores under this Job. Click a well to open its
            main page — surveys, tubulars, formations, common measures,
            and the magnetic-reference block all live there.
        </p>
    </div>
    <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
        <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}")">Back to job</NavLink>
        <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/plot")">
            Plan view
        </NavLink>
        @* "+ New well" requires write access to tenant content (Office+
           tenant member or admin). Field can browse but not create. *@
        @if (_canWrite)
        {
            <NavLink class="enki-button enki-button-primary"
                     href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/new")">
                + New well
            </NavLink>
        }
    </div>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_wells is null)
{
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Fetching wells from API&hellip;</div>
    </div>
}
else
{
    <div class="enki-stat-grid">
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_wells.Count.ToString("D2")</div>
            <div class="enki-stat-label">Wells</div>
        </div>
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_wells.Count(w => w.Type == "Target").ToString("D2")</div>
            <div class="enki-stat-label">Target</div>
        </div>
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_wells.Count(w => w.Type == "Intercept").ToString("D2")</div>
            <div class="enki-stat-label">Intercept</div>
        </div>
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_wells.Count(w => w.Type == "Offset").ToString("D2")</div>
            <div class="enki-stat-label">Offset</div>
        </div>
    </div>

    <EnkiListGrid TValue="WellSummaryDto"
                  DataSource="_wells"
                  ElasticField="@nameof(WellSummaryDto.Name)">
        <GridColumn Field="@nameof(WellSummaryDto.Name)" HeaderText="Name" MinWidth="200">
            <Template>
                @{ var row = context as WellSummaryDto; }
                @if (row is not null)
                {
                    @* Click-through lands on the well's main page
                       (WellDetail) — the user picks their child surface
                       from the four tiles there (Surveys / Tubulars /
                       Formations / Common Measures) plus the
                       magnetic-reference block. Going straight to
                       /surveys forced everyone after Tubulars /
                       Formations / etc. to "back out through Surveys
                       to see the well info"; this is the fix for
                       issue #7. *@
                    <a class="enki-row-link"
                       href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{row.Id}")">@row.Name</a>
                }
            </Template>
        </GridColumn>
        <GridColumn Field="@nameof(WellSummaryDto.Type)" HeaderText="Type">
            <Template>
                @{ var row = context as WellSummaryDto; }
                @if (row is not null)
                {
                    <span class="enki-status-pill @TypeClass(row.Type)">@row.Type</span>
                }
            </Template>
        </GridColumn>
        <GridColumn Field="@nameof(WellSummaryDto.SurveyCount)" HeaderText="Surveys" Format="N0" />
        <GridColumn Field="@nameof(WellSummaryDto.TieOnCount)"  HeaderText="Tie-ons" Format="N0" />
        <GridColumn Field="@nameof(WellSummaryDto.CreatedAt)"
                    HeaderText="Created"
                    Format="yyyy-MM-dd HH:mm" Type="ColumnType.DateTime">
            <Template>
                @{ var row = context as WellSummaryDto; }
                @if (row is not null)
                {
                    <span class="enki-mono">@row.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                }
            </Template>
        </GridColumn>
    </EnkiListGrid>
}

@code {
    [Parameter] public string TenantCode { get; set; } = "";
    [Parameter] public Guid JobId { get; set; }

    private List<WellSummaryDto>? _wells;
    private string? _error;
    private bool _canWrite;

    private string ShortJobId => JobId.ToString("N")[..8];

    protected override async Task OnInitializedAsync()
    {
        var client = HttpClientFactory.CreateClient("EnkiApi");
        var result = await client.GetAsync<List<WellSummaryDto>>(
            $"tenants/{TenantCode}/jobs/{JobId}/wells");

        if (!result.IsSuccess) { _error = result.Error.AsAlertText(); return; }
        _wells = result.Value;

        _canWrite = await Capabilities.CanWriteTenantContentAsync(TenantCode);
    }

    private static string TypeClass(string s) => s switch
    {
        "Target"    => "enki-status-active",
        "Intercept" => "enki-status-inactive",
        "Offset"    => "enki-status-archived",
        _           => "",
    };
}
