@page "/tenants/{TenantCode}/wells/{WellId:int}/tieons/new"
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using SDI.Enki.Shared.Wells.TieOns

@*
    New tie-on form. Same shape as JobCreate.razor — server-side
    rendered, EditForm + DataAnnotations. The three observed values
    (Depth / Inclination / Azimuth) are required; grid-coordinate
    fields default to zero and can be filled in later via the edit
    page if a particular reference frame is in use.

    [SupplyParameterFromForm] + the OnInitialized null-check dance
    avoids the BL0008 blow-up where Blazor nulls the model field
    during form post.
*@

<PageTitle>Enki &mdash; New Tie-On (Well @WellId)</PageTitle>

<h1 class="enki-section-title">New Tie-On</h1>
<p class="enki-section-subtitle">
    Anchors the trajectory calculation for
    <span class="enki-mono">@TenantCode</span> &middot;
    Well <span class="enki-mono">@WellId</span>. Observed values (depth,
    inclination, azimuth) are required.
</p>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

<div class="enki-card" style="max-width: 720px; margin-top: 1.25rem;">
    <EditForm Model="Form" OnValidSubmit="Submit" FormName="create-tieon"
              class="enki-form" Enhance="true">
        <DataAnnotationsValidator />
        <ValidationSummary class="enki-validation-summary" />

        <h2 class="enki-form-section-title">Observed</h2>

        <div class="enki-form-group">
            <label class="enki-form-label required" for="f-depth">Depth</label>
            <InputNumber @bind-Value="Form!.Depth" id="f-depth" class="enki-form-input" required />
            <div class="enki-form-hint">Measured depth at the tie-on station.</div>
            <ValidationMessage For="() => Form.Depth" class="enki-form-error" />
        </div>

        <div class="enki-form-group">
            <label class="enki-form-label required" for="f-inc">Inclination (°)</label>
            <InputNumber @bind-Value="Form!.Inclination" id="f-inc" class="enki-form-input" required />
            <div class="enki-form-hint">0 to 180 degrees from vertical.</div>
            <ValidationMessage For="() => Form.Inclination" class="enki-form-error" />
        </div>

        <div class="enki-form-group">
            <label class="enki-form-label required" for="f-az">Azimuth (°)</label>
            <InputNumber @bind-Value="Form!.Azimuth" id="f-az" class="enki-form-input" required />
            <div class="enki-form-hint">0 to 360 degrees, true north reference.</div>
            <ValidationMessage For="() => Form.Azimuth" class="enki-form-error" />
        </div>

        <h2 class="enki-form-section-title">Reference grid (optional)</h2>

        <div class="enki-form-grid-2col">
            <div class="enki-form-group">
                <label class="enki-form-label" for="f-north">North</label>
                <InputNumber @bind-Value="Form!.North" id="f-north" class="enki-form-input" />
            </div>
            <div class="enki-form-group">
                <label class="enki-form-label" for="f-east">East</label>
                <InputNumber @bind-Value="Form!.East" id="f-east" class="enki-form-input" />
            </div>
            <div class="enki-form-group">
                <label class="enki-form-label" for="f-northing">Northing</label>
                <InputNumber @bind-Value="Form!.Northing" id="f-northing" class="enki-form-input" />
            </div>
            <div class="enki-form-group">
                <label class="enki-form-label" for="f-easting">Easting</label>
                <InputNumber @bind-Value="Form!.Easting" id="f-easting" class="enki-form-input" />
            </div>
            <div class="enki-form-group">
                <label class="enki-form-label" for="f-vref">Vertical reference</label>
                <InputNumber @bind-Value="Form!.VerticalReference" id="f-vref" class="enki-form-input" />
            </div>
            <div class="enki-form-group">
                <label class="enki-form-label" for="f-ssref">Sub-sea reference</label>
                <InputNumber @bind-Value="Form!.SubSeaReference" id="f-ssref" class="enki-form-input" />
            </div>
            <div class="enki-form-group">
                <label class="enki-form-label" for="f-vsd">Vertical-section direction (°)</label>
                <InputNumber @bind-Value="Form!.VerticalSectionDirection" id="f-vsd" class="enki-form-input" />
            </div>
        </div>

        <div class="enki-form-actions">
            <button type="submit" class="enki-button enki-button-primary">Create tie-on</button>
            <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/wells/{WellId}/tieons")">Cancel</NavLink>
        </div>
    </EditForm>
</div>

@code {
    [Parameter] public string TenantCode { get; set; } = "";
    [Parameter] public int WellId { get; set; }

    [SupplyParameterFromForm]
    public CreateForm? Form { get; set; }

    private string? _error;

    protected override void OnInitialized()
    {
        // Same BL0008 dance as JobCreate — don't initialise a
        // [SupplyParameterFromForm] property in a field initialiser,
        // or the framework can null it during the form post.
        Form ??= new CreateForm();
    }

    private async Task Submit()
    {
        if (Form is null) return;
        _error = null;
        try
        {
            var client = HttpClientFactory.CreateClient("EnkiApi");
            var dto = new CreateTieOnDto(
                Depth:                    Form.Depth,
                Inclination:              Form.Inclination,
                Azimuth:                  Form.Azimuth,
                North:                    Form.North,
                East:                     Form.East,
                Northing:                 Form.Northing,
                Easting:                  Form.Easting,
                VerticalReference:        Form.VerticalReference,
                SubSeaReference:          Form.SubSeaReference,
                VerticalSectionDirection: Form.VerticalSectionDirection);

            using var resp = await client.PostAsJsonAsync(
                $"tenants/{TenantCode}/wells/{WellId}/tieons", dto);

            if (resp.IsSuccessStatusCode)
            {
                Nav.NavigateTo($"/tenants/{TenantCode}/wells/{WellId}/tieons");
                return;
            }

            var body = await resp.Content.ReadAsStringAsync();
            _error = $"Create failed ({(int)resp.StatusCode} {resp.StatusCode}): {body}";
        }
        catch (Exception ex)
        {
            _error = $"Unexpected error: {ex.Message}";
        }
    }

    public sealed class CreateForm
    {
        [Required(ErrorMessage = "Depth is required.")]
        public double Depth { get; set; }

        [Required(ErrorMessage = "Inclination is required.")]
        [Range(0d, 180d, ErrorMessage = "Inclination must be between 0 and 180 degrees.")]
        public double Inclination { get; set; }

        [Required(ErrorMessage = "Azimuth is required.")]
        [Range(0d, 360d, ErrorMessage = "Azimuth must be between 0 and 360 degrees.")]
        public double Azimuth { get; set; }

        public double North { get; set; }
        public double East { get; set; }
        public double Northing { get; set; }
        public double Easting { get; set; }
        public double VerticalReference { get; set; }
        public double SubSeaReference { get; set; }
        public double VerticalSectionDirection { get; set; }
    }
}
