@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav

@*
    Bulk-delete button for the well's Survey rows. Two-click "arm,
    then confirm" pattern matches what SurveyEdit.razor / WellEdit.razor
    use for single-row deletes — no JS interop, no modal, just the
    user has to acknowledge the destructive action explicitly.

    Tie-ons are NOT cleared by this button (server-side scope on
    /surveys); reference data stays put across re-imports.
*@

<div style="display: inline-block;">
    <button type="button"
            class="enki-button enki-button-danger"
            disabled="@_clearing"
            @onclick="HandleClick">
        @ButtonLabel
    </button>
</div>

@if (_message is not null)
{
    <div class="alert @_alertClass" style="margin-top: 0.75rem;">
        @_message
    </div>
}

@code {
    [Parameter, EditorRequired] public string TenantCode { get; set; } = "";
    [Parameter, EditorRequired] public Guid JobId { get; set; }
    [Parameter, EditorRequired] public int WellId { get; set; }

    private bool _armed;
    private bool _clearing;
    private string? _message;
    private string _alertClass = "alert-info";

    private string ButtonLabel =>
        _clearing ? "Clearing…"
        : _armed  ? "Click again to confirm clear"
        :           "Clear surveys";

    private async Task HandleClick()
    {
        if (!_armed)
        {
            // First click — arm the button. A real second click within
            // the user's attention window does the deed; if they
            // navigate away or refresh, the page reload disarms it.
            _armed = true;
            _message = null;
            return;
        }

        _clearing = true;
        _message  = null;
        StateHasChanged();

        try
        {
            var client = HttpClientFactory.CreateClient("EnkiApi");
            using var resp = await client.DeleteAsync(
                $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/surveys");

            if (resp.IsSuccessStatusCode)
            {
                // Force-reload the page so the static-SSR grid re-fetches
                // and the user sees the empty state immediately.
                Nav.NavigateTo(Nav.Uri, forceLoad: true);
                return;
            }

            var body = await resp.Content.ReadAsStringAsync();
            _message = $"Clear failed ({(int)resp.StatusCode}): {body}";
            _alertClass = "alert-danger";
        }
        catch (HttpRequestException ex)
        {
            _message = $"WebApi call failed: {ex.Message}";
            _alertClass = "alert-danger";
        }
        catch (Exception ex)
        {
            _message = $"Unexpected error during clear: {ex.Message}";
            _alertClass = "alert-danger";
        }
        finally
        {
            _clearing = false;
            _armed = false;
        }
    }
}
