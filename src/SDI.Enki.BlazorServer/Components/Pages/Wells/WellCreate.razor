@*
    New well form. EditForm + DataAnnotations + the standard
    [SupplyParameterFromForm] BL0008 dance from JobCreate.
*@

<PageTitle>Enki &mdash; New Well (@TenantCode)</PageTitle>

<h1 class="enki-section-title">New Well</h1>
<p class="enki-section-subtitle">
    Creates a wellbore inside <span class="enki-mono">@TenantCode</span>.
    Type drives behaviour — Target wells are the ones being intercepted,
    Intercept wells are existing cased holes providing magnetic reference for ranging,
    Offset wells are existing neighbours referenced for collision avoidance.
</p>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

<div class="enki-card" style="max-width: 620px; margin-top: 1.25rem;">
    <EditForm Model="Form" OnValidSubmit="Submit" FormName="create-well"
              class="enki-form" Enhance="true">
        <DataAnnotationsValidator />
        <ValidationSummary class="enki-validation-summary" />

        <div class="enki-form-group">
            <label class="enki-form-label required" for="f-name">Name</label>
            <InputText @bind-Value="Form!.Name" id="f-name" class="enki-form-input"
                       placeholder="e.g. Lone Star 14H"
                       required maxlength="200"
                       data-error="Name is required." />
            <div class="enki-form-hint">200 chars max.</div>
            <ValidationMessage For="() => Form.Name" class="enki-form-error" />
        </div>

        <div class="enki-form-group">
            <label class="enki-form-label required" for="f-type">Type</label>
            <InputSelect @bind-Value="Form!.Type" id="f-type" class="enki-form-input" required>
                <option value="Target">Target &mdash; the well being intercepted</option>
                <option value="Intercept">Intercept &mdash; existing cased hole; magnetic reference for ranging</option>
                <option value="Offset">Offset &mdash; neighbour referenced for collision avoidance</option>
            </InputSelect>
            <ValidationMessage For="() => Form.Type" class="enki-form-error" />
        </div>

        <div class="enki-form-actions">
            <button type="submit" class="enki-button enki-button-primary">Create well</button>
            <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells")">Cancel</NavLink>
        </div>
    </EditForm>
</div>

