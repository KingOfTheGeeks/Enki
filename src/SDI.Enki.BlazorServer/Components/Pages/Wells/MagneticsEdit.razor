@page "/tenants/{TenantCode}/jobs/{JobId:guid}/wells/{WellId:int}/magnetics/edit"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@using System.ComponentModel.DataAnnotations
@using SDI.Enki.BlazorServer.Api
@using SDI.Enki.Core.Units
@using SDI.Enki.Shared.Jobs
@using SDI.Enki.Shared.Wells

@*
    Edit (or create) the well's canonical magnetic reference —
    Declination / Dip / Total field. PUT is upsert; loading 404 just
    means "not yet set" and we open the form blank. Optional Clear
    button removes the per-well row (idempotent on the server side).

    BTotal is stored as nT to match the legacy Magnetics column
    convention (the per-shot lookup pool uses nT directly). Angles
    are degrees, signed — Mike's lock-in across the app is "user
    never sees radians", which the angle inputs honour as
    pass-through degrees regardless of the Job's preset.
*@

<PageTitle>Enki &mdash; Magnetic reference (Well @WellId)</PageTitle>

<h1 class="enki-section-title">Magnetic reference</h1>
<p class="enki-section-subtitle">
    <span class="enki-mono">@TenantCode</span> &middot;
    Well <span class="enki-mono">@WellId</span> &middot;
    record of the geomagnetic correction values applied to imported
    survey azimuths.
</p>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
@if (Form is null)
{
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Loading&hellip;</div>
    </div>
}
else
{
    <CascadingValue Name="UnitSystem" Value="_units" IsFixed="false">
    <div class="enki-card" style="max-width: 620px; margin-top: 1.25rem;">
        <EditForm Model="Form" OnValidSubmit="Submit" FormName="edit-magnetics"
                  class="enki-form" Enhance="true">
            <DataAnnotationsValidator />
            <ValidationSummary class="enki-validation-summary" />

            <div class="enki-form-group">
                <label class="enki-form-label required">@UnitLabel.For("Declination", EnkiQuantity.Angle, _units)</label>
                <UnitInput @bind-SiValue="Form.Declination"
                           Quantity="EnkiQuantity.Angle"
                           Min="-180" Max="180"
                           CssClass="enki-form-input" />
                <div class="enki-form-hint">
                    Signed degrees. Positive → magnetic north is
                    east of true / grid north.
                </div>
                <ValidationMessage For="() => Form.Declination" class="enki-form-error" />
            </div>

            <div class="enki-form-group">
                <label class="enki-form-label required">@UnitLabel.For("Dip", EnkiQuantity.Angle, _units)</label>
                <UnitInput @bind-SiValue="Form.Dip"
                           Quantity="EnkiQuantity.Angle"
                           Min="-90" Max="90"
                           CssClass="enki-form-input" />
                <div class="enki-form-hint">
                    Signed degrees. Positive → field points downward
                    (typical for the Northern hemisphere); negative
                    in the Southern hemisphere.
                </div>
                <ValidationMessage For="() => Form.Dip" class="enki-form-error" />
            </div>

            <div class="enki-form-group">
                <label class="enki-form-label required" for="f-btotal">Total field (nT)</label>
                <InputNumber @bind-Value="Form.BTotal"
                             id="f-btotal"
                             class="enki-form-input"
                             step="1"
                             required />
                <div class="enki-form-hint">
                    Nanotesla. Earth's surface values are typically
                    25,000–65,000 nT.
                </div>
                <ValidationMessage For="() => Form.BTotal" class="enki-form-error" />
            </div>

            <div class="enki-form-actions">
                <button type="submit" class="enki-button enki-button-primary">Save</button>
                <NavLink class="enki-button"
                         href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}")">
                    Cancel
                </NavLink>
            </div>
        </EditForm>
    </div>

    @if (_existing)
    {
        @* Clear path — only offered when there's something to
           clear. Server-side DELETE is idempotent so the button
           is safe even if the row's been gone since page load,
           but UI-side we hide it on the "no record yet" path so
           the user doesn't think there was something to remove. *@
        <div class="enki-card enki-danger-card" style="max-width: 620px; margin-top: 1.25rem;">
            <h2 class="enki-form-section-title">Danger zone</h2>
            <p class="enki-form-hint">
                Removing the magnetic reference doesn't change any
                survey data — it just clears the record of what
                correction was applied. Do this if the values were
                entered incorrectly and the upstream correction is
                still being re-derived.
            </p>
            <button type="button" class="enki-button enki-button-danger" @onclick="ConfirmClear">
                @(_clearArmed ? "Click again to confirm clear" : "Clear magnetic reference")
            </button>
            @if (_clearError is not null)
            {
                <div class="alert alert-danger" style="margin-top: 0.75rem;">@_clearError</div>
            }
        </div>
    }
    </CascadingValue>
}

@code {
    [Parameter] public string TenantCode { get; set; } = "";
    [Parameter] public Guid   JobId      { get; set; }
    [Parameter] public int    WellId     { get; set; }

    [SupplyParameterFromForm]
    public EditModel? Form { get; set; }

    private UnitSystem _units = UnitSystem.SI;

    /// <summary>True if a per-well row already exists at load time. Drives the Clear button visibility.</summary>
    private bool _existing;

    private bool   _clearArmed;
    private string? _error;
    private string? _clearError;

    protected override async Task OnInitializedAsync()
    {
        if (Form is not null) return;   // BL0008 dance — preserve a posted form across re-render

        var client = HttpClientFactory.CreateClient("EnkiApi");

        var jobTask = client.GetAsync<JobDetailDto>(
            $"tenants/{TenantCode}/jobs/{JobId}");
        var magTask = client.GetAsync<MagneticsDto>(
            $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/magnetics");

        await Task.WhenAll(jobTask, magTask);

        var jobResult = jobTask.Result;
        var magResult = magTask.Result;

        _units = jobResult.IsSuccess
            ? UnitSystem.FromNameOrSi(jobResult.Value.UnitSystem)
            : UnitSystem.SI;

        if (magResult.IsSuccess)
        {
            _existing = true;
            Form = new EditModel
            {
                BTotal      = magResult.Value.BTotal,
                Dip         = magResult.Value.Dip,
                Declination = magResult.Value.Declination,
            };
            return;
        }

        if (magResult.Error.Kind != ApiErrorKind.NotFound)
        {
            // 404 is the "not set yet" path; anything else is an
            // unexpected failure. Surface it but still let the
            // user fill the form (so they're not blocked).
            _error = magResult.Error.AsAlertText();
        }

        // No existing row: blank form.
        Form = new EditModel();
    }

    private async Task Submit()
    {
        if (Form is null) return;
        _error = null;

        var client = HttpClientFactory.CreateClient("EnkiApi");
        var dto = new SetMagneticsDto(Form.BTotal, Form.Dip, Form.Declination);

        var result = await client.PutAsync(
            $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/magnetics", dto);

        if (result.IsSuccess)
        {
            Nav.NavigateTo($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}");
            return;
        }

        _error = result.Error.AsAlertText();
    }

    private async Task ConfirmClear()
    {
        if (!_clearArmed) { _clearArmed = true; return; }

        _clearError = null;
        var client = HttpClientFactory.CreateClient("EnkiApi");
        // Explicit static-call form: HttpClient has an instance
        // DeleteAsync(string) that returns HttpResponseMessage, which
        // would win overload resolution against our extension.
        var result = await HttpClientApiExtensions.DeleteAsync(client,
            $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/magnetics");

        if (result.IsSuccess)
        {
            Nav.NavigateTo($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}");
            return;
        }

        _clearError = result.Error.AsAlertText();
        _clearArmed = false;
    }

    public sealed class EditModel
    {
        [Required(ErrorMessage = "Declination is required.")]
        [Range(-180d, 180d, ErrorMessage = "Declination must be between −180° and 180°.")]
        public double Declination { get; set; }

        [Required(ErrorMessage = "Dip is required.")]
        [Range(-90d, 90d, ErrorMessage = "Dip must be between −90° and 90°.")]
        public double Dip { get; set; }

        [Required(ErrorMessage = "Total field is required.")]
        [Range(0d, 100_000d, ErrorMessage = "Total field is in nT and must be between 0 and 100,000.")]
        public double BTotal { get; set; }
    }
}
