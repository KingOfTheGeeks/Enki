@rendermode InteractiveServer

@*
    Edit (or create) the well's canonical magnetic reference —
    Declination / Dip / Total field. PUT is upsert; loading 404 just
    means "not yet set" and we open the form blank. Optional Clear
    button removes the per-well row (idempotent on the server side).

    BTotal is stored as nT to match the legacy Magnetics column
    convention (the per-shot lookup pool uses nT directly). Angles
    are degrees, signed — Mike's lock-in across the app is "user
    never sees radians", which the angle inputs honour as
    pass-through degrees regardless of the Job's preset.
*@

<PageTitle>Enki &mdash; Magnetic reference (Well @WellId)</PageTitle>

<h1 class="enki-section-title">Magnetic reference</h1>
<p class="enki-section-subtitle">
    <span class="enki-mono">@TenantCode</span> &middot;
    Well <span class="enki-mono">@WellId</span> &middot;
    record of the geomagnetic correction values applied to imported
    survey azimuths.
</p>

<ApiErrorAlert Error="_error" />
@if (Form is null)
{
    <EnkiLoading />
}
else
{
    <CascadingValue Name="UnitSystem" Value="_units" IsFixed="false">
    <div class="enki-card" style="max-width: 620px; margin-top: 1.25rem;">
        <EditForm Model="Form" OnValidSubmit="Submit" FormName="edit-magnetics"
                  class="enki-form">
            <DataAnnotationsValidator />
            <ValidationSummary class="enki-validation-summary" />

            @* Hidden RowVersion round-trip — see feedback_blazor_ssr_form_roundtrip memory. *@
            <InputText @bind-Value="Form.RowVersion" style="display:none" />

            <div class="enki-form-group">
                <label class="enki-form-label required">@UnitLabel.For("Declination", EnkiQuantity.Angle, _units)</label>
                <UnitInput @bind-SiValue="Form.Declination"
                           Quantity="EnkiQuantity.Angle"
                           Min="-180" Max="180"
                           CssClass="enki-form-input" />
                <div class="enki-form-hint">
                    Signed degrees. Positive → magnetic north is
                    east of true / grid north.
                </div>
                <ValidationMessage For="() => Form.Declination" class="enki-form-error" />
            </div>

            <div class="enki-form-group">
                <label class="enki-form-label required">@UnitLabel.For("Dip", EnkiQuantity.Angle, _units)</label>
                <UnitInput @bind-SiValue="Form.Dip"
                           Quantity="EnkiQuantity.Angle"
                           Min="-90" Max="90"
                           CssClass="enki-form-input" />
                <div class="enki-form-hint">
                    Signed degrees. Positive → field points downward
                    (typical for the Northern hemisphere); negative
                    in the Southern hemisphere.
                </div>
                <ValidationMessage For="() => Form.Dip" class="enki-form-error" />
            </div>

            <div class="enki-form-group">
                @* nT wrapped in .enki-keep-case so the form label's
                   uppercase styling doesn't render the unit as "NT"
                   (which is meaningless — the SI symbol is "nT"). *@
                <label class="enki-form-label required" for="f-btotal">Total field (<span class="enki-keep-case">nT</span>)</label>
                <InputNumber @bind-Value="Form.BTotal"
                             id="f-btotal"
                             class="enki-form-input"
                             step="1"
                             required />
                <div class="enki-form-hint">
                    Nanotesla. Earth's surface values are typically
                    25,000–65,000 nT.
                </div>
                <ValidationMessage For="() => Form.BTotal" class="enki-form-error" />
            </div>

            <div class="enki-form-actions">
                <button type="submit" class="enki-button enki-button-primary">Save</button>
                <NavLink class="enki-button"
                         href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}")">
                    Cancel
                </NavLink>
            </div>
        </EditForm>
    </div>

    @if (_existing)
    {
        @* Clear path — only offered when there's something to
           clear. Server-side DELETE is idempotent so the button
           is safe even if the row's been gone since page load,
           but UI-side we hide it on the "no record yet" path so
           the user doesn't think there was something to remove. *@
        <div class="enki-card enki-danger-card" style="max-width: 620px; margin-top: 1.25rem;">
            <h2 class="enki-form-section-title">Danger zone</h2>
            <p class="enki-form-hint">
                Removing the magnetic reference doesn't change any
                survey data — it just clears the record of what
                correction was applied. Do this if the values were
                entered incorrectly and the upstream correction is
                still being re-derived.
            </p>
            <button type="button" class="enki-button enki-button-danger" @onclick="ConfirmClear">
                @(_clearArmed ? "Click again to confirm clear" : "Clear magnetic reference")
            </button>
            @if (_clearError is not null)
            {
                <div class="alert alert-danger" style="margin-top: 0.75rem;">@_clearError</div>
            }
        </div>
    }
    </CascadingValue>
}

