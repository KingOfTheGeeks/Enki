@rendermode InteractiveServer

@*
    Edit existing well — name + type only. Delete sits in a danger
    zone with the standard "click again to confirm" pattern. The
    backend refuses delete with a 409 ConflictProblem if the well has
    any child rows; we surface that body verbatim so the user
    understands why and can clear out the children first.

    Route, [Authorize], DI, and the @code block all live in
    WellEdit.razor.cs as attributes / [Inject] properties on the
    partial class. @rendermode stays here — it's per-instance and
    doesn't have a class-level attribute equivalent.
*@

<PageTitle>Enki &mdash; Edit Well @WellId (@TenantCode)</PageTitle>

<h1 class="enki-section-title">Edit Well</h1>
<p class="enki-section-subtitle">
    <span class="enki-mono">@TenantCode</span> &middot;
    Well <span class="enki-mono">@WellId</span>
</p>

@if (_loadError is not null)
{
    <div class="alert alert-danger">@_loadError</div>
    <div class="enki-form-actions" style="border-top: none; margin-top: 1rem; padding-top: 0;">
        <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells")">Back to wells</NavLink>
    </div>
}
else if (Form is null)
{
    <EnkiLoading Label="Loading well…" />
}
else
{
    @if (_submitError is not null)
    {
        <div class="alert alert-danger">@_submitError</div>
    }

    <div class="enki-card" style="max-width: 620px; margin-top: 1.25rem;">
        <EditForm Model="Form" OnValidSubmit="Submit" FormName="edit-well"
                  class="enki-form">
            <DataAnnotationsValidator />
            <ValidationSummary class="enki-validation-summary" />

            @* Hidden RowVersion round-trip — see feedback_blazor_ssr_form_roundtrip memory. *@
            <InputText @bind-Value="Form.RowVersion" style="display:none" />

            <div class="enki-form-group">
                <label class="enki-form-label required" for="f-name">Name</label>
                <InputText @bind-Value="Form.Name" id="f-name" class="enki-form-input"
                           required maxlength="200" />
                <ValidationMessage For="() => Form.Name" class="enki-form-error" />
            </div>

            <div class="enki-form-group">
                <label class="enki-form-label required" for="f-type">Type</label>
                @* Descriptive option labels mirror WellCreate.razor so the
                   meaning of each well type is visible at the point of
                   choice — the bare "Target / Intercept / Offset" label
                   would force the user to remember which is which. *@
                <InputSelect @bind-Value="Form.Type" id="f-type" class="enki-form-input" required>
                    <option value="Target">Target &mdash; the well being intercepted</option>
                    <option value="Intercept">Intercept &mdash; existing cased hole; magnetic reference for ranging</option>
                    <option value="Offset">Offset &mdash; neighbour referenced for collision avoidance</option>
                </InputSelect>
                <ValidationMessage For="() => Form.Type" class="enki-form-error" />
            </div>

            <div class="enki-form-actions">
                <button type="submit" class="enki-button enki-button-primary">Save changes</button>
                <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}")">Cancel</NavLink>
            </div>
        </EditForm>
    </div>

    <div class="enki-card enki-danger-card" style="max-width: 620px; margin-top: 1.25rem;">
        <h2 class="enki-form-section-title">Danger zone</h2>
        <p class="enki-form-hint">
            Wells with child data (surveys, tie-ons, tubulars, formations,
            common measures) cannot be deleted from here — the API
            returns a 409 conflict and refers you to clear the children
            first.
        </p>
        <button type="button" class="enki-button enki-button-danger" @onclick="ConfirmDelete">
            @(_deleteArmed ? "Click again to confirm delete" : "Delete well")
        </button>
        @if (_deleteError is not null)
        {
            <div class="alert alert-danger" style="margin-top: 0.75rem;">@_deleteError</div>
        }
    </div>
}

@* Code-behind in WellEdit.razor.cs *@
