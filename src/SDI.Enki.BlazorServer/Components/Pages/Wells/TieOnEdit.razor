@rendermode InteractiveServer

@*
    Edit existing tie-on. PUT /tieons/{id} rewrites every field; this
    page round-trips the full TieOnDetailDto so unchanged fields stay
    intact. Reset-to-zero lives at the bottom — single-click confirm
    (clicking once arms the second click), no JS dialog. The server
    DELETE endpoint zeros every observed/reference value but keeps
    the row, because every well must keep a tie-on on file so the
    survey calculation always has an anchor. Matches the Clear pattern
    in MagneticsEdit.razor.

    Inputs route through <UnitInput> for unit-aware editing in the
    Job's preferred preset; Form fields hold SI values for the PUT.
*@

<PageTitle>Enki &mdash; Edit Tie-On (@TieOnId)</PageTitle>

<h1 class="enki-section-title">Edit Tie-On</h1>
<p class="enki-section-subtitle">
    <span class="enki-mono">@TenantCode</span> &middot;
    Well <span class="enki-mono">@WellId</span> &middot;
    Tie-On <span class="enki-mono">@TieOnId</span>
</p>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

@if (_loadFailed)
{
    <div class="alert alert-danger">
        Could not load tie-on. It may have been deleted.
        <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/surveys")">
            Back to surveys
        </NavLink>
    </div>
}
else if (Form is null)
{
    <EnkiLoading Label="Loading tie-on…" />
}
else
{
    <CascadingValue Name="UnitSystem" Value="_units" IsFixed="false">
    <div class="enki-card" style="max-width: 720px; margin-top: 1.25rem;">
        <EditForm Model="Form" OnValidSubmit="Submit" FormName="edit-tieon"
                  class="enki-form">
            <DataAnnotationsValidator />
            <ValidationSummary class="enki-validation-summary" />

            @* Hidden RowVersion round-trip — see feedback_blazor_ssr_form_roundtrip memory. *@
            <InputText @bind-Value="Form.RowVersion" style="display:none" />

            <h2 class="enki-form-section-title">Observed</h2>

            <div class="enki-form-group">
                <label class="enki-form-label required">@UnitLabel.For("Depth", EnkiQuantity.Length, _units)</label>
                <UnitInput @bind-SiValue="Form.Depth" Quantity="EnkiQuantity.Length" CssClass="enki-form-input" />
                <ValidationMessage For="() => Form.Depth" class="enki-form-error" />
            </div>

            <div class="enki-form-group">
                <label class="enki-form-label required">@UnitLabel.For("Inclination", EnkiQuantity.Angle, _units)</label>
                <UnitInput @bind-SiValue="Form.Inclination" Quantity="EnkiQuantity.Angle" Min="0" Max="180" CssClass="enki-form-input" />
                <ValidationMessage For="() => Form.Inclination" class="enki-form-error" />
            </div>

            <div class="enki-form-group">
                <label class="enki-form-label required">@UnitLabel.For("Azimuth", EnkiQuantity.Angle, _units)</label>
                <UnitInput @bind-SiValue="Form.Azimuth" Quantity="EnkiQuantity.Angle" Min="0" Max="360" CssClass="enki-form-input" />
                <ValidationMessage For="() => Form.Azimuth" class="enki-form-error" />
            </div>

            <h2 class="enki-form-section-title">Reference grid</h2>

            @* North / East are anchor-relative offsets that are 0 by
               definition on the tie-on (it IS the anchor). Form.North
               and Form.East round-trip whatever's on the loaded DTO so
               historical values survive the PUT, but there's no input
               here — the user can't drift them away from 0 by accident. *@
            <div class="enki-form-grid-2col">
                <div class="enki-form-group">
                    <label class="enki-form-label">@UnitLabel.For("Northing", EnkiQuantity.Length, _units)</label>
                    <UnitInput @bind-SiValue="Form.Northing" Quantity="EnkiQuantity.Length" CssClass="enki-form-input" />
                </div>
                <div class="enki-form-group">
                    <label class="enki-form-label">@UnitLabel.For("Easting", EnkiQuantity.Length, _units)</label>
                    <UnitInput @bind-SiValue="Form.Easting" Quantity="EnkiQuantity.Length" CssClass="enki-form-input" />
                </div>
                <div class="enki-form-group">
                    <label class="enki-form-label">@UnitLabel.For("Vertical reference", EnkiQuantity.Length, _units)</label>
                    <UnitInput @bind-SiValue="Form.VerticalReference" Quantity="EnkiQuantity.Length" CssClass="enki-form-input" />
                </div>
                <div class="enki-form-group">
                    <label class="enki-form-label">@UnitLabel.For("Sub-sea reference", EnkiQuantity.Length, _units)</label>
                    <UnitInput @bind-SiValue="Form.SubSeaReference" Quantity="EnkiQuantity.Length" CssClass="enki-form-input" />
                </div>
                <div class="enki-form-group">
                    <label class="enki-form-label">@UnitLabel.For("Vertical-section direction", EnkiQuantity.Angle, _units)</label>
                    <UnitInput @bind-SiValue="Form.VerticalSectionDirection" Quantity="EnkiQuantity.Angle" Min="0" Max="360" CssClass="enki-form-input" />
                </div>
            </div>

            <div class="enki-form-actions">
                <button type="submit" class="enki-button enki-button-primary">Save changes</button>
                <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/surveys")">Cancel</NavLink>
            </div>
        </EditForm>
    </div>

    <div class="enki-card enki-danger-card" style="max-width: 720px; margin-top: 1.25rem;">
        <h2 class="enki-form-section-title">Danger zone</h2>
        <p class="enki-form-hint">
            Resets every observed and reference value on this tie-on to
            zero. Surveys on this well recompute against the zero-anchor
            immediately. Use this to start over rather than to remove the
            record — every well must keep a tie-on on file so survey
            calculation always has an anchor.
        </p>
        <button type="button" class="enki-button enki-button-danger" @onclick="ConfirmReset">
            @(_resetArmed ? "Click again to confirm reset" : "Reset tie-on to zero")
        </button>
    </div>
    </CascadingValue>
}

