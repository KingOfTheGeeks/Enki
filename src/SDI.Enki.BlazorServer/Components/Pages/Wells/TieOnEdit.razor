@page "/tenants/{TenantCode}/jobs/{JobId:guid}/wells/{WellId:int}/tieons/{TieOnId:int}/edit"
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using SDI.Enki.Shared.Wells.TieOns

@*
    Edit existing tie-on. PUT /tieons/{id} rewrites every field; this
    page round-trips the full TieOnDetailDto so unchanged fields stay
    intact. Delete lives at the bottom — single-click confirm
    (clicking once arms the second click), no JS dialog. Matches the
    pattern in JobEdit.razor.
*@

<PageTitle>Enki &mdash; Edit Tie-On (@TieOnId)</PageTitle>

<h1 class="enki-section-title">Edit Tie-On</h1>
<p class="enki-section-subtitle">
    <span class="enki-mono">@TenantCode</span> &middot;
    Well <span class="enki-mono">@WellId</span> &middot;
    Tie-On <span class="enki-mono">@TieOnId</span>
</p>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

@if (_loadFailed)
{
    <div class="alert alert-danger">
        Could not load tie-on. It may have been deleted.
        <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/tieons")">
            Back to tie-ons
        </NavLink>
    </div>
}
else if (Form is null)
{
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Loading tie-on&hellip;</div>
    </div>
}
else
{
    <div class="enki-card" style="max-width: 720px; margin-top: 1.25rem;">
        <EditForm Model="Form" OnValidSubmit="Submit" FormName="edit-tieon"
                  class="enki-form" Enhance="true">
            <DataAnnotationsValidator />
            <ValidationSummary class="enki-validation-summary" />

            <h2 class="enki-form-section-title">Observed</h2>

            <div class="enki-form-group">
                <label class="enki-form-label required" for="f-depth">Depth</label>
                <InputNumber @bind-Value="Form.Depth" id="f-depth" class="enki-form-input" required />
                <ValidationMessage For="() => Form.Depth" class="enki-form-error" />
            </div>

            <div class="enki-form-group">
                <label class="enki-form-label required" for="f-inc">Inclination (°)</label>
                <InputNumber @bind-Value="Form.Inclination" id="f-inc" class="enki-form-input" required />
                <ValidationMessage For="() => Form.Inclination" class="enki-form-error" />
            </div>

            <div class="enki-form-group">
                <label class="enki-form-label required" for="f-az">Azimuth (°)</label>
                <InputNumber @bind-Value="Form.Azimuth" id="f-az" class="enki-form-input" required />
                <ValidationMessage For="() => Form.Azimuth" class="enki-form-error" />
            </div>

            <h2 class="enki-form-section-title">Reference grid</h2>

            <div class="enki-form-grid-2col">
                <div class="enki-form-group">
                    <label class="enki-form-label" for="f-north">North</label>
                    <InputNumber @bind-Value="Form.North" id="f-north" class="enki-form-input" />
                </div>
                <div class="enki-form-group">
                    <label class="enki-form-label" for="f-east">East</label>
                    <InputNumber @bind-Value="Form.East" id="f-east" class="enki-form-input" />
                </div>
                <div class="enki-form-group">
                    <label class="enki-form-label" for="f-northing">Northing</label>
                    <InputNumber @bind-Value="Form.Northing" id="f-northing" class="enki-form-input" />
                </div>
                <div class="enki-form-group">
                    <label class="enki-form-label" for="f-easting">Easting</label>
                    <InputNumber @bind-Value="Form.Easting" id="f-easting" class="enki-form-input" />
                </div>
                <div class="enki-form-group">
                    <label class="enki-form-label" for="f-vref">Vertical reference</label>
                    <InputNumber @bind-Value="Form.VerticalReference" id="f-vref" class="enki-form-input" />
                </div>
                <div class="enki-form-group">
                    <label class="enki-form-label" for="f-ssref">Sub-sea reference</label>
                    <InputNumber @bind-Value="Form.SubSeaReference" id="f-ssref" class="enki-form-input" />
                </div>
                <div class="enki-form-group">
                    <label class="enki-form-label" for="f-vsd">Vertical-section direction (°)</label>
                    <InputNumber @bind-Value="Form.VerticalSectionDirection" id="f-vsd" class="enki-form-input" />
                </div>
            </div>

            <div class="enki-form-actions">
                <button type="submit" class="enki-button enki-button-primary">Save changes</button>
                <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/tieons")">Cancel</NavLink>
            </div>
        </EditForm>
    </div>

    <div class="enki-card enki-danger-card" style="max-width: 720px; margin-top: 1.25rem;">
        <h2 class="enki-form-section-title">Danger zone</h2>
        <p class="enki-form-hint">
            Deleting a tie-on invalidates every survey calculation that
            referenced it. Calculations re-run against the next tie-on
            on file (if any) the next time someone presses Calculate.
        </p>
        <button type="button" class="enki-button enki-button-danger" @onclick="ConfirmDelete">
            @(_deleteArmed ? "Click again to confirm delete" : "Delete tie-on")
        </button>
    </div>
}

@code {
    [Parameter] public string TenantCode { get; set; } = "";
    [Parameter] public Guid JobId { get; set; }
    [Parameter] public int WellId { get; set; }
    [Parameter] public int TieOnId { get; set; }

    private string? _error;
    private bool _loadFailed;
    private bool _deleteArmed;

    [SupplyParameterFromForm]
    public EditModel? Form { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("EnkiApi");
            var dto = await client.GetFromJsonAsync<TieOnDetailDto>(
                $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/tieons/{TieOnId}");
            if (dto is null) { _loadFailed = true; return; }

            Form ??= new EditModel
            {
                Depth                    = dto.Depth,
                Inclination              = dto.Inclination,
                Azimuth                  = dto.Azimuth,
                North                    = dto.North,
                East                     = dto.East,
                Northing                 = dto.Northing,
                Easting                  = dto.Easting,
                VerticalReference        = dto.VerticalReference,
                SubSeaReference          = dto.SubSeaReference,
                VerticalSectionDirection = dto.VerticalSectionDirection,
            };
        }
        catch (HttpRequestException ex) { _error = $"WebApi call failed: {ex.Message}"; }
        catch (Exception ex)             { _error = $"Unexpected error: {ex.Message}"; }
    }

    private async Task Submit()
    {
        if (Form is null) return;
        _error = null;
        try
        {
            var client = HttpClientFactory.CreateClient("EnkiApi");
            var dto = new UpdateTieOnDto(
                Depth:                    Form.Depth,
                Inclination:              Form.Inclination,
                Azimuth:                  Form.Azimuth,
                North:                    Form.North,
                East:                     Form.East,
                Northing:                 Form.Northing,
                Easting:                  Form.Easting,
                VerticalReference:        Form.VerticalReference,
                SubSeaReference:          Form.SubSeaReference,
                VerticalSectionDirection: Form.VerticalSectionDirection);

            using var resp = await client.PutAsJsonAsync(
                $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/tieons/{TieOnId}", dto);

            if (resp.IsSuccessStatusCode)
            {
                Nav.NavigateTo($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/tieons");
                return;
            }

            var body = await resp.Content.ReadAsStringAsync();
            _error = $"Save failed ({(int)resp.StatusCode} {resp.StatusCode}): {body}";
        }
        catch (Exception ex)
        {
            _error = $"Unexpected error: {ex.Message}";
        }
    }

    private async Task ConfirmDelete()
    {
        if (!_deleteArmed)
        {
            // First click — arm the delete; second click within the
            // same render cycle commits.
            _deleteArmed = true;
            return;
        }

        try
        {
            var client = HttpClientFactory.CreateClient("EnkiApi");
            using var resp = await client.DeleteAsync(
                $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/tieons/{TieOnId}");

            if (resp.IsSuccessStatusCode)
            {
                Nav.NavigateTo($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/tieons");
                return;
            }

            var body = await resp.Content.ReadAsStringAsync();
            _error = $"Delete failed ({(int)resp.StatusCode} {resp.StatusCode}): {body}";
            _deleteArmed = false;
        }
        catch (Exception ex)
        {
            _error = $"Unexpected error: {ex.Message}";
            _deleteArmed = false;
        }
    }

    public sealed class EditModel
    {
        [Required(ErrorMessage = "Depth is required.")]
        public double Depth { get; set; }

        [Required(ErrorMessage = "Inclination is required.")]
        [Range(0d, 180d, ErrorMessage = "Inclination must be between 0 and 180 degrees.")]
        public double Inclination { get; set; }

        [Required(ErrorMessage = "Azimuth is required.")]
        [Range(0d, 360d, ErrorMessage = "Azimuth must be between 0 and 360 degrees.")]
        public double Azimuth { get; set; }

        public double North { get; set; }
        public double East { get; set; }
        public double Northing { get; set; }
        public double Easting { get; set; }
        public double VerticalReference { get; set; }
        public double SubSeaReference { get; set; }
        public double VerticalSectionDirection { get; set; }
    }
}
