@page "/tenants/{TenantCode}/jobs/{JobId:guid}/wells/{WellId:int}/common-measures"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@inject UnitPreferenceProvider UnitPrefs
@using SDI.Enki.BlazorServer.Api
@using SDI.Enki.Core.Units
@using SDI.Enki.Shared.Paging
@using SDI.Enki.Shared.Surveys
@using SDI.Enki.Shared.Wells.CommonMeasures

@*
    Common Measures grid. From / To MD are editable Lengths (canonical
    depth on a CommonMeasure; TVD is derived server-side from the
    well's Surveys via Marduk's minimum-curvature ISurveyInterpolator
    and rendered read-only). Value is a dimensionless signal-calculation
    scaling multiplier (a "fudge factor" expressed as a percentage of 1
    — typically 0.85 to 1.15) that downhole signal-processing algorithms
    apply per depth window.

    Survey-gated creation: the well needs at least two surveys before a
    CommonMeasure can be added. Mirrors Formations.razor.

    Editing is wired through Syncfusion's native inline edit, mirroring
    Surveys.razor: double-click a row to enter Normal edit mode,
    Enter saves (toolbar Update / Cancel are the visible affordance).
    UpdateCommonMeasureDto carries the full update set (FromMeasured,
    ToMeasured, Value) so no detail-fetch round-trip is needed before
    PUT — Summary == Update field shape.
*@

<PageTitle>Enki &mdash; Common Measures (Well @WellId)</PageTitle>

<PageHeader Title="Common Measures">
    <TitleSuffix>
        <span class="enki-mono">@TenantCode &middot; Well @WellId</span>
    </TitleSuffix>
    <Subtitle>
        Depth-ranged signal-calculation scaling factors —
        dimensionless multipliers (≈ 1.0) that the downhole signal
        processing applies per measured-depth interval. Vertical
        depth is interpolated from the well's surveys.
        <strong>Double-click a row</strong> to edit it inline;
        Enter saves.
    </Subtitle>
    <Actions>
        <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}")">Back to well</NavLink>
        @if (_hasEnoughSurveys)
        {
            <NavLink class="enki-button enki-button-primary"
                     href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/common-measures/new")">
                + New measure
            </NavLink>
        }
        else
        {
            <button type="button" class="enki-button enki-button-primary" disabled
                    title="This well needs at least one survey before a measure can be created.">
                + New measure
            </button>
        }
    </Actions>
</PageHeader>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
@if (_saveStatus is not null)
{
    <div class="alert @_saveAlertClass">@_saveStatus</div>
}
@if (_rows is not null && !_hasEnoughSurveys)
{
    <div class="alert alert-warning" role="alert">
        <strong>Surveys required.</strong>
        Vertical depth on a measure is interpolated from the well's
        surveys (Marduk minimum-curvature). Add at least one survey
        station before creating a measure —
        <NavLink href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/surveys")">
            go to surveys
        </NavLink>.
    </div>
}
@if (_rows is null && _error is null)
{
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Fetching measures from API&hellip;</div>
    </div>
}

@if (_rows is not null && _error is null)
{
    <CascadingValue Name="UnitSystem" Value="_units" IsFixed="false">
    <div class="enki-stat-grid">
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_rows.Count.ToString("D2")</div>
            <div class="enki-stat-label">Measures</div>
        </div>
    </div>

    @* Toolbar hidden on an empty grid — Update / Delete have nothing
       to act on; the only useful action there is + New measure at
       the page header. *@
    <SfGrid DataSource="_rows"
            AllowSorting="true"
            AllowFiltering="true"
            AllowResizing="true"
            Toolbar="@(_rows.Count > 0 ? new List<string> { "Update", "Cancel", "Delete" } : null)"
            Height="auto">
        <GridEditSettings AllowEditing="true"
                          AllowAdding="false"
                          AllowDeleting="true"
                          ShowDeleteConfirmDialog="true"
                          Mode="EditMode.Normal" />
        <GridEvents OnActionComplete="OnActionCompleteAsync" TValue="GridRow" />
        <GridColumns>
            <GridColumn Field="@nameof(GridRow.Id)" IsPrimaryKey="true" Visible="false" />

            <GridColumn Field="@nameof(GridRow.FromMeasured)" HeaderText="@UnitLabel.For("From MD", EnkiQuantity.Length, _units)" Width="170" MinWidth="150">
                <Template>
                    @{ var row = (GridRow)context!; }
                    <UnitFormatted Value="@row.FromMeasured" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                </Template>
                <EditTemplate>
                    @{ var row = (GridRow)context!; }
                    <UnitInput @bind-SiValue="row.FromMeasured" Quantity="EnkiQuantity.Length" ShowUnit="false" />
                </EditTemplate>
            </GridColumn>
            <GridColumn Field="@nameof(GridRow.ToMeasured)" HeaderText="@UnitLabel.For("To MD", EnkiQuantity.Length, _units)" Width="170" MinWidth="150">
                <Template>
                    @{ var row = (GridRow)context!; }
                    <UnitFormatted Value="@row.ToMeasured" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                </Template>
                <EditTemplate>
                    @{ var row = (GridRow)context!; }
                    <UnitInput @bind-SiValue="row.ToMeasured" Quantity="EnkiQuantity.Length" ShowUnit="false" />
                </EditTemplate>
            </GridColumn>
            @* Read-only TVD columns derived server-side. AllowEditing="false"
               keeps Syncfusion from rendering an input on double-click;
               the matching EditTemplate keeps the cell unit-correct
               (ft↔m) in edit mode — without it, Syncfusion falls back
               to the raw SI metre value. *@
            <GridColumn Field="@nameof(GridRow.FromTvd)" HeaderText="@UnitLabel.For("From TVD", EnkiQuantity.Length, _units)" Width="170" MinWidth="150" AllowEditing="false">
                <Template>
                    @{ var row = (GridRow)context!; }
                    @if (row.FromTvd is { } v)
                    {
                        <UnitFormatted Value="@v" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                    }
                    else
                    {
                        <span class="enki-muted">&mdash;</span>
                    }
                </Template>
                <EditTemplate>
                    @{ var row = (GridRow)context!; }
                    @if (row.FromTvd is { } v)
                    {
                        <UnitFormatted Value="@v" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                    }
                    else
                    {
                        <span class="enki-muted">&mdash;</span>
                    }
                </EditTemplate>
            </GridColumn>
            <GridColumn Field="@nameof(GridRow.ToTvd)" HeaderText="@UnitLabel.For("To TVD", EnkiQuantity.Length, _units)" Width="170" MinWidth="150" AllowEditing="false">
                <Template>
                    @{ var row = (GridRow)context!; }
                    @if (row.ToTvd is { } v)
                    {
                        <UnitFormatted Value="@v" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                    }
                    else
                    {
                        <span class="enki-muted">&mdash;</span>
                    }
                </Template>
                <EditTemplate>
                    @{ var row = (GridRow)context!; }
                    @if (row.ToTvd is { } v)
                    {
                        <UnitFormatted Value="@v" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                    }
                    else
                    {
                        <span class="enki-muted">&mdash;</span>
                    }
                </EditTemplate>
            </GridColumn>
            @* Bare double — dimensionless multiplier near 1.0. No
               <UnitFormatted> because there's no SI projection to do;
               Syncfusion's built-in N4 formatter is enough.
               <EditTemplate> uses a plain numeric InputNumber so the
               edit-mode cell stays consistent with the read view's
               formatting. *@
            <GridColumn Field="@nameof(GridRow.Value)" HeaderText="Signal factor" Width="170" MinWidth="140" Format="N4">
                <EditTemplate>
                    @{ var row = (GridRow)context!; }
                    <input type="number" step="0.0001" class="enki-form-input"
                           @bind="row.Value" @bind:event="oninput" />
                </EditTemplate>
            </GridColumn>
        </GridColumns>
    </SfGrid>
    </CascadingValue>
}

@code {
    [Parameter] public string TenantCode { get; set; } = "";
    [Parameter] public Guid JobId { get; set; }
    [Parameter] public int WellId { get; set; }

    private List<GridRow>? _rows;
    private string? _error;
    private string? _saveStatus;
    private string  _saveAlertClass = "alert-info";
    private UnitSystem _units = UnitSystem.SI;

    /// <summary>
    /// True when the well has at least one survey — combined with
    /// the auto-created tie-on at depth 0, that's the minimum needed
    /// to bracket an MD for TVD interpolation. Drives the New-measure
    /// button's disabled state and the in-page warning.
    /// </summary>
    private bool _hasEnoughSurveys;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        var client = HttpClientFactory.CreateClient("EnkiApi");
        var jobTask = client.GetAsync<JobDetailDto>(
            $"tenants/{TenantCode}/jobs/{JobId}");
        var measuresTask = client.GetAsync<List<CommonMeasureSummaryDto>>(
            $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/common-measures");
        var surveysTask = client.GetAsync<PagedResult<SurveySummaryDto>>(
            $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/surveys?take=1");

        await Task.WhenAll(jobTask, measuresTask, surveysTask);

        var jobResult      = jobTask.Result;
        var measuresResult = measuresTask.Result;
        var surveysResult  = surveysTask.Result;

        if (!jobResult.IsSuccess)      { _error = jobResult.Error.AsAlertText();      return; }
        if (!measuresResult.IsSuccess) { _error = measuresResult.Error.AsAlertText(); return; }

        _hasEnoughSurveys = surveysResult.IsSuccess && surveysResult.Value.Total >= 1;

        _units = await UnitPrefs.ResolveAsync(jobResult.Value.UnitSystem);
        _rows  = measuresResult.Value
            .Select(m => new GridRow
            {
                Id           = m.Id,
                FromMeasured = m.FromMeasured,
                ToMeasured   = m.ToMeasured,
                FromTvd      = m.FromTvd,
                ToTvd        = m.ToTvd,
                Value        = m.Value,
                RowVersion   = m.RowVersion,
            })
            .ToList();
    }

    /// <summary>
    /// Save handler. The Common Measures Summary and Update DTOs share
    /// the same field set, so no detail round-trip is needed — build
    /// the UpdateCommonMeasureDto straight from the row and PUT.
    /// </summary>
    private async Task OnActionCompleteAsync(ActionEventArgs<GridRow> args)
    {
        if (args.Data is not { } row) return;

        var client = HttpClientFactory.CreateClient("EnkiApi");
        var path   = $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/common-measures/{row.Id}";

        if (args.RequestType == Syncfusion.Blazor.Grids.Action.Delete)
        {
            // Explicit static-call form: HttpClient has an instance
            // DeleteAsync(string) returning HttpResponseMessage which
            // would win overload resolution over our extension.
            var deleteResult = await HttpClientApiExtensions.DeleteAsync(client, path);
            if (deleteResult.IsSuccess)
            {
                Nav.NavigateTo(Nav.Uri, forceLoad: true);
                return;
            }

            _saveStatus     = deleteResult.Error.AsAlertText();
            _saveAlertClass = "alert-danger";
            return;
        }

        if (args.RequestType != Syncfusion.Blazor.Grids.Action.Save) return;

        var dto = new UpdateCommonMeasureDto(
            FromMeasured: row.FromMeasured,
            ToMeasured:   row.ToMeasured,
            Value:        row.Value,
            RowVersion:   row.RowVersion);

        var result = await client.PutAsync(path, dto);

        if (result.IsSuccess)
        {
            Nav.NavigateTo(Nav.Uri, forceLoad: true);
            return;
        }

        _saveStatus     = result.Error.AsAlertText();
        _saveAlertClass = "alert-danger";
    }

    /// <summary>Mutable row shape backing the editable grid.</summary>
    public sealed class GridRow
    {
        public int    Id           { get; set; }
        public double FromMeasured { get; set; }
        public double ToMeasured   { get; set; }
        /// <summary>Derived TVD from <see cref="FromMeasured"/>; null when the well has &lt; 2 surveys.</summary>
        public double? FromTvd     { get; set; }
        /// <summary>Derived TVD from <see cref="ToMeasured"/>; null when the well has &lt; 2 surveys.</summary>
        public double? ToTvd       { get; set; }
        public double Value        { get; set; }
        public string? RowVersion  { get; set; }
    }
}
