@page "/tenants/{TenantCode}/wells/{WellId:int}/tubulars/new"
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using SDI.Enki.Shared.Wells.Tubulars

<PageTitle>Enki &mdash; New Tubular (Well @WellId)</PageTitle>

<h1 class="enki-section-title">New Tubular</h1>
<p class="enki-section-subtitle">
    <span class="enki-mono">@TenantCode</span> &middot;
    Well <span class="enki-mono">@WellId</span>
</p>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

<div class="enki-card" style="max-width: 720px; margin-top: 1.25rem;">
    <EditForm Model="Form" OnValidSubmit="Submit" FormName="create-tubular"
              class="enki-form" Enhance="true">
        <DataAnnotationsValidator />
        <ValidationSummary class="enki-validation-summary" />

        <div class="enki-form-group">
            <label class="enki-form-label required" for="f-type">Type</label>
            <InputSelect @bind-Value="Form!.Type" id="f-type" class="enki-form-input" required>
                <option value="Casing">Casing</option>
                <option value="Liner">Liner</option>
                <option value="Tubing">Tubing</option>
                <option value="DrillPipe">Drill pipe</option>
                <option value="OpenHole">Open hole</option>
            </InputSelect>
            <ValidationMessage For="() => Form.Type" class="enki-form-error" />
        </div>

        <div class="enki-form-group">
            <label class="enki-form-label" for="f-name">Name</label>
            <InputText @bind-Value="Form!.Name" id="f-name" class="enki-form-input"
                       placeholder="e.g. Surface casing" maxlength="200" />
            <div class="enki-form-hint">Optional descriptive label.</div>
            <ValidationMessage For="() => Form.Name" class="enki-form-error" />
        </div>

        <div class="enki-form-group">
            <label class="enki-form-label required" for="f-order">Order</label>
            <InputNumber @bind-Value="Form!.Order" id="f-order" class="enki-form-input" required />
            <div class="enki-form-hint">Position in the stack — 0 = surface, increasing downward.</div>
            <ValidationMessage For="() => Form.Order" class="enki-form-error" />
        </div>

        <div class="enki-form-grid-2col">
            <div class="enki-form-group">
                <label class="enki-form-label required" for="f-from">From MD</label>
                <InputNumber @bind-Value="Form!.FromMeasured" id="f-from" class="enki-form-input" required />
                <ValidationMessage For="() => Form.FromMeasured" class="enki-form-error" />
            </div>
            <div class="enki-form-group">
                <label class="enki-form-label required" for="f-to">To MD</label>
                <InputNumber @bind-Value="Form!.ToMeasured" id="f-to" class="enki-form-input" required />
                <ValidationMessage For="() => Form.ToMeasured" class="enki-form-error" />
            </div>
            <div class="enki-form-group">
                <label class="enki-form-label required" for="f-diam">Diameter</label>
                <InputNumber @bind-Value="Form!.Diameter" id="f-diam" class="enki-form-input" required />
                <ValidationMessage For="() => Form.Diameter" class="enki-form-error" />
            </div>
            <div class="enki-form-group">
                <label class="enki-form-label required" for="f-weight">Weight</label>
                <InputNumber @bind-Value="Form!.Weight" id="f-weight" class="enki-form-input" required />
                <ValidationMessage For="() => Form.Weight" class="enki-form-error" />
            </div>
        </div>

        <div class="enki-form-actions">
            <button type="submit" class="enki-button enki-button-primary">Create tubular</button>
            <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/wells/{WellId}/tubulars")">Cancel</NavLink>
        </div>
    </EditForm>
</div>

@code {
    [Parameter] public string TenantCode { get; set; } = "";
    [Parameter] public int WellId { get; set; }

    [SupplyParameterFromForm]
    public CreateForm? Form { get; set; }

    private string? _error;

    protected override void OnInitialized() => Form ??= new CreateForm { Type = "Casing" };

    private async Task Submit()
    {
        if (Form is null) return;
        _error = null;
        try
        {
            var client = HttpClientFactory.CreateClient("EnkiApi");
            var dto = new CreateTubularDto(
                Type:         Form.Type,
                Order:        Form.Order,
                FromMeasured: Form.FromMeasured,
                ToMeasured:   Form.ToMeasured,
                Diameter:     Form.Diameter,
                Weight:       Form.Weight,
                Name:         string.IsNullOrWhiteSpace(Form.Name) ? null : Form.Name);

            using var resp = await client.PostAsJsonAsync(
                $"tenants/{TenantCode}/wells/{WellId}/tubulars", dto);

            if (resp.IsSuccessStatusCode)
            {
                Nav.NavigateTo($"/tenants/{TenantCode}/wells/{WellId}/tubulars");
                return;
            }

            var body = await resp.Content.ReadAsStringAsync();
            _error = $"Create failed ({(int)resp.StatusCode} {resp.StatusCode}): {body}";
        }
        catch (Exception ex) { _error = $"Unexpected error: {ex.Message}"; }
    }

    public sealed class CreateForm
    {
        [Required(ErrorMessage = "Tubular type is required.")]
        public string Type { get; set; } = "Casing";

        [MaxLength(200, ErrorMessage = "Name must be 200 characters or fewer.")]
        public string? Name { get; set; }

        [Required(ErrorMessage = "Order is required.")]
        public int Order { get; set; }

        [Required(ErrorMessage = "From MD is required.")]
        public double FromMeasured { get; set; }

        [Required(ErrorMessage = "To MD is required.")]
        public double ToMeasured { get; set; }

        [Required(ErrorMessage = "Diameter is required.")]
        public double Diameter { get; set; }

        [Required(ErrorMessage = "Weight is required.")]
        public double Weight { get; set; }
    }
}
