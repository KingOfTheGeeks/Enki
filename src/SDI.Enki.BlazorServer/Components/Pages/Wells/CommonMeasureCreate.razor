@page "/tenants/{TenantCode}/wells/{WellId:int}/common-measures/new"
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using SDI.Enki.Shared.Wells.CommonMeasures

<PageTitle>Enki &mdash; New Common Measure (Well @WellId)</PageTitle>

<h1 class="enki-section-title">New Common Measure</h1>
<p class="enki-section-subtitle">
    <span class="enki-mono">@TenantCode</span> &middot;
    Well <span class="enki-mono">@WellId</span>
</p>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

<div class="enki-card" style="max-width: 620px; margin-top: 1.25rem;">
    <EditForm Model="Form" OnValidSubmit="Submit" FormName="create-cm"
              class="enki-form" Enhance="true">
        <DataAnnotationsValidator />
        <ValidationSummary class="enki-validation-summary" />

        <div class="enki-form-grid-2col">
            <div class="enki-form-group">
                <label class="enki-form-label required" for="f-from">From TVD</label>
                <InputNumber @bind-Value="Form!.FromVertical" id="f-from" class="enki-form-input" required />
                <ValidationMessage For="() => Form.FromVertical" class="enki-form-error" />
            </div>
            <div class="enki-form-group">
                <label class="enki-form-label required" for="f-to">To TVD</label>
                <InputNumber @bind-Value="Form!.ToVertical" id="f-to" class="enki-form-input" required />
                <ValidationMessage For="() => Form.ToVertical" class="enki-form-error" />
            </div>
            <div class="enki-form-group">
                <label class="enki-form-label required" for="f-val">Value</label>
                <InputNumber @bind-Value="Form!.Value" id="f-val" class="enki-form-input" required />
                <ValidationMessage For="() => Form.Value" class="enki-form-error" />
            </div>
        </div>

        <div class="enki-form-actions">
            <button type="submit" class="enki-button enki-button-primary">Create measure</button>
            <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/wells/{WellId}/common-measures")">Cancel</NavLink>
        </div>
    </EditForm>
</div>

@code {
    [Parameter] public string TenantCode { get; set; } = "";
    [Parameter] public int WellId { get; set; }

    [SupplyParameterFromForm]
    public CreateForm? Form { get; set; }

    private string? _error;

    protected override void OnInitialized() => Form ??= new CreateForm();

    private async Task Submit()
    {
        if (Form is null) return;
        _error = null;
        try
        {
            var client = HttpClientFactory.CreateClient("EnkiApi");
            var dto = new CreateCommonMeasureDto(
                FromVertical: Form.FromVertical,
                ToVertical:   Form.ToVertical,
                Value:        Form.Value);

            using var resp = await client.PostAsJsonAsync(
                $"tenants/{TenantCode}/wells/{WellId}/common-measures", dto);

            if (resp.IsSuccessStatusCode)
            {
                Nav.NavigateTo($"/tenants/{TenantCode}/wells/{WellId}/common-measures");
                return;
            }

            var body = await resp.Content.ReadAsStringAsync();
            _error = $"Create failed ({(int)resp.StatusCode} {resp.StatusCode}): {body}";
        }
        catch (Exception ex) { _error = $"Unexpected error: {ex.Message}"; }
    }

    public sealed class CreateForm
    {
        [Required(ErrorMessage = "From TVD is required.")]
        public double FromVertical { get; set; }

        [Required(ErrorMessage = "To TVD is required.")]
        public double ToVertical { get; set; }

        [Required(ErrorMessage = "Value is required.")]
        public double Value { get; set; }
    }
}
