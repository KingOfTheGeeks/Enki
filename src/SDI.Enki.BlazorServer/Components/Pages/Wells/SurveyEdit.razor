@rendermode InteractiveServer

@*
    Edit a survey station. Only the three observed fields are editable;
    computed columns (TVD, DLS, etc.) are owned by Calculate and
    displayed read-only so the user knows what the last calculation
    produced. Single-armed-click delete in the danger zone.

    Inputs / read-outs route through <UnitInput> + <UnitFormatted> so
    the user types and reads in the Job's preferred unit-system. The
    DTO going to the WebApi still carries SI values — the conversion
    happens at the rendering edge only.
*@

<PageTitle>Enki &mdash; Edit Survey (@SurveyId)</PageTitle>

<h1 class="enki-section-title">Edit Survey Station</h1>
<p class="enki-section-subtitle">
    <span class="enki-mono">@TenantCode</span> &middot;
    Well <span class="enki-mono">@WellId</span> &middot;
    Survey <span class="enki-mono">@SurveyId</span>
</p>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

@if (_loadFailed)
{
    <div class="alert alert-danger">
        Could not load survey. It may have been deleted.
        <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/surveys")">
            Back to surveys
        </NavLink>
    </div>
}
else if (Form is null || _detail is null)
{
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Loading survey&hellip;</div>
    </div>
}
else
{
    <CascadingValue Name="UnitSystem" Value="_units" IsFixed="false">
    <div class="enki-card" style="max-width: 720px; margin-top: 1.25rem;">
        <EditForm Model="Form" OnValidSubmit="Submit" FormName="edit-survey"
                  class="enki-form">
            <DataAnnotationsValidator />
            <ValidationSummary class="enki-validation-summary" />

            @* Hidden RowVersion round-trip — see feedback_blazor_ssr_form_roundtrip memory. *@
            <InputText @bind-Value="Form.RowVersion" style="display:none" />

            <h2 class="enki-form-section-title">Observed</h2>

            <div class="enki-form-group">
                <label class="enki-form-label required" for="f-depth">@UnitLabel.For("Depth", EnkiQuantity.Length, _units)</label>
                <UnitInput @bind-SiValue="Form.Depth" Quantity="EnkiQuantity.Length" CssClass="enki-form-input" />
                <ValidationMessage For="() => Form.Depth" class="enki-form-error" />
            </div>
            <div class="enki-form-group">
                <label class="enki-form-label required" for="f-inc">@UnitLabel.For("Inclination", EnkiQuantity.Angle, _units)</label>
                <UnitInput @bind-SiValue="Form.Inclination" Quantity="EnkiQuantity.Angle" Min="0" Max="180" CssClass="enki-form-input" />
                <ValidationMessage For="() => Form.Inclination" class="enki-form-error" />
            </div>
            <div class="enki-form-group">
                <label class="enki-form-label required" for="f-az">@UnitLabel.For("Azimuth", EnkiQuantity.Angle, _units)</label>
                <UnitInput @bind-SiValue="Form.Azimuth" Quantity="EnkiQuantity.Angle" Min="0" Max="360" CssClass="enki-form-input" />
                <ValidationMessage For="() => Form.Azimuth" class="enki-form-error" />
            </div>

            <h2 class="enki-form-section-title">Computed (read-only)</h2>
            <p class="enki-form-hint">
                Last populated by Calculate. Edit the observed fields and
                re-run Calculate to refresh.
            </p>

            <div class="enki-form-grid-2col">
                <div class="enki-form-group">
                    <label class="enki-form-label">@UnitLabel.For("Vertical depth (TVD)", EnkiQuantity.Length, _units)</label>
                    <UnitReadout Value="@_detail.VerticalDepth" Quantity="EnkiQuantity.Length" />
                </div>
                <div class="enki-form-group">
                    <label class="enki-form-label">@UnitLabel.For("Sub-sea", EnkiQuantity.Length, _units)</label>
                    <UnitReadout Value="@_detail.SubSea" Quantity="EnkiQuantity.Length" />
                </div>
                <div class="enki-form-group">
                    <label class="enki-form-label">@UnitLabel.For("North", EnkiQuantity.Length, _units)</label>
                    <UnitReadout Value="@_detail.North" Quantity="EnkiQuantity.Length" />
                </div>
                <div class="enki-form-group">
                    <label class="enki-form-label">@UnitLabel.For("East", EnkiQuantity.Length, _units)</label>
                    <UnitReadout Value="@_detail.East" Quantity="EnkiQuantity.Length" />
                </div>
                <div class="enki-form-group">
                    <label class="enki-form-label">@UnitLabel.For("Dogleg severity", EnkiQuantity.CurvatureRate, _units)</label>
                    <UnitReadout Value="@_detail.DoglegSeverity" Quantity="EnkiQuantity.CurvatureRate" />
                </div>
                <div class="enki-form-group">
                    <label class="enki-form-label">@UnitLabel.For("Vertical section", EnkiQuantity.Length, _units)</label>
                    <UnitReadout Value="@_detail.VerticalSection" Quantity="EnkiQuantity.Length" />
                </div>
                <div class="enki-form-group">
                    <label class="enki-form-label">@UnitLabel.For("Northing", EnkiQuantity.Length, _units)</label>
                    <UnitReadout Value="@_detail.Northing" Quantity="EnkiQuantity.Length" />
                </div>
                <div class="enki-form-group">
                    <label class="enki-form-label">@UnitLabel.For("Easting", EnkiQuantity.Length, _units)</label>
                    <UnitReadout Value="@_detail.Easting" Quantity="EnkiQuantity.Length" />
                </div>
                <div class="enki-form-group">
                    <label class="enki-form-label">@UnitLabel.For("Build", EnkiQuantity.CurvatureRate, _units)</label>
                    <UnitReadout Value="@_detail.Build" Quantity="EnkiQuantity.CurvatureRate" />
                </div>
                <div class="enki-form-group">
                    <label class="enki-form-label">@UnitLabel.For("Turn", EnkiQuantity.CurvatureRate, _units)</label>
                    <UnitReadout Value="@_detail.Turn" Quantity="EnkiQuantity.CurvatureRate" />
                </div>
            </div>

            <div class="enki-form-actions">
                <button type="submit" class="enki-button enki-button-primary">Save changes</button>
                <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/surveys")">Cancel</NavLink>
            </div>
        </EditForm>
    </div>

    <div class="enki-card enki-danger-card" style="max-width: 720px; margin-top: 1.25rem;">
        <h2 class="enki-form-section-title">Danger zone</h2>
        <p class="enki-form-hint">
            Deleting a station drops it out of every future Calculate
            run on this well. Adjacent stations' computed values stay
            the same until the next Calculate fires.
        </p>
        <button type="button" class="enki-button enki-button-danger" @onclick="ConfirmDelete">
            @(_deleteArmed ? "Click again to confirm delete" : "Delete survey")
        </button>
    </div>
    </CascadingValue>
}

