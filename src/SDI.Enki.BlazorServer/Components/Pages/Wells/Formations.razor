@rendermode InteractiveServer

@*
    Formations grid. From / To MD are editable Lengths (the canonical
    depth on a Formation; TVD is derived server-side from the well's
    Surveys via Marduk's minimum-curvature ISurveyInterpolator and
    arrives on the DTO as nullable FromTvd / ToTvd, rendered read-only
    in the grid). Resistance is the legacy Athena ranging-input scalar
    — bare double, no SI quantity attached.

    Survey-gated creation: the well needs at least two surveys before
    a Formation can be added (TVD interpolation requires bracketing
    stations). LoadAsync calls SurveysController.List with take=1 just
    to read .Total, _hasEnoughSurveys flips the New-formation button
    + a yellow notice telling the user to add surveys first.

    Editing is wired through Syncfusion's native inline edit, mirroring
    the pattern on Surveys.razor:

      * Double-click a row → Normal edit mode opens it.
      * Enter saves, Esc cancels. Toolbar's Update / Cancel buttons are
        the discoverable affordance.
      * OnActionCompleteAsync fires on Save: fetch the row's
        FormationDetailDto first to preserve the Description (which
        the inline grid doesn't show), build UpdateFormationDto from
        the row + preserved Description, PUT to FormationsController,
        then force-reload so the grid reflects the saved state.

    Description preservation: the FormationSummaryDto returned by the
    list endpoint deliberately omits Description (it's a long free-text
    field that doesn't fit a tabular layout). To avoid wiping it on
    PUT, the save handler does a one-shot GET of FormationDetailDto
    immediately before PUT and copies Description across.
*@

<PageTitle>Enki &mdash; Formations (Well @WellId)</PageTitle>

<PageHeader Title="Formations">
    <TitleSuffix>
        <span class="enki-mono">@TenantCode &middot; Well @WellId</span>
    </TitleSuffix>
    <Subtitle>
        Geological tops intersected by the well, ordered by measured
        depth from surface down. Resistance values feed ranging
        calculations. Vertical depth is derived from the well's
        surveys. <strong>Double-click a row</strong> to edit it
        inline; Enter saves.
    </Subtitle>
    <Actions>
        <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}")">Back to well</NavLink>
        @if (_hasEnoughSurveys)
        {
            <NavLink class="enki-button enki-button-primary"
                     href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/formations/new")">
                + New formation
            </NavLink>
        }
        else
        {
            @* Disabled button — `<a>` doesn't honour `disabled`, so
               render a `<button>` styled like the primary action. *@
            <button type="button" class="enki-button enki-button-primary" disabled
                    title="This well needs at least one survey before a formation can be created.">
                + New formation
            </button>
        }
    </Actions>
</PageHeader>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
@if (_saveStatus is not null)
{
    <div class="alert @_saveAlertClass">@_saveStatus</div>
}
@if (_rows is not null && !_hasEnoughSurveys)
{
    <div class="alert alert-warning" role="alert">
        <strong>Surveys required.</strong>
        Vertical depth on a formation is interpolated from the well's
        surveys (Marduk minimum-curvature). Add at least one survey
        station before creating a formation —
        <NavLink href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/surveys")">
            go to surveys
        </NavLink>.
    </div>
}
@if (_rows is null && _error is null)
{
    <EnkiLoading Label="Fetching formations from API…" />
}

@if (_rows is not null && _error is null)
{
    <CascadingValue Name="UnitSystem" Value="_units" IsFixed="false">
    <div class="enki-stat-grid">
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_rows.Count.ToString("D2")</div>
            <div class="enki-stat-label">Formations</div>
        </div>
    </div>

    @* Toolbar's Update / Cancel buttons are the visible save
       affordance while a row is in edit mode (mirrors Surveys.razor
       pattern; without them users have to discover that Enter saves
       and miss the auto-recalc trigger). Hidden on an empty grid
       since Update / Delete have nothing to act on; the only useful
       action there is + New formation at the page header. *@
    <SfGrid DataSource="_rows"
            AllowSorting="true"
            AllowFiltering="true"
            AllowResizing="true"
            Toolbar="@(_rows.Count > 0 ? new List<string> { "Update", "Cancel", "Delete" } : null)"
            Height="auto">
        <GridEditSettings AllowEditing="true"
                          AllowAdding="false"
                          AllowDeleting="true"
                          ShowDeleteConfirmDialog="true"
                          Mode="EditMode.Normal" />
        <GridEvents OnActionComplete="OnActionCompleteAsync" TValue="GridRow" />
        <GridColumns>
            @* Stable per-row primary key — needed by Syncfusion's edit
               machinery to identify the row across data-source updates. *@
            <GridColumn Field="@nameof(GridRow.Id)" IsPrimaryKey="true" Visible="false" />

            <GridColumn Field="@nameof(GridRow.Name)" HeaderText="Name" Width="280" />
            <GridColumn Field="@nameof(GridRow.FromMeasured)" HeaderText="@UnitLabel.For("From MD", EnkiQuantity.Length, _units)" Width="160" MinWidth="150">
                <Template>
                    @{ var row = (GridRow)context!; }
                    <UnitFormatted Value="@row.FromMeasured" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                </Template>
                <EditTemplate>
                    @{ var row = (GridRow)context!; }
                    <UnitInput @bind-SiValue="row.FromMeasured" Quantity="EnkiQuantity.Length" ShowUnit="false" />
                </EditTemplate>
            </GridColumn>
            <GridColumn Field="@nameof(GridRow.ToMeasured)" HeaderText="@UnitLabel.For("To MD", EnkiQuantity.Length, _units)" Width="160" MinWidth="150">
                <Template>
                    @{ var row = (GridRow)context!; }
                    <UnitFormatted Value="@row.ToMeasured" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                </Template>
                <EditTemplate>
                    @{ var row = (GridRow)context!; }
                    <UnitInput @bind-SiValue="row.ToMeasured" Quantity="EnkiQuantity.Length" ShowUnit="false" />
                </EditTemplate>
            </GridColumn>
            @* Read-only TVD columns — derived server-side from
               Surveys via ISurveyInterpolator. AllowEditing="false"
               keeps Syncfusion from showing an edit input on
               double-click. Null renders as an em-dash so the user
               can tell "not yet computed" from "actual zero". *@
            @* EditTemplate matches the read Template — Syncfusion's
               Normal-mode edit row falls back to raw .ToString() of
               the bound field for columns without an EditTemplate
               (which would render the SI metre value, breaking the
               ft↔m unit projection). Re-rendering the same
               <UnitFormatted> keeps the cell unit-correct in both
               modes. *@
            <GridColumn Field="@nameof(GridRow.FromTvd)" HeaderText="@UnitLabel.For("From TVD", EnkiQuantity.Length, _units)" Width="160" MinWidth="150" AllowEditing="false">
                <Template>
                    @{ var row = (GridRow)context!; }
                    @if (row.FromTvd is { } v)
                    {
                        <UnitFormatted Value="@v" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                    }
                    else
                    {
                        <span class="enki-muted">&mdash;</span>
                    }
                </Template>
                <EditTemplate>
                    @{ var row = (GridRow)context!; }
                    @if (row.FromTvd is { } v)
                    {
                        <UnitFormatted Value="@v" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                    }
                    else
                    {
                        <span class="enki-muted">&mdash;</span>
                    }
                </EditTemplate>
            </GridColumn>
            <GridColumn Field="@nameof(GridRow.ToTvd)" HeaderText="@UnitLabel.For("To TVD", EnkiQuantity.Length, _units)" Width="160" MinWidth="150" AllowEditing="false">
                <Template>
                    @{ var row = (GridRow)context!; }
                    @if (row.ToTvd is { } v)
                    {
                        <UnitFormatted Value="@v" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                    }
                    else
                    {
                        <span class="enki-muted">&mdash;</span>
                    }
                </Template>
                <EditTemplate>
                    @{ var row = (GridRow)context!; }
                    @if (row.ToTvd is { } v)
                    {
                        <UnitFormatted Value="@v" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                    }
                    else
                    {
                        <span class="enki-muted">&mdash;</span>
                    }
                </EditTemplate>
            </GridColumn>
            <GridColumn Field="@nameof(GridRow.Resistance)" HeaderText="Resistance" Width="140" MinWidth="130" Format="N3" />
        </GridColumns>
    </SfGrid>
    </CascadingValue>
}

