@page "/tenants/{TenantCode}/jobs/{JobId:guid}/wells/{WellId:int}/formations"
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@using SDI.Enki.Core.Units
@using SDI.Enki.Shared.Wells.Formations
@using System.Net.Http.Json

@*
    Formations grid. From / To TVD are Lengths; Resistance is the
    legacy Athena ranging-input scalar — bare double, no SI quantity
    attached today, so it renders as Dimensionless (no unit suffix).
    If a future requirement gives Resistance a definite unit
    (Ω·m / millimho-per-metre / etc.), wire it through here.
*@

<PageTitle>Enki &mdash; Formations (Well @WellId)</PageTitle>

<div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; flex-wrap: wrap;">
    <div style="flex: 1; min-width: 280px;">
        <h1 class="enki-section-title">
            Formations
            <span class="enki-mono" style="font-size: 0.65em; opacity: 0.65; margin-left: 0.5rem;">
                @TenantCode &middot; Well @WellId
            </span>
        </h1>
        <p class="enki-section-subtitle">
            Geological tops intersected by the well, ordered by depth
            from surface down. Resistance values feed ranging
            calculations.
        </p>
    </div>
    <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
        <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}")">Back to well</NavLink>
        <NavLink class="enki-button enki-button-primary"
                 href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/formations/new")">
            + New formation
        </NavLink>
    </div>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_formations is null)
{
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Fetching formations from API&hellip;</div>
    </div>
}
else
{
    <CascadingValue Name="UnitSystem" Value="_units" IsFixed="false">
    <div class="enki-stat-grid">
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_formations.Count.ToString("D2")</div>
            <div class="enki-stat-label">Formations</div>
        </div>
    </div>

    <SfGrid DataSource="_formations" AllowSorting="true" AllowFiltering="true" AllowResizing="true" Height="auto">
        <GridColumns>
            <GridColumn Field="@nameof(FormationSummaryDto.Name)" HeaderText="Name" Width="280">
                <Template>
                    @{ var row = context as FormationSummaryDto; }
                    @if (row is not null)
                    {
                        <a class="enki-row-link"
                           href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/formations/{row.Id}/edit")">@row.Name</a>
                    }
                </Template>
            </GridColumn>
            <GridColumn Field="@nameof(FormationSummaryDto.FromVertical)" HeaderText="@UnitLabel.For("From TVD", EnkiQuantity.Length, _units)" Width="170" MinWidth="160">
                <Template>
                    @{ var row = (FormationSummaryDto)context!; }
                    <UnitFormatted Value="@row.FromVertical" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                </Template>
            </GridColumn>
            <GridColumn Field="@nameof(FormationSummaryDto.ToVertical)" HeaderText="@UnitLabel.For("To TVD", EnkiQuantity.Length, _units)" Width="170" MinWidth="160">
                <Template>
                    @{ var row = (FormationSummaryDto)context!; }
                    <UnitFormatted Value="@row.ToVertical" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                </Template>
            </GridColumn>
            <GridColumn Field="@nameof(FormationSummaryDto.Resistance)" HeaderText="Resistance" Width="140" MinWidth="130" Format="N3" />
        </GridColumns>
    </SfGrid>
    </CascadingValue>
}

@code {
    [Parameter] public string TenantCode { get; set; } = "";
    [Parameter] public Guid JobId { get; set; }
    [Parameter] public int WellId { get; set; }

    private List<FormationSummaryDto>? _formations;
    private string? _error;
    private UnitSystem _units = UnitSystem.SI;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("EnkiApi");
            var jobTask = client.GetFromJsonAsync<JobDetailDto>(
                $"tenants/{TenantCode}/jobs/{JobId}");
            var formationsTask = client.GetFromJsonAsync<List<FormationSummaryDto>>(
                $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/formations");

            await Task.WhenAll(jobTask, formationsTask);

            _units      = UnitSystem.FromNameOrSi(jobTask.Result?.UnitSystem);
            _formations = formationsTask.Result ?? new();
        }
        catch (HttpRequestException ex) { _error = $"WebApi call failed: {ex.Message}"; }
        catch (Exception ex)             { _error = $"Unexpected error: {ex.Message}"; }
    }
}
