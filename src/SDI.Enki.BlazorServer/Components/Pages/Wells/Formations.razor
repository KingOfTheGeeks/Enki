@page "/tenants/{TenantCode}/jobs/{JobId:guid}/wells/{WellId:int}/formations"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@inject UnitPreferenceProvider UnitPrefs
@using SDI.Enki.BlazorServer.Api
@using SDI.Enki.Core.Units
@using SDI.Enki.Shared.Paging
@using SDI.Enki.Shared.Surveys
@using SDI.Enki.Shared.Wells.Formations

@*
    Formations grid. From / To MD are editable Lengths (the canonical
    depth on a Formation; TVD is derived server-side from the well's
    Surveys via Marduk's minimum-curvature ISurveyInterpolator and
    arrives on the DTO as nullable FromTvd / ToTvd, rendered read-only
    in the grid). Resistance is the legacy Athena ranging-input scalar
    — bare double, no SI quantity attached.

    Survey-gated creation: the well needs at least two surveys before
    a Formation can be added (TVD interpolation requires bracketing
    stations). LoadAsync calls SurveysController.List with take=1 just
    to read .Total, _hasEnoughSurveys flips the New-formation button
    + a yellow notice telling the user to add surveys first.

    Editing is wired through Syncfusion's native inline edit, mirroring
    the pattern on Surveys.razor:

      * Double-click a row → Normal edit mode opens it.
      * Enter saves, Esc cancels. Toolbar's Update / Cancel buttons are
        the discoverable affordance.
      * OnActionCompleteAsync fires on Save: fetch the row's
        FormationDetailDto first to preserve the Description (which
        the inline grid doesn't show), build UpdateFormationDto from
        the row + preserved Description, PUT to FormationsController,
        then force-reload so the grid reflects the saved state.

    Description preservation: the FormationSummaryDto returned by the
    list endpoint deliberately omits Description (it's a long free-text
    field that doesn't fit a tabular layout). To avoid wiping it on
    PUT, the save handler does a one-shot GET of FormationDetailDto
    immediately before PUT and copies Description across.
*@

<PageTitle>Enki &mdash; Formations (Well @WellId)</PageTitle>

<PageHeader Title="Formations">
    <TitleSuffix>
        <span class="enki-mono">@TenantCode &middot; Well @WellId</span>
    </TitleSuffix>
    <Subtitle>
        Geological tops intersected by the well, ordered by measured
        depth from surface down. Resistance values feed ranging
        calculations. Vertical depth is derived from the well's
        surveys. <strong>Double-click a row</strong> to edit it
        inline; Enter saves.
    </Subtitle>
    <Actions>
        <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}")">Back to well</NavLink>
        @if (_hasEnoughSurveys)
        {
            <NavLink class="enki-button enki-button-primary"
                     href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/formations/new")">
                + New formation
            </NavLink>
        }
        else
        {
            @* Disabled button — `<a>` doesn't honour `disabled`, so
               render a `<button>` styled like the primary action. *@
            <button type="button" class="enki-button enki-button-primary" disabled
                    title="This well needs at least one survey before a formation can be created.">
                + New formation
            </button>
        }
    </Actions>
</PageHeader>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
@if (_saveStatus is not null)
{
    <div class="alert @_saveAlertClass">@_saveStatus</div>
}
@if (_rows is not null && !_hasEnoughSurveys)
{
    <div class="alert alert-warning" role="alert">
        <strong>Surveys required.</strong>
        Vertical depth on a formation is interpolated from the well's
        surveys (Marduk minimum-curvature). Add at least one survey
        station before creating a formation —
        <NavLink href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/surveys")">
            go to surveys
        </NavLink>.
    </div>
}
@if (_rows is null && _error is null)
{
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Fetching formations from API&hellip;</div>
    </div>
}

@if (_rows is not null && _error is null)
{
    <CascadingValue Name="UnitSystem" Value="_units" IsFixed="false">
    <div class="enki-stat-grid">
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_rows.Count.ToString("D2")</div>
            <div class="enki-stat-label">Formations</div>
        </div>
    </div>

    @* Toolbar's Update / Cancel buttons are the visible save
       affordance while a row is in edit mode (mirrors Surveys.razor
       pattern; without them users have to discover that Enter saves
       and miss the auto-recalc trigger). *@
    <SfGrid DataSource="_rows"
            AllowSorting="true"
            AllowFiltering="true"
            AllowResizing="true"
            Toolbar="@(new List<string> { "Update", "Cancel", "Delete" })"
            Height="auto">
        <GridEditSettings AllowEditing="true"
                          AllowAdding="false"
                          AllowDeleting="true"
                          ShowDeleteConfirmDialog="true"
                          Mode="EditMode.Normal" />
        <GridEvents OnActionComplete="OnActionCompleteAsync" TValue="GridRow" />
        <GridColumns>
            @* Stable per-row primary key — needed by Syncfusion's edit
               machinery to identify the row across data-source updates. *@
            <GridColumn Field="@nameof(GridRow.Id)" IsPrimaryKey="true" Visible="false" />

            <GridColumn Field="@nameof(GridRow.Name)" HeaderText="Name" Width="280" />
            <GridColumn Field="@nameof(GridRow.FromMeasured)" HeaderText="@UnitLabel.For("From MD", EnkiQuantity.Length, _units)" Width="160" MinWidth="150">
                <Template>
                    @{ var row = (GridRow)context!; }
                    <UnitFormatted Value="@row.FromMeasured" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                </Template>
                <EditTemplate>
                    @{ var row = (GridRow)context!; }
                    <UnitInput @bind-SiValue="row.FromMeasured" Quantity="EnkiQuantity.Length" ShowUnit="false" />
                </EditTemplate>
            </GridColumn>
            <GridColumn Field="@nameof(GridRow.ToMeasured)" HeaderText="@UnitLabel.For("To MD", EnkiQuantity.Length, _units)" Width="160" MinWidth="150">
                <Template>
                    @{ var row = (GridRow)context!; }
                    <UnitFormatted Value="@row.ToMeasured" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                </Template>
                <EditTemplate>
                    @{ var row = (GridRow)context!; }
                    <UnitInput @bind-SiValue="row.ToMeasured" Quantity="EnkiQuantity.Length" ShowUnit="false" />
                </EditTemplate>
            </GridColumn>
            @* Read-only TVD columns — derived server-side from
               Surveys via ISurveyInterpolator. AllowEditing="false"
               keeps Syncfusion from showing an edit input on
               double-click. Null renders as an em-dash so the user
               can tell "not yet computed" from "actual zero". *@
            @* EditTemplate matches the read Template — Syncfusion's
               Normal-mode edit row falls back to raw .ToString() of
               the bound field for columns without an EditTemplate
               (which would render the SI metre value, breaking the
               ft↔m unit projection). Re-rendering the same
               <UnitFormatted> keeps the cell unit-correct in both
               modes. *@
            <GridColumn Field="@nameof(GridRow.FromTvd)" HeaderText="@UnitLabel.For("From TVD", EnkiQuantity.Length, _units)" Width="160" MinWidth="150" AllowEditing="false">
                <Template>
                    @{ var row = (GridRow)context!; }
                    @if (row.FromTvd is { } v)
                    {
                        <UnitFormatted Value="@v" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                    }
                    else
                    {
                        <span class="enki-muted">&mdash;</span>
                    }
                </Template>
                <EditTemplate>
                    @{ var row = (GridRow)context!; }
                    @if (row.FromTvd is { } v)
                    {
                        <UnitFormatted Value="@v" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                    }
                    else
                    {
                        <span class="enki-muted">&mdash;</span>
                    }
                </EditTemplate>
            </GridColumn>
            <GridColumn Field="@nameof(GridRow.ToTvd)" HeaderText="@UnitLabel.For("To TVD", EnkiQuantity.Length, _units)" Width="160" MinWidth="150" AllowEditing="false">
                <Template>
                    @{ var row = (GridRow)context!; }
                    @if (row.ToTvd is { } v)
                    {
                        <UnitFormatted Value="@v" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                    }
                    else
                    {
                        <span class="enki-muted">&mdash;</span>
                    }
                </Template>
                <EditTemplate>
                    @{ var row = (GridRow)context!; }
                    @if (row.ToTvd is { } v)
                    {
                        <UnitFormatted Value="@v" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                    }
                    else
                    {
                        <span class="enki-muted">&mdash;</span>
                    }
                </EditTemplate>
            </GridColumn>
            <GridColumn Field="@nameof(GridRow.Resistance)" HeaderText="Resistance" Width="140" MinWidth="130" Format="N3" />
        </GridColumns>
    </SfGrid>
    </CascadingValue>
}

@code {
    [Parameter] public string TenantCode { get; set; } = "";
    [Parameter] public Guid JobId { get; set; }
    [Parameter] public int WellId { get; set; }

    private List<GridRow>? _rows;
    private string? _error;
    private string? _saveStatus;
    private string  _saveAlertClass = "alert-info";
    private UnitSystem _units = UnitSystem.SI;

    /// <summary>
    /// True when the well has at least one survey — combined with
    /// the auto-created tie-on at depth 0, that's the minimum needed
    /// to bracket an MD for TVD interpolation. Drives the
    /// New-formation button's disabled state and the in-page warning.
    /// </summary>
    private bool _hasEnoughSurveys;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        var client = HttpClientFactory.CreateClient("EnkiApi");
        var jobTask = client.GetAsync<JobDetailDto>(
            $"tenants/{TenantCode}/jobs/{JobId}");
        var formationsTask = client.GetAsync<List<FormationSummaryDto>>(
            $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/formations");
        // ?take=1 is enough — we only need the .Total field. The DB
        // skips fetching the rest, and we don't materialise items we
        // don't read.
        var surveysTask = client.GetAsync<PagedResult<SurveySummaryDto>>(
            $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/surveys?take=1");

        await Task.WhenAll(jobTask, formationsTask, surveysTask);

        var jobResult        = jobTask.Result;
        var formationsResult = formationsTask.Result;
        var surveysResult    = surveysTask.Result;

        if (!jobResult.IsSuccess)        { _error = jobResult.Error.AsAlertText();        return; }
        if (!formationsResult.IsSuccess) { _error = formationsResult.Error.AsAlertText(); return; }

        // Surveys 404 (well unknown) would have already failed on the
        // formations call — still guard for the rare case where one
        // succeeds and the other doesn't.
        _hasEnoughSurveys = surveysResult.IsSuccess && surveysResult.Value.Total >= 1;

        _units = await UnitPrefs.ResolveAsync(jobResult.Value.UnitSystem);
        _rows  = formationsResult.Value
            .Select(f => new GridRow
            {
                Id            = f.Id,
                Name          = f.Name,
                FromMeasured  = f.FromMeasured,
                ToMeasured    = f.ToMeasured,
                FromTvd       = f.FromTvd,
                ToTvd         = f.ToTvd,
                Resistance    = f.Resistance,
                RowVersion    = f.RowVersion,
            })
            .ToList();
    }

    /// <summary>
    /// Save / Delete handler. Save: fetches FormationDetailDto first
    /// to preserve the Description that the inline grid doesn't show,
    /// then PUTs the merged <see cref="UpdateFormationDto"/>. Delete:
    /// Syncfusion's native confirm dialog gates the action; we
    /// translate args.Data.Id into the DELETE call. On either success,
    /// force-reload so the grid renders the saved state from a fresh
    /// GET.
    /// </summary>
    private async Task OnActionCompleteAsync(ActionEventArgs<GridRow> args)
    {
        if (args.Data is not { } row) return;

        var client = HttpClientFactory.CreateClient("EnkiApi");
        var path   = $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/formations/{row.Id}";

        if (args.RequestType == Syncfusion.Blazor.Grids.Action.Delete)
        {
            // Explicit static-call form: HttpClient has an instance
            // DeleteAsync(string) returning HttpResponseMessage which
            // would win overload resolution over our extension.
            var deleteResult = await HttpClientApiExtensions.DeleteAsync(client, path);
            if (deleteResult.IsSuccess)
            {
                Nav.NavigateTo(Nav.Uri, forceLoad: true);
                return;
            }

            _saveStatus     = deleteResult.Error.AsAlertText();
            _saveAlertClass = "alert-danger";
            return;
        }

        if (args.RequestType != Syncfusion.Blazor.Grids.Action.Save) return;

        // Round-trip the existing detail so we preserve fields the
        // inline grid doesn't show — Description today, anything
        // else added to FormationDetailDto in the future.
        var detailResult = await client.GetAsync<FormationDetailDto>(path);
        if (!detailResult.IsSuccess)
        {
            _saveStatus     = detailResult.Error.AsAlertText();
            _saveAlertClass = "alert-danger";
            return;
        }
        var preservedDescription = detailResult.Value.Description;

        // Use the RowVersion captured at LoadAsync time, NOT the
        // just-fetched detailResult.Value.RowVersion — the staleness
        // check needs to run against the user's last-seen state, not
        // the inline-grid's just-now-fetched state. Otherwise a
        // racing edit between the user opening the grid and saving
        // would slip past concurrency check.
        var dto = new UpdateFormationDto(
            Name:         row.Name,
            FromMeasured: row.FromMeasured,
            ToMeasured:   row.ToMeasured,
            Resistance:   row.Resistance,
            Description:  preservedDescription,
            RowVersion:   row.RowVersion);

        var result = await client.PutAsync(path, dto);

        if (result.IsSuccess)
        {
            Nav.NavigateTo(Nav.Uri, forceLoad: true);
            return;
        }

        _saveStatus     = result.Error.AsAlertText();
        _saveAlertClass = "alert-danger";
    }

    /// <summary>
    /// Mutable row shape backing the editable grid. Mirrors the
    /// shape of <see cref="FormationSummaryDto"/> plus the int
    /// <see cref="Id"/> as the Syncfusion primary key. Description
    /// is deliberately not in this shape — the grid doesn't show
    /// it; the save handler fetches detail to preserve it.
    /// </summary>
    public sealed class GridRow
    {
        public int    Id           { get; set; }
        public string Name         { get; set; } = "";
        public double FromMeasured { get; set; }
        public double ToMeasured   { get; set; }
        /// <summary>Derived TVD from <see cref="FromMeasured"/>; null when the well has &lt; 2 surveys.</summary>
        public double? FromTvd     { get; set; }
        /// <summary>Derived TVD from <see cref="ToMeasured"/>; null when the well has &lt; 2 surveys.</summary>
        public double? ToTvd       { get; set; }
        public double Resistance   { get; set; }
        /// <summary>
        /// Captured at LoadAsync from the summary; passed back to
        /// the server on save for optimistic-concurrency check.
        /// </summary>
        public string? RowVersion  { get; set; }
    }
}
