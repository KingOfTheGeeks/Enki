@rendermode InteractiveServer

@*
    Single-station create form. Bulk CSV import lands in the Surveys
    page Import button; this is the per-row entry path for hand-typed
    additions or one-off corrections.

    Inputs route through <UnitInput> so the user types in the Job's
    preferred unit system (ft on Field, m on Metric / SI). Form.Depth
    holds the resulting SI value, which is what CreateSurveyDto carries
    to the WebApi — DB always stores SI regardless of preset.
*@

<PageTitle>Enki &mdash; New Survey (Well @WellId)</PageTitle>

<h1 class="enki-section-title">New Survey Station</h1>
<p class="enki-section-subtitle">
    <span class="enki-mono">@TenantCode</span> &middot;
    Well <span class="enki-mono">@WellId</span>. Computed trajectory
    fields populate after Calculate runs against the well's TieOn.
</p>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

<CascadingValue Name="UnitSystem" Value="_units" IsFixed="false">
<div class="enki-card" style="max-width: 620px; margin-top: 1.25rem;">
    <EditForm Model="Form" OnValidSubmit="Submit" FormName="create-survey"
              class="enki-form">
        <DataAnnotationsValidator />
        <ValidationSummary class="enki-validation-summary" />

        <div class="enki-form-group">
            <label class="enki-form-label required" for="f-depth">@UnitLabel.For("Depth", EnkiQuantity.Length, _units)</label>
            <UnitInput @bind-SiValue="Form!.Depth" Quantity="EnkiQuantity.Length" CssClass="enki-form-input" />
            <div class="enki-form-hint">Measured depth at the station.</div>
            <ValidationMessage For="() => Form.Depth" class="enki-form-error" />
        </div>

        <div class="enki-form-group">
            <label class="enki-form-label required" for="f-inc">@UnitLabel.For("Inclination", EnkiQuantity.Angle, _units)</label>
            <UnitInput @bind-SiValue="Form!.Inclination" Quantity="EnkiQuantity.Angle" Min="0" Max="180" CssClass="enki-form-input" />
            <div class="enki-form-hint">0 to 180 degrees from vertical.</div>
            <ValidationMessage For="() => Form.Inclination" class="enki-form-error" />
        </div>

        <div class="enki-form-group">
            <label class="enki-form-label required" for="f-az">@UnitLabel.For("Azimuth", EnkiQuantity.Angle, _units)</label>
            <UnitInput @bind-SiValue="Form!.Azimuth" Quantity="EnkiQuantity.Angle" Min="0" Max="360" CssClass="enki-form-input" />
            <div class="enki-form-hint">0 to 360 degrees, true north reference.</div>
            <ValidationMessage For="() => Form.Azimuth" class="enki-form-error" />
        </div>

        <div class="enki-form-actions">
            <button type="submit" class="enki-button enki-button-primary">Create survey</button>
            <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/surveys")">Cancel</NavLink>
        </div>
    </EditForm>
</div>
</CascadingValue>

