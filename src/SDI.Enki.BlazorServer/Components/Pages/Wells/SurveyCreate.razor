@page "/tenants/{TenantCode}/jobs/{JobId:guid}/wells/{WellId:int}/surveys/new"
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using SDI.Enki.Shared.Surveys

@*
    Single-station create form. Bulk CSV import lands in Step 9 of
    the Wells plan; this is the per-row entry path for hand-typed
    additions or one-off corrections.
*@

<PageTitle>Enki &mdash; New Survey (Well @WellId)</PageTitle>

<h1 class="enki-section-title">New Survey Station</h1>
<p class="enki-section-subtitle">
    <span class="enki-mono">@TenantCode</span> &middot;
    Well <span class="enki-mono">@WellId</span>. Computed trajectory
    fields populate after Calculate runs against the well's TieOn.
</p>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

<div class="enki-card" style="max-width: 620px; margin-top: 1.25rem;">
    <EditForm Model="Form" OnValidSubmit="Submit" FormName="create-survey"
              class="enki-form" Enhance="true">
        <DataAnnotationsValidator />
        <ValidationSummary class="enki-validation-summary" />

        <div class="enki-form-group">
            <label class="enki-form-label required" for="f-depth">Depth</label>
            <InputNumber @bind-Value="Form!.Depth" id="f-depth" class="enki-form-input" required />
            <div class="enki-form-hint">Measured depth at the station.</div>
            <ValidationMessage For="() => Form.Depth" class="enki-form-error" />
        </div>

        <div class="enki-form-group">
            <label class="enki-form-label required" for="f-inc">Inclination (°)</label>
            <InputNumber @bind-Value="Form!.Inclination" id="f-inc" class="enki-form-input" required />
            <div class="enki-form-hint">0 to 180 degrees from vertical.</div>
            <ValidationMessage For="() => Form.Inclination" class="enki-form-error" />
        </div>

        <div class="enki-form-group">
            <label class="enki-form-label required" for="f-az">Azimuth (°)</label>
            <InputNumber @bind-Value="Form!.Azimuth" id="f-az" class="enki-form-input" required />
            <div class="enki-form-hint">0 to 360 degrees, true north reference.</div>
            <ValidationMessage For="() => Form.Azimuth" class="enki-form-error" />
        </div>

        <div class="enki-form-actions">
            <button type="submit" class="enki-button enki-button-primary">Create survey</button>
            <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/surveys")">Cancel</NavLink>
        </div>
    </EditForm>
</div>

@code {
    [Parameter] public string TenantCode { get; set; } = "";
    [Parameter] public Guid JobId { get; set; }
    [Parameter] public int WellId { get; set; }

    [SupplyParameterFromForm]
    public CreateForm? Form { get; set; }

    private string? _error;

    protected override void OnInitialized() => Form ??= new CreateForm();

    private async Task Submit()
    {
        if (Form is null) return;
        _error = null;
        try
        {
            var client = HttpClientFactory.CreateClient("EnkiApi");
            var dto = new CreateSurveyDto(
                Depth:       Form.Depth,
                Inclination: Form.Inclination,
                Azimuth:     Form.Azimuth);

            using var resp = await client.PostAsJsonAsync(
                $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/surveys", dto);

            if (resp.IsSuccessStatusCode)
            {
                Nav.NavigateTo($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/surveys");
                return;
            }

            var body = await resp.Content.ReadAsStringAsync();
            _error = $"Create failed ({(int)resp.StatusCode} {resp.StatusCode}): {body}";
        }
        catch (Exception ex)
        {
            _error = $"Unexpected error: {ex.Message}";
        }
    }

    public sealed class CreateForm
    {
        [Required(ErrorMessage = "Depth is required.")]
        public double Depth { get; set; }

        [Required(ErrorMessage = "Inclination is required.")]
        [Range(0d, 180d, ErrorMessage = "Inclination must be between 0 and 180 degrees.")]
        public double Inclination { get; set; }

        [Required(ErrorMessage = "Azimuth is required.")]
        [Range(0d, 360d, ErrorMessage = "Azimuth must be between 0 and 360 degrees.")]
        public double Azimuth { get; set; }
    }
}
