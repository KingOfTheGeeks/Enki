@rendermode InteractiveServer

@*
    Plan-view trajectory plot — overlays every well under the Job
    on a top-down (Easting × Northing) chart so you can see
    spatial relationships between Target / Intercept / Offset wells
    at a glance. Reads the cached Northing / Easting from each
    Survey + TieOn (no math here; Marduk owns the calc).

    Two routes share this component:
      * /tenants/{code}/jobs/{id}/wells/plot           — multi-well overlay
      * /tenants/{code}/jobs/{id}/wells/{wellId}/plot  — same data, filtered
                                                          to a single well

    Single-well mode is a degenerate of multi-well — same fetch,
    same chart, just <ChartSeries> filtered. Keeps the rendering
    code path single-source.

    Three tabs share this page: Plan view, Vertical section, and
    Travelling cylinder. Plan / V-sect read the trajectories
    payload; the cylinder tab fetches a separate anti-collision
    scan (Marduk's AntiCollisionScanner) lazily on first activation
    or when the target picker changes — that's a more expensive
    read so we don't run it unless the user asks for it.

    Coordinates flip ft / m via the units cascade — Field tenants
    see ft on the axes and tooltips, Metric / SI see m. Tubular OD
    style overrides aren't needed here; surface coords are always
    a length quantity.
*@

<PageTitle>Enki &mdash; @PageTitle</PageTitle>

<div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; flex-wrap: wrap;">
    <div style="flex: 1; min-width: 280px;">
        <h1 class="enki-section-title">@PageTitle</h1>
        <p class="enki-section-subtitle">
            <span class="enki-mono">@TenantCode</span> &middot;
            @(_view switch
            {
                PlotView.Plan     => "Plan view (looking down) — Easting × Northing. ",
                PlotView.Vertical => "Vertical section (side elevation) — V-sect × TVD, depth increasing downward. ",
                PlotView.Cylinder => "Travelling cylinder — closest-approach distance from the target well to every other well, plotted vs target MD.",
                _                 => "",
            })
            @if (_view != PlotView.Cylinder)
            {
                @if (WellId is { } wid)
                {
                    @* Use the loaded well name when available; fall
                       back to the surrogate ID only while the
                       trajectories payload is still in flight. *@
                    <span>
                        Filtered to
                        <span class="enki-mono">@(FilteredWells.FirstOrDefault()?.Name ?? $"#{wid}")</span>.
                    </span>
                }
                else
                {
                    <span>All wells overlaid; click a legend entry to toggle a curve.</span>
                }
            }
        </p>
    </div>
    <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
        @if (WellId is { } wid2)
        {
            <NavLink class="enki-button"
                     href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{wid2}")">
                Back to well
            </NavLink>
            <NavLink class="enki-button"
                     href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/plot")">
                See all wells
            </NavLink>
        }
        else
        {
            <NavLink class="enki-button"
                     href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells")">
                Back to wells
            </NavLink>
        }
    </div>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_trajectories is null)
{
    <EnkiLoading Label="Fetching trajectories from API…" />
}
else if (FilteredWells.Count == 0)
{
    <div class="enki-card" style="margin-top: 1.25rem; text-align: center; padding: 2rem;">
        <p class="enki-form-hint">
            @(WellId is null
                ? "No wells under this job yet."
                : "Well not found in this job.")
        </p>
    </div>
}
else if (HasNoPlottableData)
{
    @* Wells exist but every one has zero trajectory points (no
       tie-on, no surveys). Don't render an empty chart — surface
       the situation so the user knows it's an absence of data, not
       a broken fetch. *@
    <div class="enki-card" style="margin-top: 1.25rem; text-align: center; padding: 2rem;">
        <p class="enki-form-hint">
            No surveys or tie-ons recorded yet for the
            @(FilteredWells.Count == 1 ? "selected well" : "wells under this job").
            Add a tie-on and survey stations on the well's Surveys page,
            then come back.
        </p>
    </div>
}
else
{
    <CascadingValue Name="UnitSystem" Value="_units" IsFixed="false">

    @* Tab strip — hand-rolled with the existing button styles so it
       matches the rest of the app without dragging in another
       Syncfusion component. enki-button-primary tags the active tab. *@
    <div style="display: flex; gap: 0.5rem; margin-top: 1rem;">
        <button type="button"
                class="enki-button @(_view == PlotView.Plan ? "enki-button-primary" : "")"
                @onclick="() => _view = PlotView.Plan">
            Plan view
        </button>
        <button type="button"
                class="enki-button @(_view == PlotView.Vertical ? "enki-button-primary" : "")"
                @onclick="() => _view = PlotView.Vertical">
            Vertical section
        </button>
        <button type="button"
                class="enki-button @(_view == PlotView.Cylinder ? "enki-button-primary" : "")"
                @onclick="ActivateCylinderAsync">
            Travelling cylinder
        </button>
    </div>

    <div class="enki-card enki-bracket-frame"
         style="margin-top: 0.75rem; padding: 1rem; width: 100%;">
        @if (_view == PlotView.Plan)
        {
            <div class="enki-plot-host">
                <SfChart Width="100%"
                         Height="100%"
                         Theme="Syncfusion.Blazor.Theme.FluentDark"
                         Background="transparent"
                         Title="@($"Plan view — {(JobName ?? "Job")} ({_units.Name})")">
                    <ChartArea>
                        <ChartAreaBorder Width="0" />
                    </ChartArea>

                    @* N1 (one decimal place) instead of N0 keeps tick
                       labels distinct when the data spans less than ~1m
                       on an axis. East-going wells have ~0 Northing
                       spread, north-going wells have ~0 Easting spread
                       — N0 collapsed every gridline to the same UTM
                       integer; N1 separates them at 0.1m granularity
                       without blowing up label width on multi-km wells. *@
                    <ChartPrimaryXAxis
                        Title="@UnitLabel.For("Easting", EnkiQuantity.Length, _units)"
                        LabelFormat="N1" />
                    <ChartPrimaryYAxis
                        Title="@UnitLabel.For("Northing", EnkiQuantity.Length, _units)"
                        LabelFormat="N1" />

                    <ChartTooltipSettings Enable="true"
                                          Format="${series.name}: E ${point.x}, N ${point.y}"
                                          Shared="false" />

                    @* Bottom legend frees the full chart width for the
                       plot itself. With a right-side legend SfChart was
                       auto-fitting the plot to a tight square that gave
                       the X-axis no horizontal room. *@
                    <ChartLegendSettings Visible="true"
                                         Position="Syncfusion.Blazor.Charts.LegendPosition.Bottom" />

                    <ChartSeriesCollection>
                        @foreach (var well in FilteredWells.Where(w => w.Points.Count > 0))
                        {
                            var projected = ProjectPlanPoints(well.Points);
                            var color     = ColorFor(well.Type);

                            <ChartSeries DataSource="@projected"
                                         Name="@well.Name"
                                         XName="@nameof(PlotPoint.X)"
                                         YName="@nameof(PlotPoint.Y)"
                                         Type="ChartSeriesType.Line"
                                         Width="2"
                                         Fill="@color"
                                         EnableTooltip="true">
                                <ChartMarker Visible="true" Width="6" Height="6">
                                    <ChartMarkerBorder Width="1" Color="@color" />
                                </ChartMarker>
                            </ChartSeries>
                        }
                    </ChartSeriesCollection>
                </SfChart>
            </div>
        }
        else if (_view == PlotView.Vertical)
        {
            @* Vertical section: X = each well's V-sect (already
               projected onto its tie-on's VSD by Marduk's auto-recalc),
               Y = TVD with axis inversed so depth grows downward.
               Multi-well X axes are only directly comparable when
               the wells share a VSD; the chart subtitle calls that
               out so the user knows what they're reading. *@
            <div class="enki-plot-host">
                <SfChart Width="100%"
                         Height="100%"
                         Theme="Syncfusion.Blazor.Theme.FluentDark"
                         Background="transparent"
                         Title="@($"Vertical section — {(JobName ?? "Job")} ({_units.Name})")">
                    <ChartArea>
                        <ChartAreaBorder Width="0" />
                    </ChartArea>

                    @* N1 on V-sect to keep labels distinct on
                       short-V-sect (near-vertical) wells; TVD stays
                       N0 because it always spans hundreds of metres. *@
                    <ChartPrimaryXAxis
                        Title="@UnitLabel.For("Vertical section", EnkiQuantity.Length, _units)"
                        LabelFormat="N1" />
                    @* IsInversed flips the Y axis so TVD increases
                       downward — the way drillers read it. *@
                    <ChartPrimaryYAxis
                        Title="@UnitLabel.For("TVD", EnkiQuantity.Length, _units)"
                        LabelFormat="N0"
                        IsInversed="true" />

                    <ChartTooltipSettings Enable="true"
                                          Format="${series.name}: V-sect ${point.x}, TVD ${point.y}"
                                          Shared="false" />

                    <ChartLegendSettings Visible="true"
                                         Position="Syncfusion.Blazor.Charts.LegendPosition.Bottom" />

                    <ChartSeriesCollection>
                        @foreach (var well in FilteredWells.Where(w => w.Points.Count > 0))
                        {
                            var projected = ProjectVerticalPoints(well.Points);
                            var color     = ColorFor(well.Type);

                            <ChartSeries DataSource="@projected"
                                         Name="@well.Name"
                                         XName="@nameof(PlotPoint.X)"
                                         YName="@nameof(PlotPoint.Y)"
                                         Type="ChartSeriesType.Line"
                                         Width="2"
                                         Fill="@color"
                                         EnableTooltip="true">
                                <ChartMarker Visible="true" Width="6" Height="6">
                                    <ChartMarkerBorder Width="1" Color="@color" />
                                </ChartMarker>
                            </ChartSeries>
                        }
                    </ChartSeriesCollection>
                </SfChart>
            </div>
        }
        else
        {
            @* Travelling cylinder: distance from the target well to
               every other well in the job, plotted vs target MD. The
               Y axis is target MD (inversed so depth runs downward
               like every other depth chart in the app); the X axis
               is closest-approach distance. Clock position rides
               along in the tooltip — colour-coding it would clash
               with the per-well Type colouring already in use on the
               other tabs. *@
            <div style="display: flex; gap: 0.75rem; align-items: center; margin-bottom: 0.75rem; flex-wrap: wrap;">
                <label class="enki-form-label" for="cyl-target" style="margin: 0;">Target well:</label>
                <select id="cyl-target"
                        class="enki-form-input"
                        style="width: auto; min-width: 220px;"
                        @bind="_cylinderTargetId"
                        @bind:after="ReloadCylinderAsync"
                        disabled="@(_cylinderLoading)">
                    @foreach (var w in (_trajectories ?? new()).OrderBy(w => w.Name))
                    {
                        <option value="@w.Id">@w.Name (@w.Type)</option>
                    }
                </select>
                @if (_cylinderLoading)
                {
                    <span class="enki-form-hint">Scanning&hellip;</span>
                }
            </div>

            @if (_cylinderError is not null)
            {
                <div class="alert alert-danger">@_cylinderError</div>
            }
            else if (_cylinderScans is null)
            {
                <EnkiLoading Label="Loading anti-collision scan…" />
            }
            else if (_cylinderScans.Count == 0)
            {
                <div class="enki-card" style="text-align: center; padding: 2rem;">
                    <p class="enki-form-hint">
                        No offsets to compare against. The target well needs
                        at least one sibling under this Job with a tie-on
                        and / or surveys recorded.
                    </p>
                </div>
            }
            else
            {
                <div class="enki-plot-host">
                    <SfChart Width="100%"
                             Height="100%"
                             Theme="Syncfusion.Blazor.Theme.FluentDark"
                             Background="transparent"
                             Title="@($"Travelling cylinder — {(CylinderTargetName ?? "target")} ({_units.Name})")">
                        <ChartArea>
                            <ChartAreaBorder Width="0" />
                        </ChartArea>

                        @* N1 keeps distance labels distinct when wells
                           run nearly parallel (sub-metre separation). *@
                        <ChartPrimaryXAxis
                            Title="@UnitLabel.For("Closest-approach distance", EnkiQuantity.Length, _units)"
                            LabelFormat="N1" />
                        @* MD axis inversed so depth reads downward,
                           matching the V-sect view's TVD convention. *@
                        <ChartPrimaryYAxis
                            Title="@UnitLabel.For("Target MD", EnkiQuantity.Length, _units)"
                            LabelFormat="N0"
                            IsInversed="true" />

                        @* Tooltip surfaces clock position alongside the
                           distance + depth — the key insight a driller
                           wants from this view ("the offset is at 3
                           o'clock on the high side, 80 m away"). *@
                        <ChartTooltipSettings Enable="true"
                                              Format="${series.name}: ${point.x} away, MD ${point.y}"
                                              Shared="false" />

                        <ChartLegendSettings Visible="true"
                                             Position="Syncfusion.Blazor.Charts.LegendPosition.Bottom" />

                        <ChartSeriesCollection>
                            @foreach (var scan in _cylinderScans)
                            {
                                var projected = ProjectCylinderPoints(scan.Samples);
                                var color     = ColorFor(scan.OffsetWellType);

                                <ChartSeries DataSource="@projected"
                                             Name="@scan.OffsetWellName"
                                             XName="@nameof(PlotPoint.X)"
                                             YName="@nameof(PlotPoint.Y)"
                                             Type="ChartSeriesType.Line"
                                             Width="2"
                                             Fill="@color"
                                             EnableTooltip="true">
                                    <ChartMarker Visible="true" Width="6" Height="6">
                                        <ChartMarkerBorder Width="1" Color="@color" />
                                    </ChartMarker>
                                </ChartSeries>
                            }
                        </ChartSeriesCollection>
                    </SfChart>
                </div>
            }
        }

        <div class="enki-form-hint" style="margin-top: 0.75rem;">
            @if (_view == PlotView.Cylinder)
            {
                <span>
                    Each curve is the closest 3-D distance from the target
                    trajectory to one offset well, sampled at every target
                    station. v1 is deterministic (centre-to-centre); ISCWSA
                    error-cone bounds drop in next.
                </span>
            }
            else
            {
                <span>
                    Each point is a survey station. The first point on each
                    curve is the tie-on (depth 0). Storage is canonical SI
                    metres; the chart projects through this Job's preset
                    (@_units.Name) — switch the Job's UnitSystem on JobEdit
                    to flip ft ↔ m here.
                </span>
                @if (_view == PlotView.Vertical && WellId is null && FilteredWells.Count > 1)
                {
                    <span style="display: block; margin-top: 0.4rem;">
                        <strong>Note:</strong> each well's vertical-section
                        X axis is projected onto its OWN tie-on's
                        VerticalSectionDirection. If the wells in this Job
                        don't share a VSD, the curves are not directly
                        comparable on this axis.
                    </span>
                }
            }
        </div>
    </div>
    </CascadingValue>
}

