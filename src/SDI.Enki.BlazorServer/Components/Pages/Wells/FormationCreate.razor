@page "/tenants/{TenantCode}/jobs/{JobId:guid}/wells/{WellId:int}/formations/new"
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using SDI.Enki.Core.Units
@using SDI.Enki.Shared.Wells.Formations

<PageTitle>Enki &mdash; New Formation (Well @WellId)</PageTitle>

<h1 class="enki-section-title">New Formation</h1>
<p class="enki-section-subtitle">
    <span class="enki-mono">@TenantCode</span> &middot;
    Well <span class="enki-mono">@WellId</span>
</p>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

<CascadingValue Name="UnitSystem" Value="_units" IsFixed="false">
<div class="enki-card" style="max-width: 720px; margin-top: 1.25rem;">
    <EditForm Model="Form" OnValidSubmit="Submit" FormName="create-formation"
              class="enki-form" Enhance="true">
        <DataAnnotationsValidator />
        <ValidationSummary class="enki-validation-summary" />

        <div class="enki-form-group">
            <label class="enki-form-label required" for="f-name">Name</label>
            <InputText @bind-Value="Form!.Name" id="f-name" class="enki-form-input"
                       placeholder="e.g. Eagle Ford" required maxlength="200" />
            <ValidationMessage For="() => Form.Name" class="enki-form-error" />
        </div>

        <div class="enki-form-group">
            <label class="enki-form-label" for="f-desc">Description</label>
            <InputTextArea @bind-Value="Form!.Description" id="f-desc"
                           class="enki-form-textarea"
                           placeholder="Optional notes about the formation" />
            <ValidationMessage For="() => Form.Description" class="enki-form-error" />
        </div>

        <div class="enki-form-grid-2col">
            <div class="enki-form-group">
                <label class="enki-form-label required">@UnitLabel.For("From TVD", EnkiQuantity.Length, _units)</label>
                <UnitInput @bind-SiValue="Form!.FromVertical" Quantity="EnkiQuantity.Length" CssClass="enki-form-input" />
                <ValidationMessage For="() => Form.FromVertical" class="enki-form-error" />
            </div>
            <div class="enki-form-group">
                <label class="enki-form-label required">@UnitLabel.For("To TVD", EnkiQuantity.Length, _units)</label>
                <UnitInput @bind-SiValue="Form!.ToVertical" Quantity="EnkiQuantity.Length" CssClass="enki-form-input" />
                <ValidationMessage For="() => Form.ToVertical" class="enki-form-error" />
            </div>
            <div class="enki-form-group">
                <label class="enki-form-label required" for="f-res">Resistance</label>
                <InputNumber @bind-Value="Form!.Resistance" id="f-res" class="enki-form-input" required />
                <div class="enki-form-hint">Bare scalar — legacy ranging input, no unit attached.</div>
                <ValidationMessage For="() => Form.Resistance" class="enki-form-error" />
            </div>
        </div>

        <div class="enki-form-actions">
            <button type="submit" class="enki-button enki-button-primary">Create formation</button>
            <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/formations")">Cancel</NavLink>
        </div>
    </EditForm>
</div>
</CascadingValue>

@code {
    [Parameter] public string TenantCode { get; set; } = "";
    [Parameter] public Guid JobId { get; set; }
    [Parameter] public int WellId { get; set; }

    [SupplyParameterFromForm]
    public CreateForm? Form { get; set; }

    private string? _error;
    private UnitSystem _units = UnitSystem.SI;

    protected override async Task OnInitializedAsync()
    {
        Form ??= new CreateForm();
        try
        {
            var client = HttpClientFactory.CreateClient("EnkiApi");
            var job = await client.GetFromJsonAsync<JobDetailDto>(
                $"tenants/{TenantCode}/jobs/{JobId}");
            _units = UnitSystem.FromNameOrSi(job?.UnitSystem);
        }
        catch
        {
            // Fallback to SI; the form still renders.
        }
    }

    private async Task Submit()
    {
        if (Form is null) return;
        _error = null;
        try
        {
            var client = HttpClientFactory.CreateClient("EnkiApi");
            var dto = new CreateFormationDto(
                Name:         Form.Name,
                FromVertical: Form.FromVertical,
                ToVertical:   Form.ToVertical,
                Resistance:   Form.Resistance,
                Description:  string.IsNullOrWhiteSpace(Form.Description) ? null : Form.Description);

            using var resp = await client.PostAsJsonAsync(
                $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/formations", dto);

            if (resp.IsSuccessStatusCode)
            {
                Nav.NavigateTo($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/formations");
                return;
            }

            var body = await resp.Content.ReadAsStringAsync();
            _error = $"Create failed ({(int)resp.StatusCode} {resp.StatusCode}): {body}";
        }
        catch (Exception ex) { _error = $"Unexpected error: {ex.Message}"; }
    }

    public sealed class CreateForm
    {
        [Required(ErrorMessage = "Name is required.")]
        [MaxLength(200)] public string Name { get; set; } = "";
        public string? Description { get; set; }
        [Required(ErrorMessage = "From TVD is required.")]
        public double FromVertical { get; set; }
        [Required(ErrorMessage = "To TVD is required.")]
        public double ToVertical { get; set; }
        [Required(ErrorMessage = "Resistance is required.")]
        public double Resistance { get; set; }
    }
}
