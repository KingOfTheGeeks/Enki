@page "/tenants/{TenantCode}/jobs/{JobId:guid}/wells/{WellId:int}/surveys"
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@using SDI.Enki.Shared.Surveys
@using SDI.Enki.Shared.Wells.TieOns
@using System.Net.Http.Json

@*
    Survey stations under a Well. Grid view, sortable + filterable.
    The well's tie-on is rendered as the first row (read-only) so the
    survey set is shown anchored to its reference station — the same
    way the Calculate engine consumes them. Per-row deep-link on a
    survey opens its edit page; tie-on is edited from the Tie-Ons
    page (/tieons), not from here.
*@

<PageTitle>Enki &mdash; Surveys (Well @WellId)</PageTitle>

<div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; flex-wrap: wrap;">
    <div style="flex: 1; min-width: 280px;">
        <h1 class="enki-section-title">
            Surveys
            <span class="enki-mono" style="font-size: 0.65em; opacity: 0.65; margin-left: 0.5rem;">
                @TenantCode &middot; Well @WellId
            </span>
        </h1>
        <p class="enki-section-subtitle">
            Survey stations on the well, anchored at the well's tie-on
            (top row, read-only). Observed columns (depth / inclination
            / azimuth) are entered here; computed columns (TVD, dogleg,
            …) populate after Calculate runs.
        </p>
    </div>
    <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
        @* Back to the well hub (WellDetail) — that's where the user picks
           a different child entity (tubulars, formations, etc.). Stepping
           up to the wells list from here would force a re-click. *@
        <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}")">Back to well</NavLink>
        @* No "Calculate" button here by design: the API auto-recomputes
           the trajectory after every Survey/TieOn mutation, so this
           grid is always already-calculated when it loads. *@
        <NavLink class="enki-button enki-button-primary"
                 href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/surveys/new")">
            + New survey
        </NavLink>
    </div>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_rows is null)
{
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Fetching surveys from API&hellip;</div>
    </div>
}
else
{
    <div class="enki-stat-grid">
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_surveyCount.ToString("D2")</div>
            <div class="enki-stat-label">Stations</div>
        </div>
        <div class="enki-stat-card">
            <div class="enki-stat-value">
                @(_surveyCount == 0 ? "—" : _minDepth.ToString("F0"))
            </div>
            <div class="enki-stat-label">Min depth</div>
        </div>
        <div class="enki-stat-card">
            <div class="enki-stat-value">
                @(_surveyCount == 0 ? "—" : _maxDepth.ToString("F0"))
            </div>
            <div class="enki-stat-label">Max depth</div>
        </div>
        <div class="enki-stat-card">
            <div class="enki-stat-value">@(_calculated ? "yes" : "no")</div>
            <div class="enki-stat-label">Calculated</div>
        </div>
    </div>

    <SfGrid DataSource="_rows"
            AllowSorting="true"
            AllowFiltering="true"
            AllowResizing="true"
            Height="auto">
        <GridColumns>
            <GridColumn Field="@nameof(GridRow.Depth)" HeaderText="Depth" Width="110">
                <Template>
                    @{ var r = context as GridRow; }
                    @if (r is not null)
                    {
                        @* Tie-on rows render the depth as plain text — not
                           editable from this page (the user goes to the
                           Tie-Ons page if they need to change it). Survey
                           rows render an edit link on the depth value. *@
                        @if (r.IsTieOn)
                        {
                            <span>@r.Depth.ToString("F2")</span>
                        }
                        else
                        {
                            <a class="enki-row-link"
                               href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/surveys/{r.Id}/edit")">
                                @r.Depth.ToString("F2")
                            </a>
                        }
                    }
                </Template>
            </GridColumn>
            <GridColumn Field="@nameof(GridRow.Inclination)" HeaderText="Inc °" Width="100" Format="N2" />
            <GridColumn Field="@nameof(GridRow.Azimuth)"     HeaderText="Az °"  Width="100" Format="N2" />
            @* Computed columns. For the tie-on, TVD/Sub-sea map to its
               VerticalReference / SubSeaReference values; DLS / V-sect /
               Build / Turn don't apply at the reference station and
               render as zero. *@
            <GridColumn Field="@nameof(GridRow.VerticalDepth)"   HeaderText="TVD"      Width="110" Format="N2" />
            <GridColumn Field="@nameof(GridRow.SubSea)"          HeaderText="Sub-sea"  Width="110" Format="N2" />
            <GridColumn Field="@nameof(GridRow.North)"           HeaderText="North"    Width="110" Format="N2" />
            <GridColumn Field="@nameof(GridRow.East)"            HeaderText="East"     Width="110" Format="N2" />
            <GridColumn Field="@nameof(GridRow.DoglegSeverity)"  HeaderText="DLS"      Width="100" Format="N3" />
            <GridColumn Field="@nameof(GridRow.VerticalSection)" HeaderText="V-sect"   Width="110" Format="N2" />
            <GridColumn Field="@nameof(GridRow.Northing)"        HeaderText="Northing" Width="130" Format="N2" />
            <GridColumn Field="@nameof(GridRow.Easting)"         HeaderText="Easting"  Width="130" Format="N2" />
            <GridColumn Field="@nameof(GridRow.Build)"           HeaderText="Build"    Width="100" Format="N3" />
            <GridColumn Field="@nameof(GridRow.Turn)"            HeaderText="Turn"     Width="100" Format="N3" />
        </GridColumns>
    </SfGrid>
}

@code {
    [Parameter] public string TenantCode { get; set; } = "";
    [Parameter] public Guid JobId { get; set; }
    [Parameter] public int WellId { get; set; }

    private List<GridRow>? _rows;
    private int    _surveyCount;
    private double _minDepth;
    private double _maxDepth;
    private bool   _calculated;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("EnkiApi");

            // Pull both lists in parallel — they're independent and the
            // tie-on call is small. WhenAll keeps page-load fast.
            var tieOnsTask = client.GetFromJsonAsync<List<TieOnSummaryDto>>(
                $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/tieons");
            var surveysTask = client.GetFromJsonAsync<List<SurveySummaryDto>>(
                $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/surveys");

            await Task.WhenAll(tieOnsTask, surveysTask);

            var tieOns  = tieOnsTask.Result  ?? new();
            var surveys = surveysTask.Result ?? new();

            _surveyCount = surveys.Count;
            _minDepth    = surveys.Count == 0 ? 0 : surveys.Min(s => s.Depth);
            _maxDepth    = surveys.Count == 0 ? 0 : surveys.Max(s => s.Depth);
            _calculated  = surveys.Any(s => s.VerticalDepth != 0);

            // Combined view-model: tie-on(s) first, then surveys. The
            // grid binds to GridRow so the same column set renders both.
            // The auto-calc anchors on the lowest-Id tie-on, so ordering
            // by Id keeps the visual order consistent with the
            // calculation order.
            _rows = tieOns
                .OrderBy(t => t.Id)
                .Select(MapTieOn)
                .Concat(surveys.Select(MapSurvey))
                .ToList();
        }
        catch (HttpRequestException ex) { _error = $"WebApi call failed: {ex.Message}"; }
        catch (Exception ex)             { _error = $"Unexpected error: {ex.Message}"; }
    }

    private static GridRow MapTieOn(TieOnSummaryDto t) => new(
        IsTieOn: true,
        Id:               t.Id,
        Depth:            t.Depth,
        Inclination:      t.Inclination,
        Azimuth:          t.Azimuth,
        VerticalDepth:    t.VerticalReference,
        SubSea:           t.SubSeaReference,
        North:            t.North,
        East:             t.East,
        DoglegSeverity:   0,
        VerticalSection:  0,
        Northing:         t.Northing,
        Easting:          t.Easting,
        Build:            0,
        Turn:             0);

    private static GridRow MapSurvey(SurveySummaryDto s) => new(
        IsTieOn: false,
        Id:               s.Id,
        Depth:            s.Depth,
        Inclination:      s.Inclination,
        Azimuth:          s.Azimuth,
        VerticalDepth:    s.VerticalDepth,
        SubSea:           s.SubSea,
        North:            s.North,
        East:             s.East,
        DoglegSeverity:   s.DoglegSeverity,
        VerticalSection:  s.VerticalSection,
        Northing:         s.Northing,
        Easting:          s.Easting,
        Build:            s.Build,
        Turn:             s.Turn);

    /// <summary>
    /// Unified row shape for the surveys grid — tie-ons and surveys
    /// share enough columns that one model serves both. <c>IsTieOn</c>
    /// drives the Depth-cell template branch (TIE-ON badge vs.
    /// edit-link).
    /// </summary>
    public sealed record GridRow(
        bool IsTieOn,
        int Id,
        double Depth,
        double Inclination,
        double Azimuth,
        double VerticalDepth,
        double SubSea,
        double North,
        double East,
        double DoglegSeverity,
        double VerticalSection,
        double Northing,
        double Easting,
        double Build,
        double Turn);
}
