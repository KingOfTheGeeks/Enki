@page "/tenants/{TenantCode}/jobs/{JobId:guid}/wells/{WellId:int}/surveys"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@inject UnitPreferenceProvider UnitPrefs
@using SDI.Enki.BlazorServer.Api
@using SDI.Enki.Core.Units
@using SDI.Enki.Shared.Jobs
@using SDI.Enki.Shared.Paging
@using SDI.Enki.Shared.Surveys
@using SDI.Enki.Shared.Wells.TieOns

@*
    Survey stations under a Well, plus the well's tie-on rendered as
    the first row of the same grid. Both tie-on and survey rows support
    inline edit via Syncfusion's Normal edit mode:

      * Double-click any row → opens it for editing.
      * Enter saves, Esc cancels.
      * OnActionCompleteAsync fires on Save and branches on IsTieOn:
        tie-on rows PUT to TieOnsController (UpdateTieOnDto), survey
        rows PUT to SurveysController (UpdateSurveyDto). Both endpoints
        invoke ISurveyAutoCalculator.RecalculateAsync server-side after
        the field mutation, so a force-reload below picks up the
        recomputed trajectory columns on every row.

    Edit-template gating per row type:
      * Tie-on rows can edit Depth / Inc / Az + the anchor reference
        columns it owns (TVD = VerticalReference, Sub-sea =
        SubSeaReference, Northing, Easting).
      * Survey rows can edit only the three observed fields (Depth /
        Inc / Az). The four anchor-reference columns above are computed
        by the auto-calc for surveys, so their EditTemplates fall back
        to the read-only <UnitFormatted> when IsTieOn is false.
      * Truly computed columns — North / East / DLS / V-sect / Build /
        Turn — set AllowEditing="false" so they remain read-only on
        either row type.

    VSD and other rare tie-on reference fields stay on the dedicated
    /tieons/{id}/edit page; per-survey detail edit (with Delete) is
    available at /surveys/{id}/edit. Both linked from the page header
    or from row navigation as appropriate.
*@

<PageTitle>Enki &mdash; Surveys (Well @WellId)</PageTitle>

<PageHeader Title="Surveys">
    <TitleSuffix>
        <span class="enki-mono">@TenantCode &middot; Well @WellId</span>
    </TitleSuffix>
    <Subtitle>
        Tie-on at the top, survey stations below — the same way the
        min-curvature engine consumes them. <strong>Double-click any
        row</strong> to edit it; Enter saves and the whole well's
        trajectory recalculates automatically.
    </Subtitle>
    <Actions>
        <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}")">Back to well</NavLink>
        <SurveyImportButton TenantCode="@TenantCode" JobId="@JobId" WellId="@WellId" Units="@_units" />
        <SurveyClearButton TenantCode="@TenantCode" JobId="@JobId" WellId="@WellId" />

        @if (_tieOn is null)
        {
            @* No tie-on yet → offer to seed one at depth 0. *@
            <button class="enki-button"
                    disabled="@_busy"
                    @onclick="CreateDefaultTieOnAsync">
                + Create tie-on
            </button>
        }
        else
        {
            @* Advanced reference-field editor (VSD, locals) — out of
               scope for the inline grid edit, surfaced as an opt-in link. *@
            <NavLink class="enki-button"
                     href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/tieons/{_tieOn.Id}/edit")">
                Advanced tie-on
            </NavLink>
        }

        <NavLink class="enki-button enki-button-primary"
                 href="@($"/tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/surveys/new")">
            + New survey
        </NavLink>
    </Actions>
</PageHeader>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_saveStatus is not null)
{
    <div class="alert @_saveAlertClass">@_saveStatus</div>
}
else if (_rows is null)
{
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Fetching surveys from API&hellip;</div>
    </div>
}

@if (_rows is not null && _error is null)
{
    @* One cascade for the whole content block so stat-card
       <UnitFormatted> instances and grid cell templates pick up the
       same Units value without each one being passed it explicitly. *@
    <CascadingValue Name="UnitSystem" Value="_units" IsFixed="false">
    <div class="enki-stat-grid">
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_surveyCount.ToString("D2")</div>
            <div class="enki-stat-label">Stations</div>
        </div>
        <div class="enki-stat-card">
            <div class="enki-stat-value">
                @if (_surveyCount == 0) { <text>—</text> }
                else { <UnitFormatted Value="@_minDepth" Quantity="EnkiQuantity.Length" Format="N0" ShowUnit="false" /> }
            </div>
            <div class="enki-stat-label">@UnitLabel.For("Min depth", EnkiQuantity.Length, _units)</div>
        </div>
        <div class="enki-stat-card">
            <div class="enki-stat-value">
                @if (_surveyCount == 0) { <text>—</text> }
                else { <UnitFormatted Value="@_maxDepth" Quantity="EnkiQuantity.Length" Format="N0" ShowUnit="false" /> }
            </div>
            <div class="enki-stat-label">@UnitLabel.For("Max depth", EnkiQuantity.Length, _units)</div>
        </div>
    </div>

    @* Toolbar gives the user a visible Update / Cancel pair while a
       row is being edited. Without it Syncfusion's Normal edit mode
       only saves on the Enter key — easy to miss, which is why the
       server-side recalc wasn't firing. Edit still kicks off via
       double-click on the tie-on row; the toolbar buttons are
       enabled only while the grid is in edit mode. *@
    @* HeaderText still references _units directly because it's
       evaluated at the page's @code scope; the CascadingValue
       wrapper above this block feeds the Units parameter to the
       cell templates' <UnitFormatted> / <UnitInput> children. *@
    <SfGrid DataSource="_rows"
            AllowResizing="true"
            AllowPaging="true"
            Toolbar="@(new List<string> { "Update", "Cancel" })"
            Height="auto">
        <GridEditSettings AllowEditing="true"
                          AllowAdding="false"
                          AllowDeleting="false"
                          Mode="EditMode.Normal" />
        <GridEvents OnActionBegin="OnActionBegin"
                    OnActionComplete="OnActionCompleteAsync"
                    TValue="GridRow" />
        <GridPageSettings PageSize="25" PageSizes="new[] { 10, 25, 50, 100 }" />
        <GridColumns>
            @* Stable per-row primary key — needed by Syncfusion's edit
               machinery to identify the row across data-source updates.
               "T{Id}" for the tie-on, "S{Id}" for surveys avoids the
               collision that'd happen if both shared the int Id alone. *@
            <GridColumn Field="@nameof(GridRow.RowKey)" IsPrimaryKey="true" Visible="false" />

            @* Per-cell unit projection.
               * <Template>     — read view, projects SI → display via
                                  <UnitFormatted>. ShowUnit="false"
                                  because the column header already
                                  carries the abbreviation.
               * <EditTemplate> — edit view, projects display → SI on
                                  every keystroke via <UnitInput>; the
                                  bound row field carries the SI value
                                  back through Syncfusion's edit
                                  machinery to OnActionCompleteAsync. *@
            @* Widths sized so the longest expected header
               ("DLS (°/100ft)", "Sub-sea ref (ft)", etc.) renders in
               full. MinWidth set on each so responsive shrink doesn't
               clip the unit suffix; user can still drag wider via
               AllowResizing. *@
            <GridColumn Field="@nameof(GridRow.Depth)" HeaderText="@UnitLabel.For("Depth", EnkiQuantity.Length, _units)" Width="130" MinWidth="120">
                <Template>
                    @{ var row = (GridRow)context!; }
                    <UnitFormatted Value="@row.Depth" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                </Template>
                <EditTemplate>
                    @{ var row = (GridRow)context!; }
                    <UnitInput @bind-SiValue="row.Depth" Quantity="EnkiQuantity.Length" ShowUnit="false" Format="F2" />
                </EditTemplate>
            </GridColumn>
            <GridColumn Field="@nameof(GridRow.Inclination)" HeaderText="@UnitLabel.For("Inc", EnkiQuantity.Angle, _units)" Width="120" MinWidth="100">
                <Template>
                    @{ var row = (GridRow)context!; }
                    <UnitFormatted Value="@row.Inclination" Quantity="EnkiQuantity.Angle" Format="N2" ShowUnit="false" />
                </Template>
                <EditTemplate>
                    @{ var row = (GridRow)context!; }
                    <UnitInput @bind-SiValue="row.Inclination" Quantity="EnkiQuantity.Angle" ShowUnit="false" Min="0" Max="180" Format="F2" />
                </EditTemplate>
            </GridColumn>
            <GridColumn Field="@nameof(GridRow.Azimuth)" HeaderText="@UnitLabel.For("Az", EnkiQuantity.Angle, _units)" Width="120" MinWidth="100">
                <Template>
                    @{ var row = (GridRow)context!; }
                    <UnitFormatted Value="@row.Azimuth" Quantity="EnkiQuantity.Angle" Format="N2" ShowUnit="false" />
                </Template>
                <EditTemplate>
                    @{ var row = (GridRow)context!; }
                    <UnitInput @bind-SiValue="row.Azimuth" Quantity="EnkiQuantity.Angle" ShowUnit="false" Min="0" Max="360" Format="F2" />
                </EditTemplate>
            </GridColumn>

            @* TVD shows VerticalReference for the tie-on (editable) and
               VerticalDepth for surveys (read-only by row-level cancel). *@
            @* TVD / Sub-sea: editable for the tie-on (where they map to
               VerticalReference / SubSeaReference, both user-owned), but
               computed by the auto-calc for survey rows — render read-only
               in the EditTemplate so the user can't enter a value that'd
               be silently rewritten by the post-save recalc. *@
            <GridColumn Field="@nameof(GridRow.VerticalDepth)" HeaderText="@UnitLabel.For("TVD", EnkiQuantity.Length, _units)" Width="130" MinWidth="120">
                <Template>
                    @{ var row = (GridRow)context!; }
                    <UnitFormatted Value="@row.VerticalDepth" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                </Template>
                <EditTemplate>
                    @{ var row = (GridRow)context!; }
                    @if (row.IsTieOn)
                    {
                        <UnitInput @bind-SiValue="row.VerticalDepth" Quantity="EnkiQuantity.Length" ShowUnit="false" Format="F2" />
                    }
                    else
                    {
                        <UnitFormatted Value="@row.VerticalDepth" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                    }
                </EditTemplate>
            </GridColumn>
            <GridColumn Field="@nameof(GridRow.SubSea)" HeaderText="@UnitLabel.For("Sub-sea", EnkiQuantity.Length, _units)" Width="150" MinWidth="140">
                <Template>
                    @{ var row = (GridRow)context!; }
                    <UnitFormatted Value="@row.SubSea" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                </Template>
                <EditTemplate>
                    @{ var row = (GridRow)context!; }
                    @if (row.IsTieOn)
                    {
                        <UnitInput @bind-SiValue="row.SubSea" Quantity="EnkiQuantity.Length" ShowUnit="false" Format="F2" />
                    }
                    else
                    {
                        <UnitFormatted Value="@row.SubSea" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                    }
                </EditTemplate>
            </GridColumn>

            @* Always 0 for the tie-on, computed for surveys — never
               editable through this grid. AllowEditing="false" keeps
               the cells flat text even when the row is in edit mode,
               so a single read template suffices. *@
            <GridColumn Field="@nameof(GridRow.North)" HeaderText="@UnitLabel.For("North", EnkiQuantity.Length, _units)" Width="130" MinWidth="120" AllowEditing="false">
                <Template>
                    @{ var row = (GridRow)context!; }
                    <UnitFormatted Value="@row.North" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                </Template>
            </GridColumn>
            <GridColumn Field="@nameof(GridRow.East)" HeaderText="@UnitLabel.For("East", EnkiQuantity.Length, _units)" Width="130" MinWidth="120" AllowEditing="false">
                <Template>
                    @{ var row = (GridRow)context!; }
                    <UnitFormatted Value="@row.East" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                </Template>
            </GridColumn>
            <GridColumn Field="@nameof(GridRow.DoglegSeverity)" HeaderText="@UnitLabel.For("DLS", EnkiQuantity.CurvatureRate, _units)" Width="160" MinWidth="150" AllowEditing="false">
                <Template>
                    @{ var row = (GridRow)context!; }
                    <UnitFormatted Value="@row.DoglegSeverity" Quantity="EnkiQuantity.CurvatureRate" Format="N3" ShowUnit="false" />
                </Template>
            </GridColumn>
            <GridColumn Field="@nameof(GridRow.VerticalSection)" HeaderText="@UnitLabel.For("V-sect", EnkiQuantity.Length, _units)" Width="140" MinWidth="130" AllowEditing="false">
                <Template>
                    @{ var row = (GridRow)context!; }
                    <UnitFormatted Value="@row.VerticalSection" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                </Template>
            </GridColumn>

            @* Northing / Easting: tie-on owns these as the absolute-grid
               anchor; survey rows have them computed by the auto-calc
               (relative to the tie-on plus the per-station offsets). Same
               tie-on-only edit pattern as TVD / Sub-sea above. *@
            <GridColumn Field="@nameof(GridRow.Northing)" HeaderText="@UnitLabel.For("Northing", EnkiQuantity.Length, _units)" Width="160" MinWidth="150">
                <Template>
                    @{ var row = (GridRow)context!; }
                    <UnitFormatted Value="@row.Northing" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                </Template>
                <EditTemplate>
                    @{ var row = (GridRow)context!; }
                    @if (row.IsTieOn)
                    {
                        <UnitInput @bind-SiValue="row.Northing" Quantity="EnkiQuantity.Length" ShowUnit="false" Format="F2" />
                    }
                    else
                    {
                        <UnitFormatted Value="@row.Northing" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                    }
                </EditTemplate>
            </GridColumn>
            <GridColumn Field="@nameof(GridRow.Easting)" HeaderText="@UnitLabel.For("Easting", EnkiQuantity.Length, _units)" Width="160" MinWidth="150">
                <Template>
                    @{ var row = (GridRow)context!; }
                    <UnitFormatted Value="@row.Easting" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                </Template>
                <EditTemplate>
                    @{ var row = (GridRow)context!; }
                    @if (row.IsTieOn)
                    {
                        <UnitInput @bind-SiValue="row.Easting" Quantity="EnkiQuantity.Length" ShowUnit="false" Format="F2" />
                    }
                    else
                    {
                        <UnitFormatted Value="@row.Easting" Quantity="EnkiQuantity.Length" Format="N2" ShowUnit="false" />
                    }
                </EditTemplate>
            </GridColumn>

            <GridColumn Field="@nameof(GridRow.Build)" HeaderText="@UnitLabel.For("Build", EnkiQuantity.CurvatureRate, _units)" Width="160" MinWidth="150" AllowEditing="false">
                <Template>
                    @{ var row = (GridRow)context!; }
                    <UnitFormatted Value="@row.Build" Quantity="EnkiQuantity.CurvatureRate" Format="N3" ShowUnit="false" />
                </Template>
            </GridColumn>
            <GridColumn Field="@nameof(GridRow.Turn)" HeaderText="@UnitLabel.For("Turn", EnkiQuantity.CurvatureRate, _units)" Width="160" MinWidth="150" AllowEditing="false">
                <Template>
                    @{ var row = (GridRow)context!; }
                    <UnitFormatted Value="@row.Turn" Quantity="EnkiQuantity.CurvatureRate" Format="N3" ShowUnit="false" />
                </Template>
            </GridColumn>
        </GridColumns>
    </SfGrid>
    @if (_surveysHasMore)
    {
        <p class="enki-form-hint" style="margin-top: 0.5rem;">
            Showing the first @(_rows!.Count - (_tieOn is null ? 0 : 1)) of
            @_surveysTotal stations on this well. Wells with more than
            ~2 000 surveys are unusual; if you're seeing this, capture
            a screenshot and ping engineering — paging beyond the first
            page isn't yet wired into the grid UI.
        </p>
    }
    </CascadingValue>
}



@code {
    [Parameter] public string TenantCode { get; set; } = "";
    [Parameter] public Guid JobId { get; set; }
    [Parameter] public int WellId { get; set; }

    private List<GridRow>? _rows;
    private TieOnSummaryDto? _tieOn;
    private bool _busy;
    private string? _saveStatus;
    private string _saveAlertClass = "alert-info";
    private int    _surveyCount;
    private double _minDepth;
    private double _maxDepth;
    private int    _surveysTotal;
    private bool   _surveysHasMore;
    private string? _error;

    /// <summary>
    /// The Job's preferred display unit-system. Drives the per-column
    /// HeaderText abbreviations via <see cref="UnitLabel"/>. Defaults
    /// to strict SI so the first paint (before the Job fetch returns)
    /// shows the raw stored unit names rather than guessing wrong.
    /// </summary>
    private UnitSystem _units = UnitSystem.SI;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        var client = HttpClientFactory.CreateClient("EnkiApi");

        // Pull all three calls in parallel — they're independent
        // and the Job + tie-on calls are small. WhenAll keeps
        // page-load fast. The Job fetch is here to learn the
        // UnitSystem for column-header abbreviations + to feed
        // the <CascadingValue> wrapping the grid (so cell-level
        // <UnitFormatted> / <UnitInput> templates pick it up).
        // Same pattern repeats across every Wells-area page.
        var jobTask = client.GetAsync<JobDetailDto>(
            $"tenants/{TenantCode}/jobs/{JobId}");
        var tieOnsTask = client.GetAsync<List<TieOnSummaryDto>>(
            $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/tieons");
        // Surveys list is paged at the wire layer; default take=2000
        // covers any single-well dataset we've observed. If a tenant
        // ever lands a well with > 2000 stations, the page hint at the
        // bottom of the grid surfaces the truncation; that's a
        // forward-looking signal more than a current concern.
        var surveysTask = client.GetAsync<PagedResult<SurveySummaryDto>>(
            $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/surveys");

        await Task.WhenAll(jobTask, tieOnsTask, surveysTask);

        var jobResult     = jobTask.Result;
        var tieOnsResult  = tieOnsTask.Result;
        var surveysResult = surveysTask.Result;

        if (!jobResult.IsSuccess)     { _error = jobResult.Error.AsAlertText();     return; }
        if (!tieOnsResult.IsSuccess)  { _error = tieOnsResult.Error.AsAlertText();  return; }
        if (!surveysResult.IsSuccess) { _error = surveysResult.Error.AsAlertText(); return; }

        _units      = await UnitPrefs.ResolveAsync(jobResult.Value.UnitSystem);
        var tieOns  = tieOnsResult.Value;
        var surveys = surveysResult.Value.Items;
        _surveysTotal     = surveysResult.Value.Total;
        _surveysHasMore   = surveysResult.Value.HasMore;

        // Stat tiles report the total well stations (server-truth),
        // not just the page slice. Min / max are computed against the
        // page since they're an at-a-glance summary of what the user
        // is looking at; truncation is signalled separately by the
        // paging hint below the grid.
        _surveyCount = _surveysTotal;
        _minDepth    = surveys.Count == 0 ? 0 : surveys.Min(s => s.Depth);
        _maxDepth    = surveys.Count == 0 ? 0 : surveys.Max(s => s.Depth);

        // Anchor on the lowest-Id tie-on (matches what the auto-calc
        // does server-side).
        _tieOn = tieOns.OrderBy(t => t.Id).FirstOrDefault();

        // Build grid rows: tie-on first (when present), then surveys
        // in depth order (the API already returns them sorted).
        _rows = new List<GridRow>(surveys.Count + 1);
        if (_tieOn is not null) _rows.Add(MapTieOn(_tieOn));
        _rows.AddRange(surveys.Select(MapSurvey));
    }

    /// <summary>
    /// Both tie-on and survey rows enter inline edit on double-click.
    /// The Save handler in <see cref="OnActionCompleteAsync"/> branches
    /// on <see cref="GridRow.IsTieOn"/> to PUT to the right controller;
    /// the auto-calc fires server-side after either path, so the page
    /// force-reload below picks up the recomputed trajectory.
    /// </summary>
    private void OnActionBegin(ActionEventArgs<GridRow> args)
    {
        // Intentionally empty — kept as a hook for future row-level
        // validation. Removing the wiring would also remove the place
        // we'd add it.
    }

    /// <summary>
    /// Save handler — fires when the user presses Enter (or clicks the
    /// toolbar Update button) on either a tie-on or a survey edit.
    /// Tie-on rows PUT to TieOnsController; survey rows PUT to
    /// SurveysController. Both endpoints fire the server-side
    /// <c>ISurveyAutoCalculator</c> after the field mutation, so a
    /// force-reload below picks up the recomputed trajectory columns
    /// (TVD / N / E / DLS / V-sect / Build / Turn) on every row.
    /// </summary>
    private async Task OnActionCompleteAsync(ActionEventArgs<GridRow> args)
    {
        if (args.RequestType != Syncfusion.Blazor.Grids.Action.Save) return;
        if (args.Data is not { } row) return;

        var client = HttpClientFactory.CreateClient("EnkiApi");
        var saveResult = row.IsTieOn
            ? await SaveTieOnAsync(client, row)
            : await SaveSurveyAsync(client, row);

        if (saveResult.IsSuccess)
        {
            Nav.NavigateTo(Nav.Uri, forceLoad: true);
            return;
        }

        _saveStatus     = saveResult.Error.AsAlertText();
        _saveAlertClass = "alert-danger";
    }

    private async Task<ApiResult> SaveTieOnAsync(HttpClient client, GridRow row)
    {
        if (_tieOn is null)
            return ApiResult.Failure(new ApiError(
                StatusCode:  0,
                Kind:        ApiErrorKind.Unknown,
                Title:       "No tie-on loaded — refresh the page and retry.",
                Detail:      null,
                FieldErrors: null));

        var dto = new UpdateTieOnDto(
            Depth:                    row.Depth,
            Inclination:              row.Inclination,
            Azimuth:                  row.Azimuth,
            North:                    0,
            East:                     0,
            Northing:                 row.Northing,
            Easting:                  row.Easting,
            VerticalReference:        row.VerticalDepth,    // tie-on's TVD column carries VR
            SubSeaReference:          row.SubSea,            // and Sub-sea carries SubSeaReference
            VerticalSectionDirection: _tieOn.VerticalSectionDirection,
            RowVersion:               row.RowVersion);

        return await client.PutAsync(
            $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/tieons/{_tieOn.Id}",
            dto);
    }

    private async Task<ApiResult> SaveSurveyAsync(HttpClient client, GridRow row)
    {
        // Only the three observed fields are accepted by
        // SurveysController.Update; computed columns (TVD / N / E / DLS /
        // …) are owned by the post-save auto-calc and would be silently
        // overwritten anyway. The EditTemplates above render those
        // columns read-only when IsTieOn is false so the user can't
        // accidentally edit them in the first place.
        var dto = new UpdateSurveyDto(
            Depth:       row.Depth,
            Inclination: row.Inclination,
            Azimuth:     row.Azimuth,
            RowVersion:  row.RowVersion);

        return await client.PutAsync(
            $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/surveys/{row.Id}",
            dto);
    }

    private async Task CreateDefaultTieOnAsync()
    {
        _busy = true;
        StateHasChanged();
        try
        {
            var client = HttpClientFactory.CreateClient("EnkiApi");
            var result = await client.PostAsync(
                $"tenants/{TenantCode}/jobs/{JobId}/wells/{WellId}/tieons",
                new CreateTieOnDto(Depth: 0, Inclination: 0, Azimuth: 0));

            if (result.IsSuccess)
            {
                Nav.NavigateTo(Nav.Uri, forceLoad: true);
                return;
            }
            _saveStatus     = result.Error.AsAlertText();
            _saveAlertClass = "alert-danger";
        }
        finally
        {
            _busy = false;
        }
    }

    /// <summary>
    /// Tie-on → grid-row projection. The grid's column headers map onto
    /// tie-on fields where the data exists (TVD = VerticalReference,
    /// Sub-sea = SubSeaReference) and 0 where it doesn't (anchor's local
    /// North/East and any rate-of-change quantity).
    /// </summary>
    private static GridRow MapTieOn(TieOnSummaryDto t) => new()
    {
        RowKey          = $"T{t.Id}",
        IsTieOn         = true,
        Id              = t.Id,
        Depth           = t.Depth,
        Inclination     = t.Inclination,
        Azimuth         = t.Azimuth,
        VerticalDepth   = t.VerticalReference,
        SubSea          = t.SubSeaReference,
        North           = 0,
        East            = 0,
        DoglegSeverity  = 0,
        VerticalSection = 0,
        Northing        = t.Northing,
        Easting         = t.Easting,
        Build           = 0,
        Turn            = 0,
        RowVersion      = t.RowVersion,
    };

    private static GridRow MapSurvey(SurveySummaryDto s) => new()
    {
        RowKey          = $"S{s.Id}",
        IsTieOn         = false,
        Id              = s.Id,
        Depth           = s.Depth,
        Inclination     = s.Inclination,
        Azimuth         = s.Azimuth,
        VerticalDepth   = s.VerticalDepth,
        SubSea          = s.SubSea,
        North           = s.North,
        East            = s.East,
        DoglegSeverity  = s.DoglegSeverity,
        VerticalSection = s.VerticalSection,
        Northing        = s.Northing,
        Easting         = s.Easting,
        Build           = s.Build,
        Turn            = s.Turn,
        RowVersion      = s.RowVersion,
    };

    /// <summary>
    /// Unified row shape for the surveys grid — tie-on and survey rows
    /// share the same column set. <see cref="IsTieOn"/> drives the
    /// row-level edit-cancel in <see cref="OnActionBegin"/>;
    /// <see cref="RowKey"/> is Syncfusion's primary key (both the tie-on
    /// and the surveys carry int <see cref="Id"/> values from different
    /// tables, so the prefix avoids collisions).
    ///
    /// Settable rather than init-only because Syncfusion's edit
    /// machinery — and our own <c>&lt;UnitInput @bind-SiValue=...&gt;</c>
    /// inside <c>&lt;EditTemplate&gt;</c> — write into the row in place
    /// while the user is editing, then OnActionCompleteAsync reads the
    /// updated values back to build the UpdateTieOnDto.
    /// </summary>
    public sealed class GridRow
    {
        public string  RowKey         { get; set; } = "";
        public bool    IsTieOn        { get; set; }
        public int     Id             { get; set; }
        public double  Depth          { get; set; }
        public double  Inclination    { get; set; }
        public double  Azimuth        { get; set; }
        public double  VerticalDepth  { get; set; }
        public double  SubSea         { get; set; }
        public double  North          { get; set; }
        public double  East           { get; set; }
        public double  DoglegSeverity { get; set; }
        public double  VerticalSection{ get; set; }
        public double  Northing       { get; set; }
        public double  Easting        { get; set; }
        public double  Build          { get; set; }
        public double  Turn           { get; set; }

        /// <summary>
        /// Optimistic-concurrency token for the underlying entity (tie-on
        /// or survey). Round-tripped on inline-edit save so a concurrent
        /// edit of the same row by another user 409s rather than silently
        /// overwriting.
        /// </summary>
        public string? RowVersion     { get; set; }
    }
}
