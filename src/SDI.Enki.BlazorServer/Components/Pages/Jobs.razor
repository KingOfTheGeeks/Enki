@page "/tenants/{TenantCode}/jobs"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@inject SDI.Enki.BlazorServer.Auth.IUserCapabilities Capabilities
@using SDI.Enki.BlazorServer.Api

<PageTitle>Enki &mdash; @TenantCode Jobs</PageTitle>

<div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; flex-wrap: wrap;">
    <div style="flex: 1; min-width: 280px;">
        <h1 class="enki-section-title">
            Jobs
            <span class="enki-mono" style="font-size: 0.65em; opacity: 0.65; margin-left: 0.5rem;">
                @TenantCode
            </span>
        </h1>
        <p class="enki-section-subtitle">
            Drilling projects scoped to this tenant. Each Job owns Runs, Wells,
            and the survey data that rolls up from them. Region is per-job — a
            tenant may operate across many.
        </p>
    </div>
    <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
        <NavLink class="enki-button" href="/tenants">Back to tenants</NavLink>
        @* "+ New job" requires write access to tenant content (Office+
           tenant member or admin). Field tenant members and Tenant-type
           users see the list but can't add jobs. *@
        @if (_canWrite)
        {
            <NavLink class="enki-button enki-button-primary" href="@($"/tenants/{TenantCode}/jobs/new")">
                + New job
            </NavLink>
        }
    </div>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_jobs is null)
{
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Fetching jobs from API&hellip;</div>
    </div>
}
else
{
    <div class="enki-stat-grid">
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_jobs.Count.ToString("D2")</div>
            <div class="enki-stat-label">Jobs</div>
        </div>
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_jobs.Count(j => j.Status == "Active").ToString("D2")</div>
            <div class="enki-stat-label">Active</div>
        </div>
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_jobs.Count(j => j.Status == "Draft").ToString("D2")</div>
            <div class="enki-stat-label">Draft</div>
        </div>
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_jobs.Count(j => j.Status == "Archived").ToString("D2")</div>
            <div class="enki-stat-label">Archived</div>
        </div>
    </div>

    <EnkiListGrid TValue="JobSummaryDto"
                  DataSource="_jobs"
                  ElasticField="@nameof(JobSummaryDto.Name)">
        @* Full Guid Id intentionally not rendered — the Name column is the
           human-facing identifier, the Id just carries deep-link state.
           MinWidth keeps the elastic Name column from collapsing on
           narrow viewports. *@
        <GridColumn Field="@nameof(JobSummaryDto.Name)" HeaderText="Name" MinWidth="200">
            <Template>
                @{ var row = context as JobSummaryDto; }
                @if (row is not null)
                {
                    <a class="enki-row-link"
                       href="@($"/tenants/{TenantCode}/jobs/{row.Id}")">@row.Name</a>
                }
            </Template>
        </GridColumn>
        <GridColumn Field="@nameof(JobSummaryDto.WellName)" HeaderText="Well" />
        <GridColumn Field="@nameof(JobSummaryDto.Region)" HeaderText="Region" />
        <GridColumn Field="@nameof(JobSummaryDto.UnitSystem)" HeaderText="Units" />
        <GridColumn Field="@nameof(JobSummaryDto.Status)" HeaderText="Status">
            <Template>
                @{ var row = context as JobSummaryDto; }
                @if (row is not null)
                {
                    <span class="enki-status-pill @StatusClass(row.Status)">@row.Status</span>
                }
            </Template>
        </GridColumn>
        <GridColumn Field="@nameof(JobSummaryDto.StartTimestamp)"
                    HeaderText="Start"
                    Format="yyyy-MM-dd" Type="ColumnType.DateTime" />
    </EnkiListGrid>
}

@code {
    [Parameter] public string TenantCode { get; set; } = "";

    private List<JobSummaryDto>? _jobs;
    private string? _error;
    private bool _canWrite;

    protected override async Task OnInitializedAsync()
    {
        var client = HttpClientFactory.CreateClient("EnkiApi");
        var result = await client.GetAsync<List<JobSummaryDto>>(
            $"tenants/{TenantCode}/jobs");

        if (!result.IsSuccess) { _error = result.Error.AsAlertText(); return; }
        _jobs = result.Value;

        // Tenant-scoped write capability — used to gate the "+ New job"
        // button. Membership probe is cached per-circuit; cheap on
        // subsequent navigations.
        _canWrite = await Capabilities.CanWriteTenantContentAsync(TenantCode);
    }

    private static string StatusClass(string s) => s switch
    {
        "Draft"     => "enki-status-inactive",
        "Active"    => "enki-status-active",
        "Completed" => "enki-status-active",
        "Archived"  => "enki-status-archived",
        _           => "",
    };
}
