@page "/tenants/{TenantCode}/jobs/{JobId:guid}"
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@inject SDI.Enki.BlazorServer.Auth.IUserCapabilities Capabilities
@using SDI.Enki.BlazorServer.Api
@using SDI.Enki.BlazorServer.Components.Audit
@using SDI.Enki.Core.TenantDb.Jobs
@using SDI.Enki.Core.TenantDb.Jobs.Enums

<PageTitle>Enki &mdash; Job @ShortId (@TenantCode)</PageTitle>

@if (_error is not null)
{
    <PageHeader Title="@($"Job {ShortId}")">
        <Actions>
            <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs")">Back to jobs</NavLink>
        </Actions>
    </PageHeader>
    <div class="alert alert-danger">@_error</div>
}
else if (_job is null)
{
    <PageHeader Title="@($"Job {ShortId}")">
        <Actions>
            <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs")">Back to jobs</NavLink>
        </Actions>
    </PageHeader>
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Loading job&hellip;</div>
    </div>
}
else
{
    var currentStatus = ParseStatus(_job.Status);
    var availableTransitions = currentStatus is null
        ? Array.Empty<JobStatus>()
        : JobLifecycle.TargetsFor(currentStatus);
    var isEditable = _job.Status != JobStatus.Archived.Name;

    <PageHeader Title="@_job.Name">
        <TitleSuffix>
            <span class="enki-status-pill @StatusClass(_job.Status)">@_job.Status</span>
        </TitleSuffix>
        <Subtitle>
            <span class="enki-mono">@TenantCode</span> &middot;
            <span class="enki-mono">@_job.Id</span>
        </Subtitle>
        <Actions>
            <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs")">Back to jobs</NavLink>

            @* Lifecycle transitions and Edit are tenant-content writes
               (Office+ tenant member or admin). Hidden for Field and
               Tenant users — they can browse but not change job state. *@
            @if (_canWrite)
            {
                @* Lifecycle buttons driven by JobLifecycle.AllowedTransitions.
                   Adding a new status to the map means a new button renders here
                   automatically — no changes to this template required. *@
                @foreach (var target in availableTransitions)
                {
                    <form method="post"
                          action="@($"/tenants/{TenantCode}/jobs/{_job.Id}/{TransitionAction(currentStatus, target)}")"
                          style="display:inline">
                        <AntiforgeryToken />
                        @* RowVersion pins the optimistic-concurrency check on the
                           WebApi side; see LifecycleTransitionDto. *@
                        <input type="hidden" name="rowVersion" value="@_job.RowVersion" />
                        <button type="submit"
                                class="enki-button @TransitionButtonClass(currentStatus, target)"
                                onclick="@TransitionConfirm(currentStatus, target, _job.Name)">
                            @TransitionLabel(currentStatus, target)
                        </button>
                    </form>
                }

                @if (isEditable)
                {
                    <NavLink class="enki-button enki-button-primary"
                             href="@($"/tenants/{TenantCode}/jobs/{_job.Id}/edit")">
                        Edit
                    </NavLink>
                }
            }
        </Actions>
    </PageHeader>

    @if (!isEditable && availableTransitions.Count == 0)
    {
        <p class="enki-form-hint" style="margin-top: -0.5rem;">
            Archived jobs are read-only.
        </p>
    }

    @if (_statusError is not null)
    {
        <div class="alert alert-danger">@_statusError</div>
    }

    <div class="enki-detail-grid">
        <div class="enki-detail-label">Name</div>
        <div class="enki-detail-value">@_job.Name</div>

        <div class="enki-detail-label">Description</div>
        <div class="enki-detail-value @DashClass(_job.Description)">@Dashed(_job.Description)</div>

        <div class="enki-detail-label">Well</div>
        <div class="enki-detail-value @DashClass(_job.WellName)">@Dashed(_job.WellName)</div>

        <div class="enki-detail-label">Region</div>
        <div class="enki-detail-value @DashClass(_job.Region)">@Dashed(_job.Region)</div>

        <div class="enki-detail-label">Unit system</div>
        <div class="enki-detail-value">@_job.UnitSystem</div>

        <div class="enki-detail-label">Status</div>
        <div class="enki-detail-value">@_job.Status</div>

        <div class="enki-detail-label">Created</div>
        <div class="enki-detail-value">
            @_job.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
            @if (!string.IsNullOrWhiteSpace(_job.CreatedBy))
            {
                <span class="enki-form-hint" style="margin-left: 0.5rem;">by @_job.CreatedBy</span>
            }
        </div>

        @if (_job.UpdatedAt is { } updated)
        {
            <div class="enki-detail-label">Updated</div>
            <div class="enki-detail-value">
                @updated.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                @if (!string.IsNullOrWhiteSpace(_job.UpdatedBy))
                {
                    <span class="enki-form-hint" style="margin-left: 0.5rem;">by @_job.UpdatedBy</span>
                }
            </div>
        }

        @* Start / End are calendar dates, not timestamps. Render the
           offset's underlying date directly — projecting through
           .ToLocalTime() drifts the day for any viewer not in UTC
           (a stored 2026-05-03T00:00:00Z reads as 2026-05-02 in
           UTC-6) and pairs with the JobEdit save path to drift the
           stored value down a day on every round-trip. CreatedAt /
           UpdatedAt above stay localised because those ARE
           timestamps with meaningful time-of-day. *@
        <div class="enki-detail-label">Start</div>
        <div class="enki-detail-value">
            @_job.StartTimestamp.ToString("yyyy-MM-dd")
        </div>

        <div class="enki-detail-label">End</div>
        <div class="enki-detail-value">
            @_job.EndTimestamp.ToString("yyyy-MM-dd")
        </div>

        <div class="enki-detail-label">Logo</div>
        <div class="enki-detail-value @DashClass(_job.LogoName)">@Dashed(_job.LogoName)</div>
    </div>

    <h2 class="enki-section-title" style="margin-top: 2rem; font-size: 1.25rem;">Data</h2>
    <p class="enki-section-subtitle">
        Wellbores and operational runs under this Job. Wells own
        surveys / tie-ons / tubulars / formations / common measures;
        runs own logs and the run-type-specific processing.
    </p>
    <div class="enki-stat-grid">
        <a class="enki-stat-card enki-link-card"
           href="@($"/tenants/{TenantCode}/jobs/{_job.Id}/wells")">
            <div class="enki-stat-value">@_job.WellCount.ToString("D2")</div>
            <div class="enki-stat-label">Wells</div>
        </a>
        @* Runs broken out by type so the user sees meaningful per-type
           counts at a glance. Each tile click-throughs to the unified
           Runs grid pre-filtered to that type via ?type= query param;
           the grid already has all-types stat-tiles at the top so the
           user can pivot back to "all runs" inline. *@
        <a class="enki-stat-card enki-link-card"
           href="@($"/tenants/{TenantCode}/jobs/{_job.Id}/runs?type=Gradient")">
            <div class="enki-stat-value">@_job.GradientRunCount.ToString("D2")</div>
            <div class="enki-stat-label">Gradient runs</div>
        </a>
        <a class="enki-stat-card enki-link-card"
           href="@($"/tenants/{TenantCode}/jobs/{_job.Id}/runs?type=Rotary")">
            <div class="enki-stat-value">@_job.RotaryRunCount.ToString("D2")</div>
            <div class="enki-stat-label">Rotary runs</div>
        </a>
        <a class="enki-stat-card enki-link-card"
           href="@($"/tenants/{TenantCode}/jobs/{_job.Id}/runs?type=Passive")">
            <div class="enki-stat-value">@_job.PassiveRunCount.ToString("D2")</div>
            <div class="enki-stat-label">Passive runs</div>
        </a>
    </div>
    <div class="enki-form-actions" style="border-top: none; margin-top: 0.5rem; padding-top: 0;">
        <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{_job.Id}/runs")">
            All runs
        </NavLink>
    </div>

    <AuditHistoryTile TenantCode="@TenantCode"
                      EntityType="Job"
                      EntityId="@_job.Id.ToString()"
                      FriendlyEntityName="job" />
}

@code {
    [Parameter] public string TenantCode { get; set; } = "";
    [Parameter] public Guid   JobId      { get; set; }

    [SupplyParameterFromQuery] public string? StatusError { get; set; }

    private JobDetailDto? _job;
    private string? _error;
    private string? _statusError;
    private bool _canWrite;

    /// <summary>
    /// First 8 chars of the Guid — long enough to disambiguate in a
    /// heading, short enough not to dominate the page. Full Id shows in
    /// the subtitle for copy/paste.
    /// </summary>
    private string ShortId => JobId.ToString("N")[..8];

    protected override async Task OnInitializedAsync()
    {
        _statusError = StatusError;
        var client = HttpClientFactory.CreateClient("EnkiApi");
        var result = await client.GetAsync<JobDetailDto>($"tenants/{TenantCode}/jobs/{JobId}");

        if (!result.IsSuccess)
        {
            _error = result.Error.Kind == ApiErrorKind.NotFound
                ? $"Job {ShortId} not found in tenant {TenantCode}."
                : result.Error.AsAlertText();
            return;
        }
        _job = result.Value;

        _canWrite = await Capabilities.CanWriteTenantContentAsync(TenantCode);
    }

    private static string Dashed(string? s) => string.IsNullOrWhiteSpace(s) ? "—" : s;
    private static string DashClass(string? s) => string.IsNullOrWhiteSpace(s) ? "enki-dash" : "";
    private static string StatusClass(string s) => s switch
    {
        "Draft"    => "enki-status-inactive",
        "Active"   => "enki-status-active",
        "Archived" => "enki-status-archived",
        _          => "",
    };

    /// <summary>
    /// Maps the DTO's string status back to the SmartEnum so we can feed
    /// <see cref="JobLifecycle.TargetsFor"/>. Null for unrecognised
    /// statuses (shouldn't happen; means Core + API drifted).
    /// </summary>
    private static JobStatus? ParseStatus(string name) =>
        JobStatus.List.FirstOrDefault(s =>
            string.Equals(s.Name, name, StringComparison.OrdinalIgnoreCase));

    /// <summary>
    /// Button styling per (from, to) transition. Switching on the pair
    /// (not just the target) lets us style Restore (Archived→Active)
    /// differently from Activate (Draft→Active) — Restore is the same
    /// reversal action as Tenant's Reactivate, hence neutral styling
    /// rather than the "this is the primary path forward" primary blue.
    /// </summary>
    private static string TransitionButtonClass(JobStatus? from, JobStatus target) =>
        (from?.Name, target.Name) switch
        {
            (_,         "Archived") => "enki-button-danger",
            ("Archived", "Active")  => "",                    // Restore — neutral, mirrors Tenant Reactivate
            (_,         "Active")   => "enki-button-primary", // Activate (from Draft)
            _                       => "",
        };

    /// <summary>Inline JS confirm for destructive / scary transitions only.</summary>
    private static string TransitionConfirm(JobStatus? from, JobStatus target, string jobName) =>
        (from?.Name, target.Name) switch
        {
            (_, "Archived") => $"return confirm('Archive job {jobName}? Archived jobs become read-only until restored.');",
            _               => "",
        };

    /// <summary>
    /// Imperative verb for the button face — we're writing a command,
    /// not a status. Switches on (from, to) so Archived→Active reads as
    /// "Restore" (matches Tenant's Reactivate idiom), distinct from
    /// "Activate" (Draft→Active).
    /// </summary>
    private static string TransitionLabel(JobStatus? from, JobStatus target) =>
        (from?.Name, target.Name) switch
        {
            ("Archived", "Active") => "Restore",
            (_,          "Active") => "Activate",
            (_, "Archived")        => "Archive",
            _                      => target.Name,
        };

    /// <summary>
    /// URL segment for the lifecycle endpoint — must match the verb
    /// baked into the BlazorServer MapPost route regex and the WebApi
    /// <c>JobsController</c> route templates (<c>activate</c>,
    /// <c>archive</c>, <c>restore</c>). Restore is its own URL so audit
    /// rows carry the right verb in deploy / ops logs. Extend this
    /// switch and the regex in Program.cs when a new transition ships.
    /// </summary>
    private static string TransitionAction(JobStatus? from, JobStatus target) =>
        (from?.Name, target.Name) switch
        {
            ("Archived", "Active") => "restore",
            (_,          "Active") => "activate",
            (_, "Archived")        => "archive",
            _                      => target.Name.ToLowerInvariant(),
        };
}
