@page "/tenants/{Code}/members"
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@using System.Net.Http.Json
@using SDI.Enki.Shared.Tenants

<PageTitle>Enki &mdash; @Code Members</PageTitle>

<h1 class="enki-section-title">
    Members
    <span class="enki-mono" style="font-size: 0.65em; opacity: 0.65; margin-left: 0.5rem;">@Code</span>
</h1>
<p class="enki-section-subtitle">
    Who can access this tenant's data and at what role. Tenant Admins
    and SDI system admins can add or remove members; Contributors and
    Viewers are read-only on this page.
</p>

@if (_listError is not null)
{
    <div class="alert alert-danger">@_listError</div>
}
@if (_actionError is not null)
{
    <div class="alert alert-danger">@_actionError</div>
}

@if (_members is null && _listError is null)
{
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Loading members&hellip;</div>
    </div>
}
else if (_members is not null)
{
    <SfGrid DataSource="_members"
            AllowSorting="true"
            AllowFiltering="true"
            AllowResizing="true"
            Height="auto">
        <GridColumns>
            <GridColumn Field="@nameof(TenantMemberDto.Username)" HeaderText="User" />
            <GridColumn Field="@nameof(TenantMemberDto.Role)" HeaderText="Role" Width="160">
                <Template>
                    @{ var row = context as TenantMemberDto; }
                    @if (row is not null)
                    {
                        <select class="enki-form-input" style="padding: 0.25rem 0.5rem;"
                                @onchange="@(e => ChangeRoleAsync(row.UserId, (string)e.Value!))">
                            @foreach (var role in Roles)
                            {
                                <option value="@role" selected="@(role == row.Role)">@role</option>
                            }
                        </select>
                    }
                </Template>
            </GridColumn>
            <GridColumn Field="@nameof(TenantMemberDto.GrantedAt)" HeaderText="Since" Width="180"
                        Format="yyyy-MM-dd" Type="ColumnType.DateTime" />
            <GridColumn HeaderText="" Width="120">
                <Template>
                    @{ var row = context as TenantMemberDto; }
                    @if (row is not null)
                    {
                        <button class="enki-button enki-button-danger"
                                style="padding: 0.25rem 0.75rem; font-size: 0.85rem;"
                                @onclick="() => RemoveAsync(row.UserId, row.Username)">
                            Remove
                        </button>
                    }
                </Template>
            </GridColumn>
        </GridColumns>
    </SfGrid>

    <div class="enki-card" style="max-width: 620px; margin-top: 1.5rem;">
        <h2 class="enki-section-title" style="font-size: 1rem;">Add member</h2>
        <p class="enki-section-subtitle">
            Pick a user from the SDI roster and assign their role in this tenant.
        </p>

        <div class="enki-form-group">
            <label class="enki-form-label">User</label>
            <select class="enki-form-input" @bind="_newUserId">
                <option value="">— Select a user —</option>
                @foreach (var user in CandidateUsers)
                {
                    <option value="@user.UserId">@user.Username</option>
                }
            </select>
        </div>

        <div class="enki-form-group">
            <label class="enki-form-label">Role</label>
            <select class="enki-form-input" @bind="_newRole">
                @foreach (var role in Roles)
                {
                    <option value="@role">@role</option>
                }
            </select>
        </div>

        <div class="enki-form-actions">
            <button class="enki-button enki-button-primary" @onclick="AddAsync"
                    disabled="@(string.IsNullOrEmpty(_newUserId) || _busy)">
                Add member
            </button>
            <NavLink class="enki-button" href="@($"tenants/{Code}")">Back to tenant</NavLink>
        </div>
    </div>
}

@code {
    [Parameter] public string Code { get; set; } = "";

    private static readonly string[] Roles = ["Admin", "Contributor", "Viewer"];

    private List<TenantMemberDto>? _members;
    private List<MasterUserSummaryDto> _allUsers = new();
    private string? _listError;
    private string? _actionError;
    private string  _newUserId = "";
    private string  _newRole   = "Contributor";
    private bool    _busy;

    private IEnumerable<MasterUserSummaryDto> CandidateUsers =>
        _members is null
            ? _allUsers
            : _allUsers.Where(u => !_members.Any(m => m.UserId == u.UserId));

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("EnkiApi");
            _members  = await client.GetFromJsonAsync<List<TenantMemberDto>>($"tenants/{Code}/members") ?? new();
            _allUsers = await client.GetFromJsonAsync<List<MasterUserSummaryDto>>("admin/master-users") ?? new();
        }
        catch (HttpRequestException ex) { _listError = $"WebApi call failed: {ex.Message}"; }
        catch (Exception ex)             { _listError = $"Unexpected error: {ex.Message}"; }
    }

    private async Task AddAsync()
    {
        if (_busy || string.IsNullOrEmpty(_newUserId)) return;
        _busy = true; _actionError = null;
        try
        {
            var client = HttpClientFactory.CreateClient("EnkiApi");
            var dto = new AddTenantMemberDto(Guid.Parse(_newUserId), _newRole);
            using var resp = await client.PostAsJsonAsync($"tenants/{Code}/members", dto);
            if (!resp.IsSuccessStatusCode)
            {
                _actionError = $"Add failed: {(int)resp.StatusCode} {await resp.Content.ReadAsStringAsync()}";
                return;
            }
            _newUserId = "";
            await LoadAsync();
        }
        catch (Exception ex) { _actionError = $"Unexpected error: {ex.Message}"; }
        finally { _busy = false; }
    }

    private async Task RemoveAsync(Guid userId, string username)
    {
        if (_busy) return;
        _busy = true; _actionError = null;
        try
        {
            var client = HttpClientFactory.CreateClient("EnkiApi");
            using var resp = await client.DeleteAsync($"tenants/{Code}/members/{userId}");
            if (!resp.IsSuccessStatusCode)
            {
                _actionError = $"Remove '{username}' failed: {(int)resp.StatusCode} {await resp.Content.ReadAsStringAsync()}";
                return;
            }
            await LoadAsync();
        }
        catch (Exception ex) { _actionError = $"Unexpected error: {ex.Message}"; }
        finally { _busy = false; }
    }

    private async Task ChangeRoleAsync(Guid userId, string newRole)
    {
        if (_busy) return;
        _busy = true; _actionError = null;
        try
        {
            var client = HttpClientFactory.CreateClient("EnkiApi");
            using var resp = await client.PatchAsJsonAsync(
                $"tenants/{Code}/members/{userId}",
                new SetTenantMemberRoleDto(newRole));
            if (!resp.IsSuccessStatusCode)
            {
                _actionError = $"Role change failed: {(int)resp.StatusCode} {await resp.Content.ReadAsStringAsync()}";
                await LoadAsync();   // pull fresh state — UI dropdown may have moved off-server
                return;
            }
            await LoadAsync();
        }
        catch (Exception ex) { _actionError = $"Unexpected error: {ex.Message}"; }
        finally { _busy = false; }
    }
}
