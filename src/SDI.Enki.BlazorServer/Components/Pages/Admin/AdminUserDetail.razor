@rendermode InteractiveServer
@using SDI.Enki.Shared.Identity

<PageTitle>Enki &mdash; Admin / @(_user?.UserName ?? Id)</PageTitle>

@if (_loadError is not null)
{
    <PageHeader Title="User">
        <Actions>
            <NavLink class="enki-button" href="admin/users">Back to users</NavLink>
        </Actions>
    </PageHeader>
    <div class="alert alert-danger">@_loadError</div>
}
else if (_user is null)
{
    <PageHeader Title="User">
        <Actions>
            <NavLink class="enki-button" href="admin/users">Back to users</NavLink>
        </Actions>
    </PageHeader>
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Loading user&hellip;</div>
    </div>
}
else
{
    <PageHeader Title="@_user.DisplayName">
        <TitleSuffix>
            @if (_user.IsEnkiAdmin)
            {
                <span class="enki-status-pill enki-status-active">admin</span>
            }
            @if (_user.IsLockedOut)
            {
                <span class="enki-status-pill enki-status-archived">locked</span>
            }
        </TitleSuffix>
        <Subtitle>
            <span class="enki-mono">@_user.UserName</span>
        </Subtitle>
        <Actions>
            <NavLink class="enki-button" href="admin/users">Back to users</NavLink>
            <button class="enki-button" @onclick="ResetPasswordAsync" disabled="@_busy">
                Reset password
            </button>
            @if (_user.IsLockedOut)
            {
                <button class="enki-button" @onclick="UnlockAsync" disabled="@_busy">
                    Unlock account
                </button>
            }
            else
            {
                <button class="enki-button enki-button-danger" @onclick="LockAsync" disabled="@_busy">
                    Lock account
                </button>
            }
            @if (_user.IsEnkiAdmin)
            {
                <button class="enki-button" @onclick="() => SetAdminAsync(false)" disabled="@_busy">
                    Revoke admin role
                </button>
            }
            else
            {
                <button class="enki-button enki-button-primary" @onclick="() => SetAdminAsync(true)" disabled="@_busy">
                    Grant admin role
                </button>
            }
        </Actions>
    </PageHeader>

    @if (_actionError is not null)
    {
        <div class="alert alert-danger">@_actionError</div>
    }
    @if (_temporaryPassword is not null)
    {
        <div class="alert alert-warning">
            <strong>Temporary password set:</strong>
            <code class="enki-mono" style="font-size: 1.05rem;">@_temporaryPassword</code><br/>
            <span class="enki-form-hint">
                Hand this to the user out-of-band. The user will need to change it on
                first sign-in. This page won't show it again — copy it now.
            </span>
        </div>
    }

    <h2 class="enki-section-title" style="font-size: 1rem;">Profile</h2>
    <p class="enki-section-subtitle">
        Identity profile + classification. <strong>UserType is immutable</strong> — switching
        Team↔Tenant requires creating a new account. <strong>Username</strong> is what the
        user types at login; tell them out-of-band before changing it.
    </p>

    @if (_profileError is not null)
    {
        <div class="alert alert-danger">@_profileError</div>
    }
    @if (_profileSavedAt is not null)
    {
        <div class="alert alert-success">Saved @_profileSavedAt.Value.ToLocalTime().ToString("HH:mm:ss").</div>
    }

    <div class="enki-card" style="max-width: 720px; margin-bottom: 1.5rem;">
        <div class="enki-form-group">
            <label class="enki-form-label required">Username</label>
            <input type="text" @bind="_editUserName" maxlength="256" class="enki-form-input" />
            <div class="enki-form-hint">
                Login name. Renaming changes how this user signs in — communicate before saving.
            </div>
        </div>
        <div class="enki-form-group">
            <label class="enki-form-label required">Email</label>
            <input type="email" @bind="_editEmail" maxlength="256" class="enki-form-input" />
        </div>
        <div class="enki-form-group" style="display: flex; gap: 0.75rem;">
            <div style="flex: 1;">
                <label class="enki-form-label">First name</label>
                <input type="text" @bind="_editFirstName" maxlength="100" class="enki-form-input" />
            </div>
            <div style="flex: 1;">
                <label class="enki-form-label">Last name</label>
                <input type="text" @bind="_editLastName" maxlength="100" class="enki-form-input" />
            </div>
        </div>

        <div class="enki-form-group">
            <label class="enki-form-label">User type</label>
            <div class="enki-mono">@(_user.UserType ?? "—") <span class="enki-form-hint">(immutable)</span></div>
        </div>

        @if (_user.UserType == "Team")
        {
            <div class="enki-form-group">
                <label class="enki-form-label required">Team subtype</label>
                <select class="enki-form-input" style="width: 14rem;" @bind="_editTeamSubtype">
                    <option value="Field">Field</option>
                    <option value="Office">Office</option>
                    <option value="Supervisor">Supervisor</option>
                </select>
            </div>
        }
        else if (_user.UserType == "Tenant")
        {
            <div class="enki-form-group">
                <label class="enki-form-label required">Tenant</label>
                <select class="enki-form-input" style="min-width: 18rem;" @bind="_editTenantIdString">
                    @if (_tenants is null)
                    {
                        <option value="">Loading tenants…</option>
                    }
                    else
                    {
                        @foreach (var t in _tenants)
                        {
                            <option value="@t.Id.ToString("D")">@t.Code — @t.Name</option>
                        }
                    }
                </select>
                <div class="enki-form-hint">
                    Move this Tenant user to a different tenant. Rotates the security stamp
                    so the user signs in fresh under the new binding.
                </div>
            </div>
        }

        <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
            <button class="enki-button enki-button-primary"
                    @onclick="SaveProfileAsync"
                    disabled="@(_busy || !IsProfileDirty())">
                Save profile
            </button>
            <button class="enki-button" @onclick="DiscardProfileEdits" disabled="@(_busy || !IsProfileDirty())">
                Discard
            </button>
        </div>
    </div>

    <h2 class="enki-section-title" style="font-size: 1rem;">Status</h2>
    <div class="enki-detail-grid">
        <div class="enki-detail-label">Display name</div>
        <div class="enki-detail-value">@_user.DisplayName</div>

        <div class="enki-detail-label">Admin role</div>
        <div class="enki-detail-value">@(_user.IsEnkiAdmin ? "Yes — enki-admin" : "No")</div>

        <div class="enki-detail-label">Lockout</div>
        <div class="enki-detail-value">
            @if (_user.IsLockedOut)
            {
                <text>Locked until @(_user.LockoutEnd?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "indefinitely")</text>
            }
            else
            {
                <text>Not locked</text>
            }
        </div>

        <div class="enki-detail-label">Failed sign-ins</div>
        <div class="enki-detail-value">@_user.AccessFailedCount</div>

        <div class="enki-detail-label">Session lifetime</div>
        <div class="enki-detail-value">
            @SessionLifetimeDisplay(_user.SessionLifetimeMinutes)
            @if (_user.SessionLifetimeUpdatedAt is { } sUpdAt)
            {
                <span class="enki-form-hint" style="margin-left: 0.5rem;">
                    set @sUpdAt.ToLocalTime().ToString("yyyy-MM-dd")
                    @if (!string.IsNullOrWhiteSpace(_user.SessionLifetimeUpdatedBy))
                    {
                        <text> by @_user.SessionLifetimeUpdatedBy</text>
                    }
                </span>
            }
        </div>
    </div>

    <h2 class="enki-section-title" style="font-size: 1rem; margin-top: 1.5rem;">Session lifetime</h2>
    <p class="enki-section-subtitle">
        Override how long a refresh token (and matching browser cookie) stays valid for this
        user. <strong>Default</strong> uses the global setting (1 hour access tokens with the
        configured refresh window). Selecting a longer value lets the user stay signed in
        for that long without being bounced to the login page; rotates the security stamp
        so any in-flight token under the previous policy is invalidated immediately.
    </p>
    <div class="enki-form-group" style="display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap;">
        <label class="enki-form-label" for="session-lifetime-select">Preset</label>
        <select id="session-lifetime-select"
                class="enki-form-input"
                style="width: 12rem;"
                @bind="_pendingPreset"
                @bind:after="OnPresetChanged">
            <option value="default">Default (1 hour)</option>
            <option value="480">8 hours</option>
            <option value="1440">24 hours</option>
            <option value="10080">7 days</option>
            <option value="43200">30 days</option>
            <option value="525600">1 year</option>
            <option value="custom">Custom (minutes)…</option>
        </select>
        @if (_pendingPreset == "custom")
        {
            <input type="number"
                   min="1"
                   max="525600"
                   step="1"
                   class="enki-form-input"
                   style="width: 8rem;"
                   placeholder="Minutes"
                   @bind="_pendingCustomMinutes" />
        }
        <button class="enki-button enki-button-primary"
                @onclick="ApplySessionLifetimeAsync"
                disabled="@(_busy || !IsPendingValueDifferent())">
            Apply
        </button>
    </div>

    @* Special permissions — capability claims granted to this user.
       Tenant users never see this section (capabilities are Team-side
       only); admin-only via the underlying endpoints. *@
    @if (_user.UserType == "Team")
    {
        <h2 class="enki-section-title" style="font-size: 1rem; margin-top: 1.5rem;">Special permissions</h2>
        <p class="enki-section-subtitle">
            Atomic capability grants. Toggling rotates the user's security stamp; the
            new permission set takes effect on their next refresh-token exchange.
        </p>

        @if (_capabilityError is not null)
        {
            <div class="alert alert-danger">@_capabilityError</div>
        }

        <div class="enki-card" style="max-width: 480px;">
            @foreach (var capability in EnkiCapabilities.All)
            {
                var held = _heldCapabilities.Contains(capability);
                <div class="enki-form-group" style="display: flex; align-items: center; gap: 0.5rem;">
                    <input type="checkbox"
                           id="@($"cap-{capability}")"
                           checked="@held"
                           disabled="@_busy"
                           @onchange="@(e => ToggleCapabilityAsync(capability, (bool)e.Value!))" />
                    <label for="@($"cap-{capability}")" style="cursor: pointer;">
                        <strong>@CapabilityDisplay(capability)</strong>
                        <span class="enki-form-hint" style="display: block;">@CapabilityHint(capability)</span>
                    </label>
                </div>
            }
        </div>
    }

    <UserActivityTile IdentityId="@_user.Id" UserName="@_user.UserName" />
}

