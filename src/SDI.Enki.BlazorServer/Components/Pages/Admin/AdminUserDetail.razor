@page "/admin/users/{Id}"
@layout AdminLayout
@attribute [Authorize(Roles = "enki-admin")]
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@using System.Net.Http
@using System.Net.Http.Json
@using SDI.Enki.Shared.Identity

<PageTitle>Enki &mdash; Admin / @(_user?.UserName ?? Id)</PageTitle>

@if (_loadError is not null)
{
    <h1 class="enki-section-title">User</h1>
    <div class="alert alert-danger">@_loadError</div>
    <div class="enki-form-actions" style="border-top: none; margin-top: 1rem; padding-top: 0;">
        <NavLink class="enki-button" href="admin/users">Back to users</NavLink>
    </div>
}
else if (_user is null)
{
    <h1 class="enki-section-title">User</h1>
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Loading user&hellip;</div>
    </div>
}
else
{
    <h1 class="enki-section-title">
        @_user.DisplayName
        @if (_user.IsEnkiAdmin)
        {
            <span class="enki-status-pill enki-status-active">admin</span>
        }
        @if (_user.IsLockedOut)
        {
            <span class="enki-status-pill enki-status-archived">locked</span>
        }
    </h1>
    <p class="enki-section-subtitle">
        <span class="enki-mono">@_user.UserName</span>
    </p>

    @if (_actionError is not null)
    {
        <div class="alert alert-danger">@_actionError</div>
    }
    @if (_temporaryPassword is not null)
    {
        <div class="alert alert-warning">
            <strong>Temporary password set:</strong>
            <code class="enki-mono" style="font-size: 1.05rem;">@_temporaryPassword</code><br/>
            <span class="enki-form-hint">
                Hand this to the user out-of-band. The user will need to change it on
                first sign-in. This page won't show it again — copy it now.
            </span>
        </div>
    }

    <div class="enki-detail-grid">
        <div class="enki-detail-label">User name</div>
        <div class="enki-detail-value">@_user.UserName</div>

        <div class="enki-detail-label">Display name</div>
        <div class="enki-detail-value">@_user.DisplayName</div>

        <div class="enki-detail-label">Email</div>
        <div class="enki-detail-value">@_user.Email</div>

        <div class="enki-detail-label">First name</div>
        <div class="enki-detail-value @DashClass(_user.FirstName)">@Dashed(_user.FirstName)</div>

        <div class="enki-detail-label">Last name</div>
        <div class="enki-detail-value @DashClass(_user.LastName)">@Dashed(_user.LastName)</div>

        <div class="enki-detail-label">Admin role</div>
        <div class="enki-detail-value">@(_user.IsEnkiAdmin ? "Yes — enki-admin" : "No")</div>

        <div class="enki-detail-label">Lockout</div>
        <div class="enki-detail-value">
            @if (_user.IsLockedOut)
            {
                <text>Locked until @(_user.LockoutEnd?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "indefinitely")</text>
            }
            else
            {
                <text>Not locked</text>
            }
        </div>

        <div class="enki-detail-label">Failed sign-ins</div>
        <div class="enki-detail-value">@_user.AccessFailedCount</div>
    </div>

    <div class="enki-form-actions">
        @if (_user.IsEnkiAdmin)
        {
            <button class="enki-button" @onclick="() => SetAdminAsync(false)" disabled="@_busy">
                Revoke admin role
            </button>
        }
        else
        {
            <button class="enki-button enki-button-primary" @onclick="() => SetAdminAsync(true)" disabled="@_busy">
                Grant admin role
            </button>
        }

        @if (_user.IsLockedOut)
        {
            <button class="enki-button" @onclick="UnlockAsync" disabled="@_busy">
                Unlock account
            </button>
        }
        else
        {
            <button class="enki-button enki-button-danger" @onclick="LockAsync" disabled="@_busy">
                Lock account
            </button>
        }

        <button class="enki-button" @onclick="ResetPasswordAsync" disabled="@_busy">
            Reset password
        </button>

        <NavLink class="enki-button" href="admin/users">Back to users</NavLink>
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = "";

    private AdminUserDetailDto? _user;
    private string? _loadError;
    private string? _actionError;
    private string? _temporaryPassword;
    private bool _busy;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("EnkiIdentity");
            using var resp = await client.GetAsync($"admin/users/{Id}");
            if (resp.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                _loadError = $"User '{Id}' not found.";
                return;
            }
            resp.EnsureSuccessStatusCode();
            _user = await resp.Content.ReadFromJsonAsync<AdminUserDetailDto>();
        }
        catch (HttpRequestException ex) { _loadError = $"Identity call failed: {ex.Message}"; }
        catch (Exception ex)             { _loadError = $"Unexpected error: {ex.Message}"; }
    }

    private async Task SetAdminAsync(bool isAdmin)
    {
        await PerformAsync(async client =>
            await client.PostAsJsonAsync($"admin/users/{Id}/admin", new SetAdminRoleDto(isAdmin)));
    }

    private async Task LockAsync() => await PerformAsync(async client =>
        await client.PostAsync($"admin/users/{Id}/lock", null));

    private async Task UnlockAsync() => await PerformAsync(async client =>
        await client.PostAsync($"admin/users/{Id}/unlock", null));

    private async Task ResetPasswordAsync()
    {
        if (_busy) return;
        _busy = true; _actionError = null;
        try
        {
            var client = HttpClientFactory.CreateClient("EnkiIdentity");
            using var resp = await client.PostAsync($"admin/users/{Id}/reset-password", null);
            if (!resp.IsSuccessStatusCode)
            {
                _actionError = $"Reset password failed: {(int)resp.StatusCode} {await resp.Content.ReadAsStringAsync()}";
                return;
            }
            var body = await resp.Content.ReadFromJsonAsync<ResetPasswordResponseDto>();
            _temporaryPassword = body?.TemporaryPassword;
            await LoadAsync();
        }
        catch (Exception ex) { _actionError = $"Unexpected error: {ex.Message}"; }
        finally { _busy = false; }
    }

    private async Task PerformAsync(Func<HttpClient, Task<HttpResponseMessage>> call)
    {
        if (_busy) return;
        _busy = true; _actionError = null; _temporaryPassword = null;
        try
        {
            var client = HttpClientFactory.CreateClient("EnkiIdentity");
            using var resp = await call(client);
            if (!resp.IsSuccessStatusCode)
            {
                _actionError = $"Action failed: {(int)resp.StatusCode} {await resp.Content.ReadAsStringAsync()}";
                return;
            }
            await LoadAsync();
        }
        catch (Exception ex) { _actionError = $"Unexpected error: {ex.Message}"; }
        finally { _busy = false; }
    }

    private static string Dashed(string? s) => string.IsNullOrWhiteSpace(s) ? "—" : s;
    private static string DashClass(string? s) => string.IsNullOrWhiteSpace(s) ? "enki-dash" : "";
}
