@rendermode InteractiveServer

<PageTitle>Enki &mdash; Admin / New user</PageTitle>

<PageHeader Title="New user">
    <Subtitle>Server generates the initial password. UserType chosen here is permanent.</Subtitle>
    <Actions>
        <NavLink class="enki-button" href="admin/users">Back to users</NavLink>
    </Actions>
</PageHeader>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

@if (_temporaryPassword is not null && _createdId is not null)
{
    <div class="alert alert-warning">
        <strong>User created.</strong> Temporary password (shown once):
        <code class="enki-mono" style="font-size: 1.05rem;">@_temporaryPassword</code><br/>
        <span class="enki-form-hint">
            Hand this to the user out-of-band. The user will need to change it on first sign-in.
            This page won't show it again — copy it now, then
            <NavLink href="@($"admin/users/{_createdId}")">view the created user →</NavLink>
        </span>
    </div>

    @if (_masterSyncFailed)
    {
        <div class="alert alert-danger">
            <strong>Master record sync failed.</strong> The Identity user exists and can sign in,
            but the master-DB User row wasn't created — admins can't grant tenant memberships
            until you retry. Error: @_masterSyncError
            <div style="margin-top: 0.5rem;">
                <button class="enki-button" @onclick="RetryMasterSyncAsync" disabled="@_busy">
                    Retry master sync
                </button>
            </div>
        </div>
    }
    else if (_masterUserId is not null)
    {
        <div class="alert alert-success">
            Master record synced (User.Id = <span class="enki-mono">@_masterUserId.Value.ToString("D")</span>).
            Ready to be added to tenant memberships.
        </div>
    }
}
else
{
    <div class="enki-card" style="max-width: 720px;">
        <h2 class="enki-section-title" style="font-size: 1rem;">Profile</h2>
        <div class="enki-form-group">
            <label class="enki-form-label required">Username</label>
            <input type="text" @bind="_userName" maxlength="256" class="enki-form-input"
                   placeholder="firstname.lastname" />
        </div>
        <div class="enki-form-group">
            <label class="enki-form-label required">Email</label>
            <input type="email" @bind="_email" maxlength="256" class="enki-form-input" />
        </div>
        <div class="enki-form-group" style="display: flex; gap: 0.75rem;">
            <div style="flex: 1;">
                <label class="enki-form-label">First name</label>
                <input type="text" @bind="_firstName" maxlength="100" class="enki-form-input" />
            </div>
            <div style="flex: 1;">
                <label class="enki-form-label">Last name</label>
                <input type="text" @bind="_lastName" maxlength="100" class="enki-form-input" />
            </div>
        </div>

        <h2 class="enki-section-title" style="font-size: 1rem; margin-top: 1.5rem;">Classification</h2>
        <p class="enki-section-subtitle">
            <strong>Permanent.</strong> Switching Team↔Tenant later requires creating a new account.
        </p>
        <div class="enki-form-group" style="display: flex; gap: 1.5rem;">
            @* Team radio is hidden for non-admin callers — Office can
               only provision Tenant-type users per the authorization
               redesign. The underlying API also enforces this; the UI
               just keeps the impossible option off the form. *@
            @if (Capabilities.IsAdmin)
            {
                <label>
                    <input type="radio" name="userType" value="Team"
                           checked="@(_userType == "Team")"
                           @onchange="@(() => SetUserType("Team"))" />
                    <strong>Team</strong>
                    <span class="enki-form-hint" style="display: block;">SDI internal — Field, Office, or Supervisor.</span>
                </label>
            }
            <label>
                <input type="radio" name="userType" value="Tenant"
                       checked="@(_userType == "Tenant")"
                       @onchange="@(() => SetUserType("Tenant"))" />
                <strong>Tenant</strong>
                <span class="enki-form-hint" style="display: block;">External customer — bound to one tenant.</span>
            </label>
        </div>

        @if (_userType == "Team")
        {
            <div class="enki-form-group">
                <label class="enki-form-label required">Team subtype</label>
                <select class="enki-form-input" style="width: 14rem;" @bind="_teamSubtype">
                    <option value="Field">Field</option>
                    <option value="Office">Office</option>
                    <option value="Supervisor">Supervisor</option>
                </select>
            </div>
        }
        else if (_userType == "Tenant")
        {
            <div class="enki-form-group">
                <label class="enki-form-label required">Tenant</label>
                <select class="enki-form-input" style="min-width: 18rem;" @bind="_tenantIdString">
                    @if (_tenants is null)
                    {
                        <option value="">Loading tenants…</option>
                    }
                    else
                    {
                        <option value="">Select a tenant…</option>
                        @foreach (var t in _tenants)
                        {
                            <option value="@t.Id.ToString("D")">@t.Code — @t.Name</option>
                        }
                    }
                </select>
            </div>
        }

        <div style="display: flex; gap: 0.5rem; margin-top: 1rem;">
            <button class="enki-button enki-button-primary" @onclick="CreateAsync"
                    disabled="@(_busy || !CanSubmit())">
                @(_busy ? "Creating…" : "Create user")
            </button>
            <NavLink class="enki-button" href="admin/users">Cancel</NavLink>
        </div>
    </div>
}

