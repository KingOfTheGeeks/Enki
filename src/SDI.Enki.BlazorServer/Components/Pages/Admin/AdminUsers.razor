@page "/admin/users"
@layout AdminLayout
@rendermode InteractiveServer
@attribute [Authorize(Roles = "enki-admin")]
@inject IHttpClientFactory HttpClientFactory
@using SDI.Enki.BlazorServer.Api
@using SDI.Enki.Shared.Identity
@using SDI.Enki.Shared.Paging

<PageTitle>Enki &mdash; Admin / Users</PageTitle>

<PageHeader Title="Users">
    <Subtitle>SDI Team accounts and external Tenant users. Click a username to edit profile + classification.</Subtitle>
    <Actions>
        <NavLink class="enki-button enki-button-primary" href="admin/users/new">+ New user</NavLink>
    </Actions>
</PageHeader>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_users is null)
{
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Loading users&hellip;</div>
    </div>
}
else
{
    <div class="enki-stat-grid">
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_total.ToString("D2")</div>
            <div class="enki-stat-label">Users</div>
        </div>
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_users.Count(u => u.IsEnkiAdmin).ToString("D2")</div>
            <div class="enki-stat-label">Admins (page)</div>
        </div>
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_users.Count(u => u.IsLockedOut).ToString("D2")</div>
            <div class="enki-stat-label">Locked (page)</div>
        </div>
    </div>

    @* Email is the elastic column — usernames are uniformly short
       (sdi-handle), email addresses vary widely. *@
    <EnkiListGrid TValue="AdminUserSummaryDto"
                  DataSource="_users"
                  ElasticField="@nameof(AdminUserSummaryDto.Email)">
        <GridColumn Field="@nameof(AdminUserSummaryDto.UserName)" HeaderText="Username">
            <Template>
                @{ var row = context as AdminUserSummaryDto; }
                @if (row is not null)
                {
                    <a class="enki-row-link" href="@($"/admin/users/{row.Id}")">@row.UserName</a>
                }
            </Template>
        </GridColumn>
        <GridColumn Field="@nameof(AdminUserSummaryDto.Email)" HeaderText="Email" MinWidth="240" />
        <GridColumn Field="@nameof(AdminUserSummaryDto.UserType)" HeaderText="Type">
            <Template>
                @{ var row = context as AdminUserSummaryDto; }
                @if (row is not null)
                {
                    <span class="enki-mono">@(row.UserType ?? "—")</span>
                }
            </Template>
        </GridColumn>
        <GridColumn HeaderText="Subtype / Tenant" MinWidth="160">
            <Template>
                @{ var row = context as AdminUserSummaryDto; }
                @if (row?.UserType == "Team")
                {
                    <text>@(row.TeamSubtype ?? "—")</text>
                }
                else if (row?.UserType == "Tenant" && row.TenantId is { } tid)
                {
                    <span class="enki-mono">@tid.ToString("D")[..8]</span>
                }
                else
                {
                    <text>—</text>
                }
            </Template>
        </GridColumn>
        <GridColumn Field="@nameof(AdminUserSummaryDto.IsEnkiAdmin)" HeaderText="Admin">
            <Template>
                @{ var row = context as AdminUserSummaryDto; }
                @if (row?.IsEnkiAdmin == true)
                {
                    <span class="enki-status-pill enki-status-active">admin</span>
                }
            </Template>
        </GridColumn>
        <GridColumn Field="@nameof(AdminUserSummaryDto.IsLockedOut)" HeaderText="Status">
            <Template>
                @{ var row = context as AdminUserSummaryDto; }
                @if (row?.IsLockedOut == true)
                {
                    <span class="enki-status-pill enki-status-archived">locked</span>
                }
                else
                {
                    <span class="enki-status-pill enki-status-active">active</span>
                }
            </Template>
        </GridColumn>
    </EnkiListGrid>
}

@code {
    // Single-page-fetch today (take=500 covers the small SDI roster).
    // Server-side virtual scroll wires straight onto PagedResult — slot
    // a Syncfusion DataAdaptor here when row counts grow.
    private List<AdminUserSummaryDto>? _users;
    private int _total;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var client = HttpClientFactory.CreateClient("EnkiIdentity");
        var result = await client.GetAsync<PagedResult<AdminUserSummaryDto>>(
            "admin/users?skip=0&take=500");

        if (!result.IsSuccess) { _error = result.Error.AsAlertText(); return; }
        _users = result.Value.Items.ToList();
        _total = result.Value.Total;
    }
}
