@page "/admin/settings"
@layout AdminLayout
@attribute [Authorize(Roles = "enki-admin")]
@inject IHttpClientFactory HttpClientFactory
@using System.Net.Http.Json
@using SDI.Enki.Shared.Settings

<PageTitle>Enki &mdash; Admin / Settings</PageTitle>

<h1 class="enki-section-title">System settings</h1>
<p class="enki-section-subtitle">
    App-wide configuration. Settings change scope is the entire
    deployment — not per-tenant or per-user.
</p>

@if (_listError is not null)
{
    <div class="alert alert-danger">@_listError</div>
}
@if (_actionError is not null)
{
    <div class="alert alert-danger">@_actionError</div>
}
@if (_savedKey is not null)
{
    <div class="alert alert-success">Saved <code>@_savedKey</code>.</div>
}

@if (_settings is null && _listError is null)
{
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Loading settings&hellip;</div>
    </div>
}
else if (_settings is not null)
{
    @foreach (var setting in _settings)
    {
        <div class="enki-card" style="max-width: 720px; margin-top: 1.25rem;">
            <h2 class="enki-section-title" style="font-size: 1rem;">
                @FriendlyName(setting.Key)
                <span class="enki-mono" style="font-size: 0.7em; opacity: 0.6; margin-left: 0.5rem;">@setting.Key</span>
            </h2>
            <p class="enki-section-subtitle">@FriendlyHelp(setting.Key)</p>

            <div class="enki-form-group">
                <textarea class="enki-form-textarea" rows="10"
                          @bind="_buffer[setting.Key]"></textarea>
            </div>

            <div class="enki-form-actions">
                <button class="enki-button enki-button-primary"
                        @onclick="() => SaveAsync(setting.Key)"
                        disabled="@_busy">
                    Save
                </button>
                @if (setting.UpdatedAt is { } u)
                {
                    <span class="enki-form-hint" style="margin-left: auto;">
                        Last updated @u.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                        @if (!string.IsNullOrWhiteSpace(setting.UpdatedBy))
                        {
                            <text>by @setting.UpdatedBy</text>
                        }
                    </span>
                }
            </div>
        </div>
    }
}

@code {
    private List<SystemSettingDto>? _settings;
    private readonly Dictionary<string, string> _buffer = new();
    private string? _listError;
    private string? _actionError;
    private string? _savedKey;
    private bool    _busy;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("EnkiApi");
            _settings = await client.GetFromJsonAsync<List<SystemSettingDto>>("admin/settings") ?? new();
            foreach (var s in _settings) _buffer[s.Key] = s.Value;
        }
        catch (HttpRequestException ex) { _listError = $"WebApi call failed: {ex.Message}"; }
        catch (Exception ex)             { _listError = $"Unexpected error: {ex.Message}"; }
    }

    private async Task SaveAsync(string key)
    {
        if (_busy) return;
        _busy = true; _actionError = null; _savedKey = null;
        try
        {
            var client = HttpClientFactory.CreateClient("EnkiApi");
            using var resp = await client.PutAsJsonAsync(
                $"admin/settings/{Uri.EscapeDataString(key)}",
                new SetSystemSettingDto(_buffer[key]));
            if (!resp.IsSuccessStatusCode)
            {
                _actionError = $"Save failed: {(int)resp.StatusCode} {await resp.Content.ReadAsStringAsync()}";
                return;
            }
            _savedKey = key;
            await LoadAsync();
        }
        catch (Exception ex) { _actionError = $"Unexpected error: {ex.Message}"; }
        finally { _busy = false; }
    }

    /// <summary>Hand-curated friendly labels per known key. Add as new keys ship.</summary>
    private static string FriendlyName(string key) => key switch
    {
        "Jobs:RegionSuggestions" => "Region suggestions",
        _                         => key,
    };

    private static string FriendlyHelp(string key) => key switch
    {
        "Jobs:RegionSuggestions" =>
            "One region per line. Drives the suggestion dropdown on the Job " +
            "create / edit pages. Users can still type a free-form value " +
            "that isn't in this list.",
        _ => "",
    };
}
