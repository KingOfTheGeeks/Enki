@rendermode InteractiveServer

<PageTitle>Enki &mdash; Admin / Settings</PageTitle>

<h1 class="enki-section-title">System settings</h1>
<p class="enki-section-subtitle">
    App-wide configuration. Settings change scope is the entire
    deployment — not per-tenant or per-user.
</p>

@if (_listError is not null)
{
    <div class="alert alert-danger">@_listError</div>
}
@if (_actionError is not null)
{
    <div class="alert alert-danger">@_actionError</div>
}
@if (_savedKey is not null)
{
    <div class="alert alert-success">Saved <code>@_savedKey</code>.</div>
}
@if (_resetKey is not null)
{
    <div class="alert alert-success">Reset <code>@_resetKey</code> to its default value.</div>
}

@if (_settings is null && _listError is null)
{
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Loading settings&hellip;</div>
    </div>
}
else if (_settings is not null)
{
    @foreach (var setting in _settings)
    {
        <div class="enki-card" style="max-width: 720px; margin-top: 1.25rem;">
            <h2 class="enki-section-title" style="font-size: 1rem;">
                @FriendlyName(setting.Key)
                <span class="enki-mono" style="font-size: 0.7em; opacity: 0.6; margin-left: 0.5rem;">@setting.Key</span>
            </h2>
            <p class="enki-section-subtitle">@FriendlyHelp(setting.Key)</p>

            <div class="enki-form-group">
                @if (IsMultiline(setting.Key))
                {
                    @* Multi-line list keys (e.g. region suggestions) — give
                       the textarea room to breathe so the operator can
                       see the full list without scrolling. *@
                    <textarea class="enki-form-textarea" rows="10"
                              @bind="_buffer[setting.Key]"></textarea>
                }
                else
                {
                    @* Single-value keys (numeric / bool / enum) — single-
                       line input keeps each card compact so all 12 settings
                       fit on the page without endless scrolling. *@
                    <input type="text" class="enki-form-input"
                           @bind="_buffer[setting.Key]" />
                }
            </div>

            <div class="enki-form-actions">
                <button class="enki-button enki-button-primary"
                        @onclick="() => SaveAsync(setting.Key)"
                        disabled="@_busy">
                    Save
                </button>
                <button class="enki-button"
                        @onclick="() => ResetAsync(setting.Key)"
                        disabled="@_busy"
                        title="Restore this setting to the value it shipped with.">
                    Reset to default
                </button>
                @if (setting.UpdatedAt is { } u)
                {
                    <span class="enki-form-hint" style="margin-left: auto;">
                        Last updated @u.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                        @if (!string.IsNullOrWhiteSpace(setting.UpdatedBy))
                        {
                            <text>by @setting.UpdatedBy</text>
                        }
                    </span>
                }
            </div>
        </div>
    }
}

@* Logic is in AdminSettings.razor.cs (partial class) — no @code block here. *@
