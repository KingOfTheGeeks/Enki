@rendermode InteractiveServer

@*
    Auth-events feed against /admin/audit/auth-events on the Identity
    host. Different shape from the audit feeds — no Old/New JSON;
    has IpAddress / UserAgent / Detail. Same paging + filter pattern.
*@

<PageTitle>Enki &mdash; Admin / Auth events</PageTitle>

<h1 class="enki-section-title">Auth events</h1>
<p class="enki-section-subtitle">
    Sign-ins, sign-outs, token issuance, lockouts. Every authentication
    attempt against the Identity host lands here — both successful and
    failed.
</p>

<DateRangeFilter From="_from" FromChanged="@(v => _from = v)"
                 To="_to"     ToChanged="@(v => _to = v)"
                 OnRangeChanged="ReloadAsync" />

<div class="enki-filter-row">
    <div class="enki-filter-group">
        <label class="enki-form-label" for="auth-event-type">Event type</label>
        <select id="auth-event-type" class="enki-form-select"
                value="@_eventType" @onchange="OnEventTypeChanged">
            <option value="">All</option>
            <option value="SignInSucceeded">SignInSucceeded</option>
            <option value="SignInFailed">SignInFailed</option>
            <option value="LockoutTriggered">LockoutTriggered</option>
            <option value="TokenIssued">TokenIssued</option>
            <option value="SignOut">SignOut</option>
        </select>
    </div>

    <div class="enki-filter-group">
        <label class="enki-form-label" for="auth-username">Username</label>
        <input id="auth-username" class="enki-form-input"
               value="@_username" @onchange="OnUsernameChanged"
               placeholder="exact match" />
    </div>

    <div class="enki-filter-group" style="align-self: flex-end;">
        <button class="enki-button" type="button" @onclick="ShowFailuresOnly">
            Failures only
        </button>
    </div>

    <div class="enki-filter-group" style="align-self: flex-end;">
        <CsvExportButton ClientName="EnkiIdentity"
                         Path="@CsvPath"
                         DownloadName="@CsvDownloadName" />
    </div>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_rows is null)
{
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Loading auth events&hellip;</div>
    </div>
}
else if (_rows.Count == 0)
{
    <p class="enki-form-hint">No auth events match the current filters.</p>
}
else
{
    <table class="enki-table" style="width: 100%;">
        <thead>
            <tr>
                <th style="width: 14rem;">When</th>
                <th style="width: 11rem;">Event</th>
                <th style="width: 12rem;">Username</th>
                <th style="width: 10rem;">IP</th>
                <th>User-Agent / Detail</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in _rows)
            {
                <tr>
                    <td class="enki-mono">@row.OccurredAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td><AuthEventTypeBadge EventType="@row.EventType" /></td>
                    <td class="enki-mono">@row.Username</td>
                    <td class="enki-mono">@(row.IpAddress ?? "—")</td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(row.Detail))
                        {
                            <div class="enki-mono" style="font-size: 0.75rem;">@row.Detail</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(row.UserAgent))
                        {
                            <div class="enki-form-hint" style="margin-top: 0.25rem;" title="@row.UserAgent">
                                @TruncateUa(row.UserAgent)
                            </div>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="enki-form-actions" style="justify-content: space-between; align-items: center; margin-top: 0.75rem;">
        <span class="enki-form-hint">
            Showing @(_skip + 1)–@(_skip + _rows.Count) of @_total
        </span>
        <span>
            <button class="enki-button" type="button"
                    disabled="@(!CanGoPrev)" @onclick="PrevPageAsync">‹ Previous</button>
            <button class="enki-button" type="button"
                    disabled="@(!CanGoNext)" @onclick="NextPageAsync">Next ›</button>
        </span>
    </div>
}

