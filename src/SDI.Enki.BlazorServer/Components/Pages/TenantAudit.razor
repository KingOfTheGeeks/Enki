@rendermode InteractiveServer

@*
    Tenant-wide audit feed. Sister of MasterAudit but pointed at
    /tenants/{code}/audit — covers every IAuditable mutation in the
    tenant DB (Job/Run/Well/Survey/Tubular/Formation/Magnetics/Shot/
    Log/CommonMeasure/TieOn). Tenant members can read; auth via
    [Authorize] which picks up the cookie. The server-side policy
    on /tenants/{code}/audit is CanAccessTenant.
*@

<PageTitle>Enki &mdash; @Code / Audit</PageTitle>

<h1 class="enki-section-title">
    Tenant audit
    <span class="enki-mono" style="font-size: 0.65em; opacity: 0.65; margin-left: 0.5rem;">@Code</span>
</h1>
<p class="enki-section-subtitle">
    Every recorded change inside this tenant — job/well/run/survey/etc.
    Newest first.
</p>

<DateRangeFilter From="_from" FromChanged="@(v => _from = v)"
                 To="_to"     ToChanged="@(v => _to = v)"
                 OnRangeChanged="ReloadAsync" />

<div class="enki-filter-row">
    <div class="enki-filter-group">
        <label class="enki-form-label" for="audit-entity-type">Entity type</label>
        <input id="audit-entity-type" class="enki-form-input"
               value="@_entityType" @onchange="OnEntityTypeChanged"
               placeholder="Survey / Well / Run / …" />
    </div>

    <div class="enki-filter-group">
        <label class="enki-form-label" for="audit-action">Action</label>
        <select id="audit-action" class="enki-form-select"
                value="@_action" @onchange="OnActionChanged">
            <option value="">All</option>
            <option value="Created">Created</option>
            <option value="Updated">Updated</option>
            <option value="Deleted">Deleted</option>
        </select>
    </div>

    <div class="enki-filter-group">
        <label class="enki-form-label" for="audit-changed-by">Changed by</label>
        <input id="audit-changed-by" class="enki-form-input"
               value="@_changedBy" @onchange="OnChangedByChanged"
               placeholder="actor sub or 'system'" />
    </div>

    <div class="enki-filter-group" style="align-self: flex-end;">
        <CsvExportButton ClientName="EnkiApi"
                         Path="@CsvPath"
                         DownloadName="@CsvDownloadName" />
    </div>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_rows is null)
{
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Loading audit feed&hellip;</div>
    </div>
}
else if (_rows.Count == 0)
{
    <p class="enki-form-hint">No tenant events match the current filters.</p>
}
else
{
    <table class="enki-table" style="width: 100%;">
        <thead>
            <tr>
                <th style="width: 14rem;">When</th>
                <th style="width: 9rem;">Action</th>
                <th style="width: 11rem;">Entity</th>
                <th>EntityId</th>
                <th style="width: 10rem;">By</th>
                <th>Changed</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in _rows)
            {
                <tr>
                    <td class="enki-mono">@row.ChangedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td><AuditActionBadge Action="@row.Action" /></td>
                    <td class="enki-mono">@row.EntityType</td>
                    <td class="enki-mono" style="word-break: break-all;">@row.EntityId</td>
                    <td class="enki-mono">@row.ChangedBy</td>
                    <td>
                        <ChangedColumnsChips Value="@row.ChangedColumns" Action="@row.Action" />
                        <div style="margin-top: 0.25rem;">
                            <JsonExpandableRow OldValues="@row.OldValues" NewValues="@row.NewValues" />
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="enki-form-actions" style="justify-content: space-between; align-items: center; margin-top: 0.75rem;">
        <span class="enki-form-hint">
            Showing @(_skip + 1)–@(_skip + _rows.Count) of @_total
        </span>
        <span>
            <button class="enki-button" type="button"
                    disabled="@(!CanGoPrev)" @onclick="PrevPageAsync">‹ Previous</button>
            <button class="enki-button" type="button"
                    disabled="@(!CanGoNext)" @onclick="NextPageAsync">Next ›</button>
        </span>
    </div>
}

