@page "/tools/{Serial:int}"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject SDI.Enki.BlazorServer.Auth.IUserCapabilities Capabilities
@using SDI.Enki.BlazorServer.Api

<PageTitle>Enki &mdash; Tool @Serial</PageTitle>

@if (_error is not null)
{
    <PageHeader Title="@($"Tool {Serial}")">
        <Actions>
            <NavLink class="enki-button" href="tools">Back to tools</NavLink>
        </Actions>
    </PageHeader>
    <div class="alert alert-danger">@_error</div>
}
else if (_tool is null)
{
    <PageHeader Title="@($"Tool {Serial}")">
        <Actions>
            <NavLink class="enki-button" href="tools">Back to tools</NavLink>
        </Actions>
    </PageHeader>
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Loading tool&hellip;</div>
    </div>
}
else
{
    <PageHeader Title="@_tool.DisplayName">
        <TitleSuffix>
            <span class="enki-status-pill @StatusClass(_tool.Status)">@_tool.Status</span>
        </TitleSuffix>
        <Subtitle>
            Serial <span class="enki-mono">@_tool.SerialNumber</span>
        </Subtitle>
        <Actions>
            <NavLink class="enki-button" href="tools">Back to tools</NavLink>

            @* Retire / Reactivate / Edit are master-tool CRUD — Supervisor+
               or admin. Hidden for Field/Office (and Tenant users) since
               the underlying API will reject them anyway. Calibrate is a
               separate gate (Office+) — Office can run a calibration on
               a tool they can't otherwise edit. *@
            @if (Capabilities.CanManageMasterTools)
            {
                @if (_tool.Status == "Active")
                {
                    @* Opens the retire dialog (markup further down). The actual
                       form post lives inside the <dialog>; this button only
                       triggers showModal() via enki-dialog.js. *@
                    <button type="button" class="enki-button enki-button-danger"
                            @onclick="OpenRetireDialog">
                        Retire
                    </button>
                }
                else if (_tool.Status == "Retired" || _tool.Status == "Lost")
                {
                    <form method="post" action="@($"/tools/{_tool.SerialNumber}/reactivate")"
                          style="display:inline">
                        <AntiforgeryToken />
                        <input type="hidden" name="rowVersion" value="@_tool.RowVersion" />
                        <button type="submit" class="enki-button">Reactivate</button>
                    </form>
                }

                <NavLink class="enki-button" href="@($"tools/{_tool.SerialNumber}/edit")">
                    Edit
                </NavLink>
            }

            @if (_tool.Status == "Active" && Capabilities.CanWriteMasterContent)
            {
                <NavLink class="enki-button enki-button-primary" href="@($"tools/{_tool.SerialNumber}/calibrate")">
                    + Calibrate
                </NavLink>
            }
        </Actions>
    </PageHeader>

    @if (_statusError is not null)
    {
        <div class="alert alert-danger">@_statusError</div>
    }

    <div class="enki-detail-grid">
        <div class="enki-detail-label">Serial</div>
        <div class="enki-detail-value">@_tool.SerialNumber</div>

        <div class="enki-detail-label">Generation</div>
        <div class="enki-detail-value">@_tool.Generation</div>

        <div class="enki-detail-label">Firmware</div>
        <div class="enki-detail-value">@_tool.FirmwareVersion</div>

        <div class="enki-detail-label">Configuration</div>
        <div class="enki-detail-value">@_tool.Configuration</div>

        <div class="enki-detail-label">Size</div>
        <div class="enki-detail-value">@_tool.Size</div>

        <div class="enki-detail-label">Magnetometers</div>
        <div class="enki-detail-value">@_tool.MagnetometerCount</div>

        <div class="enki-detail-label">Accelerometers</div>
        <div class="enki-detail-value">@_tool.AccelerometerCount</div>

        <div class="enki-detail-label">Status</div>
        <div class="enki-detail-value">@_tool.Status</div>

        <div class="enki-detail-label">Notes</div>
        <div class="enki-detail-value @DashClass(_tool.Notes)">@Dashed(_tool.Notes)</div>

        <div class="enki-detail-label">Created</div>
        <div class="enki-detail-value">@_tool.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>

        <div class="enki-detail-label">Updated</div>
        <div class="enki-detail-value @DashClass(_tool.UpdatedAt?.ToString())">
            @(_tool.UpdatedAt is { } u ? u.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "—")
        </div>
    </div>

    @* Retirement metadata panel. Only renders for non-Active tools — the
       fields are server-cleared on Reactivate so an Active row never
       carries stale values here. *@
    @if (_tool.Status != "Active" && _tool.Disposition is not null)
    {
        <h2 class="enki-section-title" style="font-size: 1.1rem; margin-top: 2rem;">
            Retirement
        </h2>
        <div class="enki-detail-grid">
            <div class="enki-detail-label">Disposition</div>
            <div class="enki-detail-value">@_tool.Disposition</div>

            <div class="enki-detail-label">Effective</div>
            <div class="enki-detail-value">
                @(_tool.RetiredAt is { } r ? r.ToLocalTime().ToString("yyyy-MM-dd") : "—")
            </div>

            <div class="enki-detail-label">Recorded by</div>
            <div class="enki-detail-value @DashClass(_tool.RetiredBy)">@Dashed(_tool.RetiredBy)</div>

            <div class="enki-detail-label">Reason</div>
            <div class="enki-detail-value @DashClass(_tool.RetirementReason)">@Dashed(_tool.RetirementReason)</div>

            <div class="enki-detail-label">Final location</div>
            <div class="enki-detail-value @DashClass(_tool.RetirementLocation)">@Dashed(_tool.RetirementLocation)</div>

            <div class="enki-detail-label">Replaced by</div>
            <div class="enki-detail-value @DashClass(_tool.ReplacementToolDisplayName)">
                @if (_tool.ReplacementToolSerial is { } rs)
                {
                    <a class="enki-row-link" href="@($"/tools/{rs}")">@_tool.ReplacementToolDisplayName</a>
                }
                else
                {
                    <span>—</span>
                }
            </div>
        </div>
    }

    @* Retire dialog. Posts a multipart form to the BlazorServer proxy at
       /tools/{n}/retire which forwards a RetireToolDto JSON to the WebApi.
       The Cancel button closes the dialog without submitting; Confirm
       performs a real form post (browser navigation). *@
    @if (Capabilities.CanManageMasterTools && _tool.Status == "Active")
    {
        <dialog id="retire-dialog" class="enki-dialog">
            <form method="post" action="@($"/tools/{_tool.SerialNumber}/retire")" class="enki-form">
                <AntiforgeryToken />
                <input type="hidden" name="rowVersion" value="@_tool.RowVersion" />

                <div class="enki-dialog-header">
                    <h2 class="enki-dialog-title">Retire tool @_tool.SerialNumber</h2>
                    <p class="enki-dialog-subtitle">
                        @_tool.DisplayName &middot; @_tool.CalibrationCount calibration@(_tool.CalibrationCount == 1 ? "" : "s") on file
                    </p>
                </div>

                <div class="enki-dialog-body">
                    <div class="enki-form-group">
                        <label class="enki-form-label required" for="retire-disposition">Disposition</label>
                        <select id="retire-disposition" name="disposition" class="enki-form-select" required>
                            <option value="" disabled selected>— select —</option>
                            @foreach (var d in DispositionOptions)
                            {
                                <option value="@d">@d</option>
                            }
                        </select>
                    </div>

                    <div class="enki-form-group">
                        <label class="enki-form-label required" for="retire-effective-date">Effective date</label>
                        <input id="retire-effective-date" type="date" name="effectiveDate"
                               class="enki-form-input" required
                               value="@DateTime.UtcNow.ToString("yyyy-MM-dd")" />
                    </div>

                    <div class="enki-form-group">
                        <label class="enki-form-label required" for="retire-reason">Reason</label>
                        <textarea id="retire-reason" name="reason" maxlength="500" required
                                  class="enki-form-textarea"
                                  placeholder="Why is this tool leaving service?"></textarea>
                    </div>

                    <div class="enki-form-group">
                        <label class="enki-form-label" for="retire-replacement">Replacement tool serial (optional)</label>
                        <input id="retire-replacement" type="number" name="replacementSerial"
                               class="enki-form-input"
                               placeholder="e.g. 1000093" />
                        <div class="enki-form-hint">Leave blank if no direct swap-out.</div>
                    </div>

                    <div class="enki-form-group">
                        <label class="enki-form-label" for="retire-location">Final location (optional)</label>
                        <input id="retire-location" type="text" name="finalLocation"
                               class="enki-form-input" maxlength="200"
                               placeholder="e.g. Houston yard, customer site, scrap" />
                    </div>
                </div>

                <div class="enki-dialog-actions">
                    <button type="button" class="enki-button" @onclick="CloseRetireDialog">Cancel</button>
                    <button type="submit" class="enki-button enki-button-danger">Confirm retirement</button>
                </div>
            </form>
        </dialog>
    }

    <h2 class="enki-section-title" style="font-size: 1.1rem; margin-top: 2rem;">
        Calibrations
        <span class="enki-section-subtitle" style="font-weight: normal; margin-left: 0.5rem;">
            @_tool.CalibrationCount total
        </span>
    </h2>

    @if (_calibrations is null)
    {
        <div class="enki-loading-block" role="status" aria-live="polite">
            <div class="enki-spinner" aria-hidden="true"></div>
            <div class="enki-loading-text">Loading calibrations&hellip;</div>
        </div>
    }
    else if (_calibrations.Count == 0)
    {
        <p class="enki-section-subtitle">No calibrations on file.</p>
    }
    else
    {
        <div style="display: flex; align-items: center; gap: 0.75rem; margin: 0.5rem 0 0.75rem;">
            <button type="button"
                    class="enki-button enki-button-primary"
                    @onclick="GoCompare"
                    disabled="@(_selectedCalIds.Count < 2)">
                Compare selected (@_selectedCalIds.Count)
            </button>
            <span class="enki-section-subtitle" style="font-size: 0.85rem;">
                Tick at least two calibrations to compare them side-by-side.
            </span>
        </div>

        <SfGrid DataSource="_calibrations"
                AllowSorting="true"
                AllowFiltering="true"
                Height="auto">
            <GridColumns>
                <GridColumn HeaderText="" Width="48">
                    <Template>
                        @{
                            var row = context as CalibrationSummaryDto;
                        }
                        @if (row is not null)
                        {
                            <input type="checkbox"
                                   checked="@_selectedCalIds.Contains(row.Id)"
                                   @onchange="e => ToggleCalSelected(row.Id, e)" />
                        }
                    </Template>
                </GridColumn>
                <GridColumn Field="@nameof(CalibrationSummaryDto.CalibrationDate)"
                            HeaderText="Date" Width="160"
                            Format="yyyy-MM-dd" Type="ColumnType.DateTime">
                    <Template>
                        @{
                            var row = context as CalibrationSummaryDto;
                        }
                        @if (row is not null)
                        {
                            <a class="enki-row-link" href="@($"/calibrations/{row.Id}")">
                                @row.CalibrationDate.ToLocalTime().ToString("yyyy-MM-dd")
                            </a>
                        }
                    </Template>
                </GridColumn>
                <GridColumn Field="@nameof(CalibrationSummaryDto.CalibratedBy)"
                            HeaderText="By" Width="200" />
                <GridColumn Field="@nameof(CalibrationSummaryDto.MagnetometerCount)"
                            HeaderText="Mags" Width="80" TextAlign="TextAlign.Right" />
                <GridColumn Field="@nameof(CalibrationSummaryDto.Source)"
                            HeaderText="Source" Width="120" />
                <GridColumn HeaderText="Flags" Width="160">
                    <Template>
                        @{
                            var row = context as CalibrationSummaryDto;
                        }
                        @if (row is not null)
                        {
                            @if (row.IsNominal)
                            {
                                <span class="enki-status-pill enki-status-inactive">Nominal</span>
                            }
                            @if (row.IsSuperseded)
                            {
                                <span class="enki-status-pill enki-status-archived" style="margin-left: 0.25rem;">Superseded</span>
                            }
                            @if (!row.IsNominal && !row.IsSuperseded)
                            {
                                <span class="enki-status-pill enki-status-active">Current</span>
                            }
                        }
                    </Template>
                </GridColumn>
            </GridColumns>
        </SfGrid>
    }
}

@* Logic is in ToolDetail.razor.cs (partial class) — no @code block here. *@
