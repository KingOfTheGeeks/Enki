@page "/account/settings"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@inject UnitPreferenceProvider UnitPrefs
@using SDI.Enki.BlazorServer.Api
@using SDI.Enki.Shared.Identity

<PageTitle>Enki &mdash; My settings</PageTitle>

<h1 class="enki-section-title">My settings</h1>
<p class="enki-section-subtitle">
    Personal preferences applied wherever you sign in. Unset values
    inherit the per-tenant or per-job default.
</p>

@* ---------- Preferences card ---------- *@
@if (_prefsError is not null)
{
    <div class="alert alert-danger">@_prefsError</div>
}
@if (_prefsSaved)
{
    <div class="alert alert-success">Settings saved.</div>
}

@if (_prefs is null && _prefsError is null)
{
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Loading preferences&hellip;</div>
    </div>
}
else if (_prefs is not null)
{
    <div class="enki-card" style="max-width: 620px; margin-top: 1.25rem;">
        <div class="enki-form-group">
            <label class="enki-form-label">Preferred unit system</label>
            <select class="enki-form-input" @bind="_unitSystem">
                <option value="">— Use the per-Job default —</option>
                <option value="Field">Field — ft / psi / °F / ppg (US oilfield)</option>
                <option value="Metric">Metric — m / bar / °C / kg/m³</option>
                <option value="SI">SI — m / Pa / K / kg/m³</option>
            </select>
            <div class="enki-form-hint">
                Overrides the Job's preset for display only. Storage is always
                canonical SI; this controls what numbers you see in the UI.
            </div>
        </div>

        <div class="enki-form-actions">
            <button class="enki-button enki-button-primary" @onclick="SavePreferencesAsync" disabled="@_prefsBusy">
                Save settings
            </button>
            <NavLink class="enki-button" href="">Back home</NavLink>
        </div>
    </div>
}

@* ---------- Change password card ---------- *@
<h2 class="enki-section-title" style="font-size: 1.1rem; margin-top: 2.5rem;">Change password</h2>
<p class="enki-section-subtitle">
    Replace the temporary password an administrator assigned you with one of your own.
    Existing sessions on other devices will be signed out after a successful change.
</p>

@if (_passwordError is not null)
{
    <div class="alert alert-danger">@_passwordError</div>
}
@if (_passwordSaved)
{
    <div class="alert alert-success">Password changed. Use your new password next time you sign in.</div>
}

<div class="enki-card" style="max-width: 620px; margin-top: 1.25rem;">
    <div class="enki-form-group">
        <label class="enki-form-label required" for="current-password">Current password</label>
        <input id="current-password" type="password" autocomplete="current-password"
               class="enki-form-input @(_currentPasswordError is not null ? "is-user-invalid" : "")"
               @bind="_currentPassword" />
        @if (_currentPasswordError is not null)
        {
            <div class="enki-form-error">@_currentPasswordError</div>
        }
    </div>

    <div class="enki-form-group">
        <label class="enki-form-label required" for="new-password">New password</label>
        <input id="new-password" type="password" autocomplete="new-password"
               class="enki-form-input @(_newPasswordError is not null ? "is-user-invalid" : "")"
               @bind="_newPassword" />
        @if (_newPasswordError is not null)
        {
            <div class="enki-form-error">@_newPasswordError</div>
        }
        <div class="enki-form-hint">
            At least 8 characters with a mix of upper / lower / digit / non-alphanumeric.
        </div>
    </div>

    <div class="enki-form-group">
        <label class="enki-form-label required" for="confirm-password">Confirm new password</label>
        <input id="confirm-password" type="password" autocomplete="new-password"
               class="enki-form-input @(_confirmPasswordError is not null ? "is-user-invalid" : "")"
               @bind="_confirmPassword" />
        @if (_confirmPasswordError is not null)
        {
            <div class="enki-form-error">@_confirmPasswordError</div>
        }
    </div>

    <div class="enki-form-actions">
        <button class="enki-button enki-button-primary" @onclick="ChangePasswordAsync" disabled="@_passwordBusy">
            @(_passwordBusy ? "Changing…" : "Change password")
        </button>
    </div>
</div>

@* Logic is in AccountSettings.razor.cs (partial class) — no @code block here. *@
