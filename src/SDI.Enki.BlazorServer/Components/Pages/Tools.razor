@page "/tools"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject SDI.Enki.BlazorServer.Auth.IUserCapabilities Capabilities
@using SDI.Enki.BlazorServer.Api

<PageTitle>Enki &mdash; Tools</PageTitle>

<div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; flex-wrap: wrap;">
    <div style="flex: 1; min-width: 280px;">
        <h1 class="enki-section-title">Tools</h1>
        <p class="enki-section-subtitle">
            Fleet-wide registry of physical downhole tools. Each tool serves
            many tenants across its lifetime; calibrations are intrinsic to
            the tool and travel with it.
        </p>
    </div>
    @* "+ New tool" requires master-tool CRUD (Supervisor+ or admin).
       Field/Office can browse the registry but can't add new tools. *@
    @if (Capabilities.CanManageMasterTools)
    {
        <NavLink class="enki-button enki-button-primary" href="tools/new">+ New tool</NavLink>
    }
</div>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_tools is null)
{
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Fetching tools from API&hellip;</div>
    </div>
}
else
{
    <div class="enki-stat-grid">
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_tools.Count.ToString("D2")</div>
            <div class="enki-stat-label">Tools</div>
        </div>
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_tools.Count(t => t.Status == "Active").ToString("D2")</div>
            <div class="enki-stat-label">Active</div>
        </div>
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_tools.Count(t => t.Status == "Retired").ToString("D2")</div>
            <div class="enki-stat-label">Retired</div>
        </div>
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_tools.Count(NeedsCalibration).ToString("D2")</div>
            <div class="enki-stat-label">Cal &gt; 365d</div>
        </div>
    </div>

    @* DisplayName is the elastic column — serials are uniformly short
       (T-001 etc.) so leaving them tight, while Name absorbs leftover. *@
    <EnkiListGrid TValue="ToolSummaryDto"
                  DataSource="_tools"
                  ElasticField="@nameof(ToolSummaryDto.DisplayName)">
        <GridColumn Field="@nameof(ToolSummaryDto.SerialNumber)"
                    HeaderText="Serial" TextAlign="TextAlign.Left">
            <Template>
                @{ var row = context as ToolSummaryDto; }
                @if (row is not null)
                {
                    <a class="enki-row-link" href="@($"/tools/{row.SerialNumber}")">@row.SerialNumber</a>
                }
            </Template>
        </GridColumn>
        <GridColumn Field="@nameof(ToolSummaryDto.DisplayName)" HeaderText="Name" MinWidth="200" />
        <GridColumn Field="@nameof(ToolSummaryDto.Generation)" HeaderText="Gen" />
        <GridColumn Field="@nameof(ToolSummaryDto.FirmwareVersion)" HeaderText="Firmware" />
        <GridColumn Field="@nameof(ToolSummaryDto.MagnetometerCount)"
                    HeaderText="Mags" TextAlign="TextAlign.Right" />
        <GridColumn Field="@nameof(ToolSummaryDto.AccelerometerCount)"
                    HeaderText="Accs" TextAlign="TextAlign.Right" />
        <GridColumn Field="@nameof(ToolSummaryDto.CalibrationCount)"
                    HeaderText="Cals" TextAlign="TextAlign.Right" />
        <GridColumn Field="@nameof(ToolSummaryDto.LatestCalibrationDate)"
                    HeaderText="Last Cal"
                    Format="yyyy-MM-dd" Type="ColumnType.DateTime" />
        <GridColumn Field="@nameof(ToolSummaryDto.Status)" HeaderText="Status">
            <Template>
                @{ var row = context as ToolSummaryDto; }
                @if (row is not null)
                {
                    <span class="enki-status-pill @StatusClass(row.Status)">@row.Status</span>
                }
            </Template>
        </GridColumn>
    </EnkiListGrid>
}

@code {
    private List<ToolSummaryDto>? _tools;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var client = HttpClientFactory.CreateClient("EnkiApi");
        var result = await client.GetAsync<List<ToolSummaryDto>>("tools");

        if (!result.IsSuccess) { _error = result.Error.AsAlertText(); return; }
        _tools = result.Value;
    }

    private static bool NeedsCalibration(ToolSummaryDto t) =>
        t.Status == "Active" &&
        (t.LatestCalibrationDate is null ||
         (DateTimeOffset.UtcNow - t.LatestCalibrationDate.Value).TotalDays > 365);

    private static string StatusClass(string s) => s switch
    {
        "Active"  => "enki-status-active",
        "Retired" => "enki-status-archived",
        "Lost"    => "enki-status-inactive",
        _         => "",
    };
}
