@page "/tenants"
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@using SDI.Enki.BlazorServer.Api

<PageTitle>Enki &mdash; Tenants</PageTitle>

<div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; flex-wrap: wrap;">
    <div style="flex: 1; min-width: 280px;">
        <h1 class="enki-section-title">Tenants</h1>
        <p class="enki-section-subtitle">
            Per-client master registry. Each tenant carries an Active + Archive
            database pair on the configured SQL Server; Jobs nest under a tenant.
        </p>
    </div>
    <NavLink class="enki-button enki-button-primary" href="tenants/new">+ New tenant</NavLink>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_tenants is null)
{
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Fetching tenants from API&hellip;</div>
    </div>
}
else
{
    <div class="enki-stat-grid">
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_tenants.Count.ToString("D2")</div>
            <div class="enki-stat-label">Tenants</div>
        </div>
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_tenants.Count(t => t.Status == "Active").ToString("D2")</div>
            <div class="enki-stat-label">Active</div>
        </div>
        <div class="enki-stat-card">
            <div class="enki-stat-value">@_tenants.Count(t => t.Status == "Inactive").ToString("D2")</div>
            <div class="enki-stat-label">Inactive</div>
        </div>
    </div>

    <SfGrid DataSource="_tenants"
            AllowSorting="true"
            AllowFiltering="true"
            AllowResizing="true"
            Height="auto">
        <GridColumns>
            <GridColumn Field="@nameof(TenantSummaryDto.Code)"
                        HeaderText="Code" Width="120" TextAlign="TextAlign.Left">
                <Template>
                    @{
                        var row = context as TenantSummaryDto;
                    }
                    @* Click goes straight to Jobs — that's where the work
                       happens. Tenant identity / lifecycle / member admin
                       are reachable via the sidebar's Operations →
                       Overview when scoped to a tenant. *@
                    @if (row is not null)
                    {
                        <a class="enki-row-link" href="@($"/tenants/{row.Code}/jobs")">@row.Code</a>
                    }
                </Template>
            </GridColumn>
            <GridColumn Field="@nameof(TenantSummaryDto.Name)" HeaderText="Name" />
            <GridColumn Field="@nameof(TenantSummaryDto.DisplayName)" HeaderText="Display Name" />
            <GridColumn Field="@nameof(TenantSummaryDto.Status)"
                        HeaderText="Status" Width="130">
                <Template>
                    @{
                        var row = context as TenantSummaryDto;
                    }
                    @if (row is not null)
                    {
                        <span class="enki-status-pill @StatusClass(row.Status)">@row.Status</span>
                    }
                </Template>
            </GridColumn>
            <GridColumn Field="@nameof(TenantSummaryDto.CreatedAt)"
                        HeaderText="Created" Width="180"
                        Format="yyyy-MM-dd HH:mm" Type="ColumnType.DateTime" />
        </GridColumns>
    </SfGrid>
}

@code {
    private List<TenantSummaryDto>? _tenants;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var client = HttpClientFactory.CreateClient("EnkiApi");
        var result = await client.GetAsync<List<TenantSummaryDto>>("tenants");

        if (!result.IsSuccess) { _error = result.Error.AsAlertText(); return; }
        _tenants = result.Value;
    }

    private static string StatusClass(string s) => s switch
    {
        "Active"   => "enki-status-active",
        "Inactive" => "enki-status-inactive",
        "Archived" => "enki-status-archived",
        _          => "",
    };
}
