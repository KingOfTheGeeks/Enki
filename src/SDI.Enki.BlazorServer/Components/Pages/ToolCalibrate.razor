@rendermode InteractiveServer
@implements IDisposable
@using SDI.Enki.Shared.Calibrations.Processing

<PageTitle>Enki &mdash; Calibrate tool @Serial</PageTitle>

<h1 class="enki-section-title">Calibrate tool @Serial</h1>
<p class="enki-section-subtitle">
    Upload 25 shot binaries — <span class="enki-mono">0.bin</span> is the
    <strong>baseline</strong> (Helmholtz loop not energized) and
    <span class="enki-mono">1.bin</span>–<span class="enki-mono">24.bin</span>
    are the active shots. The server parses + NarrowBand-processes all 25,
    you pick which active shots to use, then run the Marduk computation.
    Saving promotes the result into a new <strong>current</strong>
    calibration for this tool and supersedes the previous one.
</p>

@switch (_view)
{
    case View.Upload:    @UploadView();   break;
    case View.Preview:   @PreviewView();  break;
    case View.Results:   @ResultsView();  break;
    case View.Saved:     @SavedView();    break;
}

@code {
    // Markup-bearing RenderFragment helpers — stay in the .razor's @code
    // block because they use razor markup syntax (<div>, @foreach, etc.)
    // that only the razor compiler parses. Pure C# (lifecycle, fields,
    // async work) lives in ToolCalibrate.razor.cs.

    // ====================== Upload ======================

    private RenderFragment UploadView() => __builder =>
    {
        @* Drop-zone styling around a hidden InputFile. The native input
           accepts both clicks (forwarded by clicking the visible "Browse"
           label) and drops (the absolute-positioned input covers the
           whole zone), so the picker handles drag-drop and click-to-browse
           without JS interop. SfUploader was tried here first but its API
           is upload-pipeline-centric and doesn't expose file streams to
           the server until you actually post to a SaveUrl — wrong fit for
           "stage 25 files then batch-process as one multipart POST". *@
        <style>
            .enki-dropzone {
                position: relative;
                border: 2px dashed var(--enki-border, #2a3543);
                border-radius: var(--enki-radius-lg, 8px);
                padding: 2rem 1.5rem;
                text-align: center;
                background: var(--enki-surface-alt, rgba(255,255,255,0.02));
                transition: border-color 120ms ease, background 120ms ease;
            }
            .enki-dropzone:hover,
            .enki-dropzone:focus-within {
                border-color: var(--enki-accent, #5cc4ff);
                background: var(--enki-surface, rgba(92,196,255,0.05));
            }
            .enki-dropzone-input {
                position: absolute;
                inset: 0;
                width: 100%;
                height: 100%;
                opacity: 0;
                cursor: pointer;
            }
            .enki-dropzone-prompt {
                pointer-events: none;
                font-size: 1rem;
                color: var(--enki-fg-muted, #a0a8b4);
            }
            .enki-dropzone-prompt strong {
                color: var(--enki-fg, #e6ecf3);
            }
            .enki-picked-list {
                margin-top: 1rem;
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
                gap: 0.5rem;
            }
            .enki-picked-chip {
                font-family: var(--enki-mono-font, monospace);
                font-size: 0.85rem;
                padding: 0.35rem 0.6rem;
                border: 1px solid var(--enki-border, #2a3543);
                border-radius: var(--enki-radius-sm, 4px);
                background: var(--enki-surface, rgba(255,255,255,0.03));
                display: flex;
                justify-content: space-between;
                gap: 0.5rem;
            }
            .enki-picked-chip-size {
                color: var(--enki-fg-muted, #a0a8b4);
                font-size: 0.75rem;
            }
        </style>

        <div class="enki-card" style="max-width: 720px; margin-top: 1.25rem;">
            <h2 class="enki-section-title" style="font-size: 1.1rem;">1 / 3 &mdash; Upload shot binaries</h2>

            <div class="enki-form-group">
                <label class="enki-form-label">Files</label>
                <div class="enki-dropzone">
                    <InputFile OnChange="HandleFilesPicked" multiple
                               accept=".bin"
                               class="enki-dropzone-input"
                               aria-label="Drop or browse for 25 .bin files" />
                    <div class="enki-dropzone-prompt">
                        <strong>Drop 25 <span class="enki-mono">.bin</span> files</strong> here,
                        or click to browse. Names must be
                        <span class="enki-mono">0.bin</span> (baseline) through
                        <span class="enki-mono">24.bin</span>.
                    </div>
                </div>

                @if (_picked.Count > 0)
                {
                    <div class="enki-picked-list">
                        @foreach (var f in _picked.OrderBy(NameToIndex))
                        {
                            <div class="enki-picked-chip" title="@f.Name">
                                <span>@f.Name</span>
                                <span class="enki-picked-chip-size">@FormatSize(f.Size)</span>
                            </div>
                        }
                    </div>
                }
            </div>

            @if (_uploadError is not null)
            {
                <div class="alert alert-danger" style="margin-top: 1rem;">@_uploadError</div>
            }

            @if (_picked.Count > 0)
            {
                var allValid = ValidatePicked(out var report);
                <div class="enki-form-group">
                    <label class="enki-form-label">Validation</label>
                    <div class="enki-form-hint" style="@(allValid ? "" : "color: var(--enki-danger, #ff6464);")">@report</div>
                </div>

                @* Manual fallback button — auto-fire from HandleFilesPicked
                   triggers processing the moment 25 valid files are picked,
                   so in the happy path the user never sees this. It's here
                   for "retry after a transient upload failure" cases. *@
                @if (!_uploading || _uploadError is not null)
                {
                    <div class="enki-form-actions">
                        <button class="enki-button enki-button-primary"
                                @onclick="StartProcessingAsync"
                                disabled="@(!allValid || _uploading)">
                            @(_uploading ? "Uploading…" : "Upload + start processing")
                        </button>
                        <NavLink class="enki-button" href="@($"tools/{Serial}")">Cancel</NavLink>
                    </div>
                }
                else
                {
                    <div class="enki-form-actions">
                        <span class="enki-form-hint">Uploading 25 files and starting processing&hellip;</span>
                    </div>
                }
            }
        </div>
    };

    // ====================== Preview ======================

    private RenderFragment PreviewView() => __builder =>
    {
        var parsed = _status?.ShotsParsed ?? 0;
        var ready = _status?.State == nameof(ProcessingSessionState.ReadyForCompute);

        <div class="enki-card" style="margin-top: 1.25rem;">
            <h2 class="enki-section-title" style="font-size: 1.1rem;">
                2 / 3 &mdash; Parse + NarrowBand &mdash;
                @if (ready)
                {
                    <span style="font-weight: normal;">all 25 shots ready (1 baseline + 24 active)</span>
                }
                else
                {
                    <span style="font-weight: normal;">@parsed / 25 shots processed&hellip;</span>
                }
            </h2>

            @if (_status?.State == nameof(ProcessingSessionState.Failed))
            {
                <div class="alert alert-danger">@_status.Error</div>
            }
            else if (!ready)
            {
                <div class="enki-loading-block" role="status" aria-live="polite">
                    <div class="enki-spinner" aria-hidden="true"></div>
                    <div class="enki-loading-text">
                        Parsing binaries and running NarrowBand pass&hellip;
                    </div>
                </div>
            }
            else
            {
                @ShotPreviewTable()

                @if (_defaults is null)
                {
                    <p class="enki-section-subtitle">Loading reference defaults&hellip;</p>
                }
                else
                {
                    @ReferenceParamsForm()
                }

                @if (_computeError is not null)
                {
                    <div class="alert alert-danger" style="margin-top: 1rem;">@_computeError</div>
                }

                <div class="enki-form-actions">
                    <button class="enki-button enki-button-primary"
                            @onclick="ComputeAsync"
                            disabled="@(_defaults is null || _computing || !_enabled.Skip(1).Take(24).Any(e => e))">
                        @(_computing ? "Computing…" : "Compute calibration")
                    </button>
                    <NavLink class="enki-button" href="@($"tools/{Serial}")">Cancel</NavLink>
                </div>
            }
        </div>
    };

    private RenderFragment ShotPreviewTable() => __builder =>
    {
        <table class="enki-table" style="width: 100%; margin: 1rem 0;">
            <thead>
                <tr>
                    <th>Use</th>
                    <th>#</th>
                    <th>Samples</th>
                    <th>Freq (Hz)</th>
                    <th>Temp (°C)</th>
                    <th>Acollinearity</th>
                    <th>Current (A)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in _status!.Previews.OrderBy(p => p.ShotIndex))
                {
                    var idx = p.ShotIndex;
                    var isBaseline = idx == 0;
                    <tr>
                        <td>
                            @if (isBaseline)
                            {
                                <span class="enki-status-pill enki-status-archived" title="Loop not energized — baseline reference">Baseline</span>
                            }
                            else
                            {
                                <input type="checkbox" @bind="_enabled[idx]" />
                            }
                        </td>
                        <td>@p.ShotIndex</td>
                        <td>@p.SampleCount</td>
                        <td>@p.FrequencyHz.ToString("F3")</td>
                        <td>@p.TemperatureC.ToString("F1")</td>
                        <td>@string.Join(", ", p.PerMagAcollinearity.Select(a => a.ToString("F4")))</td>
                        <td>
                            @if (isBaseline)
                            {
                                <span class="enki-dash">—</span>
                            }
                            else
                            {
                                <input type="number" step="0.01" @bind="_currents[idx]" style="width: 6rem;" />
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    };

    private RenderFragment ReferenceParamsForm() => __builder =>
    {
        <h3 class="enki-section-title" style="font-size: 1rem; margin-top: 1rem;">Reference fields</h3>
        <div class="enki-detail-grid">
            <div class="enki-detail-label">G total (mG)</div>
            <div class="enki-detail-value"><input type="number" step="any" @bind="_gTotal" class="enki-form-input" /></div>

            <div class="enki-detail-label">B total (nT)</div>
            <div class="enki-detail-value"><input type="number" step="any" @bind="_bTotal" class="enki-form-input" /></div>

            <div class="enki-detail-label">Dip (deg)</div>
            <div class="enki-detail-value"><input type="number" step="any" @bind="_dipDegrees" class="enki-form-input" /></div>

            <div class="enki-detail-label">Declination (deg)</div>
            <div class="enki-detail-value"><input type="number" step="any" @bind="_declinationDegrees" class="enki-form-input" /></div>

            <div class="enki-detail-label">Coil constant (nT/A)</div>
            <div class="enki-detail-value"><input type="number" step="any" @bind="_coilConstant" class="enki-form-input" /></div>

            <div class="enki-detail-label">Active B dip (deg)</div>
            <div class="enki-detail-value"><input type="number" step="any" @bind="_activeBDipDegrees" class="enki-form-input" /></div>

            <div class="enki-detail-label">Sample rate (Hz)</div>
            <div class="enki-detail-value"><input type="number" step="any" @bind="_sampleRateHz" class="enki-form-input" /></div>

            <div class="enki-detail-label">Manual sign</div>
            <div class="enki-detail-value"><input type="number" step="any" @bind="_manualSign" class="enki-form-input" /></div>
        </div>
    };

    // ====================== Results / Save ======================

    private RenderFragment ResultsView() => __builder =>
    {
        <div class="enki-card" style="margin-top: 1.25rem;">
            <h2 class="enki-section-title" style="font-size: 1.1rem;">
                3 / 3 &mdash; Review &amp; save
            </h2>

            <div class="enki-detail-grid" style="margin-top: 1rem;">
                <div class="enki-detail-label">Gravity residual</div>
                <div class="enki-detail-value">@_result!.GravityResidual.ToString("F4") mG RMS</div>

                <div class="enki-detail-label">Magnetic residuals</div>
                <div class="enki-detail-value">
                    @string.Join(" / ", _result.MagneticResiduals.Select(r => $"{r:F2} nT"))
                </div>
            </div>

            @if (_result.ShotDiagnostics.Count > 0)
            {
                <h3 class="enki-section-title" style="font-size: 1rem; margin-top: 1rem;">Per-shot diagnostics</h3>
                <table class="enki-table" style="width: 100%; margin: 0.5rem 0;">
                    <thead>
                        <tr>
                            <th>#</th><th>Used</th><th>|G| (mG)</th><th>|B| per mag (nT)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in _result.ShotDiagnostics)
                        {
                            <tr>
                                <td>@d.ShotIndex</td>
                                <td>@(d.Enabled ? "✓" : "")</td>
                                <td>@d.CalibratedGTotal.ToString("F2")</td>
                                <td>@string.Join(", ", d.CalibratedBTotalPerMag.Select(b => b.ToString("F1")))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            @if (_result.Report.Count > 0)
            {
                <h3 class="enki-section-title" style="font-size: 1rem; margin-top: 1rem;">Marduk report</h3>
                <pre style="background: var(--enki-surface); border: 1px solid var(--enki-border); border-radius: var(--enki-radius-lg); padding: 1rem; overflow-x: auto; font-size: 0.85rem; max-height: 300px;">@string.Join("\n", _result.Report)</pre>
            }

            <h3 class="enki-section-title" style="font-size: 1rem; margin-top: 1rem;">Save calibration</h3>

            <div class="enki-form-group">
                <label class="enki-form-label required">Name</label>
                <input type="text" @bind="_calibrationName" maxlength="200" class="enki-form-input" />
            </div>

            <div class="enki-form-group">
                <label class="enki-form-label">Calibrated by</label>
                <input type="text" @bind="_calibratedBy" maxlength="200" class="enki-form-input" />
            </div>

            <div class="enki-form-group">
                <label class="enki-form-label">Notes</label>
                <textarea @bind="_notes" rows="3" maxlength="1000" class="enki-form-textarea"></textarea>
            </div>

            @if (_saveError is not null)
            {
                <div class="alert alert-danger">@_saveError</div>
            }

            <div class="enki-form-actions">
                <button class="enki-button enki-button-primary"
                        @onclick="SaveWithConfirmAsync"
                        disabled="@(_saving || string.IsNullOrWhiteSpace(_calibrationName))">
                    @(_saving ? "Saving…" : "Save calibration")
                </button>
                <button class="enki-button" @onclick="GoBackToPreview" disabled="@_saving">
                    Back to selections
                </button>
            </div>
        </div>
    };

    // ====================== Saved ======================

    private RenderFragment SavedView() => __builder =>
    {
        <div class="enki-card" style="max-width: 720px; margin-top: 1.25rem;">
            <h2 class="enki-section-title" style="font-size: 1.1rem;">Calibration saved</h2>

            <p>
                New calibration written and marked current for tool
                <span class="enki-mono">@Serial</span>.
            </p>

            @if (_supersededCalibrationId is not null)
            {
                <p class="enki-section-subtitle">
                    Previous current calibration flipped to <strong>Superseded</strong>.
                </p>
            }

            <div class="enki-form-actions">
                <NavLink class="enki-button enki-button-primary" href="@($"calibrations/{_savedCalibrationId}")">
                    View calibration
                </NavLink>
                <NavLink class="enki-button" href="@($"tools/{Serial}")">Back to tool</NavLink>
            </div>
        </div>
    };
}
