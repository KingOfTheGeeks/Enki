@page "/tenants/{TenantCode}/jobs/{JobId:guid}/runs/new"
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@using System.ComponentModel.DataAnnotations
@using SDI.Enki.BlazorServer.Api
@using SDI.Enki.Shared.Runs
@using SDI.Enki.Shared.Tools

<PageTitle>Enki &mdash; New Run (@TenantCode)</PageTitle>

<h1 class="enki-section-title">New Run</h1>
<p class="enki-section-subtitle">
    Creates a Run inside this Job. Pick the type up front
    (Gradient / Rotary / Passive) — it's fixed at create time
    because the type drives which downstream processing satellites
    apply. Status starts as <span class="enki-mono">Planned</span>;
    transition with <span class="enki-mono">Start</span> from the
    detail page once the BHA is downhole.
</p>
<p class="enki-section-subtitle">
    The run carries its own Magnetics (BTotal / Dip / Declination) —
    fill these in from the well's geomagnetic reference. Tool is
    optional at creation; assign it later via Edit if you don't have
    the BHA picked yet, but Shots and Logs can't be added until a
    tool is on file.
</p>

@if (_submitError is not null)
{
    <div class="alert alert-danger">@_submitError</div>
}

<div class="enki-card" style="max-width: 620px; margin-top: 1.25rem;">
    <EditForm Model="Form" OnValidSubmit="Submit" FormName="create-run"
              class="enki-form" Enhance="true">
        <DataAnnotationsValidator />
        <ValidationSummary class="enki-validation-summary" />

        <div class="enki-form-group">
            <label class="enki-form-label required" for="f-name">Name</label>
            <InputText @bind-Value="Form!.Name" id="f-name" class="enki-form-input"
                       placeholder="e.g. Run-3 Gradient"
                       required maxlength="100"
                       data-error="Name is required." />
            <div class="enki-form-hint">Short identifier the rig crew uses for the run.</div>
            <ValidationMessage For="() => Form.Name" class="enki-form-error" />
        </div>

        <div class="enki-form-group">
            <label class="enki-form-label required" for="f-desc">Description</label>
            <InputTextArea @bind-Value="Form!.Description" id="f-desc"
                           class="enki-form-textarea"
                           placeholder="Objective, BHA notes, conditions&hellip;"
                           required maxlength="500"
                           data-error="Description is required." />
            <ValidationMessage For="() => Form.Description" class="enki-form-error" />
        </div>

        <div class="enki-form-group">
            <label class="enki-form-label required" for="f-type">Run type</label>
            @* Display labels track Marduk's terminology: the Rotary
               run type maps to AMR.Core.Rotary.Models.RotatingDipoleConfiguration /
               RotatingDipoleSolution. The persisted RunType enum is
               still "Rotary" — the dropdown just calls it what
               Marduk calls it. *@
            <InputSelect @bind-Value="Form!.Type" id="f-type" class="enki-form-input" required>
                <option value="Gradient">Gradient &mdash; mag/grav with current injection</option>
                <option value="Rotary">Rotating Dipole &mdash; continuous while drilling</option>
                <option value="Passive">Passive &mdash; sit-and-measure (no pulses)</option>
            </InputSelect>
            <div class="enki-form-hint">
                Fixed at create time. To change type after the run starts,
                cancel this run and create a new one.
            </div>
            <ValidationMessage For="() => Form.Type" class="enki-form-error" />
        </div>

        <div class="enki-form-group">
            <label class="enki-form-label required" for="f-start-md">Start MD</label>
            <InputNumber @bind-Value="Form!.StartDepth" id="f-start-md" class="enki-form-input"
                         step="0.1" required />
            <div class="enki-form-hint">Measured depth at run start (m).</div>
            <ValidationMessage For="() => Form.StartDepth" class="enki-form-error" />
        </div>

        <div class="enki-form-group">
            <label class="enki-form-label required" for="f-end-md">End MD</label>
            <InputNumber @bind-Value="Form!.EndDepth" id="f-end-md" class="enki-form-input"
                         step="0.1" required />
            <div class="enki-form-hint">Measured depth at run end (m).</div>
            <ValidationMessage For="() => Form.EndDepth" class="enki-form-error" />
        </div>

        @* Magnetics — required for every run. Manually entered (no
           auto-prefill from well) per the issue #26 follow-up plan. *@
        <h3 class="enki-form-section-title">Magnetic reference</h3>
        <div class="enki-form-group">
            <label class="enki-form-label required" for="f-btotal">BTotal (nT)</label>
            <InputNumber @bind-Value="Form!.BTotalNanoTesla" id="f-btotal" class="enki-form-input"
                         step="1" required />
            <div class="enki-form-hint">Magnetic flux density in nanotesla (typical: 45,000–60,000 nT).</div>
            <ValidationMessage For="() => Form.BTotalNanoTesla" class="enki-form-error" />
        </div>

        <div class="enki-form-group">
            <label class="enki-form-label required" for="f-dip">Dip (°)</label>
            <InputNumber @bind-Value="Form!.DipDegrees" id="f-dip" class="enki-form-input"
                         step="0.01" required />
            <div class="enki-form-hint">Signed degrees; positive = downward in the northern hemisphere.</div>
            <ValidationMessage For="() => Form.DipDegrees" class="enki-form-error" />
        </div>

        <div class="enki-form-group">
            <label class="enki-form-label required" for="f-decl">Declination (°)</label>
            <InputNumber @bind-Value="Form!.DeclinationDegrees" id="f-decl" class="enki-form-input"
                         step="0.01" required />
            <div class="enki-form-hint">Signed degrees; positive = east of true north.</div>
            <ValidationMessage For="() => Form.DeclinationDegrees" class="enki-form-error" />
        </div>

        @* Gradient-only fields are visible when Type=Gradient. The
           server filters them out for Rotary/Passive even if a chatty
           client sends them, so it's a UX nicety more than a
           correctness guard. *@
        @if (Form?.Type == "Gradient")
        {
            <div class="enki-form-group">
                <label class="enki-form-label" for="f-bridle">Bridle length</label>
                <InputNumber @bind-Value="Form.BridleLength" id="f-bridle" class="enki-form-input"
                             step="0.01" />
                <div class="enki-form-hint">Metres. Gradient-only.</div>
                <ValidationMessage For="() => Form.BridleLength" class="enki-form-error" />
            </div>

            <div class="enki-form-group">
                <label class="enki-form-label" for="f-current">Current injection</label>
                <InputNumber @bind-Value="Form.CurrentInjection" id="f-current" class="enki-form-input"
                             step="0.01" />
                <div class="enki-form-hint">Amperes. Gradient-only.</div>
                <ValidationMessage For="() => Form.CurrentInjection" class="enki-form-error" />
            </div>
        }

        @* Tool selection — Gradient/Rotary only. Optional at creation;
           assigning a tool triggers the calibration snapshot.
           Passive runs don't carry a calibration. *@
        @if (Form?.Type != "Passive")
        {
            <div class="enki-form-group">
                <label class="enki-form-label" for="f-tool">Tool</label>
                <InputSelect @bind-Value="Form!.ToolIdString" id="f-tool" class="enki-form-input">
                    <option value="">(assign later)</option>
                    @if (_tools is not null)
                    {
                        @foreach (var t in _tools)
                        {
                            <option value="@t.Id">@t.DisplayName &mdash; FW @t.FirmwareVersion (@t.CalibrationCount cal@(t.CalibrationCount == 1 ? "" : "s"))</option>
                        }
                    }
                </InputSelect>
                <div class="enki-form-hint">
                    Optional at creation. Shots and Logs can only be added once a tool is assigned —
                    assigning a tool snapshots its latest calibration into this tenant.
                </div>
            </div>
        }

        <div class="enki-form-group">
            <label class="enki-form-label" for="f-start">Start timestamp</label>
            <InputDate @bind-Value="Form!.StartTimestamp" id="f-start" class="enki-form-input"
                       Type="InputDateType.DateTimeLocal" />
            <ValidationMessage For="() => Form.StartTimestamp" class="enki-form-error" />
        </div>

        <div class="enki-form-group">
            <label class="enki-form-label" for="f-end">End timestamp</label>
            <InputDate @bind-Value="Form!.EndTimestamp" id="f-end" class="enki-form-input"
                       Type="InputDateType.DateTimeLocal" />
            <ValidationMessage For="() => Form.EndTimestamp" class="enki-form-error" />
        </div>

        <div class="enki-form-actions">
            <button type="submit" class="enki-button enki-button-primary">Create run</button>
            <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/runs")">Cancel</NavLink>
        </div>
    </EditForm>
</div>

@code {
    [Parameter] public string TenantCode { get; set; } = "";
    [Parameter] public Guid   JobId      { get; set; }

    [SupplyParameterFromForm]
    public CreateFormModel? Form { get; set; }

    private string? _submitError;
    private List<ToolSummaryDto>? _tools;

    protected override async Task OnInitializedAsync()
    {
        Form ??= new CreateFormModel();

        // Pull the active-tools list once for the dropdown. Failure to
        // load is non-fatal — the user can still type other fields and
        // submit with no tool assigned.
        var client = HttpClientFactory.CreateClient("EnkiApi");
        var result = await client.GetAsync<List<ToolSummaryDto>>("tools?status=Active");
        _tools = result.IsSuccess ? result.Value : new List<ToolSummaryDto>();
    }

    private async Task Submit()
    {
        if (Form is null) return;
        _submitError = null;

        var client = HttpClientFactory.CreateClient("EnkiApi");
        var dto = new CreateRunDto(
            Name:                Form.Name,
            Description:         Form.Description,
            Type:                Form.Type,
            StartDepth:          Form.StartDepth,
            EndDepth:            Form.EndDepth,
            BTotalNanoTesla:     Form.BTotalNanoTesla,
            DipDegrees:          Form.DipDegrees,
            DeclinationDegrees:  Form.DeclinationDegrees,
            BridleLength:        Form.Type == "Gradient" ? Form.BridleLength     : null,
            CurrentInjection:    Form.Type == "Gradient" ? Form.CurrentInjection : null,
            ToolId:              ParseToolId(Form),
            StartTimestamp:      ToOffset(Form.StartTimestamp),
            EndTimestamp:        ToOffset(Form.EndTimestamp));

        var result = await client.PostAsync<CreateRunDto, RunDetailDto>(
            $"tenants/{TenantCode}/jobs/{JobId}/runs", dto);

        if (result.IsSuccess)
        {
            Nav.NavigateTo($"/tenants/{TenantCode}/jobs/{JobId}/runs/{result.Value.Id}");
            return;
        }

        _submitError = result.Error.AsAlertText();
    }

    private static Guid? ParseToolId(CreateFormModel form)
    {
        if (form.Type == "Passive") return null;
        if (string.IsNullOrWhiteSpace(form.ToolIdString)) return null;
        return Guid.TryParse(form.ToolIdString, out var g) ? g : null;
    }

    private static DateTimeOffset? ToOffset(DateTime? d) =>
        d.HasValue ? new DateTimeOffset(d.Value, TimeSpan.Zero) : null;

    public sealed class CreateFormModel
    {
        [Required(ErrorMessage = "Name is required.")]
        [MaxLength(100, ErrorMessage = "Name must be 100 chars or fewer.")]
        public string Name { get; set; } = "";

        [Required(ErrorMessage = "Description is required.")]
        [MaxLength(500, ErrorMessage = "Description must be 500 chars or fewer.")]
        public string Description { get; set; } = "";

        [Required(ErrorMessage = "Run type is required.")]
        public string Type { get; set; } = "Gradient";

        [Required, Range(0d, 100_000d)]
        public double StartDepth { get; set; }

        [Required, Range(0d, 100_000d)]
        public double EndDepth { get; set; }

        // Magnetics — required.
        [Required(ErrorMessage = "BTotal is required.")]
        [Range(20_000d, 80_000d, ErrorMessage = "BTotal must be between 20,000 and 80,000 nT.")]
        public double BTotalNanoTesla { get; set; } = 50_000;   // pre-fill with a sensible default

        [Required(ErrorMessage = "Dip is required.")]
        [Range(-90d, 90d, ErrorMessage = "Dip must be between -90 and 90 degrees.")]
        public double DipDegrees { get; set; } = 60;

        [Required(ErrorMessage = "Declination is required.")]
        [Range(-180d, 180d, ErrorMessage = "Declination must be between -180 and 180 degrees.")]
        public double DeclinationDegrees { get; set; }

        [Range(0d, 100d)]
        public double? BridleLength { get; set; }

        [Range(0d, 1_000d)]
        public double? CurrentInjection { get; set; }

        /// <summary>
        /// Bound to the tool dropdown. Empty string = "(assign later)".
        /// Submit parses to Guid? before posting.
        /// </summary>
        public string? ToolIdString { get; set; }

        public DateTime? StartTimestamp { get; set; }
        public DateTime? EndTimestamp { get; set; }
    }
}
