@rendermode InteractiveServer
@using SDI.Enki.Shared.Logs

@*
    Logs under a Run. A Log is one captured "log activity" — each Run
    can have many; each Log carries a captured binary, an optional
    config blob, and any result files (LAS or similar) Marduk produced.

    Phase 2 surface: list + create + edit identity. Binary upload /
    config set / result-file attach happen on the per-Log detail page
    (lands in a follow-up slice).
*@

<PageTitle>Enki &mdash; Logs (Run @ShortRunId)</PageTitle>

<div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; flex-wrap: wrap;">
    <div style="flex: 1; min-width: 280px;">
        <h1 class="enki-section-title">
            Logs
            <span class="enki-mono" style="font-size: 0.65em; opacity: 0.65; margin-left: 0.5rem;">
                @TenantCode &middot; Run @ShortRunId
            </span>
        </h1>
        <p class="enki-section-subtitle">
            Captured log activities under this run. Each log holds
            shot identity, an optional calibration link, the captured
            binary, a config blob, and result files Marduk produced.
        </p>
    </div>
    <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
        <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/runs/{RunId}")">Back to run</NavLink>
        <NavLink class="enki-button enki-button-primary"
                 href="@($"/tenants/{TenantCode}/jobs/{JobId}/runs/{RunId}/logs/new")">
            + New log
        </NavLink>
    </div>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_logs is null)
{
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Fetching logs from API&hellip;</div>
    </div>
}
else if (_logs.Count == 0)
{
    <p class="enki-section-subtitle" style="margin-top: 1.5rem;">
        No logs recorded yet under this run. Click <strong>+ New log</strong>
        to add one.
    </p>
}
else
{
    <EnkiListGrid TValue="LogSummaryDto"
                  DataSource="_logs"
                  ElasticField="@nameof(LogSummaryDto.ShotName)">
        <GridColumn Field="@nameof(LogSummaryDto.ShotName)" HeaderText="Shot name" MinWidth="200">
            <Template>
                @{ var row = context as LogSummaryDto; }
                @if (row is not null)
                {
                    <a class="enki-row-link"
                       href="@($"/tenants/{TenantCode}/jobs/{JobId}/runs/{RunId}/logs/{row.Id}")">@row.ShotName</a>
                }
            </Template>
        </GridColumn>
        <GridColumn Field="@nameof(LogSummaryDto.FileTime)" HeaderText="File time"
                    Format="yyyy-MM-dd HH:mm" Type="ColumnType.DateTime">
            <Template>
                @{ var row = context as LogSummaryDto; }
                @if (row is not null)
                {
                    <span class="enki-mono">@row.FileTime.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                }
            </Template>
        </GridColumn>
        <GridColumn Field="@nameof(LogSummaryDto.CalibrationId)" HeaderText="Calibration">
            <Template>
                @{ var row = context as LogSummaryDto; }
                @if (row is not null)
                {
                    @(row.CalibrationId?.ToString() ?? "(unset)")
                }
            </Template>
        </GridColumn>
        <GridColumn Field="@nameof(LogSummaryDto.HasBinary)" HeaderText="Binary">
            <Template>
                @{ var row = context as LogSummaryDto; }
                @if (row is not null)
                {
                    @(row.HasBinary ? "Uploaded" : "(none)")
                }
            </Template>
        </GridColumn>
        <GridColumn Field="@nameof(LogSummaryDto.ResultFileCount)" HeaderText="Result files" />
    </EnkiListGrid>
}

