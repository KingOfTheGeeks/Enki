<PageTitle>Enki &mdash; Edit Shot #@ShotId</PageTitle>

<h1 class="enki-section-title">Edit Shot</h1>
<p class="enki-section-subtitle">
    Editing the identity columns of an existing shot. Binary
    upload, config, gyro, and result management happen on the
    detail page — this form covers ShotName / FileTime /
    Calibration only.
</p>

@if (_loadError is not null)
{
    <div class="alert alert-danger">@_loadError</div>
    <div class="enki-form-actions" style="border-top: none; margin-top: 1rem; padding-top: 0;">
        <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/runs/{RunId}/shots")">Back to shots</NavLink>
    </div>
}
else if (Form is null)
{
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Loading shot&hellip;</div>
    </div>
}
else
{
    @if (_submitError is not null)
    {
        <div class="alert alert-danger">@_submitError</div>
    }

    <div class="enki-card" style="max-width: 620px; margin-top: 1.25rem;">
        <EditForm Model="Form" OnValidSubmit="Submit" FormName="edit-shot"
                  class="enki-form" Enhance="true">
            <DataAnnotationsValidator />
            <ValidationSummary class="enki-validation-summary" />

            @* Hidden RowVersion round-trip — see feedback_blazor_ssr_form_roundtrip memory. *@
            <InputText @bind-Value="Form.RowVersion" style="display:none" />

            <div class="enki-form-group">
                <label class="enki-form-label">Shot #</label>
                <div class="enki-form-input" style="opacity: 0.6; cursor: not-allowed;">@ShotId</div>
                <div class="enki-form-hint">Immutable.</div>
            </div>

            <div class="enki-form-group">
                <label class="enki-form-label required" for="f-shot">Shot name</label>
                <InputText @bind-Value="Form.ShotName" id="f-shot" class="enki-form-input"
                           required maxlength="200" />
                <ValidationMessage For="() => Form.ShotName" class="enki-form-error" />
            </div>

            <div class="enki-form-group">
                <label class="enki-form-label required" for="f-time">File time</label>
                <InputDate @bind-Value="Form.FileTime" id="f-time" class="enki-form-input"
                           Type="InputDateType.DateTimeLocal" required />
                <ValidationMessage For="() => Form.FileTime" class="enki-form-error" />
            </div>

            <div class="enki-form-group">
                <label class="enki-form-label" for="f-cal">Calibration</label>
                <InputSelect @bind-Value="Form.CalibrationIdString" id="f-cal" class="enki-form-input">
                    <option value="">(none)</option>
                    @if (_calibrations is not null)
                    {
                        @foreach (var c in _calibrations)
                        {
                            <option value="@c.Id">@c.DisplayName@(c.IsNominal ? " (nominal)" : "")</option>
                        }
                    }
                </InputSelect>
                <div class="enki-form-hint">
                    Snapshots of the run's tool calibrations.
                    @if (_calibrations is { Count: 0 })
                    {
                        <span> Run has no calibration snapshots yet — assign a tool on the run detail page.</span>
                    }
                </div>
                <ValidationMessage For="() => Form.CalibrationIdString" class="enki-form-error" />
            </div>

            <div class="enki-form-actions">
                <button type="submit" class="enki-button enki-button-primary">Save changes</button>
                <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/runs/{RunId}/shots/{ShotId}")">
                    Cancel
                </NavLink>
            </div>
        </EditForm>
    </div>
}

