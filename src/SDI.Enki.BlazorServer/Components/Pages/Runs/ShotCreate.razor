@rendermode InteractiveServer

@*
    Upload-a-shot. Two-stage:

    Stage 1 — pick the capture binary. We buffer the bytes in
    memory and pre-populate ShotName (from filename) + FileTime
    (from the file's modified timestamp).

    Stage 2 — review/edit the metadata, optionally fill in a typed
    Configuration / Solution form. Submit chains:
      create → binary → config (if filled) → result (if filled)
    and lands on the shot detail page.

    Configuration / Solution editors are typed forms — no JSON
    surfaces in the UI. The editors serialize themselves on
    submit and the JSON is what hits PUT /shots/{id}/config and
    PUT /shots/{id}/result. This shape will rarely be hand-typed
    in production (automatic import takes over), but it must
    work cleanly when it is.
*@

<PageTitle>Enki &mdash; Upload Shot (Run @ShortRunId)</PageTitle>

<h1 class="enki-section-title">Upload Shot</h1>
<p class="enki-section-subtitle">
    Pick the capture binary first &mdash; we'll pull the shot
    name from the filename and the file time from the file's
    modified timestamp. You can edit either before submitting,
    and optionally fill in a @ConfigShapeName or @SolutionShapeName.
</p>

@if (_buffered is null)
{
    @* Stage 1 — binary picker only *@
    <div class="enki-card" style="max-width: 720px; margin-top: 1.25rem; padding: 1.25rem;">
        <label class="enki-button enki-button-primary" style="cursor: @(_busy ? "wait" : "pointer");">
            @(_busy ? "Reading…" : "Pick capture binary")
            <InputFile OnChange="HandleBinaryPickedAsync"
                       disabled="@_busy"
                       style="display: none;"
                       accept=".bin,application/octet-stream" />
        </label>
        <div class="enki-form-hint" style="margin-top: 0.75rem;">
            Up to @FormatBytes(MaxBinaryBytes). The file is held in memory
            until you submit; cancel by navigating away.
        </div>
        @if (_pickError is not null)
        {
            <div class="alert alert-danger" style="margin-top: 0.75rem;">@_pickError</div>
        }
    </div>

    <div class="enki-form-actions" style="border-top: none; margin-top: 1rem; padding-top: 0;">
        <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/runs/{RunId}/shots")">Cancel</NavLink>
    </div>
}
else
{
    @* Stage 2 — file is in hand, edit metadata + optional typed
       config / solution, submit *@
    @if (_submitError is not null)
    {
        <div class="alert alert-danger">@_submitError</div>
    }

    <div class="enki-card" style="max-width: 720px; margin-top: 1.25rem;">
        <EditForm Model="Form" OnValidSubmit="SubmitAsync" FormName="upload-shot"
                  class="enki-form">
            <DataAnnotationsValidator />
            <ValidationSummary class="enki-validation-summary" />

            <div class="enki-form-group">
                <label class="enki-form-label">Selected file</label>
                <div class="enki-form-input enki-mono" style="opacity: 0.85;">
                    @_buffered.FileName
                    <span class="enki-form-hint" style="margin-left: 0.5rem;">
                        @FormatBytes(_buffered.Bytes.Length)
                    </span>
                </div>
                <div class="enki-form-hint">
                    <button type="button" class="enki-button" style="padding: 0.15rem 0.5rem;"
                            @onclick="ClearBuffered" disabled="@_busy">
                        Pick a different file
                    </button>
                </div>
            </div>

            <div class="enki-form-group">
                <label class="enki-form-label required" for="f-shot">Shot name</label>
                <InputText @bind-Value="Form!.ShotName" id="f-shot" class="enki-form-input"
                           required maxlength="200" />
                <div class="enki-form-hint">Pre-filled from the filename. Edit if needed.</div>
                <ValidationMessage For="() => Form.ShotName" class="enki-form-error" />
            </div>

            <div class="enki-form-group">
                <label class="enki-form-label required" for="f-time">File time</label>
                <InputDate @bind-Value="Form!.FileTime" id="f-time" class="enki-form-input"
                           Type="InputDateType.DateTimeLocal" required />
                <div class="enki-form-hint">Pre-filled from the file's modified timestamp.</div>
                <ValidationMessage For="() => Form.FileTime" class="enki-form-error" />
            </div>

            @* ---------- Optional Configuration ---------- *@
            <div class="enki-form-group">
                <label class="enki-form-label">@ConfigShapeName (optional)</label>
                @if (!_includeConfig)
                {
                    <button type="button" class="enki-button" disabled="@_busy"
                            @onclick="() => _includeConfig = true">
                        + Add @ConfigShapeName
                    </button>
                    <div class="enki-form-hint">
                        Pre-computed @ConfigShapeName. Leave off if the calc
                        pipeline should build it from the run's tool.
                    </div>
                }
                else
                {
                    <div class="enki-card" style="padding: 0.75rem; margin-top: 0.4rem;">
                        @if (_runType == "Gradient")
                        {
                            <GradientConfigurationEditor @ref="_gradientConfigEditor" />
                        }
                        else if (_runType == "Rotary")
                        {
                            <RotatingDipoleConfigurationEditor @ref="_rotaryConfigEditor" />
                        }
                        else
                        {
                            <p class="enki-form-hint">
                                @ConfigShapeName editor is not available for
                                this run type. Use config import instead.
                            </p>
                        }
                        <div style="margin-top: 0.5rem;">
                            <button type="button" class="enki-button" style="padding: 0.15rem 0.5rem;"
                                    @onclick="() => _includeConfig = false" disabled="@_busy">
                                Remove @ConfigShapeName
                            </button>
                        </div>
                    </div>
                }
            </div>

            @* ---------- Optional Solution ---------- *@
            <div class="enki-form-group">
                <label class="enki-form-label">@SolutionShapeName (optional)</label>
                @if (!_includeSolution)
                {
                    <button type="button" class="enki-button" disabled="@_busy"
                            @onclick="() => _includeSolution = true">
                        + Add @SolutionShapeName
                    </button>
                    <div class="enki-form-hint">
                        Pre-computed @SolutionShapeName. When supplied, the
                        shot lands with status Success and is not queued
                        for recalc.
                    </div>
                }
                else
                {
                    <div class="enki-card" style="padding: 0.75rem; margin-top: 0.4rem;">
                        @if (_runType == "Gradient")
                        {
                            <GradientSolutionEditor @ref="_gradientSolutionEditor" />
                        }
                        else if (_runType == "Rotary")
                        {
                            <RotatingDipoleSolutionEditor @ref="_rotarySolutionEditor" />
                        }
                        else
                        {
                            <p class="enki-form-hint">
                                @SolutionShapeName editor is not available for
                                this run type. Use solution import instead.
                            </p>
                        }
                        <div style="margin-top: 0.5rem;">
                            <button type="button" class="enki-button" style="padding: 0.15rem 0.5rem;"
                                    @onclick="() => _includeSolution = false" disabled="@_busy">
                                Remove @SolutionShapeName
                            </button>
                        </div>
                    </div>
                }
            </div>

            <div class="enki-form-actions">
                <button type="submit" class="enki-button enki-button-primary" disabled="@_busy">
                    @(_busy ? "Uploading…" : "Create shot + upload binary")
                </button>
                <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/runs/{RunId}/shots")">
                    Cancel
                </NavLink>
            </div>
        </EditForm>
    </div>
}

