@rendermode InteractiveServer
@using SDI.Enki.Core.TenantDb.Runs
@using SDI.Enki.Core.TenantDb.Runs.Enums

@*
    Run detail. Identity + lifecycle buttons + Logs tile + audit tile.
    Lifecycle buttons render dynamically from RunLifecycle.TargetsFor()
    so adding a transition is one entry in the map — no template
    surgery here.
*@

<PageTitle>Enki &mdash; Run @ShortRunId (@TenantCode)</PageTitle>

@if (_error is not null)
{
    <PageHeader Title="@($"Run {ShortRunId}")">
        <Actions>
            <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/runs")">Back to runs</NavLink>
        </Actions>
    </PageHeader>
    <div class="alert alert-danger">@_error</div>
}
else if (_run is null)
{
    <PageHeader Title="@($"Run {ShortRunId}")">
        <Actions>
            <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/runs")">Back to runs</NavLink>
        </Actions>
    </PageHeader>
    <div class="enki-loading-block" role="status" aria-live="polite">
        <div class="enki-spinner" aria-hidden="true"></div>
        <div class="enki-loading-text">Loading run&hellip;</div>
    </div>
}
else
{
    var currentStatus = ParseStatus(_run.Status);
    var transitions = currentStatus is null
        ? Array.Empty<RunStatus>()
        : RunLifecycle.TargetsFor(currentStatus);
    var isEditable = _run.Status != "Completed" && _run.Status != "Cancelled";

    <PageHeader Title="@_run.Name">
        <TitleSuffix>
            <span class="enki-status-pill @TypeClass(_run.Type)">@_run.Type</span>
            <span class="enki-status-pill @StatusClass(_run.Status)">@_run.Status</span>
        </TitleSuffix>
        <Subtitle>
            <span class="enki-mono">@TenantCode</span> &middot;
            <span class="enki-mono">Run @ShortRunId</span>
        </Subtitle>
        <Actions>
            <NavLink class="enki-button" href="@($"/tenants/{TenantCode}/jobs/{JobId}/runs")">Back to runs</NavLink>

            @* Lifecycle buttons rendered from RunLifecycle.TargetsFor() —
               adding a transition (e.g. "Restart" out of Suspended) is a
               map entry; the button shows up automatically. *@
            @foreach (var target in transitions)
            {
                <form method="post"
                      action="@($"/tenants/{TenantCode}/jobs/{JobId}/runs/{_run.Id}/{TransitionAction(target)}")"
                      style="display:inline">
                    <AntiforgeryToken />
                    @* RowVersion pins the optimistic-concurrency check on the
                       WebApi side; see LifecycleTransitionDto. *@
                    <input type="hidden" name="rowVersion" value="@_run.RowVersion" />
                    <button type="submit"
                            class="enki-button @TransitionButtonClass(target)"
                            onclick="@TransitionConfirm(target, _run.Name)">
                        @TransitionLabel(target)
                    </button>
                </form>
            }

            @if (isEditable)
            {
                <NavLink class="enki-button enki-button-primary"
                         href="@($"/tenants/{TenantCode}/jobs/{JobId}/runs/{_run.Id}/edit")">
                    Edit
                </NavLink>
            }
        </Actions>
    </PageHeader>

    <div class="enki-detail-grid">
        <div class="enki-detail-label">Description</div>
        <div class="enki-detail-value">@_run.Description</div>

        <div class="enki-detail-label">Type</div>
        <div class="enki-detail-value">@_run.Type</div>

        <div class="enki-detail-label">Status</div>
        <div class="enki-detail-value">@_run.Status</div>

        <div class="enki-detail-label">Start MD</div>
        <div class="enki-detail-value enki-mono">@_run.StartDepth.ToString("N1")</div>

        <div class="enki-detail-label">End MD</div>
        <div class="enki-detail-value enki-mono">@_run.EndDepth.ToString("N1")</div>

        @if (_run.StartTimestamp is { } st)
        {
            <div class="enki-detail-label">Started</div>
            <div class="enki-detail-value">@st.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
        }
        @if (_run.EndTimestamp is { } et)
        {
            <div class="enki-detail-label">Ended</div>
            <div class="enki-detail-value">@et.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
        }

        @if (_run.Type == "Gradient" && _run.BridleLength is { } bl)
        {
            <div class="enki-detail-label">Bridle length</div>
            <div class="enki-detail-value enki-mono">@bl.ToString("N3") m</div>
        }
        @if (_run.Type == "Gradient" && _run.CurrentInjection is { } ci)
        {
            <div class="enki-detail-label">Current injection</div>
            <div class="enki-detail-value enki-mono">@ci.ToString("N2") A</div>
        }

        @* Tool + snapshot calibration — Gradient/Rotary only.
           Tool is optional at run creation but required before
           shots/logs can be added; the link goes to the master Tool
           detail. The calibration line shows the snapshot row's date
           + serial as resolved server-side. *@
        @if (_run.Type != "Passive")
        {
            <div class="enki-detail-label">Tool</div>
            <div class="enki-detail-value enki-mono">
                @if (_run.ToolDisplayName is { } toolName)
                {
                    <span>@toolName</span>
                }
                else
                {
                    <span class="enki-dash">— (none — assign before adding shots)</span>
                }
            </div>

            @if (_run.SnapshotCalibrationDisplayName is { } calDisplay)
            {
                <div class="enki-detail-label">Calibration</div>
                <div class="enki-detail-value enki-mono">@calDisplay</div>
            }
        }

        @* Magnetic reference — required, present on every run. *@
        <div class="enki-detail-label">BTotal</div>
        <div class="enki-detail-value enki-mono">@_run.BTotalNanoTesla.ToString("N0") nT</div>
        <div class="enki-detail-label">Dip</div>
        <div class="enki-detail-value enki-mono">@_run.DipDegrees.ToString("N2")°</div>
        <div class="enki-detail-label">Declination</div>
        <div class="enki-detail-value enki-mono">@_run.DeclinationDegrees.ToString("N2")°</div>

        <div class="enki-detail-label">Created</div>
        <div class="enki-detail-value">
            @_run.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
            @if (!string.IsNullOrWhiteSpace(_run.CreatedBy))
            {
                <span class="enki-form-hint" style="margin-left: 0.5rem;">by @_run.CreatedBy</span>
            }
        </div>

        @if (_run.UpdatedAt is { } updated)
        {
            <div class="enki-detail-label">Updated</div>
            <div class="enki-detail-value">
                @updated.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                @if (!string.IsNullOrWhiteSpace(_run.UpdatedBy))
                {
                    <span class="enki-form-hint" style="margin-left: 0.5rem;">by @_run.UpdatedBy</span>
                }
            </div>
        }
    </div>

    <h2 class="enki-section-title" style="margin-top: 2rem; font-size: 1.25rem;">Data</h2>
    <div class="enki-stat-grid">
        @* Shots tile — meaningful only on Gradient / Rotary; Passive
           runs don't have shots (their data attaches to the Run row
           directly via the Passive section below). *@
        @if (_run.Type != "Passive")
        {
            <a class="enki-stat-card enki-link-card"
               href="@($"/tenants/{TenantCode}/jobs/{JobId}/runs/{_run.Id}/shots")">
                <div class="enki-stat-value">@_run.ShotCount.ToString("D2")</div>
                <div class="enki-stat-label">Shots</div>
            </a>
        }
        <a class="enki-stat-card enki-link-card"
           href="@($"/tenants/{TenantCode}/jobs/{JobId}/runs/{_run.Id}/logs")">
            <div class="enki-stat-value">@_run.LogCount.ToString("D2")</div>
            <div class="enki-stat-label">Logs</div>
        </a>
    </div>

    @* ---------- Passive capture workbench ---------- *@
    @if (_run.Type == "Passive")
    {
        <h2 class="enki-section-title" style="margin-top: 2rem; font-size: 1.25rem;">
            Passive capture
            @if (_run.PassiveResultStatus is { } status)
            {
                <span class="enki-status-pill @ResultClass(status)">@status</span>
            }
        </h2>
        <p class="enki-section-subtitle">
            Passive runs hold their captured data on the run itself
            rather than per-shot. Optional binary up to
            @FormatBytes(MaxPassiveBytes) plus a JSON config Marduk
            consumes; result is computed server-side.
        </p>

        @* Binary slot *@
        <div class="enki-card" style="padding: 1rem; margin-top: 0.5rem;">
            @if (_run.HasPassiveBinary)
            {
                <div class="enki-detail-grid">
                    <div class="enki-detail-label">Filename</div>
                    <div class="enki-detail-value enki-mono">@_run.PassiveBinaryName</div>
                    <div class="enki-detail-label">Uploaded</div>
                    <div class="enki-detail-value">@(_run.PassiveBinaryUploadedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm"))</div>
                </div>
                <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.75rem;">
                    <button type="button" class="enki-button"
                            disabled="@_busy"
                            @onclick="DownloadPassiveBinaryAsync">
                        Download
                    </button>
                    <label class="enki-button" style="cursor: @(_busy ? "wait" : "pointer");">
                        Replace
                        <InputFile OnChange="UploadPassiveBinaryAsync"
                                   disabled="@_busy"
                                   style="display: none;" />
                    </label>
                    <button type="button" class="enki-button enki-button-danger"
                            disabled="@_busy"
                            @onclick="DeletePassiveBinaryWithConfirmAsync">
                        Delete
                    </button>
                </div>
            }
            else
            {
                <p class="enki-section-subtitle" style="margin: 0 0 0.75rem 0;">
                    No passive binary uploaded yet. The slot is
                    optional — a passive run with config + computed
                    result but no captured file is valid.
                </p>
                <label class="enki-button enki-button-primary" style="cursor: @(_busy ? "wait" : "pointer");">
                    @(_busy ? "Uploading…" : "Upload binary")
                    <InputFile OnChange="UploadPassiveBinaryAsync"
                               disabled="@_busy"
                               style="display: none;" />
                </label>
            }

            @if (_passiveBinaryMessage is not null)
            {
                <div class="alert @_passiveBinaryAlertClass" style="margin-top: 0.75rem;">
                    @_passiveBinaryMessage
                </div>
            }
        </div>

        @* Config + result *@
        <div class="enki-card" style="padding: 1rem; margin-top: 0.75rem;">
            <h3 style="margin-top: 0;">Config (JSON)</h3>
            <textarea class="enki-form-input" rows="6"
                      placeholder='{ "...": "..." }'
                      @bind="_passiveConfigDraft"
                      @bind:event="oninput"
                      disabled="@_busy"></textarea>
            <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
                <button type="button" class="enki-button enki-button-primary"
                        disabled="@_busy"
                        @onclick="SavePassiveConfigAsync">
                    Save config
                </button>
                <button type="button" class="enki-button"
                        disabled="@_busy"
                        @onclick="RevertPassiveConfig">
                    Revert
                </button>
                @if (_run.PassiveConfigUpdatedAt is { } cu)
                {
                    <span class="enki-form-hint" style="margin-left: auto; align-self: center;">
                        Last saved @cu.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                    </span>
                }
            </div>

            @if (_passiveConfigMessage is not null)
            {
                <div class="alert @_passiveConfigAlertClass" style="margin-top: 0.75rem;">
                    @_passiveConfigMessage
                </div>
            }

            <h3 style="margin-top: 1.5rem;">Result</h3>
            @if (_run.PassiveResultJson is { } resultJson)
            {
                <pre class="enki-mono" style="background: rgba(255,255,255,0.04); padding: 0.5rem; max-height: 320px; overflow: auto;">@resultJson</pre>
                <div class="enki-form-hint">
                    Computed @(_run.PassiveResultComputedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm"))
                    @if (!string.IsNullOrWhiteSpace(_run.PassiveResultMardukVersion))
                    {
                        <text>by Marduk @_run.PassiveResultMardukVersion</text>
                    }
                </div>
            }
            else if (_run.PassiveResultStatus == "Failed")
            {
                <div class="alert alert-danger">
                    <strong>Calc failed.</strong> @_run.PassiveResultError
                </div>
            }
            else
            {
                <p class="enki-section-subtitle" style="margin: 0;">
                    @(_run.PassiveResultStatus switch
                    {
                        "Pending"   => "Calc is pending — the future Marduk service will pick this up.",
                        "Computing" => "Marduk is computing now.",
                        _           => "No result yet — set a config (and optionally a binary) to queue calc.",
                    })
                </p>
            }
        </div>
    }

    <AuditHistoryTile TenantCode="@TenantCode"
                      EntityType="Run"
                      EntityId="@_run.Id.ToString()"
                      FriendlyEntityName="run" />
}

