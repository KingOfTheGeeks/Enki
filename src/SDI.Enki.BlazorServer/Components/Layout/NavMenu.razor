@* Unified primary sidebar. Single nav across the whole app — no
   separate AdminNavMenu sibling that swaps in on /admin/* routes
   (that previous shape made the sidebar shape change mid-navigation).

   Five groups, ordered by audience reach (broadest first):

     OVERVIEW   — personal landing page, every signed-in user.
     TENANTS    — cross-tenant browsing + per-tenant drill-in. Hidden
                  cross-tenant link for Tenant-type users (bound to
                  one tenant). Members sub-link gated by
                  CanManageTenantMembersAsync against the URL tenant.
     FLEET      — cross-tenant equipment registry (Tools), read-only
                  for non-admins.
     LICENSING  — admins, Supervisor+ Team users, and any user with
                  the explicit 'licensing' capability claim. Lives in
                  its own group rather than under SYSTEM because the
                  audience is broader than admin-only.
     SYSTEM     — enki-admin-only operations (Users, Settings,
                  system-level Audit). The whole group is hidden for
                  non-admins via AuthorizeView Roles=enki-admin.

   Per-route Authorize attributes still gate access — the sidebar just
   hides links the current user can't reach. Defense-in-depth: a
   crafted URL still gets a 403 even if the link is rendered.

   Icons are inline SVG so they inherit currentColor and no webfont ships.
*@

<nav class="enki-nav" aria-label="Primary">

    @* ---- OVERVIEW ---- *@
    <div class="enki-nav-group">
        <div class="enki-nav-label">Overview</div>

        <NavLink class="enki-nav-item" href="" Match="NavLinkMatch.All">
            <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="1.5"
                 stroke-linecap="round" stroke-linejoin="round"
                 aria-hidden="true">
                <path d="M3 12 L12 3 L21 12" />
                <path d="M5 10 V21 H19 V10" />
                <path d="M10 21 V15 H14 V21" />
            </svg>
            Home
        </NavLink>
    </div>

    <AuthorizeView>
        <Authorized>

            @* ---- TENANTS ---- *@
            <div class="enki-nav-group">
                <div class="enki-nav-label">
                    Tenants
                    @if (_tenantCode is { Length: > 0 } && _canAccessTenant)
                    {
                        <span class="enki-nav-scope" title="Current tenant">@_tenantCode</span>
                    }
                </div>

                @* Tenant-type users are bound to a single tenant — the
                   "All Tenants" listing isn't meaningful for them and
                   the route would 403 anyway. Hide for them; Team-side
                   users (Field/Office/Supervisor) and admins always
                   see the cross-tenant index. *@
                @if (!Capabilities.IsTenantUser)
                {
                    <NavLink class="enki-nav-item" href="tenants" Match="NavLinkMatch.All">
                        <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5"
                             stroke-linecap="round" stroke-linejoin="round"
                             aria-hidden="true">
                            <path d="M3 20 V9 L9 5 V9 L15 5 V9 L21 7 V20" />
                            <path d="M3 20 H21" />
                            <path d="M8 20 V15 H11 V20" />
                            <path d="M14 20 V15 H17 V20" />
                        </svg>
                        All Tenants
                    </NavLink>
                }

                @* Tenant-scoped sub-nav (Overview / Jobs / Members /
                   Audit) only makes sense for users with access to the
                   tenant in URL scope. Without this gate, a non-member
                   typing /tenants/PERMIAN into the address bar gets a
                   tenant shell that pretends they're inside it — the
                   body shows "Forbidden" but the sidebar lists the
                   per-tenant pages anyway. _canAccessTenant is probed
                   in RefreshTenantScopedCapabilitiesAsync via
                   IUserCapabilities.CanAccessTenantAsync — same source
                   the WebApi uses for CanAccessTenant. *@
                @if (_tenantCode is { Length: > 0 } && _canAccessTenant)
                {
                    <NavLink class="enki-nav-item"
                             href="@($"tenants/{_tenantCode}")"
                             Match="NavLinkMatch.All">
                        <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5"
                             stroke-linecap="round" stroke-linejoin="round"
                             aria-hidden="true">
                            <circle cx="12" cy="12" r="8" />
                            <path d="M8 12 H16 M12 8 V16" />
                        </svg>
                        Overview
                    </NavLink>

                    <NavLink class="enki-nav-item"
                             href="@($"tenants/{_tenantCode}/jobs")"
                             Match="NavLinkMatch.All">
                        <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5"
                             stroke-linecap="round" stroke-linejoin="round"
                             aria-hidden="true">
                            <path d="M4 7 H20 V20 H4 Z" />
                            <path d="M9 7 V5 Q9 4 10 4 H14 Q15 4 15 5 V7" />
                            <path d="M4 13 H20" />
                        </svg>
                        Jobs
                    </NavLink>

                    @if (_jobId is { } jobId)
                    {
                        <NavLink class="enki-nav-subitem"
                                 href="@($"tenants/{_tenantCode}/jobs/{jobId}")"
                                 Match="NavLinkMatch.All">
                            <span class="enki-nav-subitem-rail" aria-hidden="true"></span>
                            <span class="enki-nav-subitem-label">@(_jobName ?? "Job…")</span>
                        </NavLink>

                        @* Three peer drill-ins under a Job: Wells, Runs, Models.
                           Models is intentionally listed even though the routes
                           don't exist yet — the sidebar shape is the contract
                           for when those pages land. Until then the link is
                           commented out below; the URL parser already extracts
                           a ModelId for the future drill-in marker. *@
                        <NavLink class="enki-nav-item"
                                 href="@($"tenants/{_tenantCode}/jobs/{jobId}/wells")"
                                 Match="NavLinkMatch.Prefix">
                            <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="1.5"
                                 stroke-linecap="round" stroke-linejoin="round"
                                 aria-hidden="true">
                                <circle cx="12" cy="5" r="2" />
                                <path d="M12 7 V20" />
                                <path d="M9 20 H15" />
                            </svg>
                            Wells
                        </NavLink>

                        @if (_wellId is { } wellId)
                        {
                            <NavLink class="enki-nav-subitem"
                                     href="@($"tenants/{_tenantCode}/jobs/{jobId}/wells/{wellId}")"
                                     Match="NavLinkMatch.Prefix">
                                <span class="enki-nav-subitem-rail" aria-hidden="true"></span>
                                <span class="enki-nav-subitem-label">@(_wellName ?? "Well…")</span>
                            </NavLink>
                        }

                        <NavLink class="enki-nav-item"
                                 href="@($"tenants/{_tenantCode}/jobs/{jobId}/runs")"
                                 Match="NavLinkMatch.Prefix">
                            <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="1.5"
                                 stroke-linecap="round" stroke-linejoin="round"
                                 aria-hidden="true">
                                <path d="M12 3 V21" />
                                <path d="M9 7 H15" />
                                <path d="M9 12 H15" />
                                <path d="M9 17 H15" />
                            </svg>
                            Runs
                        </NavLink>

                        @if (_runId is { } runId)
                        {
                            <NavLink class="enki-nav-subitem"
                                     href="@($"tenants/{_tenantCode}/jobs/{jobId}/runs/{runId}")"
                                     Match="NavLinkMatch.Prefix">
                                <span class="enki-nav-subitem-rail" aria-hidden="true"></span>
                                <span class="enki-nav-subitem-label">@(_runName ?? "Run…")</span>
                            </NavLink>
                        }

                        @* Models — slots in here once /tenants/{code}/jobs/{jobId}/models
                           routes land. The URL parser already extracts ModelId so
                           the [Model name] sub-item is one un-commenting away.
                        <NavLink class="enki-nav-item"
                                 href="@($"tenants/{_tenantCode}/jobs/{jobId}/models")"
                                 Match="NavLinkMatch.Prefix">
                            <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="1.5"
                                 stroke-linecap="round" stroke-linejoin="round"
                                 aria-hidden="true">
                                <path d="M4 8 L12 4 L20 8 L12 12 Z" />
                                <path d="M4 12 L12 16 L20 12" />
                                <path d="M4 16 L12 20 L20 16" />
                            </svg>
                            Models
                        </NavLink>

                        @if (_modelId is { } modelId)
                        {
                            <NavLink class="enki-nav-subitem"
                                     href="@($"tenants/{_tenantCode}/jobs/{jobId}/models/{modelId}")"
                                     Match="NavLinkMatch.Prefix">
                                <span class="enki-nav-subitem-rail" aria-hidden="true"></span>
                                <span class="enki-nav-subitem-label">@(_modelName ?? "Model…")</span>
                            </NavLink>
                        }
                        *@
                    }

                    @* Members admin = Supervisor+ tenant member or admin.
                       _canManageMembers is refreshed when the tenant in
                       URL scope changes (see ApplyContextAsync). Hide the
                       link for Field/Office/Tenant users — the page would
                       /forbidden them anyway, this avoids the bounce. *@
                    @if (_canManageMembers)
                    {
                        <NavLink class="enki-nav-item"
                                 href="@($"tenants/{_tenantCode}/members")"
                                 Match="NavLinkMatch.All">
                            <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="1.5"
                                 stroke-linecap="round" stroke-linejoin="round"
                                 aria-hidden="true">
                                <circle cx="9" cy="8" r="3" />
                                <path d="M3 20 Q3 14 9 14 Q15 14 15 20" />
                                <circle cx="17" cy="9" r="2" />
                                <path d="M14 20 Q14 16 17 16 Q21 16 21 20" />
                            </svg>
                            Members
                        </NavLink>
                    }

                    <NavLink class="enki-nav-item"
                             href="@($"tenants/{_tenantCode}/audit")"
                             Match="NavLinkMatch.Prefix">
                        <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5"
                             stroke-linecap="round" stroke-linejoin="round"
                             aria-hidden="true">
                            <path d="M4 6 H16" />
                            <path d="M4 10 H14" />
                            <path d="M4 14 H12" />
                            <circle cx="17" cy="17" r="3" />
                            <path d="M19.5 19.5 L21.5 21.5" />
                        </svg>
                        Audit
                    </NavLink>
                }
            </div>

            @* ---- FLEET ---- *@
            <div class="enki-nav-group">
                <div class="enki-nav-label">Fleet</div>

                <NavLink class="enki-nav-item" href="tools">
                    <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.5"
                         stroke-linecap="round" stroke-linejoin="round"
                         aria-hidden="true">
                        <path d="M14 4 L20 10 L14 16" />
                        <path d="M4 12 H20" />
                        <path d="M6 20 H18" />
                    </svg>
                    Tools
                </NavLink>
            </div>

            @* ---- LICENSING ----
               Visible to admins, Supervisor+ Team users, and any user
               with the explicit 'licensing' capability claim. Sits in
               its own group rather than under SYSTEM because the
               audience is broader than admin-only — most production
               licensing work is done by Office staff with the capability
               grant, not by tech admins.
            *@
            @if (Capabilities.CanManageLicensing)
            {
                <div class="enki-nav-group">
                    <div class="enki-nav-label">Licensing</div>

                    <NavLink class="enki-nav-item" href="licenses">
                        <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5"
                             stroke-linecap="round" stroke-linejoin="round"
                             aria-hidden="true">
                            <rect x="4" y="4" width="16" height="16" rx="2" />
                            <path d="M8 9 H16" />
                            <path d="M8 12 H14" />
                            <path d="M8 15 H12" />
                            <circle cx="17.5" cy="16.5" r="2.5" />
                        </svg>
                        Licenses
                    </NavLink>
                </div>
            }

            @* ---- SYSTEM (enki-admin only) ----
               Whole group hidden for non-admins. Each route is also
               role-gated server-side; this is just visual cleanup so
               the sidebar doesn't show 403-bound links.
            *@
            <AuthorizeView Roles="enki-admin" Context="adminCtx">
                <div class="enki-nav-group">
                    <div class="enki-nav-label">System</div>

                    <NavLink class="enki-nav-item" href="admin/users">
                        <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5"
                             stroke-linecap="round" stroke-linejoin="round"
                             aria-hidden="true">
                            <circle cx="9" cy="8" r="3" />
                            <path d="M3 20 Q3 14 9 14 Q15 14 15 20" />
                            <circle cx="17" cy="9" r="2" />
                            <path d="M14 20 Q14 16 17 16 Q21 16 21 20" />
                        </svg>
                        Users
                    </NavLink>

                    <NavLink class="enki-nav-item" href="admin/settings">
                        <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5"
                             stroke-linecap="round" stroke-linejoin="round"
                             aria-hidden="true">
                            <circle cx="12" cy="12" r="3" />
                            <path d="M12 3 V6 M12 18 V21 M3 12 H6 M18 12 H21 M5.5 5.5 L7.5 7.5 M16.5 16.5 L18.5 18.5 M5.5 18.5 L7.5 16.5 M16.5 7.5 L18.5 5.5" />
                        </svg>
                        Settings
                    </NavLink>

                    <NavLink class="enki-nav-item" href="admin/audit">
                        <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5"
                             stroke-linecap="round" stroke-linejoin="round"
                             aria-hidden="true">
                            <path d="M4 6 H16" />
                            <path d="M4 10 H14" />
                            <path d="M4 14 H12" />
                            <circle cx="17" cy="17" r="3" />
                            <path d="M19.5 19.5 L21.5 21.5" />
                        </svg>
                        Audit
                    </NavLink>
                </div>
            </AuthorizeView>

        </Authorized>
    </AuthorizeView>

</nav>
