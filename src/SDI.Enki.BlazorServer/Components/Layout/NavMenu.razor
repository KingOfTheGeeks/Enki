@* Sidebar navigation. Groups are separated by a hairline divider. The
   Admin group is always visible when authenticated; the Operations group
   appears only when a tenant is in scope (URL starts with /tenants/{code}).

   Operations also nests the current Job + Well below "Jobs" once the
   user has drilled in — so Surveys / Tubulars / Formations / etc. all
   show "you are inside Ridge-25-3H, well Lambert 2H" without dropping
   to the URL bar to find out. Each level is a clickable shortcut back
   to that level's detail page.

   Icons are inline SVG so they inherit currentColor and no webfont ships. *@

@implements IDisposable
@inject NavigationManager Nav
@inject IHttpClientFactory HttpClientFactory
@using SDI.Enki.BlazorServer.Api
@using SDI.Enki.Shared.Wells

<nav class="enki-nav" aria-label="Primary">

    <div class="enki-nav-group">
        <div class="enki-nav-label">Overview</div>

        <NavLink class="enki-nav-item" href="" Match="NavLinkMatch.All">
            <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="1.5"
                 stroke-linecap="round" stroke-linejoin="round"
                 aria-hidden="true">
                <path d="M3 12 L12 3 L21 12" />
                <path d="M5 10 V21 H19 V10" />
                <path d="M10 21 V15 H14 V21" />
            </svg>
            Home
        </NavLink>
    </div>

    <AuthorizeView>
        <Authorized>
            <div class="enki-nav-group">
                <div class="enki-nav-label">Admin</div>

                <NavLink class="enki-nav-item" href="tenants">
                    <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.5"
                         stroke-linecap="round" stroke-linejoin="round"
                         aria-hidden="true">
                        <path d="M3 20 V9 L9 5 V9 L15 5 V9 L21 7 V20" />
                        <path d="M3 20 H21" />
                        <path d="M8 20 V15 H11 V20" />
                        <path d="M14 20 V15 H17 V20" />
                    </svg>
                    Tenants
                </NavLink>

                @* The admin role unlocks cross-tenant operations (managing
                   the SDI team-member accounts, system settings, etc).
                   AuthorizeView with Roles renders nothing for non-admins. *@
                <AuthorizeView Roles="enki-admin" Context="adminCtx">
                    <NavLink class="enki-nav-item" href="admin">
                        <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5"
                             stroke-linecap="round" stroke-linejoin="round"
                             aria-hidden="true">
                            <path d="M12 2 L20 6 V11 Q20 17 12 22 Q4 17 4 11 V6 Z" />
                            <path d="M9 12 L11 14 L15 10" />
                        </svg>
                        Admin
                    </NavLink>
                </AuthorizeView>
            </div>

            @if (_tenantCode is { Length: > 0 })
            {
                <div class="enki-nav-group">
                    <div class="enki-nav-label">
                        Operations
                        <span class="enki-nav-scope" title="Current tenant">@_tenantCode</span>
                    </div>

                    <NavLink class="enki-nav-item" href="@($"tenants/{_tenantCode}")"
                             Match="NavLinkMatch.All">
                        <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5"
                             stroke-linecap="round" stroke-linejoin="round"
                             aria-hidden="true">
                            <circle cx="12" cy="12" r="8" />
                            <path d="M8 12 H16 M12 8 V16" />
                        </svg>
                        Overview
                    </NavLink>

                    <NavLink class="enki-nav-item" href="@($"tenants/{_tenantCode}/jobs")">
                        <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5"
                             stroke-linecap="round" stroke-linejoin="round"
                             aria-hidden="true">
                            <path d="M4 7 H20 V20 H4 Z" />
                            <path d="M9 7 V5 Q9 4 10 4 H14 Q15 4 15 5 V7" />
                            <path d="M4 13 H20" />
                        </svg>
                        Jobs
                    </NavLink>

                    @* Drill-in breadcrumb. Each level is a clickable
                       shortcut back to that detail page, and uses
                       NavLinkMatch.Prefix so the highlight follows the
                       user as they descend (every level on the path
                       reads "active" — a trail of breadcrumbs). Only
                       renders when the URL has descended that far, so
                       the menu stays small at shallow depths. *@
                    @if (_jobId is { } jobId)
                    {
                        <NavLink class="enki-nav-subitem"
                                 href="@($"tenants/{_tenantCode}/jobs/{jobId}")"
                                 Match="NavLinkMatch.Prefix">
                            <span class="enki-nav-subitem-rail" aria-hidden="true"></span>
                            <span class="enki-nav-subitem-label">@(_jobName ?? "Job…")</span>
                        </NavLink>

                        @if (_wellId is { } wellId)
                        {
                            <NavLink class="enki-nav-subitem enki-nav-subitem-2"
                                     href="@($"tenants/{_tenantCode}/jobs/{jobId}/wells/{wellId}")"
                                     Match="NavLinkMatch.Prefix">
                                <span class="enki-nav-subitem-rail" aria-hidden="true"></span>
                                <span class="enki-nav-subitem-label">@(_wellName ?? "Well…")</span>
                            </NavLink>
                        }
                    }
                </div>
            }
        </Authorized>
    </AuthorizeView>

</nav>

@code {
    private string? _tenantCode;
    private Guid?   _jobId;
    private string? _jobName;
    private int?    _wellId;
    private string? _wellName;

    protected override async Task OnInitializedAsync()
    {
        await ApplyContextAsync(Nav.Uri);
        Nav.LocationChanged += OnLocationChanged;
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        // async void on an event handler is the documented pattern for
        // NavigationManager.LocationChanged; surface unexpected exceptions
        // through the Blazor renderer rather than silently dropping them.
        await ApplyContextAsync(e.Location);
    }

    /// <summary>
    /// Re-derives the tenant + job + well context from the URL and
    /// fetches names for any that changed. Idempotent across repeat
    /// invocations on the same URL — only fires HTTP when an ID
    /// actually moves.
    /// </summary>
    private async Task ApplyContextAsync(string url)
    {
        var ctx = ExtractContext(url);
        var stateChanged = false;

        // Tenant — purely a URL slice, no fetch.
        if (!string.Equals(ctx.TenantCode, _tenantCode, StringComparison.Ordinal))
        {
            _tenantCode = ctx.TenantCode;
            stateChanged = true;
        }

        // Job — fetch name only when the ID changes. Clearing on null
        // (left the job tree) collapses the breadcrumb without a network
        // round-trip.
        if (ctx.JobId != _jobId)
        {
            _jobId   = ctx.JobId;
            _jobName = null;
            stateChanged = true;

            if (ctx.JobId is { } jobId && _tenantCode is { Length: > 0 })
                _ = FetchJobNameAsync(_tenantCode, jobId);
        }

        // Well — same dance. Lives under Job in the URL, so we only
        // ever fetch one when the parent Job is also known.
        if (ctx.WellId != _wellId)
        {
            _wellId   = ctx.WellId;
            _wellName = null;
            stateChanged = true;

            if (ctx.WellId is { } wellId
                && ctx.JobId is { } parentJobId
                && _tenantCode is { Length: > 0 })
            {
                _ = FetchWellNameAsync(_tenantCode, parentJobId, wellId);
            }
        }

        if (stateChanged)
            await InvokeAsync(StateHasChanged);
    }

    private async Task FetchJobNameAsync(string tenantCode, Guid jobId)
    {
        var client = HttpClientFactory.CreateClient("EnkiApi");
        var result = await client.GetAsync<JobDetailDto>(
            $"tenants/{tenantCode}/jobs/{jobId}");

        // Stale-fetch guard: by the time the response lands the user
        // may have navigated to another job. Only apply when the ID
        // we fetched is still the current context. Failure swallowed —
        // the placeholder "Job…" stays visible. Sidebar is non-blocking;
        // failing here can't break navigation.
        if (result.IsSuccess && _jobId == jobId)
        {
            _jobName = result.Value.Name;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task FetchWellNameAsync(string tenantCode, Guid jobId, int wellId)
    {
        var client = HttpClientFactory.CreateClient("EnkiApi");
        var result = await client.GetAsync<WellDetailDto>(
            $"tenants/{tenantCode}/jobs/{jobId}/wells/{wellId}");

        // Same swallow rationale as FetchJobNameAsync.
        if (result.IsSuccess && _wellId == wellId)
        {
            _wellName = result.Value.Name;
            await InvokeAsync(StateHasChanged);
        }
    }

    private readonly record struct UrlContext(string? TenantCode, Guid? JobId, int? WellId);

    /// <summary>
    /// Pulls <c>{tenantCode}</c>, <c>{jobId}</c>, and <c>{wellId}</c>
    /// segments out of a URL of the shape
    /// <c>/tenants/{code}/jobs/{guid}/wells/{int}/...</c>. Each segment
    /// is independent — a missing well doesn't blank the job, a missing
    /// job doesn't blank the tenant. The literal "tenants" / "jobs" /
    /// "wells" segments match case-insensitively; ID segments parse
    /// strictly so "/jobs/new" or "/wells/import" don't masquerade
    /// as IDs.
    /// </summary>
    private static UrlContext ExtractContext(string url)
    {
        // NavigationManager exposes an absolute URI; strip everything up to
        // the first '/' after the scheme+host. We only care about the path.
        var path = url;
        var schemeIdx = path.IndexOf("://", StringComparison.Ordinal);
        if (schemeIdx >= 0)
        {
            var slash = path.IndexOf('/', schemeIdx + 3);
            path = slash >= 0 ? path[slash..] : "/";
        }
        var q = path.IndexOf('?');
        if (q >= 0) path = path[..q];

        var parts = path.Trim('/').Split('/', StringSplitOptions.RemoveEmptyEntries);

        // Need at least /tenants/{code} for the group to render.
        if (parts.Length < 2) return default;
        if (!string.Equals(parts[0], "tenants", StringComparison.OrdinalIgnoreCase)) return default;

        // "new" is the create-tenant form, not a real tenant code.
        if (string.Equals(parts[1], "new", StringComparison.OrdinalIgnoreCase)) return default;

        var code = parts[1];

        // /tenants/{code}/jobs/{guid}/...
        Guid? jobId = null;
        if (parts.Length >= 4
            && string.Equals(parts[2], "jobs", StringComparison.OrdinalIgnoreCase)
            && Guid.TryParse(parts[3], out var parsedJobId))
        {
            jobId = parsedJobId;
        }

        // /tenants/{code}/jobs/{guid}/wells/{int}/...
        int? wellId = null;
        if (jobId is not null
            && parts.Length >= 6
            && string.Equals(parts[4], "wells", StringComparison.OrdinalIgnoreCase)
            && int.TryParse(parts[5], out var parsedWellId))
        {
            wellId = parsedWellId;
        }

        return new UrlContext(code, jobId, wellId);
    }

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;
}
