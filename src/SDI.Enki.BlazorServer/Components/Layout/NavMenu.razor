@* Unified primary sidebar. Single nav across the whole app — no
   separate AdminNavMenu sibling that swaps in on /admin/* routes
   (that previous shape made the sidebar shape change mid-navigation).

   Four groups, ordered by audience reach (broadest first):

     OVERVIEW   — personal landing page, every signed-in user.
     TENANTS    — cross-tenant browsing + per-tenant drill-in. Every
                  signed-in user; the drill-in (Jobs / [Job] / Wells /
                  [Well] / Runs / [Run] / Models / [Model]) appears
                  only when a tenant is in URL scope.
     FLEET      — cross-tenant equipment registry (Tools), read-only
                  for non-admins.
     SYSTEM     — enki-admin-only operations (Users, Licensing,
                  Settings, system-level Audit). The whole group is
                  hidden for non-admins via AuthorizeView Roles=...

   Per-route Authorize attributes still gate access — the sidebar just
   hides links the current user can't reach. Defense-in-depth: a
   crafted URL still gets a 403 even if the link is rendered.

   Icons are inline SVG so they inherit currentColor and no webfont ships.
*@

@implements IDisposable
@inject NavigationManager Nav
@inject IHttpClientFactory HttpClientFactory
@using SDI.Enki.BlazorServer.Api
@using SDI.Enki.Shared.Runs
@using SDI.Enki.Shared.Wells

<nav class="enki-nav" aria-label="Primary">

    @* ---- OVERVIEW ---- *@
    <div class="enki-nav-group">
        <div class="enki-nav-label">Overview</div>

        <NavLink class="enki-nav-item" href="" Match="NavLinkMatch.All">
            <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="1.5"
                 stroke-linecap="round" stroke-linejoin="round"
                 aria-hidden="true">
                <path d="M3 12 L12 3 L21 12" />
                <path d="M5 10 V21 H19 V10" />
                <path d="M10 21 V15 H14 V21" />
            </svg>
            Home
        </NavLink>
    </div>

    <AuthorizeView>
        <Authorized>

            @* ---- TENANTS ---- *@
            <div class="enki-nav-group">
                <div class="enki-nav-label">
                    Tenants
                    @if (_tenantCode is { Length: > 0 })
                    {
                        <span class="enki-nav-scope" title="Current tenant">@_tenantCode</span>
                    }
                </div>

                <NavLink class="enki-nav-item" href="tenants" Match="NavLinkMatch.All">
                    <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.5"
                         stroke-linecap="round" stroke-linejoin="round"
                         aria-hidden="true">
                        <path d="M3 20 V9 L9 5 V9 L15 5 V9 L21 7 V20" />
                        <path d="M3 20 H21" />
                        <path d="M8 20 V15 H11 V20" />
                        <path d="M14 20 V15 H17 V20" />
                    </svg>
                    All Tenants
                </NavLink>

                @if (_tenantCode is { Length: > 0 })
                {
                    <NavLink class="enki-nav-item"
                             href="@($"tenants/{_tenantCode}")"
                             Match="NavLinkMatch.All">
                        <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5"
                             stroke-linecap="round" stroke-linejoin="round"
                             aria-hidden="true">
                            <circle cx="12" cy="12" r="8" />
                            <path d="M8 12 H16 M12 8 V16" />
                        </svg>
                        Overview
                    </NavLink>

                    <NavLink class="enki-nav-item"
                             href="@($"tenants/{_tenantCode}/jobs")"
                             Match="NavLinkMatch.All">
                        <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5"
                             stroke-linecap="round" stroke-linejoin="round"
                             aria-hidden="true">
                            <path d="M4 7 H20 V20 H4 Z" />
                            <path d="M9 7 V5 Q9 4 10 4 H14 Q15 4 15 5 V7" />
                            <path d="M4 13 H20" />
                        </svg>
                        Jobs
                    </NavLink>

                    @if (_jobId is { } jobId)
                    {
                        <NavLink class="enki-nav-subitem"
                                 href="@($"tenants/{_tenantCode}/jobs/{jobId}")"
                                 Match="NavLinkMatch.All">
                            <span class="enki-nav-subitem-rail" aria-hidden="true"></span>
                            <span class="enki-nav-subitem-label">@(_jobName ?? "Job…")</span>
                        </NavLink>

                        @* Three peer drill-ins under a Job: Wells, Runs, Models.
                           Models is intentionally listed even though the routes
                           don't exist yet — the sidebar shape is the contract
                           for when those pages land. Until then the link is
                           commented out below; the URL parser already extracts
                           a ModelId for the future drill-in marker. *@
                        <NavLink class="enki-nav-item"
                                 href="@($"tenants/{_tenantCode}/jobs/{jobId}/wells")"
                                 Match="NavLinkMatch.Prefix">
                            <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="1.5"
                                 stroke-linecap="round" stroke-linejoin="round"
                                 aria-hidden="true">
                                <circle cx="12" cy="5" r="2" />
                                <path d="M12 7 V20" />
                                <path d="M9 20 H15" />
                            </svg>
                            Wells
                        </NavLink>

                        @if (_wellId is { } wellId)
                        {
                            <NavLink class="enki-nav-subitem"
                                     href="@($"tenants/{_tenantCode}/jobs/{jobId}/wells/{wellId}")"
                                     Match="NavLinkMatch.Prefix">
                                <span class="enki-nav-subitem-rail" aria-hidden="true"></span>
                                <span class="enki-nav-subitem-label">@(_wellName ?? "Well…")</span>
                            </NavLink>
                        }

                        <NavLink class="enki-nav-item"
                                 href="@($"tenants/{_tenantCode}/jobs/{jobId}/runs")"
                                 Match="NavLinkMatch.Prefix">
                            <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="1.5"
                                 stroke-linecap="round" stroke-linejoin="round"
                                 aria-hidden="true">
                                <path d="M12 3 V21" />
                                <path d="M9 7 H15" />
                                <path d="M9 12 H15" />
                                <path d="M9 17 H15" />
                            </svg>
                            Runs
                        </NavLink>

                        @if (_runId is { } runId)
                        {
                            <NavLink class="enki-nav-subitem"
                                     href="@($"tenants/{_tenantCode}/jobs/{jobId}/runs/{runId}")"
                                     Match="NavLinkMatch.Prefix">
                                <span class="enki-nav-subitem-rail" aria-hidden="true"></span>
                                <span class="enki-nav-subitem-label">@(_runName ?? "Run…")</span>
                            </NavLink>
                        }

                        @* Models — slots in here once /tenants/{code}/jobs/{jobId}/models
                           routes land. The URL parser already extracts ModelId so
                           the [Model name] sub-item is one un-commenting away.
                        <NavLink class="enki-nav-item"
                                 href="@($"tenants/{_tenantCode}/jobs/{jobId}/models")"
                                 Match="NavLinkMatch.Prefix">
                            <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="1.5"
                                 stroke-linecap="round" stroke-linejoin="round"
                                 aria-hidden="true">
                                <path d="M4 8 L12 4 L20 8 L12 12 Z" />
                                <path d="M4 12 L12 16 L20 12" />
                                <path d="M4 16 L12 20 L20 16" />
                            </svg>
                            Models
                        </NavLink>

                        @if (_modelId is { } modelId)
                        {
                            <NavLink class="enki-nav-subitem"
                                     href="@($"tenants/{_tenantCode}/jobs/{jobId}/models/{modelId}")"
                                     Match="NavLinkMatch.Prefix">
                                <span class="enki-nav-subitem-rail" aria-hidden="true"></span>
                                <span class="enki-nav-subitem-label">@(_modelName ?? "Model…")</span>
                            </NavLink>
                        }
                        *@
                    }

                    <NavLink class="enki-nav-item"
                             href="@($"tenants/{_tenantCode}/members")"
                             Match="NavLinkMatch.All">
                        <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5"
                             stroke-linecap="round" stroke-linejoin="round"
                             aria-hidden="true">
                            <circle cx="9" cy="8" r="3" />
                            <path d="M3 20 Q3 14 9 14 Q15 14 15 20" />
                            <circle cx="17" cy="9" r="2" />
                            <path d="M14 20 Q14 16 17 16 Q21 16 21 20" />
                        </svg>
                        Members
                    </NavLink>

                    <NavLink class="enki-nav-item"
                             href="@($"tenants/{_tenantCode}/audit")"
                             Match="NavLinkMatch.Prefix">
                        <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5"
                             stroke-linecap="round" stroke-linejoin="round"
                             aria-hidden="true">
                            <path d="M4 6 H16" />
                            <path d="M4 10 H14" />
                            <path d="M4 14 H12" />
                            <circle cx="17" cy="17" r="3" />
                            <path d="M19.5 19.5 L21.5 21.5" />
                        </svg>
                        Audit
                    </NavLink>
                }
            </div>

            @* ---- FLEET ---- *@
            <div class="enki-nav-group">
                <div class="enki-nav-label">Fleet</div>

                <NavLink class="enki-nav-item" href="tools">
                    <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.5"
                         stroke-linecap="round" stroke-linejoin="round"
                         aria-hidden="true">
                        <path d="M14 4 L20 10 L14 16" />
                        <path d="M4 12 H20" />
                        <path d="M6 20 H18" />
                    </svg>
                    Tools
                </NavLink>
            </div>

            @* ---- SYSTEM (enki-admin only) ----
               Whole group hidden for non-admins. Each route is also
               role-gated server-side; this is just visual cleanup so
               the sidebar doesn't show 403-bound links.
            *@
            <AuthorizeView Roles="enki-admin" Context="adminCtx">
                <div class="enki-nav-group">
                    <div class="enki-nav-label">System</div>

                    <NavLink class="enki-nav-item" href="admin/users">
                        <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5"
                             stroke-linecap="round" stroke-linejoin="round"
                             aria-hidden="true">
                            <circle cx="9" cy="8" r="3" />
                            <path d="M3 20 Q3 14 9 14 Q15 14 15 20" />
                            <circle cx="17" cy="9" r="2" />
                            <path d="M14 20 Q14 16 17 16 Q21 16 21 20" />
                        </svg>
                        Users
                    </NavLink>

                    <NavLink class="enki-nav-item" href="licenses">
                        <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5"
                             stroke-linecap="round" stroke-linejoin="round"
                             aria-hidden="true">
                            <rect x="4" y="4" width="16" height="16" rx="2" />
                            <path d="M8 9 H16" />
                            <path d="M8 12 H14" />
                            <path d="M8 15 H12" />
                            <circle cx="17.5" cy="16.5" r="2.5" />
                        </svg>
                        Licensing
                    </NavLink>

                    <NavLink class="enki-nav-item" href="admin/settings">
                        <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5"
                             stroke-linecap="round" stroke-linejoin="round"
                             aria-hidden="true">
                            <circle cx="12" cy="12" r="3" />
                            <path d="M12 3 V6 M12 18 V21 M3 12 H6 M18 12 H21 M5.5 5.5 L7.5 7.5 M16.5 16.5 L18.5 18.5 M5.5 18.5 L7.5 16.5 M16.5 7.5 L18.5 5.5" />
                        </svg>
                        Settings
                    </NavLink>

                    <NavLink class="enki-nav-item" href="admin/audit">
                        <svg class="enki-nav-icon" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5"
                             stroke-linecap="round" stroke-linejoin="round"
                             aria-hidden="true">
                            <path d="M4 6 H16" />
                            <path d="M4 10 H14" />
                            <path d="M4 14 H12" />
                            <circle cx="17" cy="17" r="3" />
                            <path d="M19.5 19.5 L21.5 21.5" />
                        </svg>
                        Audit
                    </NavLink>
                </div>
            </AuthorizeView>

        </Authorized>
    </AuthorizeView>

</nav>

@code {
    private string? _tenantCode;
    private Guid?   _jobId;
    private string? _jobName;
    private int?    _wellId;
    private string? _wellName;
    private Guid?   _runId;
    private string? _runName;
    private Guid?   _modelId;
    // _modelName is reserved for the future drill-in marker — see the
    // commented Models nav block above. Will be assigned by a
    // FetchModelNameAsync helper once /tenants/{code}/jobs/{jobId}/models
    // routes land. Suppressing the unused-warning rather than deleting
    // the field keeps the wire-up obvious for the next pass.
#pragma warning disable CS0414
    private string? _modelName;
#pragma warning restore CS0414

    protected override async Task OnInitializedAsync()
    {
        await ApplyContextAsync(Nav.Uri);
        Nav.LocationChanged += OnLocationChanged;
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        // async void on event handler is the documented pattern for
        // NavigationManager.LocationChanged; surface unexpected exceptions
        // through the Blazor renderer rather than silently dropping them.
        await ApplyContextAsync(e.Location);
    }

    /// <summary>
    /// Re-derives the tenant + job + well + run + model context from
    /// the URL and fetches names for any that changed. Idempotent
    /// across repeat invocations on the same URL — only fires HTTP
    /// when an ID actually moves.
    /// </summary>
    private async Task ApplyContextAsync(string url)
    {
        var ctx = ExtractContext(url);
        var stateChanged = false;

        if (!string.Equals(ctx.TenantCode, _tenantCode, StringComparison.Ordinal))
        {
            _tenantCode = ctx.TenantCode;
            stateChanged = true;
        }

        if (ctx.JobId != _jobId)
        {
            _jobId   = ctx.JobId;
            _jobName = null;
            stateChanged = true;

            if (ctx.JobId is { } jobId && _tenantCode is { Length: > 0 })
                _ = FetchJobNameAsync(_tenantCode, jobId);
        }

        if (ctx.WellId != _wellId)
        {
            _wellId   = ctx.WellId;
            _wellName = null;
            stateChanged = true;

            if (ctx.WellId is { } wellId
                && ctx.JobId is { } parentJobId
                && _tenantCode is { Length: > 0 })
            {
                _ = FetchWellNameAsync(_tenantCode, parentJobId, wellId);
            }
        }

        if (ctx.RunId != _runId)
        {
            _runId   = ctx.RunId;
            _runName = null;
            stateChanged = true;

            if (ctx.RunId is { } runId
                && ctx.JobId is { } parentJobId
                && _tenantCode is { Length: > 0 })
            {
                _ = FetchRunNameAsync(_tenantCode, parentJobId, runId);
            }
        }

        if (ctx.ModelId != _modelId)
        {
            _modelId   = ctx.ModelId;
            _modelName = null;
            stateChanged = true;

            // Models routes don't exist yet — when they do, drop in a
            // FetchModelNameAsync mirror of the Run helper. Until then
            // ModelId stays null on every URL because no /models/{guid}
            // segment ever matches.
        }

        if (stateChanged)
            await InvokeAsync(StateHasChanged);
    }

    private async Task FetchJobNameAsync(string tenantCode, Guid jobId)
    {
        var client = HttpClientFactory.CreateClient("EnkiApi");
        var result = await client.GetAsync<JobDetailDto>(
            $"tenants/{tenantCode}/jobs/{jobId}");

        // Stale-fetch guard: by the time the response lands the user
        // may have navigated to another job. Only apply when the ID
        // we fetched is still the current context. Failure swallowed —
        // the placeholder "Job…" stays visible. Sidebar is non-blocking;
        // failing here can't break navigation.
        if (result.IsSuccess && _jobId == jobId)
        {
            _jobName = result.Value.Name;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task FetchWellNameAsync(string tenantCode, Guid jobId, int wellId)
    {
        var client = HttpClientFactory.CreateClient("EnkiApi");
        var result = await client.GetAsync<WellDetailDto>(
            $"tenants/{tenantCode}/jobs/{jobId}/wells/{wellId}");

        if (result.IsSuccess && _wellId == wellId)
        {
            _wellName = result.Value.Name;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task FetchRunNameAsync(string tenantCode, Guid jobId, Guid runId)
    {
        var client = HttpClientFactory.CreateClient("EnkiApi");
        var result = await client.GetAsync<RunDetailDto>(
            $"tenants/{tenantCode}/jobs/{jobId}/runs/{runId}");

        if (result.IsSuccess && _runId == runId)
        {
            _runName = result.Value.Name;
            await InvokeAsync(StateHasChanged);
        }
    }

    private readonly record struct UrlContext(
        string? TenantCode,
        Guid?   JobId,
        int?    WellId,
        Guid?   RunId,
        Guid?   ModelId);

    /// <summary>
    /// Pulls <c>{tenantCode}</c>, <c>{jobId}</c>, <c>{wellId}</c>,
    /// <c>{runId}</c>, and <c>{modelId}</c> segments out of a URL of
    /// the shape
    /// <c>/tenants/{code}/jobs/{guid}/(wells/{int}|runs/{guid}|models/{guid})/...</c>.
    /// Each segment is independent — a missing well doesn't blank the
    /// job, a missing job doesn't blank the tenant. The literal
    /// "tenants" / "jobs" / "wells" / "runs" / "models" segments match
    /// case-insensitively; ID segments parse strictly so "/jobs/new",
    /// "/wells/import", etc. don't masquerade as IDs.
    /// </summary>
    private static UrlContext ExtractContext(string url)
    {
        var path = url;
        var schemeIdx = path.IndexOf("://", StringComparison.Ordinal);
        if (schemeIdx >= 0)
        {
            var slash = path.IndexOf('/', schemeIdx + 3);
            path = slash >= 0 ? path[slash..] : "/";
        }
        var q = path.IndexOf('?');
        if (q >= 0) path = path[..q];

        var parts = path.Trim('/').Split('/', StringSplitOptions.RemoveEmptyEntries);

        if (parts.Length < 2) return default;
        if (!string.Equals(parts[0], "tenants", StringComparison.OrdinalIgnoreCase)) return default;
        if (string.Equals(parts[1], "new", StringComparison.OrdinalIgnoreCase)) return default;

        var code = parts[1];

        Guid? jobId = null;
        if (parts.Length >= 4
            && string.Equals(parts[2], "jobs", StringComparison.OrdinalIgnoreCase)
            && Guid.TryParse(parts[3], out var parsedJobId))
        {
            jobId = parsedJobId;
        }

        // /tenants/{code}/jobs/{guid}/wells/{int}/...
        int? wellId = null;
        if (jobId is not null
            && parts.Length >= 6
            && string.Equals(parts[4], "wells", StringComparison.OrdinalIgnoreCase)
            && int.TryParse(parts[5], out var parsedWellId))
        {
            wellId = parsedWellId;
        }

        // /tenants/{code}/jobs/{guid}/runs/{guid}/...
        // Runs / Wells / Models are siblings — at most one is in scope at a time.
        Guid? runId = null;
        if (jobId is not null
            && parts.Length >= 6
            && string.Equals(parts[4], "runs", StringComparison.OrdinalIgnoreCase)
            && Guid.TryParse(parts[5], out var parsedRunId))
        {
            runId = parsedRunId;
        }

        // /tenants/{code}/jobs/{guid}/models/{guid}/...
        Guid? modelId = null;
        if (jobId is not null
            && parts.Length >= 6
            && string.Equals(parts[4], "models", StringComparison.OrdinalIgnoreCase)
            && Guid.TryParse(parts[5], out var parsedModelId))
        {
            modelId = parsedModelId;
        }

        return new UrlContext(code, jobId, wellId, runId, modelId);
    }

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;
}
