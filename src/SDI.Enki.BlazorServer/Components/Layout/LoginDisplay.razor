@* Login / logout widget for the top bar.

   Styled as a pill that fits the dark-industrial header rather than a
   stock Bootstrap button. Contents swap to a spinner on click so the
   user gets immediate feedback while the OIDC redirect round-trips. *@

<AuthorizeView>
    <Authorized>
        <a class="enki-user-name enki-user-link" href="/account/settings"
           title="My settings">@context.User.Identity?.Name</a>
        <form method="post" action="/account/logout" class="enki-user-form"
              onsubmit="this.querySelector('button').disabled=true;
                        this.querySelector('button').textContent='Signing out…';">
            <AntiforgeryToken />
            <button type="submit" class="enki-pill-button">Sign out</button>
        </form>
    </Authorized>
    <NotAuthorized>
        <a class="enki-pill-button enki-pill-primary" href="/account/login"
           onclick="this.classList.add('is-loading');
                    this.style.pointerEvents='none';
                    this.textContent='Signing in…';">
            Sign in
        </a>
    </NotAuthorized>
</AuthorizeView>
