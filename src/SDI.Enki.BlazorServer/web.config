<?xml version="1.0" encoding="utf-8"?>
<!--
  Project-root web.config. `dotnet publish` runs _TransformWebConfig
  which substitutes %LAUNCHER_PATH% / %LAUNCHER_ARGS% with the right
  dotnet invocation and copies the rest into the publish output.

  Why <webSocket enabled="true" /> is set here:
  Blazor Server uses SignalR over WebSockets for the circuit. Without
  this opt-in IIS strips WebSockets from the advertised transports at
  /_blazor/negotiate and clients fall back to long polling — 5–8s
  round-trips on every interactive page (Tie-on edit, Magnetic edit,
  audit-tile expand, inline grid edits) plus the console warning
  "Failed to connect via WebSockets, using the Long Polling fallback
  transport."

  Host prerequisites — one-time per staging box, run via
  scripts/install-iis-websockets.ps1:
    1. IIS-WebSockets Windows feature installed (Enable-Windows-
       OptionalFeature -All so the Web-App-Dev parent comes too;
       without -All the install silently no-ops).
    2. system.webServer/webSocket section unlocked at applicationhost.
       config (otherwise IIS rejects this per-site override on load
       with a "section is locked at a parent level" 500).

  IIS Express enables WebSockets by default; this file is a no-op there.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="%LAUNCHER_PATH%" arguments="%LAUNCHER_ARGS%" stdoutLogEnabled="false" stdoutLogFile=".\logs\stdout" hostingModel="inprocess" />
      <webSocket enabled="true" />
    </system.webServer>
  </location>
</configuration>
