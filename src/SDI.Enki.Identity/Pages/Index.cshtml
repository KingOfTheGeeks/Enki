@page
@{
    ViewData["Title"] = "Identity";
}

<p style="color: var(--enki-text-dim); margin: 0 0 1rem;">
    OIDC provider for the Enki Web API and Blazor client.
</p>

@if (User.Identity?.IsAuthenticated == true)
{
    <p>Signed in as <strong style="color: var(--enki-accent);">@User.Identity.Name</strong>.</p>
    <form method="post" asp-page="/Account/Logout">
        <button type="submit">Sign out</button>
    </form>
}
else
{
    <p><a class="enki-btn" href="/Account/Login" style="margin-top: 0.5rem;">Sign in</a></p>
}
